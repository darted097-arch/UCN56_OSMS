     TextProcessing.visibility = 0;
  }`

  function `void escape()
  {
  DisplayPage(Page681);
  }`

  function `void GettingData()
  {
     if (0 == UTDVDataWaitingTime)
     {
        TextProcessing.visibility = 0;
        WaitingUTDVData684 = 0;
        DisplayUTDVData();
     }
     else
     {
        UTDVDataWaitingTime = UTDVDataWaitingTime - 1;
     }
  }`

  function `void Initialize()
  {
     Current_Page = 684;
     CFMLevel =0;
     Increment.visibility = 1;
     EFPHValue.visibility = 1;
     Present.visibility = 0;
  
     strcpy(Choice.TheNewText, "1");
     Choice.Flag = 2;
     Text1.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     Text2.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     Text31.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     Text32.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
  
     EFPHValue.TheNewNumber = 0; //JHC 990419
  
     Current_page = 684;
     Interface->UtdvDialogue.option = 9;
     Interface->UtdvDialogue.current_page = Current_page;
  
     execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
  
     TextProcessing.visibility = 1;
     UTDVDataWaitingTime = 5;
     WaitingUTDVData684 = 1;
     processfiles.UnSelect(); //jsk
  
  }`

  function `void MakeVis()
  {
     Text1.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     Text2.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     Text31.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     Text32.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
  
     if (strcmp(Choice.TheNewText, "1") == 0)
     {
     Increment.visibility = 1;
     Present.visibility = 0;
     EFPHValue.visibility = 1;
     Text1.foregroundColour = \`COLOR_DATA_NORMAL\`;  //JHC 990419
     }
     else if ( strcmp(Choice.TheNewText, "2") == 0)
     {
     Increment.visibility = 0;
     Present.visibility = 0;
     EFPHValue.visibility = 0;
     Text2.foregroundColour = \`COLOR_DATA_NORMAL\`;  //JHC 990419
     }
     else if ( strcmp(Choice.TheNewText, "3") == 0)
     {
     Increment.visibility = 0;
     Present.visibility = 1;
     EFPHValue.visibility = 1;
     Text31.foregroundColour = \`COLOR_DATA_NORMAL\`;  //JHC 990419
     Text32.foregroundColour = \`COLOR_DATA_NORMAL\`;  //JHC 990419
     }
  
  }`

  function `void NextAction()
  {
     if (strcmp(Choice.TheNewText, "1") == 0  || strcmp(Choice.TheNewText, "3") == 0)
     {
     Interface->UtdvDialogue.option = atoi(Choice.TheNewText);
     Interface->UtdvDialogue.entered_EFPH = EFPHValue.TheNewNumber;
     execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
     //printf("dATA is Correct1...%d ", atoi(Choice.TheNewText));
     }
     else
     {
     Interface->UtdvDialogue.option = atoi(Choice.TheNewText);
     execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");  //jsk
     //printf("dATA is Correct2...%d ", atoi(Choice.TheNewText));
     }
  }`

