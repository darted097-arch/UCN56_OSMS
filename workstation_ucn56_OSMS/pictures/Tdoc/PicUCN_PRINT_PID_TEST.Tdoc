  function `void ProcessingConfirmed()
  {
  	procMsg.visibility = 0;
  
  	DisplayAdvisoryMessage("   ");
  	DisplayAdvisoryMessage1("   ");
  	DisplayAdvisoryMessage2("   ");
  
  	DisplayAdvisoryMessage(pHostPidTestMsg->message1);
  	DisplayAdvisoryMessage1(pHostPidTestMsg->message2);
  	DisplayAdvisoryMessage2(pHostPidTestMsg->message3);
  
  }`

  function `void verifyMaxRate()
  {
  	printf("verifyMaxRate started");
  	// MaxRate = atoi(rateInput.TheNewText);
  	MaxRate = (int)rateInput.TheNewNumber;
  	printf("verifyMaxRate MaxRate=[%d]", (int)MaxRate);
  	if(MaxRate < 1 || MaxRate > 60)
  	{
  		DisplayAdvisoryMessage("INVALID MAXIMUM RATE: MUST BE 1 TO 60");
  		OptionERR3 = 1;
  	}
  	else
  		OptionERR3 = 0;
  }`

  function `void verifyMaxTime()
  {
  	printf("verifyMaxTime started");
  	//MaxTime = atoi(timeInput.TheNewText);
  	MaxTime = (int)timeInput.TheNewNumber;
  	if(MaxTime < 1 || MaxTime > 999)
  	{
  		DisplayAdvisoryMessage("INVALID MAXIMUM TIME: MUST BE 1 TO 999");
  		OptionERR4 = 1;
  	}
  	else
  		OptionERR4 = 0;
  }`

