  function `int Checkup(int position)
  {
  	printf("Checkup position = %d", position);
  	switch(position){
  		case 1:		// SYSTEM
  			if(strcmp(systemInput.TheOriginalText,"AF")!=0 &&
  			   strcmp(systemInput.TheOriginalText,"MV")!=0 &&
  			   strcmp(systemInput.TheOriginalText,"ALL")!=0){
  				DisplayAdvisoryMessage1("SYSTEM CHOICE: (ALL OR AF TO MV)");
  				OptionERR1 = 1;
  				return -1;
  			}
  			else
  				OptionERR1 = 0;
  			break;
  		case 2:		// SIGNAL TYPE
  			if(strcmp(signalInput.TheNewText,"AO")!=0 &&
  			strcmp(signalInput.TheOriginalText,"QA")!=0 &&
  			strcmp(signalInput.TheOriginalText,"XA")!=0 &&
  			strcmp(signalInput.TheOriginalText,"KO")!=0 &&
  			strcmp(signalInput.TheOriginalText,"AL")!=0 &&
  			strcmp(signalInput.TheOriginalText,"AI")!=0 &&
  			strcmp(signalInput.TheOriginalText,"PI")!=0 &&
  			strcmp(signalInput.TheOriginalText,"FI")!=0 &&
  			strcmp(signalInput.TheOriginalText,"ROD")!=0 &&
  			strcmp(signalInput.TheOriginalText,"CI")!=0 &&
  			strcmp(signalInput.TheOriginalText,"DI")!=0 &&
  			strcmp(signalInput.TheOriginalText,"SOE")!=0 &&
  			strcmp(signalInput.TheOriginalText,"BCI")!=0 &&
  			strcmp(signalInput.TheOriginalText,"DL")!=0 &&
  			strcmp(signalInput.TheOriginalText,"QD")!=0 &&
  			strcmp(signalInput.TheOriginalText,"XD")!=0 &&
  			strcmp(signalInput.TheOriginalText,"CO")!=0 &&
  			strcmp(signalInput.TheOriginalText,"BCO")!=0 &&
  			strcmp(signalInput.TheOriginalText,"NPTYPES")!=0 &&
  			strcmp(signalInput.TheOriginalText,"ALL")!=0){
  				DisplayAdvisoryMessage1("SIGNAL TYPE CHOICE: (ALL OR AI,CI,AO,XA,QO, ...)");
  				OptionERR2 = 1;
  				return -1;
  			}
  			else
  				OptionERR2 = 0;
  			break;
  	}
  	update();
  	return 0;
  }`

  function `void escape()
  {
     execute("{DisplayPage(\\"%s\\");}",TheDisplayPage);
     update();
  }`

  function `void InitConfirmMessages()
  {
  	DisplayAdvisoryMessage("   ");
  	DisplayAdvisoryMessage1("   ");
  	DisplayAdvisoryMessage2("   ");
  	DisplayAdvisoryMessage3("   ");
  
  	// Initialize Confirm Message in Interface Shared Memory
  	strcpy(pHostPidTestMsg->message1,"");
  	strcpy(pHostPidTestMsg->message2,"");
  	strcpy(pHostPidTestMsg->message3,"");
  }`

  function `void Initialize()
  {
  	CFMLevel = 0;
  	Current_Page = 870;
  	OptionERR1 = 1;
  	OptionERR2 = 1;
  	OptionERR3 = 0;
  	OptionERR4 = 0;
  	MaxRate = 1;
  	MaxTime = 1;
  
  	InitializeInput();
  	InitConfirmMessages();
  
  	procMsg.visibility = 0;
  
  	update();
  }`

// ***CORENET 20170601 by Philkyu Kwon ************
  function `void DummyProcess()
  {
      //printf("Button Select OR Button Unselected");
  }`
// ***************************************************

  function `void InitializeInput()
  {
  	printf("InitializeInput --");
  	strcpy(systemInput.TheOriginalText,"  ");
  	strcpy(systemInput.TheNewText,"  ");
  	strcpy(signalInput.TheOriginalText,"  ");
  	strcpy(signalInput.TheNewText,"  ");
  
  	rateInput.TheNewNumber = 1;
  	timeInput.TheNewNumber = 1;
  }`

  function `void process()
  {
  	printf("process started");
  	int OptionStatus;
  
  	DisplayAdvisoryMessage("   ");
  	DisplayAdvisoryMessage1("   ");
  	DisplayAdvisoryMessage2("   ");
  	DisplayAdvisoryMessage3("   ");
  
  	OptionStatus = OptionERR1 + OptionERR2 + OptionERR3 + OptionERR4;
  
  	if(OptionStatus == 0)
  	{
  		strcpy(pHostPidTestMsg->message1,"");
  		strcpy(pHostPidTestMsg->message2,"");
  		strcpy(pHostPidTestMsg->message3,"");
  
  		DisplayAdvisoryMessage("SENDING A REQUEST TO THE HOST");
  		strcpy(Interface->wsPidTestData.sysName,systemInput.TheNewText);
  		strcpy(Interface->wsPidTestData.sigType,signalInput.TheNewText);
  		Interface->wsPidTestData.prnRate = (int)MaxRate;
  		Interface->wsPidTestData.prnTime = (int)MaxTime;
  		printf("---[%s]---[%s]---",Interface->wsPidTestData.sysName, systemInput.TheNewText);
  		printf("---[%s]---[%s]---",Interface->wsPidTestData.sigType, signalInput.TheNewText);
  		printf("---[%d]---[%d]---",Interface->wsPidTestData.prnRate, (int)MaxRate);
  		printf("---[%d]---[%d]---",Interface->wsPidTestData.prnTime, (int)MaxTime);
  		execute("{sendMessageToHost(REQUEST_PIDTEST);}");
  		procMsg.visibility = 1;
  	}
  	else
  		DisplayAdvisoryMessage1("INVALID FIELD VALUE");
  
  	update();
  }`

