   update();
}`;
  }

  dialogue
  {
    event = `shapeLeft()`;
    action = statement `{
mbox.foregroundColour = COLOR_BUTTON_BACKGROUND;
mbox.foregroundFillColour = COLOR_BUTTON_BACKGROUND;

upleft.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
upleft.foregroundFillColour = COLOR_BUTTON_TOP_SHADOW;
up.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
up.foregroundFillColour = COLOR_BUTTON_TOP_SHADOW;

downright.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
downright.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;
down.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
down.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;
   TheFontColor = COLOR_STATIC_TEXT;
//   TheTextFont = \`font6\`;
   update();
}`;
  }

  dialogue
  {
    event = `buttonPressed(Left) && !Cascade`;
    action = statement `{
mbox.foregroundColour = COLOR_BUTTON_BACKGROUND;
mbox.foregroundFillColour = COLOR_BUTTON_BACKGROUND;

upleft.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
upleft.foregroundFillColour = COLOR_BUTTON_TOP_SHADOW;
up.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
up.foregroundFillColour = COLOR_BUTTON_TOP_SHADOW;

downright.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
downright.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;
down.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
down.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;

   if ( strlen(ExecuteString) > 0)
       execute(ExecuteString);

//   execute("{DisplayPage(\\"%s\\");}",TheDisplayPage);
}`;
  }

