  class EnterSmallPointId
  {
    char FindPidScope[80] = "";

    int ERROR = 1;

    char Scope[80] = "";

    char NotFoundAction[100] = "{printf(\"Point Id Not Found\");}";

    char FoundAction[100] = "{printf(\"Point Id Found\");}";

    char TheNewText[40] = "OP";

    char TheOriginalText[40] = "Original";

    int Selected = 0;

function `void ExecuteFailure()
{
   ERROR = 1;
// Point Id not found; execute failure routine
   executeAsync(Scope,NotFoundAction);
}`

function `void ExecuteSuccess()
{
// Point Id found, copy it into the original area
   strcpy(TheOriginalText,TheNewText);
   executeAsync(Scope,FoundAction);
}`



  dialogue
  {
    event = `buttonPressed(Left) || shapeEntered()`;
    action = statement `{
   Selected = 1;
   strcpy(TheNewText,"");
   InputArea.theText = \`TheNewText\`;
   InputArea.edit(ON);
   InputArea.edit(OFF);
   InputArea.edit(ON);
   InputArea.moveToHome(); 
   update(); 
}`;
  }

  dialogue
  {
    event = `Selected && shapeLeft()`;
    action = statement `{
   Selected = 0;
   strcpy(TheNewText,TheOriginalText);
   ERROR = 0;
   InputArea.edit(OFF);
   update();
}`;
  }

    text InputArea
    {
      dialogue
      {
        event = `keyPressed(RETURN)`;
        action = statement `{
   Selected = 0;
   if (InputArea.position() > 0)
   { 
      strcpy(TheNewText,InputArea.buffer());
      ParseAndToupper(TheNewText,InputArea.position());
   }
   else
      strcpy(TheNewText,TheOriginalText);

   InputArea.edit(OFF);

// call findpid
   execute("{ findPidForGUI(TheNewText,FindPidScope,\\"ExecuteSuccess()\\",\\"ExecuteFailure()\\"); }");
}`;
      }
      x = 5;
      y = 23;
      format = "%-20s";
      theText = `TheNewText`;

      visibility = 1;
      foregroundColour = `COLOR_DATA_NORMAL`;
      backgroundColour = -1;
      theFont = `font2`;
      xReference = 5;
      yReference = 23;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    line 
    {
      numberOfPoints = 2;

      point[0] = (5, 30);
      point[1] = (95, 30);

      visibility = 1;
      foregroundColour = `(Selected)?COLOR_DATA_ENTRY:COLOR_NON_ESSENTIAL`;
      backgroundColour = -1;
      lineWidth = 2;
      lineStyle = `SolidPattern`;
      xReference = 5;
      yReference = 30;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



