    text InputArea
    {
      dialogue
      {
        event = `keyPressed(RETURN)`;
        action = statement `{
   UnSelectButton();
// See if the user entered more than max digits
   if(InputArea.position() > MaxDigits)
   {
      strcpy(TheNewText,"ERROR");
      ERROR = 1;
   }
   else if(InputArea.position() > 0)
   {
      strncpy(TheNewText,InputArea.buffer(),InputArea.position());
      TheNewText[InputArea.position()] = '\\0';
      TheNewNumber = atof(TheNewText);
      ERROR = 0;
   }
   else
// User did not enter anything, reset to last value
   {
      strcpy(TheNewText,TheOriginalText);
      TheNewNumber = TheOriginalNumber;
      ERROR = 0;
   }

   InputArea.edit(OFF);
   ExecuteReturn();
   update();
}`;
      }
      x = `TextX`;
      y = `TextY`;
      format = "%-8s";
      theText = `TheNewText`;

      visibility = `Selected || ERROR`;
      foregroundColour = `TextColour`;
      backgroundColour = `BackgroundColour`;
      theFont = `TextFont`;
      xReference = 8;
      yReference = 21;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    text TheNumber
    {
      x = `TextX`;
      y = `TextY`;
      format = `TheNumberFormat`;
      theText = `TheNewNumber`;

      visibility = `!Selected && !ERROR`;
      foregroundColour = `TextColour`;
      backgroundColour = `BackgroundColour`;
      theFont = `TextFont`;
      xReference = 96;
      yReference = 53;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
