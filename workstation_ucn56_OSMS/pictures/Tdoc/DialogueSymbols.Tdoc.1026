  class GroupView
  {

    RECORD *ThePointId = `&BLANK`;

function `char *SigTypeDisplay()
{
 switch(ThePointId->sig_type) {
    
    case 1:  return("AO") ;
    case 2:  return("QA") ;
    case 3:  return("XA") ;
    case 4:  return("KO") ;
    case 5:  return("AL") ;

    case 6:  return("AI") ;
    case 7:  return("PI") ;
    case 8:  return("FI") ;
    case 9:  return("ROD") ;

    case 10:  return("CI") ;
    case 11:  return("DI") ;
    case 12:  return("SOE") ;
    case 13:  return("BCI") ;
    case 14:  return("DL") ;
    case 15:  return("QD") ;

    case 16:  return("XD") ;
    case 17:  return("CO") ;
    case 18:  return("BCO") ;

    default:  return("") ;
   }
}`

