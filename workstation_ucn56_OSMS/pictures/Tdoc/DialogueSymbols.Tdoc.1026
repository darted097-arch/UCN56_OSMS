  class smallSelectButton
  {
    char UnSelectAction[100] = " ";

    int Selected = 1;

    char DynamicLabel[10] = "DISK";

    char StaticLabel[10] = " D";

    char Scope[100] = "";

    char Action[100] = "{printf(\"Hello World\");}";

    char Label[10] = "DISK";

function `void UnSelect()
{
// Set the "raised" colors for the input field
   TopEdge.foregroundColour = COLOR_TOP_EDGE;
   LeftEdge.foregroundColour = COLOR_TOP_EDGE;
   BottomEdge.foregroundColour = COLOR_BOTTOM_EDGE;
   RightEdge.foregroundColour = COLOR_BOTTOM_EDGE;
   Button.foregroundColour  = COLOR_BUTTON_BACKGROUND ;
   Button.foregroundFillColour  = COLOR_BUTTON_BACKGROUND ;
   InputArea.backgroundColour = COLOR_BUTTON_BACKGROUND ;
// 
   InputArea.theFont = 4;
   strcpy(Label,StaticLabel);
//
// Unselect it
   Selected = 0;
// and update the display
   updateShape();
}`

function `void Select()
{
//
// Set the edge colors to visualize a sunken field
   TopEdge.foregroundColour    = COLOR_BOTTOM_EDGE;
   LeftEdge.foregroundColour   = COLOR_BOTTOM_EDGE;
   BottomEdge.foregroundColour = COLOR_TOP_EDGE;
   RightEdge.foregroundColour  = COLOR_TOP_EDGE;
   Button.foregroundColour  = COLOR_BUTTON_SELECTED ;
   Button.foregroundFillColour  = COLOR_BUTTON_SELECTED ;
   InputArea.backgroundColour = COLOR_BUTTON_SELECTED ;
// 
   InputArea.theFont = 2;
   strcpy(Label,DynamicLabel);
//
// Set it to be selected
   Selected = 1;
// Update the display
   updateShape();

   executeAsync(Scope,Action);
}`



  dialogue
  {
    event = `buttonPressed(Left)  && Selected`;
    action = statement `{
// CANCEL INPUT FUNCTION
// 
// Unselect the field
//   UnSelect();
//
// execute the desired action
//   executeAsync(Scope,UnSelectAction); 
}`;
  }

  dialogue
  {
