  class InputDialogueNumber
  {
    int vis = `visibility`;

    int Active = 1;

    char Scope[80] = "";

    float TheNewNumber = 100;

    int MaxDigits = 8;

    float TheOriginalNumber = 34.5;

    char ReturnAction[100] = "";

    int Selected = 0;

    char *TheNumberFormat = "%-8.2f";

    int ERROR = 0;

    char TheOriginalText[80] = "100";

    char TheNewText[80] = "100";

    char ExecuteUnSelect[100] = "";

    char ExecuteSelect[100] = "";

    int TextFont = 4;

    int TextColour = `COLOR_PICTURE_BACKGROUND`;

    float TextY = 21;

    float TextX = 10;

    int TopShadow = `COLOR_BUTTON_TOP_SHADOW`;

    int BottomShadow = `COLOR_BUTTON_BOTTOM_SHADOW`;

    int BackgroundColour = `COLOR_BUTTON_BACKGROUND`;

    int SelectColour = `COLOR_BUTTON_SELECTED`;

    float Width = 150;

    float Height = 30;

    int isDown = 0;

    int isInside = 1;

function `void RestoreOriginalNumber()
{
// Copy the original contents back into the input field
   TheNewNumber = TheOriginalNumber;
   ERROR = 0;
}`

function `void ExecuteReturn()
{
   strcpy(TheOriginalText,TheNewText);
   executeAsync(Scope,ReturnAction);
}`

function `void UnSelectButton()
{
   up.foregroundColour = \`TopShadow\`;
   down.foregroundColour = \`BottomShadow\`;
   button.foregroundFillColour = \`BackgroundColour\`;
   button.foregroundColour = \`BackgroundColour\`;
   InputArea.backgroundColour =\`BackgroundColour\`;
   execute("{InputArea.format = \\"%%-%ds\\";}",MaxDigits);
   Selected = 0;
   executeAsync(Scope,ExecuteUnSelect);
}`

function `void SelectButton()
{

   up.foregroundColour = \`BottomShadow\`;
   down.foregroundColour = \`TopShadow\`;
   button.foregroundFillColour = \`SelectColour\`;
   button.foregroundColour = \`SelectColour\`;
   InputArea.backgroundColour = \`SelectColour\`;
   execute("{InputArea.format = \\"%%-%ds\\";}",2*MaxDigits);
   Selected = 1;
   executeAsync(Scope,ExecuteSelect);
}`

function `void pushButtonDown()
{

	up.foregroundColour = \`BottomShadow\`;
	down.foregroundColour = \`TopShadow\`;
	button.foregroundFillColour = \`SelectColour\`;
	button.foregroundColour = \`SelectColour\`;

	ButtonState = 1;

	update();
}`

function `void pushButtonUp()
{
	up.foregroundColour = \`TopShadow\`;
	down.foregroundColour = \`BottomShadow\`;
	button.foregroundFillColour = \`BackgroundColour\`;
	button.foregroundColour = \`BackgroundColour\`;

	ButtonState = 0;

	update();
}`



  dialogue
  {
    event = `buttonPressed(Left) || shapeEntered()`;
    action = statement `{
   SelectButton();
   strcpy(TheNewText,"");
   InputArea.theText = \`TheNewText\`;
   InputArea.edit(ON);
   InputArea.edit(OFF);
   InputArea.edit(ON);
   InputArea.moveToHome();
   update();
}`;
  }

  dialogue
  {
    event = `(Selected && buttonPressed(Right) ) || (Selected && shapeLeft())`;
    action = statement `{ 
   UnSelectButton();
   Selected = 0;
   strcpy(TheNewText,TheOriginalText);
   InputArea.edit(OFF);
   update();
}`;
  }

    rectangle button
    {
      x = 0;
      y = 0;
      width = `Width`;
      height = `Height`;

      visibility = 1;
      foregroundFillColour = `BackgroundColour`;
      backgroundFillColour = -1;
      foregroundColour = `BackgroundColour`;
      backgroundColour = -1;
      lineWidth = 0;
      linePattern = 1;
      fillPattern = 1;
      xReference = 0;
      yReference = 0;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    line up
    {
      numberOfPoints = 3;

      point[0] = (0, `Height`);
      point[1] = (0, 0);
      point[2] = (`Width`, 0);

      visibility = 1;
      foregroundColour = `TopShadow`;
      backgroundColour = -1;
      lineWidth = 2;
      lineStyle = 1;
      xReference = 0;
      yReference = `Height`;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    line down
    {
      numberOfPoints = 3;

      point[0] = (`Width`, 0);
      point[1] = (`Width`, `Height`);
      point[2] = (0, `Height`);

      visibility = 1;
      foregroundColour = `BottomShadow`;
      backgroundColour = -1;
      lineWidth = 2;
      lineStyle = 1;
      xReference = `Width`;
      yReference = 0;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    text InputArea
    {
      dialogue
      {
        event = `keyPressed(RETURN)`;
        action = statement `{
   UnSelectButton();
// See if the user entered more than max digits
   if(InputArea.position() > MaxDigits)
   {
      strcpy(TheNewText,"ERROR");
      ERROR = 1;
   }
   else if(InputArea.position() > 0)
   {
      strncpy(TheNewText,InputArea.buffer(),InputArea.position());
      TheNewText[InputArea.position()] = '\\0';
      TheNewNumber = atof(TheNewText);
      ERROR = 0;
   }
   else
// User did not enter anything, reset to last value
   {
      strcpy(TheNewText,TheOriginalText);
      TheNewNumber = TheOriginalNumber;
      ERROR = 0;
   }
   InputArea.edit(OFF);
   ExecuteReturn();
   update();
}`;
      }
      x = `TextX`;
      y = `TextY`;
      format = "%-8s";
      theText = `TheNewText`;

      visibility = `Selected && !ERROR && vis`;
      foregroundColour = `TextColour`;
      backgroundColour = `BackgroundColour`;
      theFont = `TextFont`;
      xReference = 8;
      yReference = 21;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    text TheNumber
    {
      x = `TextX`;
      y = `TextY`;
      format = `TheNumberFormat`;
      theText = `TheNewNumber`;

      visibility = `!Selected && vis`;
      foregroundColour = `TextColour`;
      backgroundColour = `BackgroundColour`;
      theFont = `TextFont`;
      xReference = 96;
      yReference = 53;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



// The class' other attributes:

  xSnap       = 8;
  ySnap       = 8;
  angleSnap   = 8;
  radiusSnap  = 8;
  worldX      = -100;
  worldY      = -100;
  worldWidth  = 1280;
  worldHeight = 1024;
  oneToOne    = 1;
  backgroundColour  = 0;
  xReference = 0;
  yReference = 0;
  xScaleFactor = 1;
  yScaleFactor = 1;
  rotationAngle = 0;

  } // end of class InputDialogueNumber



  class InputDialogueText
  {
    int vis = `visibility`;

    int isInside = 1;

    int isDown = 0;

    float Height = 30;

    float Width = 200;

    int SelectColour = `COLOR_BUTTON_SELECTED`;

    int BackgroundColour = `COLOR_BUTTON_BACKGROUND`;

    int BottomShadow = `COLOR_BUTTON_BOTTOM_SHADOW`;

    int TopShadow = `COLOR_BUTTON_TOP_SHADOW`;

    float TextX = 10;

    float TextY = 21;

    int TextColour = `COLOR_PICTURE_BACKGROUND`;

    int TextFont = 4;

    char ExecuteSelect[100] = "";

    char ExecuteUnSelect[100] = "";

    char TheNewText[80] = "DFN";

    char TheOriginalText[80] = "DFN";

    int ERROR = 0;

    int Selected = 0;

    char ReturnAction[100] = "";

    int MaxCharacters = 15;

    char Scope[80] = "";

function `void ExecuteReturn()
{
   strcpy(TheOriginalText,TheNewText);
   executeAsync(Scope,ReturnAction);
}`

function `void UnSelectButton()
{
   up.foregroundColour = \`TopShadow\`;
   down.foregroundColour = \`BottomShadow\`;
   button.foregroundFillColour = \`BackgroundColour\`;
   button.foregroundColour = \`BackgroundColour\`;
   InputArea.backgroundColour =\`BackgroundColour\`;
   execute("{InputArea.format = \\"%%-%ds\\";}",MaxCharacters);
   Selected = 0;
   executeAsync(Scope,ExecuteUnSelect);
}`

function `void SelectButton()
{

   up.foregroundColour = \`BottomShadow\`;
   down.foregroundColour = \`TopShadow\`;
   button.foregroundFillColour = \`SelectColour\`;
   button.foregroundColour = \`SelectColour\`;
   InputArea.backgroundColour = \`SelectColour\`;
   execute("{InputArea.format = \\"%%-%ds\\";}",2*MaxCharacters);
   Selected = 1;
   executeAsync(Scope,ExecuteSelect);
}`

function `void pushButtonDown()
{

	up.foregroundColour = \`BottomShadow\`;
	down.foregroundColour = \`TopShadow\`;
	button.foregroundFillColour = \`SelectColour\`;
	button.foregroundColour = \`SelectColour\`;

	ButtonState = 1;

	update();
}`

