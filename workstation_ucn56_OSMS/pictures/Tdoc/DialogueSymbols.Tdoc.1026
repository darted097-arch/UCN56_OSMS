    int BottomShadow = `COLOR_BUTTON_BOTTOM_SHADOW`;

    int BackgroundColour = `COLOR_BUTTON_BACKGROUND`;

    int SelectColour = `COLOR_BUTTON_SELECTED`;

    float Width = 200;

    float Height = 30;

    int isDown = 0;

    int isInside = 1;

    int vis = `visibility`;

function `void ExecuteReturn()
{
   strcpy(TheOriginalText,TheNewText);
   executeAsync(Scope,ReturnAction);
}`

function `void UnSelectButton()
{
   up.foregroundColour = \`TopShadow\`;
   down.foregroundColour = \`BottomShadow\`;
   button.foregroundFillColour = \`BackgroundColour\`;
   button.foregroundColour = \`BackgroundColour\`;
   InputArea.backgroundColour =\`BackgroundColour\`;
   execute("{InputArea.format = \\"%%-%ds\\";}",MaxCharacters);
   Selected = 0;
   executeAsync(Scope,ExecuteUnSelect);
}`

function `void SelectButton()
{

   up.foregroundColour = \`BottomShadow\`;
   down.foregroundColour = \`TopShadow\`;
   button.foregroundFillColour = \`SelectColour\`;
   button.foregroundColour = \`SelectColour\`;
   InputArea.backgroundColour = \`SelectColour\`;
   execute("{InputArea.format = \\"%%-%ds\\";}",2*MaxCharacters);
   Selected = 1;
   executeAsync(Scope,ExecuteSelect);
}`

function `void pushButtonDown()
{

	up.foregroundColour = \`BottomShadow\`;
	down.foregroundColour = \`TopShadow\`;
	button.foregroundFillColour = \`SelectColour\`;
	button.foregroundColour = \`SelectColour\`;

	ButtonState = 1;

	update();
}`

function `void pushButtonUp()
{
	up.foregroundColour = \`TopShadow\`;
	down.foregroundColour = \`BottomShadow\`;
	button.foregroundFillColour = \`BackgroundColour\`;
	button.foregroundColour = \`BackgroundColour\`;

	ButtonState = 0;

	update();
}`



  dialogue
  {
    event = `buttonPressed(Left) || shapeEntered()`;
    action = statement `{
   SelectButton();
   strcpy(TheNewText,"");
   InputArea.theText = \`TheNewText\`;
   InputArea.edit(ON);
   InputArea.edit(OFF);
   InputArea.edit(ON);
   InputArea.moveToHome();
   update();
}`;
  }

  dialogue
  {
    event = `(Selected && buttonPressed(Right) ) || (Selected && shapeLeft())`;
    action = statement `{ 
   UnSelectButton();
   Selected = 0;
   strcpy(TheNewText,TheOriginalText);
   InputArea.edit(OFF);

   update();
}`;
  }

    rectangle button
    {
      x = 0;
      y = 0;
      width = 49;
      height = 30;

      visibility = 1;
      foregroundFillColour = `BackgroundColour`;
      backgroundFillColour = -1;
      foregroundColour = `BackgroundColour`;
      backgroundColour = -1;
      lineWidth = 0;
      linePattern = 1;
      fillPattern = 1;
      xReference = 0;
      yReference = 0;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    line up
    {
      numberOfPoints = 3;

      point[0] = (0, `Height`);
      point[1] = (0, 0);
      point[2] = (50, 0);

      visibility = 1;
      foregroundColour = `TopShadow`;
      backgroundColour = -1;
      lineWidth = 2;
      lineStyle = 1;
      xReference = 0;
      yReference = `Height`;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    line down
    {
      numberOfPoints = 3;

      point[0] = (50, 0);
      point[1] = (50, 30);
      point[2] = (0, 30);

      visibility = 1;
      foregroundColour = `BottomShadow`;
      backgroundColour = -1;
      lineWidth = 2;
      lineStyle = 1;
      xReference = 50;
      yReference = 0;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    text InputArea
    {
      dialogue
      {
        event = `keyPressed(RETURN)`;
        action = statement `{
   UnSelectButton();
   if(InputArea.position() > 0)
   {
      strncpy(TheNewText,InputArea.buffer(),InputArea.position());
      ParseAndToupper(TheNewText,InputArea.position());
   }
   else
      strcpy(TheNewText,TheOriginalText);

   InputArea.edit(OFF);
   ExecuteReturn();
   update();
}`;
      }
      x = `TextX`;
      y = `TextY`;
      format = "%-3s";
      theText = `TheNewText`;

      visibility = `vis`;
      foregroundColour = `TextColour`;
      backgroundColour = `BackgroundColour`;
      theFont = `TextFont`;
      xReference = 8;
      yReference = 21;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



