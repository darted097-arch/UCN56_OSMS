      lineStyle = 1;
      xReference = 1;
      yReference = 30;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    line down
    {
      numberOfPoints = 3;

      point[0] = (39, -1);
      point[1] = (40, 31);
      point[2] = (1, 31);

      visibility = 1;
      foregroundColour = `BottomShadow`;
      backgroundColour = -1;
      lineWidth = 2;
      lineStyle = 1;
      xReference = 40;
      yReference = 1;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    text InputArea
    {
      dialogue
      {
        event = `keyPressed(RETURN)`;
        action = statement `{
   UnSelectButton();
   if(InputArea.position() > 0)
   {
      strncpy(TheNewText,InputArea.buffer(),InputArea.position());
      ParseAndToupper(TheNewText,InputArea.position());
   }
   else
   {
      strcpy(TheNewText,TheOriginalText);
   }
   InputArea.edit(OFF);
   ExecuteReturn();
   update();
}`;
      }
      x = 10;
      y = 21;
      format = "%-3s";
      theText = `TheNewText`;

      visibility = `vis`;
      foregroundColour = `TextColour`;
      backgroundColour = `BackgroundColour`;
      theFont = `TextFont`;
      xReference = 8;
      yReference = 21;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



