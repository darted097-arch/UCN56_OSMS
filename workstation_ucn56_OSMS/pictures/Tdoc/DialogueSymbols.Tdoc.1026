  dialogue
  {
    event = `shapeEntered()`;
    action = statement `{
mbox.foregroundColour = COLOR_BUTTON_SELECTED;
mbox.foregroundFillColour = COLOR_BUTTON_SELECTED;


upleft.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
upleft.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;
up.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
up.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;


downright.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
downright.foregroundFillColour = COLOR_BUTTON_TOP_SHADOW;
down.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
down.foregroundFillColour = COLOR_BUTTON_TOP_SHADOW;
TheFontColor = COLOR_DATA_NORMAL;
//   TheTextFont = \`font7\`;
   update();
}`;
  }

  dialogue
  {
    event = `shapeLeft()`;
    action = statement `{
mbox.foregroundColour = COLOR_BUTTON_BACKGROUND;
mbox.foregroundFillColour = COLOR_BUTTON_BACKGROUND;

upleft.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
upleft.foregroundFillColour = COLOR_BUTTON_TOP_SHADOW;
up.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
up.foregroundFillColour = COLOR_BUTTON_TOP_SHADOW;

downright.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
downright.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;
down.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
down.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;
   TheFontColor = COLOR_STATIC_TEXT;
//   TheTextFont = \`font6\`;
   update();
}`;
  }

  dialogue
  {
    event = `buttonPressed(Left) && Cascade`;
    action = statement `{
   CascadeMenuActive = 1;
   if (CascadeEnter.isMapped())
       CascadeEnter.unmap();
   execute("{DisplayCascadeEnter(\\"%s\\",%d,%d,%f,%f);}",TheDisplayPage,CascadeX,CascadeY,10.0,10.0);
}`;
  }

