  class SmallMenuSelection
  {
    char *TheOption = "?";

    int TheFontColor = `COLOR_CONFIG_ERROR`;

    char *TheTitle = "INSERT YOUR TEXT";

    char TheDisplayPage[50] = "PicUCN_Mainmenu.ppic";

    int Cascade = 0;

    int CascadeX = 400;

    int CascadeY = 400;

    float CursorX = 10;

    float CursorY = 10;





  dialogue
  {
    event = `shapeEntered()`;
    action = statement `{
   TheFontColor = \`COLOR_DATA_NORMAL\`;
   update();
}`;
  }

  dialogue
  {
    event = `shapeLeft()`;
    action = statement `{
   TheFontColor = \`COLOR_STATIC_TEXT\`;
   update();
}`;
  }

  dialogue
  {
    event = `buttonPressed(Left) && !Cascade`;
    action = statement `{
   execute("{DisplayPage(\\"%s\\");}",TheDisplayPage);
}`;
  }

  dialogue
  {
    event = `buttonPressed(Left) && Cascade`;
    action = statement `{
   CascadeEnterActive = 1;
   execute("{DisplayCascadeEnter(\\"%s\\",%d,%d,%f,%f);}",TheDisplayPage,CascadeX,CascadeY,CursorX,CursorY);
}`;
  }

