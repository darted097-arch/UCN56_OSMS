    char ExecuteUnSelect[100] = "";

    char TheNewText[80] = "";

    char TheOriginalText[80] = "45";

    int ERROR = 0;

    char *TheNumberFormat = "%-14.5f";

    int Selected = 0;

    char ReturnAction[100] = "";

    float TheOriginalNumber = 34.5;

    int MaxDigits = 8;

    float TheNewNumber = 1.23458e+07;

    char Scope[80] = "";

    int Active = 1;

function `void pushButtonDown()
{

	up.foregroundColour = \`BottomShadow\`;
	down.foregroundColour = \`TopShadow\`;
	button.foregroundFillColour = \`SelectColour\`;
	button.foregroundColour = \`SelectColour\`;

	ButtonState = 1;

	update();
}`

function `void pushButtonUp()
{
	up.foregroundColour = \`TopShadow\`;
	down.foregroundColour = \`BottomShadow\`;
	button.foregroundFillColour = \`BackgroundColour\`;
	button.foregroundColour = \`BackgroundColour\`;

	ButtonState = 0;

	update();
}`

    text InputArea
    {
      x = 10;
      y = 21;
      format = "%-8s";
      theText = `TheNewText`;

      visibility = `Selected || ERROR`;
      foregroundColour = `COLOR_BAD_OOR_ACK`;
      backgroundColour = `COLOR_PICTURE_BACKGROUND`;
      theFont = `TextFont`;
      xReference = 8;
      yReference = 21;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    text TheNumber
    {
      x = 14;
      y = 21;
      format = `TheNumberFormat`;
      theText = `TheNewNumber`;

      visibility = `!Selected && !ERROR`;
      foregroundColour = `COLOR_DATA_NORMAL`;
      backgroundColour = `COLOR_PICTURE_BACKGROUND`;
      theFont = `TextFont`;
      xReference = 100;
      yReference = 53;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



