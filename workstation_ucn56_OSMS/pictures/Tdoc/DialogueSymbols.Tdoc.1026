  class BarUpdate
  {








    float HH_TEMP_POS = 0;

    float L_TEMP_POS = 0;

    float LL_TEMP_POS = 0;

    float H_TEMP_POS = 580.691;

    float BASE = 340;

    float MIN = 330;

    float MAX = 350;

    RECORD *pPID = `&::UCN5and6.InterfaceToGUI.RCT111X`;

    int BAR_SET_NUM = 1;

    int CHART_NUM = 1;

    BAR_DATA *pBAR_DATA = `Interface.BarChartData`;

    float TEMP_POS = 377.5;

    float TEMP_HEIGHT = 0;

    float TEMP_HEIGHT_OLD = `TEMP_HEIGHT`;

    char TEMP_STRING[18] = "NTROL          ";

    int ll_vis = 0;

    int l_vis = 0;

    int h_vis = 1;

    int hh_vis = 0;

function `float UpdateBarBox()
{
//   printf("Hmet, HVAL, MIN, MAX is %f %f %f %f",pPID->hmet, pPID->hval, GetMin(), GetMax());
     float INCREASE;

   hy();
   hhy();
   ly();
   lly();

   if ((MAX-MIN) !=0)
   {
      if ( (pPID->value >= MIN)  && (pPID->value <= MAX) )
      {
         execute("{TEMP_HEIGHT = -( (pPID->value-MIN) * (521 / (MAX-MIN) ));}");
         return(TEMP_HEIGHT);
      }
      else if (pPID->value > MAX) 
      {
         TEMP_HEIGHT = -521;         
         return(TEMP_HEIGHT);
      }
      else if (pPID->value < MIN) 
      {
         TEMP_HEIGHT = 0;
         return(TEMP_HEIGHT);
      }
   }
//   printf("height1 () is %f %f %f %f",TEMP_HEIGHT, pPID->value ,MIN ,MAX);
}`

function `float hhy()
{
   if ( (MAX-MIN)!=0)
   {
      if (!Interface->System.displayedUnits)
         execute("{HH_TEMP_POS = pPID->hhval;}");
      else if (Interface->System.displayedUnits)
         execute("{HH_TEMP_POS = pPID->hhmet;}");
//--------------------------------------------------------------------------
      hh_vis = 1;

      if ((HH_TEMP_POS > MAX) || (HH_TEMP_POS < MIN))
         hh_vis = 0;
      else
         HH_TEMP_POS  = (638-( (HH_TEMP_POS-MIN) * (521.0/(MAX-MIN)) ) );

      return(HH_TEMP_POS);
   }
}`

function `float hy()
{
   if ( (MAX-MIN)!=0)
   {
      if (!Interface->System.displayedUnits)
         execute("{H_TEMP_POS = pPID->hval;}");
      else
         execute("{H_TEMP_POS = pPID->hmet;}");
//--------------------------------------------------------------------------
      h_vis = 1;

      if ((H_TEMP_POS > MAX) || (H_TEMP_POS < MIN))
         h_vis = 0;
      else
         H_TEMP_POS  = (638-( (H_TEMP_POS-MIN) * (521.0/(MAX-MIN)) ) );

      return(H_TEMP_POS);
   }
}`

function `float basey()
{
   if ((MAX-MIN)!=0)
   {
      execute("{TEMP_POS = BASE;}");
      TEMP_POS = 638-( (BASE-MIN)*(521.0/(MAX-MIN)) ); 
//    printf("min, max is %f %f ", MIN, MAX);
      return(TEMP_POS);
   }
}`

function `float ly()
{
   if ( (MAX-MIN)!=0)
   {
      if (!Interface->System.displayedUnits)
         execute("{L_TEMP_POS = pPID->lval;}");
      else
         execute("{L_TEMP_POS = pPID->lmet;}");
//--------------------------------------------------------------------------
      l_vis = 1;

      if ((L_TEMP_POS > MAX) || (L_TEMP_POS < MIN))
         l_vis = 0;
      else
         L_TEMP_POS  = (638-( (L_TEMP_POS-MIN) * (521.0/(MAX-MIN)) ) );

      return(L_TEMP_POS);
   }

}`

function `float lly()
{
   if ( (MAX-MIN)!=0)
   {
      if (!Interface->System.displayedUnits)
         execute("{LL_TEMP_POS = pPID->llval;}");
      else
         execute("{LL_TEMP_POS = pPID->llmet;}");
//--------------------------------------------------------------------------
      ll_vis = 1;

      if ((LL_TEMP_POS > MAX) || (LL_TEMP_POS < MIN))
         ll_vis = 0;
      else
         LL_TEMP_POS  = (638-( (LL_TEMP_POS-MIN) * (521.0/(MAX-MIN)) ) );

      return(LL_TEMP_POS);
   }
}`

function `int GetBoxColor()
{

   if ((pPID->pisabitmap & bOOSCAN) > 0)
   {
      if (pPID->pisabitmap & bENVAL) return (Colour46);
      else return(COLOR_BAD_OOR_ACK);
   }
   else if (pPID->newsta == NORMAL ||
            pPID->newsta == RALACK ||
            pPID->newsta == RORACK ||
            pPID->newsta == RBDACK ||
            pPID->newsta == RALNAK ||
            pPID->newsta == RORNAK ||
            pPID->newsta == RBDNAK)
   {
      return (Colour46);
   }
   else
   {
      return(COLORS[pPID->newsta]);
   }
}
`

function `char * Get1halfString()
{
strncpy(TEMP_STRING, pPID->desc, 18);
//printf("STRING = %s", TEMP_STRING);
return(TEMP_STRING);
}`

function `char * Get2halfString()
{
strncpy(TEMP_STRING, pPID->desc+17, 18);
//printf("2STRING = %s", TEMP_STRING);
return(TEMP_STRING);
}`

function `int IsDigital(RECORD *pRECORD)
{
  int retval, sigtype;

// get a pointer to the record for the PID
//  execute("{pRECORD = &%s;}",PID);


  sigtype = pRECORD->sig_type;
  switch(sigtype)
  {
    case CI:
    case DI:
    case SOE:
    case BCI:
    case DL:
    case QD:
    case XD:
    case CO:
    case BCO:
      retval = 1;
      break;
    default:
      retval = 0;
      break;
  }//endswitch
  return(retval);
}`

