function `void NoButtonSelect()
{
   YesBut.UnSelect();
   OptionSelected = 0;   
   if ( strlen( ExecuteNoButtonSelect ) > 0 )
	executeAsync( Scope,ExecuteNoButtonSelect );
   update();
}`

function `void Initialize()
{
   YesBut.UnSelect();
   NoBut.UnSelect();
}`

function `void YesButtonSelect()
{
   YesBut.UnSelect();
   OptionSelected = 1;   
   if ( strlen( ExecuteYesButtonSelect ) > 0 )
	executeAsync( Scope,ExecuteYesButtonSelect );
   update();
}`

