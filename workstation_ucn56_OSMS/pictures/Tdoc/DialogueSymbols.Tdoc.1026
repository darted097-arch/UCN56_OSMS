  class LargeMenuSelection
  {
    int CascadeY = 400;

    int CascadeX = 400;

    int Cascade = 0;

    int TheTextFont = `font6`;

    char TheDisplayPage[50] = "PicUCN_Mainmenu.ppic";

    char *TheTitle = "INSERT YOUR TEXT";

    int TheFontColor = `COLOR_CONFIG_ERROR`;

