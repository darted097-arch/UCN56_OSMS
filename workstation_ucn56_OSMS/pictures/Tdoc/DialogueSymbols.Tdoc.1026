  class FooterMenuButton
  {
    char ExecuteString[100] = "DisplayESCPage()";

    int isInside = 1;

    int isDown = 0;

    float Height = 30;

    float Width = 100;

    int ButtonState = 0;

    int SelectColour = `COLOR_BUTTON_SELECTED`;

    int BackgroundColour = `COLOR_BUTTON_BACKGROUND`;

    int BottomShadow = `COLOR_BUTTON_BOTTOM_SHADOW`;

    int TopShadow = `COLOR_BUTTON_TOP_SHADOW`;

    float TextX = 17;

    float TextY = 22;

    char Label[30] = "ESC";

    int TextColour = `COLOR_PICTURE_BACKGROUND`;

    int TextFont = 2;

    float TextXStatic = 17;

    float TextXDynamic = 15;

    float TextYStatic = 22;

    float TextYDynamic = 21;

    char DynamicLabel[30] = "DYNAMIC";

    char StaticLabel[30] = "STATIC";

    int TextFontStatic = `font4`;

    int TextFontDynamic = `font2`;

function `void Select()
{
//
   if (0 == Logon) return; 

//
	up.foregroundColour = Colour50;
	down.foregroundColour = Colour29;
	button.foregroundFillColour = Colour39;
	button.foregroundColour = Colour39;
//        strcpy(Label,DynamicLabel);
//        TextX = TextXDynamic;
//        TextY = TextYDynamic;
//        TextFont = TextFontDynamic;

	ButtonState = 1;

	if ( strlen( ExecuteString ) > 0 )
		execute( ExecuteString );
	update();
}`

function `void UnSelect()
{
	up.foregroundColour = Colour48;
	down.foregroundColour = Colour50;
	button.foregroundFillColour = Colour45;
	button.foregroundColour = Colour45;
//        strcpy(Label,StaticLabel);
//        TextX = TextXStatic;
//        TextY = TextYStatic;
//        TextFont = TextFontStatic;

        ButtonState = 0;

	update();
}`

function `void pushButtonDown()
{

	up.foregroundColour = \`BottomShadow\`;
	down.foregroundColour = \`TopShadow\`;
	button.foregroundFillColour = \`SelectColour\`;
	button.foregroundColour = \`SelectColour\`;

	ButtonState = 1;

	update();
}`

function `void pushButtonUp()
{
	up.foregroundColour = \`TopShadow\`;
	down.foregroundColour = \`BottomShadow\`;
	button.foregroundFillColour = \`BackgroundColour\`;
	button.foregroundColour = \`BackgroundColour\`;

	ButtonState = 0;

	update();
}`

function `int ChangeColor()
{
   //if ((0 == CFMLevel || 3 == CFMLevel) && !strcmp(MenuTitle.theText, "SECTOR"))	//for ucn56EOF by feel9 20200212
	 if ((0 == CFMLevel || 3 == CFMLevel) && !strcmp(MenuTitle.theText, "SECTOR") && !strcmp(MenuTitle.theText, "MAIN") && !strcmp(MenuTitle.theText, "CFM MON") && !strcmp(MenuTitle.theText, "ALM ACK") && !strcmp(MenuTitle.theText, "ALM RST") && !strcmp(MenuTitle.theText, "CAL") && !strcmp(MenuTitle.theText, "PAGE"))		
   {
      return Colour41;
   }
   else
   {
      return COLOR_DATA_NORMAL;
   }

}`



  dialogue
  {
    event = `buttonPressed(Left)`;
    action = statement `{ Select(); }`;
  }

  dialogue
  {
    event = `buttonReleased(Left)`;
    action = statement `{ UnSelect(); }`;
  }

