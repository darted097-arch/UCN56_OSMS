      dialogue
      {
        event = `keyPressed(RETURN)`;
        action = statement `{
   if (Interface->System.displayedUnits)         // if Current display is METRIC 
   {
      UnSelectButton();



      if(InputArea.position() > MaxDigits)          // See if the user entered more than max digits
      {
         strcpy(TheNewText,"ERROR");
         ERROR = 1;
      }
      else if(InputArea.position() > 0)
      {
         strncpy(TheNewText,InputArea.buffer(),InputArea.position());

         TheNewText[InputArea.position()] = '\\0';
         TheNewNumber = atof(TheNewText);

         if (  strcmp(TheNewText, "bd") == 0 || strcmp(TheNewText, "BD") == 0 )       //    To recognize input is numeric or NOT(ALPH-ANUMERIC)
         {
            TheNewNumber = -1;                             // To display BAD data for "bd" or "BD"
            TheOriginalNumber = TheNewNumber;
	    strcpy(TheOriginalText, TheNewText);	// CORENET 201705 by Philkyu Kwon
            ERROR = 0;
         }
         else if (  (TheNewNumber > 0.0) && (TheNewNumber <= 381.0) && (strcmp(TheNewText, "0") != 0)  )
         {
            RestoreColorAndState();
            TheNewText[InputArea.position()] = '\\0';
            TheNewNumber = atof(TheNewText);
            TheOriginalNumber = TheNewNumber;
            ERROR = 0;
         }
         else
         {   
            if (atof(TheNewText) == 0 && strcmp(TheNewText, "0") == 0)
            {
               TheNewNumber = 0.00;
               TheOriginalNumber= TheNewNumber;
               strcpy(TheNewText,"0.00");
               strcpy(TheOriginalText, TheNewText);
               ERROR = 0;
            }
            else
            {
//             strcpy(TheNewText,TheOriginalText);
               sprintf(TheNewText,"%-8.2f",TheOriginalNumber);
               TheNewNumber = TheOriginalNumber;
               ERROR = 1;
               DisplayAdvisoryMessage1("BD  OR  VALUE  WITHIN  0-381  REQUIRED ");
            }
         }
      }
      else      // User did not enter anything, reset to last value
      {
//       strcpy(TheNewText,TheOriginalText);
         sprintf(TheNewText,"%-8.2f",TheOriginalNumber);
         TheNewNumber = TheOriginalNumber;
         ERROR = 0;
      }
   }
   else if (Interface->System.displayedUnits == 0)      // if Current display is not ENGLISH
   {
      UnSelectButton();
                                                   // See if the user entered more than max digits
      if(InputArea.position() > MaxDigits)
      {
         strcpy(TheNewText,"ERROR");
         ERROR = 1;
      }
      else if(InputArea.position() > 0)
      {
         strncpy(TheNewText,InputArea.buffer(),InputArea.position());
         TheNewText[InputArea.position()] = '\\0';
         TheNewNumber = atof(TheNewText);
         if (  strcmp(TheNewText, "bd") == 0 || strcmp(TheNewText, "BD") == 0 ) 
         {
            // To display BAD data for "bd" or "BD"
            TheNewNumber = -1;
            TheOriginalNumber = TheNewNumber;
	    strcpy(TheOriginalText, TheNewText);	// CORENET 201705 by Philkyu Kwon
            ERROR = 0;
         }
         else if (  (TheNewNumber > 0.0) && (TheNewNumber <= 150.0) && (strcmp(TheNewText, "0") != 0)  )
         {
                 //printf("TheNewText = %s", TheNewText);
            RestoreColorAndState();
            TheNewText[InputArea.position()] = '\\0';
            TheNewNumber = atof(TheNewText);
            TheOriginalNumber = TheNewNumber;
            ERROR = 0;
         }
         else
         {   
            if (atof(TheNewText) == 0 && strcmp(TheNewText, "0") == 0)
            {
                   TheNewNumber = 0.00;
                   TheOriginalNumber= TheNewNumber;
                   strcpy(TheNewText,"0.00");
                   strcpy(TheOriginalText, TheNewText);
                   ERROR = 0;
                  // printf("NNNNTheNewText = %s", TheNewText);
             }
             else
             {
                   //printf("xxxxxTheNewText = %s", TheNewText);
                   strcpy(TheNewText,TheOriginalText);
                   TheNewNumber = TheOriginalNumber;
                   ERROR = 1;
                   DisplayAdvisoryMessage1("BD  OR  VALUE  WITHIN  0-150  REQUIRED ");
             }
         }
      }
      else         // User did not enter anything, reset to last value
      {
         strcpy(TheNewText,TheOriginalText);
         TheNewNumber = TheOriginalNumber;
         ERROR = 0;
      }
   }
   InputArea.edit(OFF);
   ExecuteReturn();

   if(ERROR){ }
   else if(TheNewNumber < 0) 
   {
      strcpy(TheNewText," BD -------");
      TheNewNumber = -1.0 ;
   }
   else sprintf(TheNewText,"%-8.2f",TheNewNumber);  // yrlee 

   strcpy(TheOriginalText,TheNewText);

   update();
}`;
      }
      x = `TextX`;
