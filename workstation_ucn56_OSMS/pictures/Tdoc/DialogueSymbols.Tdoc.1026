  class OptionButton
  {
    char ExecuteUnSelect[100] = "";

    char ExecuteSelect[100] = "";

    int TextFontDynamic = `font2`;

    int TextFontStatic = `font4`;

    char StaticLabel[30] = "STATIC";

    char DynamicLabel[30] = "DYNAMIC";

    float TextYDynamic = `TextY`;

    float TextYStatic = `TextY`;

    float TextXDynamic = 15;

    float TextXStatic = 17;

    int TextFont = 4;

    int TextColour = `COLOR_PICTURE_BACKGROUND`;

    char Label[30] = "STATIC";

    float TextY = 22;

    float TextX = 17;

    int TopShadow = `COLOR_BUTTON_TOP_SHADOW`;

    int BottomShadow = `COLOR_BUTTON_BOTTOM_SHADOW`;

    int BackgroundColour = `COLOR_BUTTON_BACKGROUND`;

    int SelectColour = `COLOR_BUTTON_SELECTED`;

    int ButtonState = 0;

    float Width = 100;

    float Height = 30;

    int isDown = 0;

    int isInside = 1;

    int DisplayText = 1;

function `void pushButtonDown()
{

	up.foregroundColour = \`BottomShadow\`;
	down.foregroundColour = \`TopShadow\`;
	button.foregroundFillColour = \`SelectColour\`;
	button.foregroundColour = \`SelectColour\`;

	ButtonState = 1;

	update();
}`

function `void pushButtonUp()
{
	up.foregroundColour = \`TopShadow\`;
	down.foregroundColour = \`BottomShadow\`;
	button.foregroundFillColour = \`BackgroundColour\`;
	button.foregroundColour = \`BackgroundColour\`;

	ButtonState = 0;

	update();
}`

function `void UnSelect()
{
	up.foregroundColour = \`TopShadow\`;
	down.foregroundColour = \`BottomShadow\`;
	button.foregroundFillColour = \`BackgroundColour\`;
	button.foregroundColour = \`BackgroundColour\`;
        strcpy(Label,StaticLabel);
        TextX = TextXStatic;
        TextY = TextYStatic;
        TextFont = TextFontStatic;

        ButtonState = 0;

	if ( strlen( ExecuteUnSelect ) > 0 )
		execute( ExecuteUnSelect );
	update();
}`

function `void Select()
{

	up.foregroundColour = \`BottomShadow\`;
	down.foregroundColour = \`TopShadow\`;
	button.foregroundFillColour = \`SelectColour\`;
	button.foregroundColour = \`SelectColour\`;
        strcpy(Label,DynamicLabel);
        TextX = TextXDynamic;
        TextY = TextYDynamic;
        TextFont = TextFontDynamic;

	ButtonState = 1;

	if ( strlen( ExecuteSelect ) > 0 )
		execute( ExecuteSelect );
	update();
}`


  dialogue
  {
    event = `buttonPressed(Left)`;
    action = statement `{ 
//  if (ButtonState)
//      UnSelect(); 
//  else
      Select();
}`;
  }

    rectangle button
    {
      x = 0;
      y = 0;
      width = `Width`;
      height = `Height`;

      visibility = 1;
      foregroundFillColour = `BackgroundColour`;
      backgroundFillColour = -1;
      foregroundColour = `BackgroundColour`;
      backgroundColour = -1;
      lineWidth = 0;
      linePattern = 1;
      fillPattern = 1;
      xReference = 0;
      yReference = 0;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    line up
    {
      numberOfPoints = 3;

      point[0] = (0, `Height`);
      point[1] = (0, 0);
      point[2] = (`Width`, 0);

      visibility = 1;
      foregroundColour = `TopShadow`;
      backgroundColour = -1;
      lineWidth = 2;
      lineStyle = 1;
      xReference = 0;
      yReference = `Height`;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    line down
    {
      numberOfPoints = 3;

      point[0] = (`Width`, 0);
      point[1] = (`Width`, `Height`);
      point[2] = (0, `Height`);

      visibility = 1;
      foregroundColour = `BottomShadow`;
      backgroundColour = -1;
      lineWidth = 2;
      lineStyle = 1;
      xReference = `Width`;
      yReference = 0;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    text 
    {
      x = `TextX`;
      y = `TextY`;
      format = "%s";
      theText = `Label`;

      visibility = `DisplayText`;
      foregroundColour = `TextColour`;
      backgroundColour = -1;
      theFont = `TextFont`;
      xReference = 8;
      yReference = 21;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



