function `void UnSelect()
{
// Set the "raised" colors for the input field
   TopEdge.foregroundColour = COLOR_TOP_EDGE;
   LeftEdge.foregroundColour = COLOR_TOP_EDGE;
   BottomEdge.foregroundColour = COLOR_BOTTOM_EDGE;
   RightEdge.foregroundColour = COLOR_BOTTOM_EDGE;
// 
   InputArea.theFont = 4;
   strcpy(Label,StaticLabel);
// and update the display
   updateShape();
}`

function `void Select()
{
//
// Set the edge colors to visualize a sunken field
   TopEdge.foregroundColour    = COLOR_BOTTOM_EDGE;
   LeftEdge.foregroundColour   = COLOR_BOTTOM_EDGE;
   BottomEdge.foregroundColour = COLOR_TOP_EDGE;
   RightEdge.foregroundColour  = COLOR_TOP_EDGE;
// 
   InputArea.theFont = 2;
   strcpy(Label,DynamicLabel);
// Update the display
   updateShape();
}`



