  worldY      = -100;
  worldWidth  = 1280;
  worldHeight = 1024;
  oneToOne    = 1;
  backgroundColour  = 0;
  xReference = 0;
  yReference = 0;
  xScaleFactor = 1;
  yScaleFactor = 1;
  rotationAngle = 0;

  } // end of class InputDialogueTextUTDV



  class YesButton
  {
    char Scope[80] = "";

