  class EnterSmallLSFPointId
  {
    int Selected = 0;

    char TheOriginalText[40] = "Original";

    char TheNewText[40] = "ERROR";

    char FoundAction[100] = "{printf(\"Point Id Found\");}";

    char NotFoundAction[100] = "{printf(\"Point Id Not Found\");}";

    char Scope[80] = "";

    int ERROR = 1;

    char FindPidScope[80] = "";

    char PolyAction[100] = "{printf(\"Valid Degree Entered\");}";

function `void ExecuteFailure()
{
   ERROR = 1;
// Point Id not found; execute failure routine
   executeAsync(Scope,NotFoundAction);
}`

function `void ExecuteSuccess()
{
// Point Id found, copy it into the original area
   strcpy(TheOriginalText,TheNewText);
   executeAsync(Scope,FoundAction);
}`

function `void ExecutePoly()
{
// Point Id found, copy it into the original area
   strcpy(TheOriginalText,TheNewText);
   executeAsync(Scope,PolyAction);
}`



  dialogue
  {
    event = `buttonPressed(Left) || shapeEntered()`;
    action = statement `{
   Selected = 1;
   strcpy(TheNewText,"");
   InputArea.theText = \`TheNewText\`;
   InputArea.edit(ON);
   InputArea.edit(OFF);
   InputArea.edit(ON);
   InputArea.moveToHome(); 
   update(); 
}`;
  }

  dialogue
  {
    event = `Selected && shapeLeft()`;
    action = statement `{
   Selected = 0;
   strcpy(TheNewText,TheOriginalText);
   ERROR = 0;
   InputArea.edit(OFF);
   update();
}`;
  }

    text InputArea
    {
      dialogue
      {
        event = `keyPressed(RETURN)`;
        action = statement `{
   Selected = 0;

   if (InputArea.position() > 0)
   { 
      strcpy(TheNewText,InputArea.buffer());
      ParseAndToupper(TheNewText,InputArea.position());
   }
   else
      strcpy(TheNewText,TheOriginalText);

   InputArea.edit(OFF);

   if (*TheNewText == ' ') 
      strcpy(TheNewText,"ERROR") ;      // for error message generation


// call findpid
   if ((*TheNewText >= '1') && (*TheNewText <= '5') && (strlen(TheNewText)==1))
   {
      //if ((atoi(*TheNewText) >= 1) && (atoi(*TheNewText) <=5))
      //{
//          printf("Got a valid number");
          execute("{ ::UCN5and6.PicUCN_LSFCascade.InputArea.ExecutePoly(); }");
       //}
   }
   else
      execute("{ findPidForGUI(TheNewText,FindPidScope,\\"ExecuteSuccess()\\",\\"ExecuteFailure()\\"); }");

   if(!strcmp(TheNewText,"ERROR")) strcpy(TheNewText," ") ;      // for error message generation

}`;
      }
      x = 5;
      y = 23;
      format = "%-20s";
      theText = `TheNewText`;

      visibility = 1;
      foregroundColour = `COLOR_DATA_NORMAL`;
      backgroundColour = -1;
      theFont = `font2`;
      xReference = 5;
      yReference = 23;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    line 
    {
      numberOfPoints = 2;

      point[0] = (5, 30);
      point[1] = (95, 30);

