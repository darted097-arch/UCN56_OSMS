  class ProcessButton
  {
    char ExecuteUnSelect[100] = "";

    char ExecuteSelect[100] = "";

    int TextFontDynamic = `font4`;

    int TextFontStatic = `font4`;

    char StaticLabel[30] = "PROCESS";

    char DynamicLabel[30] = "PROCESS";

    float TextYDynamic = `TextY`;

    float TextYStatic = `TextY`;

    float TextXDynamic = 15;

    float TextXStatic = 17;

    int TextFont = 4;

    int TextColour = `COLOR_PICTURE_BACKGROUND`;

    char Label[30] = "PROCESS";

    float TextY = 22;

    float TextX = 17;

    int TopShadow = `COLOR_BUTTON_TOP_SHADOW`;

    int BottomShadow = `COLOR_BUTTON_BOTTOM_SHADOW`;

    int BackgroundColour = `COLOR_BUTTON_BACKGROUND`;

    int SelectColour = `COLOR_BUTTON_SELECTED`;

    int ButtonState = 0;

    float Width = 100;

    float Height = 30;

    int isDown = 0;

    int isInside = 1;

    int DisplayText = 1;

function `void pushButtonDown()
{

	up.foregroundColour = \`BottomShadow\`;
	down.foregroundColour = \`TopShadow\`;
	button.foregroundFillColour = \`SelectColour\`;
	button.foregroundColour = \`SelectColour\`;

	ButtonState = 1;

	update();
}`

function `void pushButtonUp()
{
	up.foregroundColour = \`TopShadow\`;
	down.foregroundColour = \`BottomShadow\`;
	button.foregroundFillColour = \`BackgroundColour\`;
	button.foregroundColour = \`BackgroundColour\`;

	ButtonState = 0;

	update();
}`

function `void UnSelect()
{
	up.foregroundColour = \`TopShadow\`;
	down.foregroundColour = \`BottomShadow\`;
	button.foregroundFillColour = \`BackgroundColour\`;
	button.foregroundColour = \`BackgroundColour\`;
        strcpy(Label,StaticLabel);
        TextX = TextXStatic;
        TextY = TextYStatic;
        TextFont = TextFontStatic;

        ButtonState = 0;

	if ( strlen( ExecuteUnSelect ) > 0 )
		execute( ExecuteUnSelect );
	update();
}`

function `void Select()
{

	up.foregroundColour = \`BottomShadow\`;
	down.foregroundColour = \`TopShadow\`;
	button.foregroundFillColour = \`SelectColour\`;
	button.foregroundColour = \`SelectColour\`;
        strcpy(Label,DynamicLabel);
        TextX = TextXDynamic;
        TextY = TextYDynamic;
        TextFont = TextFontDynamic;

	ButtonState = 1;

	if ( strlen( ExecuteSelect ) > 0 )
		execute( ExecuteSelect );
	update();
}`

function `void Initialize()
{  
   ButtonState =0;
   UnSelect();
}`


  dialogue
  {
    event = `buttonPressed(Left)`;
    action = statement `{ 
  if (ButtonState)
      UnSelect(); 
  else
      Select();
}`;
  }

    rectangle button
    {
      x = 2;
