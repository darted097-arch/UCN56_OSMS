  function `void CorrectClr() // JHC 990419
  {
   if (strcmp(Correct.TheNewText, "N") == 0) {
     nText.foregroundColour = \`COLOR_DATA_NORMAL\`;
     yText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;
     }
   else {
     yText.foregroundColour = \`COLOR_DATA_NORMAL\`;
     nText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;
     }
  }`

  function `void DisplayUTDVData()
  {
     //printf("DisplayUTDVData(): copying shared memory data into local ...");
  
     //printf(" Filename: %s", filename2.TheNewText);
     //printf(" Date: %d", Interface->UtdvData.nextToLastMidnight.efphFile);
     //printf(" Date: %s", Interface->UtdvData.nextToLastMidnight.dateFile);
  //
  // -- Last Midnight Data ----------------------------------------------------------------------
     execute ("{strcpy(filename2.TheNewText, utlmid652);}");
     execute ("{efph21.TheNewNumber = Interface->UtdvData.lastMidnight.efphFile;}");
     execute ("{efph22.TheNewNumber = Interface->UtdvData.lastMidnight.efphRpcb;}");
     execute ("{efph23.TheNewNumber = Interface->UtdvData.lastMidnight.efphColss;}");
     execute ("{efph24.TheNewNumber = Interface->UtdvData.lastMidnight.efphIncore;}");
     execute ("{efph25.TheNewNumber = Interface->UtdvData.lastMidnight.efphCeaExposure;}");
  
     execute ("{strcpy(date21.TheNewText, Interface->UtdvData.lastMidnight.dateFile);}");
     execute ("{strcpy(date22.TheNewText, Interface->UtdvData.lastMidnight.dateRpcb);}");
     execute ("{strcpy(date23.TheNewText, Interface->UtdvData.lastMidnight.dateColss);}");
     execute ("{strcpy(date24.TheNewText, Interface->UtdvData.lastMidnight.dateIncore);}");
     execute ("{strcpy(date25.TheNewText, Interface->UtdvData.lastMidnight.dateCeaExposure);}");
     execute ("{strcpy(date26.TheNewText, Interface->UtdvData.lastMidnight.dateCeaPosition);}");
  
     execute ("{strcpy(time21.TheNewText, Interface->UtdvData.lastMidnight.timeFile);}");
     execute ("{strcpy(time22.TheNewText, Interface->UtdvData.lastMidnight.timeRpcb);}");
     execute ("{strcpy(time23.TheNewText, Interface->UtdvData.lastMidnight.timeColss);}");
     execute ("{strcpy(time24.TheNewText, Interface->UtdvData.lastMidnight.timeIncore);}");
     execute ("{strcpy(time25.TheNewText, Interface->UtdvData.lastMidnight.timeCeaExposure);}");
     execute ("{strcpy(time26.TheNewText, Interface->UtdvData.lastMidnight.timeCeaPosition);}");
  //
  // -- Latest Hourly Data ----------------------------------------------------------------------
     execute ("{strcpy(filename3.TheNewText, utlhcea652);}");
     execute ("{efph31.TheNewNumber = Interface->UtdvData.latestHourly.efphFile;}");
     execute ("{efph32.TheNewNumber = Interface->UtdvData.latestHourly.efphRpcb;}");
     execute ("{efph33.TheNewNumber = Interface->UtdvData.latestHourly.efphCeaExposure;}");
  
     execute ("{strcpy(date31.TheNewText, Interface->UtdvData.latestHourly.dateFile);}");
     execute ("{strcpy(date32.TheNewText, Interface->UtdvData.latestHourly.dateRpcb);}");
     execute ("{strcpy(date33.TheNewText, Interface->UtdvData.latestHourly.dateCeaExposure);}");
     execute ("{strcpy(date34.TheNewText, Interface->UtdvData.latestHourly.dateCeaPosition);}");
  
     execute ("{strcpy(time31.TheNewText, Interface->UtdvData.latestHourly.timeFile);}");
     execute ("{strcpy(time32.TheNewText, Interface->UtdvData.latestHourly.timeRpcb);}");
     execute ("{strcpy(time33.TheNewText, Interface->UtdvData.latestHourly.timeCeaExposure);}");
     execute ("{strcpy(time34.TheNewText, Interface->UtdvData.latestHourly.timeCeaPosition);}");
  //
  // -- Delta Data ----------------------------------------------------------------------
      execute ("{efph41.TheNewNumber = Interface->UtdvData.present.mostRecentEfphFile;}");
     TextProcessing.visibility = 0;
  }`

  function `void escape()
  {
  DisplayPage(Page681);
