  {
  }`

  function `void Vis()
  {
     if (UTDV681_option == 1)
     {
     strcpy(WhichFile.TheNewText, "1");
     WhichFile.Flag =2;
     WhichFile.visibility =1;
     SelFileTxt.visibility =1;
     SelText.visibility = 1;
     File1Text.visibility =0;
     File2Text.visibility =0;
     TextFile1.visibility =1;
     TextFile2.visibility =1;
     SelFileTxt.Text1.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     SelFileTxt.Text2.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     }
     else if (UTDV681_option == 2)
     {
     strcpy(WhichFile.TheNewText, "1");
     WhichFile.Flag =2;
     WhichFile.visibility =0;
     SelFileTxt.visibility =0;
     SelText.visibility = 0;
     File1Text.visibility =1;
     File2Text.visibility =0;
     TextFile1.visibility =1;
     TextFile2.visibility =1;
     SelFileTxt.Text1.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     SelFileTxt.Text2.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     }
     else
     {
     strcpy(WhichFile.TheNewText, "2");
     WhichFile.Flag =1;
     WhichFile.visibility =0;
     SelFileTxt.visibility =0;
     SelText.visibility = 0;
     File1Text.visibility =0;
     File2Text.visibility =1;
     TextFile1.visibility =0;
     TextFile2.visibility =0;
     SelFileTxt.Text2.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     SelFileTxt.Text1.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
  
     }
  }`

  function `void WFcolor()
  {
     //int clr;
     //clr = atoi(WhichFile.TheNewText);
     if(0 == strcmp(WhichFile.TheNewText, "2")){
                SelFileTxt.Text2.foregroundColour = \`COLOR_DATA_NORMAL\`;
                SelFileTxt.Text1.foregroundColour = \`COLOR_NON_ESSENTIAL\`;
                }
     if(0 == strcmp(WhichFile.TheNewText, "1")){
                SelFileTxt.Text1.foregroundColour = \`COLOR_DATA_NORMAL\`;
                SelFileTxt.Text2.foregroundColour = \`COLOR_NON_ESSENTIAL\`;
                }
  }
