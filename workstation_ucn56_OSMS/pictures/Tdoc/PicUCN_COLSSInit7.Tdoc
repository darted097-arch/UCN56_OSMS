  function `void InputVerify()
  {
     if(input_status)
     {
        InputArea.Active = 0;
        Interface->ColssData->message_type = REQUEST_COLSS_INITIALIZATION;
        if(selected_option != 3)   //CORENET 2017 : 5 -> 3
        {
             Interface->ColssData->InitData->value_initialized = InputArea.TheNewNumber;
             printf("Input value: %f\\n", Interface->ColssData->InitData->value_initialized);
        }
        else
            Interface->ColssData->InitData->sample_value = InputArea.TheNewNumber;
  
        Interface->ColssData->InitData->selected_option = selected_option;
        DisplayAdvisoryMessage3("REQUESTING COLSS INITIALIZATION");
        execute("{sendMessageToHost(REQUEST_COLSS_PROCESSING);}");
        input_status =0;
     }
      else
      {
        DisplayAdvisoryMessage("ENTER A VALID INITIALIZATION VALUE");
      }
  }`

  function `void ProcessingConfirmed()
  {
  //   ProcessCancelText.Initialize();
     update();
  }`

  function `void selectOption(int selectedValue)
  {
     Option = selectedValue;
     displayOptionSelected(selectedValue);
     SetupReadInputValue(selectedValue);
     update();
  }`

  function `void setReverseMode(int value)
  {
  
     switch(value)
     {
        case 1:
         text1.TheFontColor= COLOR_DATA_NORMAL;
         text1.TheTextFont = \`font7\`;
         break;
        case 2:
         text2.TheFontColor= COLOR_DATA_NORMAL;
         text2.TheTextFont = \`font7\`;
         break;
        case 3:
         text3.TheFontColor= COLOR_DATA_NORMAL;
         text3.TheTextFont = \`font7\`;
         break;
        case 4:
         text4.TheFontColor= COLOR_DATA_NORMAL;
         text4.TheTextFont = \`font7\`;
         break;
        case 5:
         text5.TheFontColor= COLOR_DATA_NORMAL;
         text5.TheTextFont = \`font7\`;
         break;
     }
     update();
  }`

  function `void setSelection(int opt)
  {
     InputArea.Active = 1;
     strcpy(format, "%8.2f");
     switch(opt)
     {
        case 1:
           selected_option = 1;
           ctext1 = t1.TheTitle;
            strcpy(ctext2, "VALUE OF CDP");
           InputArea.TheNewNumber = \`pid_cdp->value\`;
           sprintf(InputArea.TheOriginalText,"%-8.2f",  pid_cdp->value );
	   KeepSelected();	//CORENET 20170629
           break;
        case 2:
           selected_option = 2;
           ctext1 = t2.TheTitle;
           strcpy(ctext2, "VALUE OF CTP");
           InputArea.TheNewNumber = \`pid_ctp->value\`;
           sprintf(InputArea.TheOriginalText,"%-8.2f",  pid_ctp->value );
	   KeepSelected();	//CORENET 20170629
           break;
        case 3:
           selected_option = 3;
           ctext1 = t3.TheTitle;
           strcpy(format, "%d");
           strcpy(ctext2, "SAMPLE NUMBER");
           InputArea.TheNewNumber = 0;
           sprintf(InputArea.TheOriginalText,"%-8d",  InputArea.TheNewNumber);
	   KeepSelected();	//CORENET 20170629
           break;
  //CORENET 2017 for DELETE 3 or 4 OPTIONS
  //    case 3:
  //         selected_option = 3;
  //         ctext1 = t3.TheTitle;
  //         strcpy(ctext2, "VALUE OF CDFP");
  //         InputArea.TheNewNumber = \`pid_cdfp->value\`;
  //         sprintf(InputArea.TheOriginalText,"%-8.2f",  pid_cdfp->value );
