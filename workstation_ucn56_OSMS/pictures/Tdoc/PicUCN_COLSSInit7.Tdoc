  function `void SetupReadInputValue(int option)
  {
    MenuSelectionBox0.NumericValue=option;
    InputValue.inputTrigger=option;
    MenuSelectionBox0.DisplaySelectedValue();
    InputValue.ReadInputValue();
    update();
  }`

  function `void Verifyinput()
  {
       input_status = 1;
       if(selected_option == 3) // sample value, CORENET 2017: 5 -> 3
       {
       //CORENET 20170629 by Philkyu Kwon
          if(InputArea.TheNewNumber == 0 ) {
              DisplayAdvisoryMessage("STATISTICAL REPORT NOT PERFORMED FOR ZERO ITERATIONS");
              DisplayAdvisoryMessage2(" ");
              DisplayAdvisoryMessage3(" ");
              input_status = 0;
	  }
          else if(InputArea.TheNewNumber < 0 || InputArea.TheNewNumber > 2000) 
	  {
              DisplayAdvisoryMessage("VALID CHOICE 0 <  X <= 2000");
              DisplayAdvisoryMessage2(" ");
              DisplayAdvisoryMessage3(" ");
              input_status = 0;
          } 
       }
  }`

