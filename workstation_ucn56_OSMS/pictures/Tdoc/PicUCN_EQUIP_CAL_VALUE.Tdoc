     numDay = 0;
     numMonth = 0;
     numYear = 0;
     runDay = 0;
     runMonth = 0;
     runYear = 0;
  
     InitializeInput();
     InitConfirmMessages();
  
     procMsg.visibility = 0;
  
     update();
  
  }`

