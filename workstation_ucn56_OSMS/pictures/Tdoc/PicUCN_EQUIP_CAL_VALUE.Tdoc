  }`

  function `void process()
  {
  	printf("process clicked");
  	int OptionStatus;
  	DisplayAdvisoryMessage("    ");
  	DisplayAdvisoryMessage1("    ");
  	DisplayAdvisoryMessage2("    ");
  	DisplayAdvisoryMessage3("    ");
  
  	OptionStatus = OptionERR1 + OptionERR2 + OptionERR3 + OptionERR4 + OptionERR5 + OptionERR6;
  
  	if(OptionStatus == 0)
  	{
  
  		strcpy(pHostEquipMsg->message1,"");
  		strcpy(pHostEquipMsg->message2,"");
  		strcpy(pHostEquipMsg->message3,"");
  
  		DisplayAdvisoryMessage("SENDING A REQUEST TO THE HOST");
  		strcpy(Interface->wsEquipValChgData.pointId,pidInput.TheNewText);
  		Interface->wsEquipValChgData.numDay = numDay;
  		Interface->wsEquipValChgData.numMonth = numMonth;
  		Interface->wsEquipValChgData.numYear = numYear;
  		Interface->wsEquipValChgData.runDay = runDay;
  		Interface->wsEquipValChgData.runMonth = runMonth;
  		Interface->wsEquipValChgData.runYear = runYear;
  
  		printf("---[%s]---[%s]---",Interface->wsEquipValChgData.pointId, pidInput.TheNewText);
  		printf("---[%d]---[%d]---",Interface->wsEquipValChgData.numDay , numDay);
  		printf("---[%d]---[%d]---",Interface->wsEquipValChgData.numMonth , numMonth);
  		printf("---[%d]---[%d]---",Interface->wsEquipValChgData.numYear , numYear);
  		printf("---[%f]---[%f]---",Interface->wsEquipValChgData.runDay , runDay);
  		printf("---[%f]---[%f]---",Interface->wsEquipValChgData.runMonth , runMonth);
  		printf("---[%f]---[%f]---",Interface->wsEquipValChgData.runYear , runYear);
  
  		execute("{sendMessageToHost(REQUEST_EQUIPVALCHG);}");
  		procMsg.visibility = 1;
  	}
  	else
  		DisplayAdvisoryMessage1("INVALID FIELD VALUE");
  
  	update();
  }`

