  function `void ProcessingConfirmed()
  {
        procMsg.visibility = 0;
  
  	DisplayAdvisoryMessage("    ");
  	DisplayAdvisoryMessage1("    ");
  	DisplayAdvisoryMessage2("    ");
  
        DisplayAdvisoryMessage(pHostEquipMsg->message1);
        DisplayAdvisoryMessage1(pHostEquipMsg->message2);
        DisplayAdvisoryMessage2(pHostEquipMsg->message3);
  
  	printf("message 1 = %s", pHostEquipMsg->message1);
  	printf("message 2 = %s", pHostEquipMsg->message2);
  	printf("message 3 = %s", pHostEquipMsg->message3);
  }`

