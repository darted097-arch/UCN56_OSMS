  function `int Checkup(int position)
  {
  	switch(position){
  		case 1:		// NO. OF EQUIPMENT RUN(DAY)
  			printf("Checkup position = %d", position);
  			//numDay = (int)numDayInput.TheNewNumber;
  			numDay = atoi(numDayInput.TheNewText);
  			printf("Checkup numDay=[%d]",numDay);
  
  			if(numDay < 1 || numDay > 31)
  			{
  				DisplayAdvisoryMessage("INVALID NO. OF EQUIPMENT RUN(DAY)");
  				OptionERR1 = 1;
  			}
  			else
  				OptionERR1 = 0;
  			break;
  		case 2:		// NO. OF EQUIPMENT RUN(MONTH)
  			printf("Checkup position = %d", position);
  			//numMonth = (int)numMonthInput.TheNewNumber;
  			numMonth = atoi(numMonthInput.TheNewText);
  			printf("Checkup numMonth=[%d]",numMonth);
  
  			if(numMonth < 1 || numMonth > 12)
  			{
  				DisplayAdvisoryMessage("INVALID NO. OF EQUIPMENT RUN(MONTH)");
  				OptionERR2 = 1;
  			}
  			else
  				OptionERR2 = 0;
  			break;
  		case 3:		// NO. OF EQUIPMENT RUN(YEAR)
  			printf("Checkup position = %d", position);
  			//numYear = (int)numYearInput.TheNewNumber;
  			numYear = atoi(numYearInput.TheNewText);
  			printf("Checkup numYear=[%d]",numYear);
  
  			if(numYear < 1900 || numYear > 2100)
  			{
  				DisplayAdvisoryMessage("INVALID NO. OF EQUIPMENT RUN(YEAR)");
  				OptionERR3 = 1;
  			}
  			else
  				OptionERR3 = 0;
  			break;
  		case 4:		// RUNNING TIME DAY(HRS)
  			printf("Checkup position = %d", position);
  			//runDay = runDayInput.TheNewNumber;
  			runDay = atof(runDayInput.TheNewText);
  			printf("Checkup runDay=[%f]",runDay);
  
  			if(runDay < 1 || runDay > 10000)
  			{
  				DisplayAdvisoryMessage("INVALID RUNNING TIME DAY(HRS)");
  				OptionERR4 = 1;
  			}
  			else
  				OptionERR4 = 0;
  			break;
  		case 5:		// RUNNING TIME MONTH(HRS)
  			printf("Checkup position = %d", position);
  			//runMonth = runMonthInput.TheNewNumber;
  			runMonth = atof(runMonthInput.TheNewText);
  			printf("Checkup runMonth=[%f]",runMonth);
  
  			if(runMonth < 1 || runMonth > 10000)
  			{
  				DisplayAdvisoryMessage("INVALID RUNNING TIME MONTH(HRS)");
  				OptionERR5 = 1;
  			}
  			else
  				OptionERR5 = 0;
  			break;
  		case 6:		// RUNNING TIME YEAR(HRS)
  			printf("Checkup position = %d", position);
  			//runYear = runYearInput.TheNewNumber;
  			runYear = atof(runYearInput.TheNewText);
  			printf("Checkup runYear=[%f]",runYear);
  
  			if(runYear < 1 || runYear > 10000)
  			{
  				DisplayAdvisoryMessage("INVALID RUNNING TIME YEAR(HRS)");
  				OptionERR6 = 1;
  			}
  			else
  				OptionERR6 = 0;
  			break;
  	}
  	update();
  	return 0;
  }`

  function `void escape()
  {
     execute("{DisplayPage(\\"%s\\");}",TheDisplayPage);
     update();
  }`

  function `void InitConfirmMessages()
  {
  	DisplayAdvisoryMessage("    ");
  	DisplayAdvisoryMessage1("    ");
  	DisplayAdvisoryMessage2("    ");
  	DisplayAdvisoryMessage3("    ");
  
  	// Initialize Confirm Message in Interface Shared Memory
  	strcpy(pHostEquipMsg->message1,"");
  	strcpy(pHostEquipMsg->message2,"");
  	strcpy(pHostEquipMsg->message3,"");
  
  }`

  function `void Initialize()
  {
     CFMLevel = 0;
     Current_Page = 636;
     OptionERR1 = 1;
     OptionERR2 = 1;
     OptionERR3 = 1;
