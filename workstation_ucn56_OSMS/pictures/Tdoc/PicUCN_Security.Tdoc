  function `void ProcessThis()
  {
       accessstatus=Interface->SecureConfirm.data.accessstatus;
       accesslevel=Interface->SecureConfirm.data.accesslevel;
       utdvflag=Interface->SecureConfirm.data.utdvflag;
  //   printf("utdvflag = ", i);
  
       ProcessReqMsg.visibility = 0;
  //
  
       switch(accessstatus)
       {
          case 0 : Logon = 1; break ;
          case 1 : DisplayAdvisoryMessage("ALREADY SIGNED ON");
                   break ;
          case 2 : DisplayAdvisoryMessage("INVALID PASSWORD ENTERED");
                   break ;
          case 3 : DisplayAdvisoryMessage("ALREADY SIGNED OFF");
                   break ;
          case 4 : DisplayAdvisoryMessage("SIGN OFF ANOTHER STATION");
                   Logon = 1;
                   break ;
       }
  
  //
        if(accesslevel==3 && utdvflag==1)
