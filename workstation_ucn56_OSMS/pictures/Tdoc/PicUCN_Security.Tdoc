  `

  function `void SendMsgToHost()
  {
     Input.TheNewText[7] = '\\0';
     ProcessReqMsg.visibility = 1;
     Interface->SecureRequest.data.signonoff=1;
     strcpy(Interface->SecureRequest.data.password,Input.TheNewText);
     execute("{sendMessageToHost(PROCESS_SECURE_DATA);}");
  }`

  function `void Signoff()
  {
  
  // level3_box.foregroundFillColour=0;
  // level4_box.foregroundFillColour=0;
  // level5_box.foregroundFillColour=0;
  // signoff_box.foregroundFillColour=7;
  
     Input.TheNewText[0]='\\0';
     Input.TheOriginalText[0]='\\0';
     Input.TheViewText[0]='\\0';
  
     Logon=0;
     accesslevel=0;
     update();
  }`

  function `void Signoff1()
  {
     Interface->SecureRequest.data.signonoff=2;
     execute("{sendMessageToHost(PROCESS_SECURE_DATA);}");
  
     Signoff() ;
  }`

