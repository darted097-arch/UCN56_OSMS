  function `int CheckVisibility(RECORD *PointId_1, RECORD *PointId_2, int channel)
  {
     char unreli_1, unreli_2;
  
     unreli_1 = ( ((PointId_1->newsta >= ORHACK) && (PointId_1->newsta <= BDNAK)) ||
                   (PointId_1->newsta == BADSTA) || (PointId_1->newsta == UNKNOWN) );
     unreli_2 = ( ((PointId_2->newsta >= ORHACK) && (PointId_2->newsta <= BDNAK)) ||
                   (PointId_2->newsta == BADSTA) || (PointId_2->newsta == UNKNOWN) );
  
     //if( (PointId_1 == BAD) && (PointId_2 == Good) )
     if( unreli_1 && !unreli_2 )
     {
        if(channel == 0)
           return (0);
        else
           return (1);
     }
     else
     {
        if(channel == 0)
           return (1);
        else
           return (0);
     }
  }`

