  function `void ProcessingConfirmed(int i)
  {
     printf("*** RCS ONLINE DATA RECEIVED FROM CCUR\\n");
     DisplayAdvisoryMessage1("                    ");
  }
  `

  function `void ProcessUpdate()
  {
     int i;
  
     // Set the buttons to "Unselect" status
     for(i=1; i<=3; i++)
     {
        if(Interface->RcsLeak.data.timeInterval != i)
           execute("{ buttonTime%d.UnSelect(); }",i) ;
     }
  
     switch(Interface->RcsLeak.data.timeInterval)
     {
        case 1:
           strcpy(wTimeSelection, "10 MINUTES");
           break;
  
        case 2:
           strcpy(wTimeSelection, "30 MINUTES");
           break;
  
        case 3:
           strcpy(wTimeSelection, "1 HOUR");
           break;
  
        default:
           break;
     }
     update();
  
     printf("[Rcs Leak Rate] All Status : 0x%x.", Interface->RcsLeak.data.uAllStatus );
     printf("[Rcs Leak Rate] Event Status : 0x%x.", Interface->RcsLeak.data.EventStatus );
     // Display the Event Status
     //
  //   sprintf( wBalCharg, "%8.2f", Interface->RcsLeak.data.balCharg );
  
     if( Interface->RcsLeak.data.EventStatus & 0x1 )
        ErrorText1.visibility = 1;
     else
        ErrorText1.visibility = 0;
  
     if( Interface->RcsLeak.data.EventStatus & 0x2 )
        ErrorText2.visibility = 1;
     else
        ErrorText2.visibility = 0;
  
     if( Interface->RcsLeak.data.EventStatus & 0x4 )
        ErrorText3.visibility = 1;
     else
        ErrorText3.visibility = 0;
  
     if( Interface->RcsLeak.data.EventStatus & 0x8 )
        ErrorText4.visibility = 1;
     else
        ErrorText4.visibility = 0;
  
     if( Interface->RcsLeak.data.uAllStatus != 0 )
     {
        // for the color setting of Unidentified Leak
        dUnidentiLeakGpm.backgroundColour = COLOR_DANGER_UNACK;
        dUnidentiLeakGpm.foregroundColour = COLOR_PICTURE_BACKGROUND;
  
        strcpy( wUnidentiLeakGpm, "BAD DATA" );
     }
     else
     {
        // for the color setting of Unidentified Leak
        if( Interface->RcsLeak.data.UnidentiLeakGpm > 0.5 )
        {
           dUnidentiLeakGpm.backgroundColour = COLOR_DANGER_UNACK;
           dUnidentiLeakGpm.foregroundColour = COLOR_PICTURE_BACKGROUND;
        }
        else
        {
           dUnidentiLeakGpm.backgroundColour = COLOR_PICTURE_BACKGROUND;
           dUnidentiLeakGpm.foregroundColour = COLOR_NON_ESSENTIAL;
        }
  
        sprintf( wUnidentiLeakGpm, "%8.2f", Interface->RcsLeak.data.UnidentiLeakGpm );
     }
     if( (Interface->RcsLeak.data.uAllStatus & 0x31) != 0 )
     {
        strcpy( wSystemChange, "BAD DATA" );
        strcpy( wSystemChangeGpm, "BAD DATA" );
     }
     else
     {
        sprintf( wSystemChange, "%8.2f", Interface->RcsLeak.data.SystemChange );
        sprintf( wSystemChangeGpm, "%8.2f", Interface->RcsLeak.data.SystemChangeGpm );
     }
     if( (Interface->RcsLeak.data.uAllStatus & 0x0E) != 0 )
     {
        strcpy( wIdentiLeak, "BAD DATA" );
        strcpy( wIdentiLeakGpm, "BAD DATA" );
     }
     else
     {
        sprintf( wIdentiLeak, "%8.2f", Interface->RcsLeak.data.IdentiLeak );
        sprintf( wIdentiLeakGpm, "%8.2f", Interface->RcsLeak.data.IdentiLeakGpm );
     }
  
     if( Interface->RcsLeak.data.uAllStatus & 0x01 )
     {
        strcpy( wVctChange, "BAD DATA" );
     }
     else
        sprintf( wVctChange, "%8.2f", Interface->RcsLeak.data.VctChange );
     if( Interface->RcsLeak.data.uPzrAllStatus != 0 )
     {
        strcpy( wPzrChange, "BAD DATA" );
     }
     else
        sprintf( wPzrChange, "%8.2f", Interface->RcsLeak.data.PzrChange );
     if( Interface->RcsLeak.data.uRcsAllStatus != 0 )
     {
        strcpy( wRcsChange, "BAD DATA" );
     }
     else
        sprintf( wRcsChange, "%8.2f", Interface->RcsLeak.data.RcsChange );
     if( Interface->RcsLeak.data.uAllStatus & 0x02 )
     {
        strcpy( wRdtChange, "BAD DATA" );
     }
     else
        sprintf( wRdtChange, "%8.2f", Interface->RcsLeak.data.RdtChange );
     if( Interface->RcsLeak.data.uAllStatus & 0x04 )
     {
        strcpy( wEdtChange, "BAD DATA" );
     }
     else
        sprintf( wEdtChange, "%8.2f", Interface->RcsLeak.data.EdtChange );
     if( Interface->RcsLeak.data.uSitAllStatus != 0 )
     {
        strcpy( wSitChange, "BAD DATA" );
     }
     else
        sprintf( wSitChange, "%8.2f", Interface->RcsLeak.data.SitChange );
  
     Interface->RcsLeak.data.leakRatePrint = 0;
  }`

  function `void RangeSelection(int k)
  {
     int i;
  
     for(i=1; i<=3; i++)
     {
        if(k != i)
           execute("{ range%d.UnSelect(); }",i) ;
     }
  
     switch( k )
     {
        case 1 :
           strcpy(wModeSelection, "NARROW");
           leakTrend.HighLimit = 1;
           leakTrend.LowLimit = -1;
           break;
  
        case 2 :
           strcpy(wModeSelection, "WIDE");
           leakTrend.HighLimit = 10;
           leakTrend.LowLimit = -10;
           break;
  
        case 3 :
           strcpy(wModeSelection, "WIDE2");
           leakTrend.HighLimit = 20;
           leakTrend.LowLimit = -20;
           break;
  
        default :
           printf("Selected Button == %d", k);
     }
     update();
  }`

  function `void TimeSelection(int k)
  {
     int i;
  
      for (i=1 ; i<=3 ; i++)
         if(i!=k)
            execute("{ buttonTime%d.UnSelect(); }",i) ;
  
     // Change the Time. If Time is not the correct range, set the time to 1(10M).
     if( (k <= 0) && (k >=4) ) k = 1;
  
     switch(k)
     {
        case 1: strcpy(wTimeSelection, "10 MINUTES");
                break;
        case 2: strcpy(wTimeSelection, "30 MINUTES");
                break;
        case 3: strcpy(wTimeSelection, "60 MINUTES");
                break;
     }
  
       Interface->WSOnData.TIME = k;
       execute("{sendMessageToHost(REQUEST_RCS_LEAK_DATA);}");
       DisplayAdvisoryMessage1("PROCESSING...  WAIT");
       printf("------%d\\n",k);
  }
  `

  function `void UpdateAutoRequest()
  {
     if( strcmp( &Interface->System.timeString[7], "1" )==0 )
     {
        DisplayAdvisoryMessage("REQUEST RCS LEAK RATE TO HOST.");
        execute("{sendMessageToHost(REQUEST_RCSLEAK_RESULTS);}");
     }
  }`

