                 //break;
              //default :
                 //printf("Selected Time Interval == %d", Interface->RcsLeak.data.timeInterval);
           }
           break;
  
        // When "Identified Leak" button is selected.
        case 2 :
           iLeakSelection = 2;
           //switch(Interface->RcsLeak.data.timeInterval)
           {
              //case 1 :
                 leakTrend.TheTrendVariable = trend2;
                 //execute("{leakTrend.TheVariable = \`&RCT111Y\`; }") ;
                 break;
              //case 2 :
                 //leakTrend.TheTrendVariable = trend2;
                 //execute("{leakTrend.TheVariable = \`&RCT111Y\`; }") ;
                 //break;
              //case 3 :
                 //leakTrend.TheTrendVariable = trend2;
                 //execute("{leakTrend.TheVariable = \`&RCT111Y\`; }") ;
                 break;
              //default :
                 //printf("Selected Time Interval == %d", Interface->RcsLeak.data.timeInterval);
           }
           //break;
  
        default :
           printf("Selected Leak Button == %d", k);
     }
     update();
  }`

  function `void myPrintButton()
  {
  //   strcpy(Interface->WSPrnData.WSNAME,"2");
     Interface->WSPrnData.PAGENUM = Current_Page;
     DisplayAdvisoryMessage("REQUEST RCS LEAK RATE DATA PRINT TO HOST.");
     execute("{sendMessageToHost(REQUEST_LEAKPRN);}");
  }
