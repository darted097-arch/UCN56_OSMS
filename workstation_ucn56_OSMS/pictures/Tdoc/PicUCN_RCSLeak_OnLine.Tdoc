  //   Interface->RcsLeak.data.timeInterval = 1;
  
      for (i=1 ; i<=3 ; i++)
         execute("{ buttonTime%d.UnSelect(); }",i) ;
      buttonTime3.Select();
  //    strcpy(wTimeSelection, "1 HOUR");
  
      for (i=1 ; i<=3 ; i++)
         execute("{ range%d.UnSelect(); }",i) ;
      range1.Select();
  //    strcpy(wModeSelection, "NARROW");
  
      for (i=1 ; i<=2 ; i++)
          execute("{ buttonLeak%d.UnSelect(); }",i) ;
      buttonLeak1.Select();
  
       for (i=1 ; i<=5 ; i++)
         execute("{ freq%d.UnSelect(); }",i) ;
      freq1.Select();
  
  //   RcsLeakRate_Active = 1;
  //   execute("{sendMessageToHost(REQUEST_RCSLEAK_RESULTS);}");
  
  
  
  }`

  function `void InitTimes(int kk)
  {
     int i;
  
  // Unselect them all
  
      for (i=1 ; i<=5 ; i++)
         if(kk!=i)
            execute("{ freq%d.UnSelect(); }",i) ;
  
  
        switch (kk) {
  
        case 1 :
           leakTrend.TheFrequency = 1;
           break;
  
        case 2 :
           leakTrend.TheFrequency = 5;
           break;
  
        case 3 :
           leakTrend.TheFrequency = 10;
           break;
  
        case 4 :
           leakTrend.TheFrequency = 30;
           break;
  
        case 5 :
           leakTrend.TheFrequency = 60;
           break;
  
        default :
  
           printf("Selected Button == %d", kk);
  
       }
  
     update();
  }`

  function `void LeakSelection(int k)
  {
     int i;
  
     // Unselect the button.
     for(i=1; i<=2; i++)
     {
        if( k != i )
           execute("{ buttonLeak%d.UnSelect(); }",i) ;
     }
  
     // Change the PointID of Statusline and Trend.
     switch( k )
     {
        // When "Unidentified Leak" button is selected.
        case 1 :
           iLeakSelection = 1;
           //switch(Interface->RcsLeak.data.timeInterval)
           {
