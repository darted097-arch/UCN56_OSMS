    text4.visibility=0;
    text5.visibility=0;
    text6.visibility=0;
    text7.visibility=0;
    text8.visibility=0;
    selectfile1.visibility=0;
    selectfile1.vis=0;
    selectfile2.visibility=0;
    selectfile2.vis=0;
    selectfile3.visibility=0;
    selectfile3.vis=0;
    processfiles.visibility=0;
    update();
  }`

  function `void MakeVisible()
  {
    text1.visibility=1;
    text2.visibility=1;
    text3.visibility=1;
    text4.visibility=1;
    text5.visibility=1;
    text6.visibility=1;
    text7.visibility=1;
    text8.visibility=1;
    selectfile1.visibility=1;
    selectfile2.visibility=1;
    selectfile3.visibility=1;
    processfiles.visibility=1;
    update();
  }`

  function `void Option1()
