  function `void Process1()
  {
  if (SELECTED == 0) DisplayAdvisoryMessage("SELECT 1 - 3 FIRST BEFORE PROCESS ");
  else if (SELECTED == 1)
  {
    Interface->UtdvDialogue.option=option;
    Interface->UtdvDialogue.current_page=Current_page;
    execute("{strcpy(Interface->UtdvDialogue.filename1, selectfile1.TheNewText);}");
    execute("{strcpy(Interface->UtdvDialogue.filename2, selectfile2.TheNewText);}");
    execute("{strcpy(Interface->UtdvDialogue.filename3, selectfile3.TheNewText);}");
  
    // printf(" Filename1 = %s", Interface->UtdvDialogue.filename1);
    // printf(" Filename2 = %s", Interface->UtdvDialogue.filename2);
    // printf(" Filename3 = %s", Interface->UtdvDialogue.filename3);
  
     execute("{strcpy(utnlmid652, selectfile1.TheNewText);}");
     execute("{strcpy(utlmid652, selectfile2.TheNewText);}");
     execute("{strcpy(utlhcea652, selectfile3.TheNewText);}");
  
    execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
    // printf("Process(): SendMessageToHost(PROCESS_UTDV_SEND) done ....");
  }
  }
  `

