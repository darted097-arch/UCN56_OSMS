//
// UTDV data structures
//

// Each CEA subgroup displayed on UTDV page 658 or 694
struct UTDV_CEA_SUBGROUP{
//
   int		SubGrpNumber;		// ( 4)
//
   int		row1CeaNumber;		// ( 4)
   int		row2CeaNumber;		// ( 4)
   int		row3CeaNumber;		// ( 4)
   int		row4CeaNumber;		// ( 4) 
//
   float	row1CeaValue;		// ( 4)
   float	row2CeaValue;		// ( 4)
   float	row3CeaValue;		// ( 4)
   float	row4CeaValue;		// ( 4)
//   
   int		row1CeaQuality;		// ( 4)
   int		row2CeaQuality;		// ( 4)
   int		row3CeaQuality;		// ( 4)
   int		row4CeaQuality;		// ( 4)
//              
}; 					// (52)   
// 
// When in a message, as in the Concurrent, all byte counts will 
// increase by header bytes (i.e. 24 bytes).
//
struct UTDV_DIALOGUE_DATA {
   int          current_page;    // ( 4) current page displayed on workstation  
   int          option;          // ( 4) most pages  
   int		new_page_request;// ( 4) (no new page=-1, active=new Utdv page desired) 
   char		password[8];     // ( 8) page 650
   float        entered_EFPH;    // ( 4) page 653 (increment or present value for EFPH)   
//				 // (24) 
//
   float        cea_average;     //      page 658,694 (group average cea position)
// float        cea[73];         //      page 658,694 (individual cea position)
                                 // (4)
//
   char         cea_with[12];    // (12) page 657,692 (cea withdrawal)
   char         cea_group[12];   // (12) page 658,694 (cea group position)
   char         type_of_EFPH[2]; // ( 2) page 653 (increment or present)
   char         change[2];       // ( 2) page 658,694 (change required or not)
   char         cea_modify[2];   // ( 2) page 658,694 (group or individual)
   char         next_group[2];   // ( 2) page 658,694 (next group to be processed) 
//				    (32)
//
   UTDV_CEA_SUBGROUP 	col1; 	 // (52) page 658,694 (column1 individual cea position)
   UTDV_CEA_SUBGROUP 	col2; 	 // (52) page 658,694 (column2 individual cea position)  
   UTDV_CEA_SUBGROUP 	col3;	 // (52) page 658,694 (column3 individual cea position)   
   UTDV_CEA_SUBGROUP 	col4;	 // (52) page 658,694 (column4 individual cea position)
   UTDV_CEA_SUBGROUP 	col5;	 // (52) page 658,694 (column4 individual cea position)
   UTDV_CEA_SUBGROUP 	col6;	 // (52) page 658,694 (column4 individual cea position)
//			            (312)
//
   char         filename1[24];   // (24) page 652
   char         filename2[24];   // (24) page 652
   char         filename3[24];	 // (24) page 652
//				 // (72) 
// 
   char         message1[52];	 // (52) most pages
   char         message2[52];	 // (52) most pages
   char         message3[52];	 // (52) most pages
//				 //(156)      			
};						 	

//  >>>>>>>>>>>>>>>>>>>	Workstation UTDV Message Template
//  24 + 24+4+32+(6*52)+(3*24)+(3*52) == 624
struct WSUtdvDialogueMessage {
   WSmessageHeader	header; // ( 24)  message information		
   UTDV_DIALOGUE_DATA   data;	// (600)  data portion	
   char		spareData[400]; // (400)			
};			        //(1024)

