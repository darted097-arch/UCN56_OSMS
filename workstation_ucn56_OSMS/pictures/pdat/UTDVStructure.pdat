// UTDV Midnight File Data (EFPHs, Dates & Times)
struct UTDV_MIDNIGHT_FILE_DATA {
   // filename 
   char         filename[24];   // (24) page 652 and other pages
   //
   // data available flag (1=data available, 0=data not avaiable)
   int		data_available;
   //
   // efphs from midnight file 
   float	efphFile;
   float	efphRpcb;
   float	efphColss;
   float	efphIncore;
   float	efphCeaExposure;
   //
   // rpcb burnup from midnight file 
   float	rpcbBurnup;
   //
   // dates from midnight file 
   char		dateFile[12];
   char		dateRpcb[12];
   char		dateColss[12];
   char		dateIncore[12];
   char		dateCeaExposure[12];
   char		dateCeaPosition[12];
   //
   // times from midnight file 
   char		timeFile[12];
   char		timeRpcb[12];
   char		timeColss[12];
   char		timeIncore[12];
   char		timeCeaExposure[12];
   char		timeCeaPosition[12];
};
// UTDV HOURLY CEA File Data (EFPHs, Dates & Times)
struct UTDV_HOURLY_CEA_FILE_DATA {
   // filename 
   char         filename[24];   // (24) page 652 and other pages 
   //
   // data available flag (1=data available, 0=data not avaiable)
   int		data_available;
   //
   // efphs from hourly cea file 
   float	efphFile;
   float	efphRpcb;
   float	efphCeaExposure;
   //
   // rpcb burnup from hourly cea file 
   float	rpcbBurnup;
   //
   // dates from hourly cea file 
   char		dateFile[12];
   char		dateRpcb[12];
   char		dateCeaExposure[12];
   char		dateCeaPosition[12];
   //
   // times from hourly cea file 
   char		timeFile[12];
   char		timeRpcb[12];
   char		timeCeaExposure[12];
   char		timeCeaPosition[12];
};
// UTDV EFPH Deltas (Delta EFPHs)
struct UTDV_EFPH_DELTAS {
   //
   // efph deltas between file 1 and file 2 
   float	efphDeltaFile12;
   float	efphDeltaColss12;
   float	efphDeltaIncore12;
   //
   // efph deltas between file 2 and present efph 
   float	efphDeltaFile2;
   float	efphDeltaRpcb2;
   float	efphDeltaColss2;
   float	efphDeltaIncore2;
   float	efphDeltaCeaExposure2;
   //
   // efph deltas between file 3 and present efph 
   float	efphDeltaFile3;
   float	efphDeltaRpcb3;
   float	efphDeltaCeaExposure3;
};
// UTDV Most Recent and Present EFPHs (EFPHs)
struct UTDV_PRESENT_EFPHS {
   //
   //  Most Recent and Present EFPHs
   float	mostRecentEfphFile;
   float	oldPresentEfph;
   float	pendingPresentEfph;
};

// UTDV Data (file dates, times, efphs), efph deltas, present efphs
struct UTDV_DATA {
   //
   UTDV_MIDNIGHT_FILE_DATA	nextToLastMidnight;	 // (172)	
   UTDV_MIDNIGHT_FILE_DATA	lastMidnight;		 // (172)
   UTDV_HOURLY_CEA_FILE_DATA	latestHourly;		 // (140)
   UTDV_PRESENT_EFPHS		present;		 // ( 12)
   UTDV_EFPH_DELTAS		calc;			 // ( 44)
   };							 // (540)

// UTDV File Data Message
struct WSUtdvDataMessage {
   WSmessageHeader	header;	// ( 24)			
   UTDV_DATA	  	data;	// (540)
   char		spareData[460]; // (460)	  
};			        //(1024)

