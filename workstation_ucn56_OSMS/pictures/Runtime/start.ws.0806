# No command line options for default startup.
#
# Revision 1.3  1997/11/25 21:19:45  leo
# Author: leo@y6maint1.usnus.abb.com (Leo Olbrych)
# Use default settings for WSPCS startup, i.e., no options. -CPU1, -CPU2, -PRIMARY
# options are available to override CommLink1 connection, CommLink2 connection, and
# to lock the primary CommLink to a particular host.
#
# Revision 1.2  1997/10/30 00:02:03  jnl
# Author: jnl@y6maint1.usnus.abb.com (Jim Lanzalotta)
# Modified log file name.
#
# Revision 1.1  1997/10/15 20:00:37  leo
# Author: leo@y6maint1.usnus.abb.com (Leo Olbrych)
# Initial revision
#

cd $HOME/pictures

stop.ws

#
# Get options from WSPCS.cfg
#
FDDIOPT=`awk 'match($1,"-FDDI") == 1 {print tolower($2)}' WSPCS.cfg`
# MODEMOPT=`awk 'match($1,"-MODEM") == 1 {print tolower($2)}' WSPCS.cfg`

#
# Build Tdoc file list
#
echo "Building List of Tdoc Files"
echo
echo "Adding the CFM Matrix Page to the file list"
ls -1 PicYGN_CFMmatrix.Tdoc > $HOME/lst/FileList
echo "Adding the CFM 100 Series pages to the file list";
ls -1 Pic1*.Tdoc >> $HOME/lst/FileList
echo "Adding the CFM 200 Series pages to the file list"
ls -1 Pic2*.Tdoc >> $HOME/lst/FileList
echo "Adding the CFM 300 Series pages to the file list"
ls -1 Pic3*.Tdoc >> $HOME/lst/FileList
echo "Adding the Display Header Page to the file list"
ls -1 PicYGN_header.Tdoc >> $HOME/lst/FileList
echo "Adding the Display Footer Page to the file list"
ls -1 PicYGN_footer.Tdoc >> $HOME/lst/FileList
echo "Adding the CEA Alarm Limit Display Page to the file list"
ls -1 PicYGN_CEAAlmLimitDisp.Tdoc >> $HOME/lst/FileList
echo "Adding the COLSS Display Pages to the file list"
ls -1 PicYGN_COLSS*.Tdoc >> $HOME/lst/FileList
echo "Adding the Mid-Loop Display Page to the file list"
ls -1 PicYGN_Midloop.Tdoc >> $HOME/lst/FileList
echo "Adding the PT-Plot Normal Page to the file list"
ls -1 PicYGN_PtPlotNormal.Tdoc >> $HOME/lst/FileList
echo "Adding the PT-Plot Emergenct Page to the file list"
ls -1 PicYGN_PtPlotEmergency.Tdoc >> $HOME/lst/FileList
echo "Adding the UTDV Pages that Display Point-IDs to the file list"
ls -1 PicYGN_UTDVEnterEFPH1.Tdoc >> $HOME/lst/FileList
ls -1 PicYGN_UTDVEnterEFPH2.Tdoc >> $HOME/lst/FileList
ls -1 PicYGN_UTDVEnterEFPH3.Tdoc >> $HOME/lst/FileList
ls -1 PicYGN_UTDVConfirmEFPH2.Tdoc >> $HOME/lst/FileList
ls -1 PicYGN_UTDVConfirmEFPH3.Tdoc >> $HOME/lst/FileList


echo

#
# For each Tdoc in the file list build a shopping list only if necessary
#
for file in `cat $HOME/lst/FileList`
do
if [ $HOME/pictures/$file -nt $HOME/lst/$file.ShoppingList ]
then
   echo "Building PID list for" $file
   grep "&" $file | grep -Ev -e"&=" -e"&&" -e\" | /usr/bin/awk -F\& '{print $2}' | /usr/bin/awk -F\` '{print $1}' | /usr/bin/awk '$1 == toupper($1) {print $1}' | sort -u > $HOME/lst/$file.ShoppingList
else
   echo "Skipping PID list for" $file
fi
done

#
# Perform initializations for FDDI
#
if [ "$FDDIOPT" = "on" ]
then
   if [ -a fddi.in ]
   then
      /usr/bin/rm -f fddi.in
   fi
   echo >fddi.in
   if [ -a fddi.out ]
   then
      /usr/bin/mv -f fddi.out fddi.out.old
   fi
fi

#
# Perform initializations for modem
#
# if [ "$MODEMOPT" != "" ] && [ "$MODEMOPT" != "off" ]
# then
#    ppl -o $MODEMOPT
# fi

#
# Start WPSCS task
#
xhost +`hostname`
WSPCS 2>&1 | sysLog -l WSPCS.log

echo "Return from WSPCS in start.ws"

stop.ws

echo "EXITING start.ws"
