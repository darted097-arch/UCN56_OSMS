  function `void ProcessThis()
{
   if( ((4==accesslevel) && (2==Option)) || ((4==accesslevel) && (3==Option)) ||
       ((5==accesslevel) && (2==Option)) || ((5==accesslevel) && (3==Option)) )
   {
   DisplayAdvisoryMessage("ACCESS LEVEL 3 REQUIRED");
   return;
   }
   else
   {
//   set option number to Option
   execute("{Interface->GenericRequestMessage.data.requestOption = %d;}",Option);
//   Send data request message to the host
   execute("{sendMessageToHost(RPCCEA_PROCESS_REQUEST);}");
   }
}`



