}`



  function `char *ModeAssign()
{
   switch(Interface->RPCCEACurrentModeMessage.data.mode)
   {
      case 0:
         return(" INACTIVE");
      case 1:
         return(" SCHEDULED");
      default:
         return(" ERROR");
   }
}`



