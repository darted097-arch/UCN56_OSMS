  function `void RequestPrint()
  {
     DisplayAdvisoryMessage3("REQUESTING CPU COMPARISON DATA PRINT");
  
     if (status)
     {
           DisplayAdvisoryMessage3("RETRY AFTER CPU COMPARISON COMPLETED");
           print.Initialize();
           return;
     }
    Interface->ColssData.message_type = REQUEST_COLSS_CPUC_PRINT;
    execute("{sendMessageToHost(REQUEST_COLSS_PROCESSING);}");
    update();
  }`

  function `void selectOption(int selectedValue)
  {
     Option = selectedValue;
     displayOptionSelected(selectedValue);
     SetupReadInputValue(selectedValue);
     update();
  }`

