  function `void InputVerify()
   {
      DisplayAdvisoryMessage3("REQUESTING CPU COMPARISON DATA");
  
      if (status)
      {
            DisplayAdvisoryMessage3("ALREADY CPU COMPARISON IN PROGRESS");
            //ProcessCancelText.Initialize();
            return;
      }
  //   ChangeColor();
  
     cpu_status.visibility = 0;
     update();
     Interface->ColssData.message_type = REQUEST_COLSS_CPU_COMPARISON;
     execute("{sendMessageToHost(REQUEST_COLSS_PROCESSING);}");
     status = 1;
     update();
   }`

  function `void PrintRequest()
  {
    DisplayAdvisoryMessage3("REQUESTING CPU COMPARISON DATA PRINT");
    Interface->ColssData.message_type = REQUEST_COLSS_CPUC_PRINT;
    execute("{sendMessageToHost(REQUEST_COLSS_PROCESSING);}");
    print.Initialize();
    update();
  }`

  function `void ProcessingConfirmed()
  {
     if( Current_Page != 47 )
        return;
  
  int i;
  //   ProcessCancelText.Initialize();
  
     cpu_status.visibility = 1;
  AssignPID();
  c1 = Interface->ColssData.CpuData.cpucomps3 ;
  if(strcmp(c1,"BD------") == 0) {
     PID1.CpuCompfColor = 0;
     PID1.CpuCompbColor = \`COLOR_BAD_OOR_UNACK\`;
  } else {
     PID1.CpuCompfColor = \`COLOR_DATA_NORMAL\`;
