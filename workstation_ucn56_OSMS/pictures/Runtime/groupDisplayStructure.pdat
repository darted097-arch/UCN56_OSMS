   char		Title20[24];		
};
//

struct GROUP_DISPLAY_TEMPLATE {
   GROUP_MEMBER_TEMPLATE		group;
   GROUP_TITLES_TEMPLATE		Titles;
};
//
// ***********************************
struct Group_Info_Data {
    WSmessageHeader		header;	        // message information
    GROUP_DISPLAY_TEMPLATE	data;		// ALL group display data
   };
struct Group_Update {
    WSmessageHeader		header;		//message information
    GROUP_MEMBER_TEMPLATE 	data;		//ONE GROUP display data;
    };

// Generic workstation flag set/reset request data
// This data is for messages from the client to the host.
struct WSflagMessageData {
   int				requestOption;		// requested option	 	(   4)
   int                          flipflop1;              // 		                (   4)
   int                          flipflop2;              //                              (   4)    
};
//
// Generic workstation flag set/reset request message
// This message is for messages from the client to the host / server
struct WSflagMessage {
   WSmessageHeader		header;			// message information		(  24)
   WSflagMessageData		data;			// requested option and data	(1000)
};
