//
// Attribute for each Group Display
//

struct GRconfirmMessageData{
   int			option;			// confirm option	 	(   4)
   char			confirmMessage[996];	// data portion			( 996)
} ;

struct GRconfirmMessage{
   WSmessageHeader	header;			// message information		(  24)
   GRconfirmMessageData	data;			// message information		(1000)
} ;

struct GROUP_MEMBER_TEMPLATE {			// for recieving message 
   char		Point1[12];			// all titles and info.
   char		Point2[12];		
   char		Point3[12];		
   char		Point4[12];		
   char		Point5[12];		
   char		Point6[12];		
   char		Point7[12];		
   char		Point8[12];		
   char		Point9[12];		
   char		Point10[12];		
   char		Point11[12];		
   char		Point12[12];		
   char		Point13[12];		
   char		Point14[12];		
   char		Point15[12];		
   char		Point16[12];		
   char		Point17[12];		
   char		Point18[12];		
   char		Point19[12];		
   char		Point20[12];		
   char		Point21[12];		
   char		Point22[12];		
   char		Point23[12];		
   char		Point24[12];		
   char		Title[24];
   int		groupNumber;
   int		printRate;
   int		timesToPrint;
   int          displayRate;
   char         theWorkstation[12];
};
struct GROUP_TITLES_TEMPLATE {
   char		Title1[24];		
   char		Title2[24];		
   char		Title3[24];		
   char		Title4[24];		
   char		Title5[24];		
   char		Title6[24];		
