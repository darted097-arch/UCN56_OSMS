  class ThermocoupleSquare2
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 23;
    worldHeight = 23;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 4;
    ySnap = 4;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 500;
    yReference = 500;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    int DisplayTCNumber = 0;

    RECORD* PointId = `&ERRORPID`;

    char* ThermocoupleNumber = "??";

    function `int GetFillColor()
    {
    // if the point id is not instantiated, output ERROR
       if (strcmp ("ERRORPID", PointId->pid) == 0)
          return (COLOR_CONFIG_ERROR);
       if (((PointId->pisabitmap & bOOSCAN) > 0) || ((PointId->pisabitmap & bOOSCAN) > 0))
          return(COLOR_BAD_OOR_ACK);
       if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
          return (COLOR_BAD_OOR_ACK);
       if (PointId->value < 343)
          return(COLOR_DATA_NORMAL);
       else
          return(COLOR_BAD_OOR_ACK);
    }`

    function `int GetFillPattern()
    {
       if (((PointId->pisabitmap & bOOSCAN) > 0) || ((PointId->pisabitmap & bOOSCAN) > 0))
          return(SolidPattern);
       if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
          return (SolidPattern);
       if ((PointId->value >= 343) && (PointId->value < 385))
           return(DefaultPattern2);
       else if (PointId->value >= 385)
           return(DefaultPattern3);
    }`

    function `int GetforegroundColour()
    {
    // if the point id is not instantiated, output ERROR
       if (strcmp ("ERRORPID", PointId->pid) == 0)
          return (COLOR_CONFIG_ERROR);
       if (((PointId->pisabitmap & bOOSCAN) > 0) || ((PointId->pisabitmap & bOOSCAN) > 0))
          return(COLOR_BAD_OOR_ACK);
    //   else
    //   {
       if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
          return (COLOR_BAD_OOR_ACK);
       else
          return (COLORS[PointId->newsta]);
    //   }
    }`

