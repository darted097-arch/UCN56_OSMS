  class ControlRodSquare
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 46;
    worldHeight = 46;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 4;
    ySnap = 4;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 500;
    yReference = 500;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    RECORD* PointId = `&RCT111X`;

    function `int GetforegroundColour()
    {
    // if the point id is not instantiated, output ERROR
       if (strcmp("ERRORPID",PointId->pid)==0)
          return (COLOR_CONFIG_ERROR);
    //
    // if the point is open (0), then rod is up
    //   else if ( (PointId->newsta < HACK) && (PointId->value < 1.0) )
       else if ( (NORMAL <= PointId->newsta <= RBDNAK) && (PointId->value < 1.0) )
           return (COLOR_ACTIVE_ON_OPEN);
    //
    // if the point is closed (1), then the rod is down
    //   else if ( (PointId->newsta < HACK) && (PointId->value >= 1.0) )
       else if ( (NORMAL <= PointId->newsta <= RBDNAK) && (PointId->value >= 1.0) )
           return (COLOR_INACTIVE_OFF_CLOSED);
    // otherwise, output the newsta color (BAD, etc...)
       else
           return (COLORS[PointId->newsta]);
    }`

    function `int GetforegroundFillColour()
    {
    //
    // if the point is open (0), then rod is up
       if ( (PointId->newsta<=RBDNAK) && (PointId->value < 1.0) )
           return (COLOR_PICTURE_BACKGROUND);
    //
    // if the point is closed (1), then the rod is down
       else if ( (PointId->newsta<=RBDNAK) && (PointId->value >= 1.0) )
           return (COLOR_INACTIVE_OFF_CLOSED);
    // otherwise, output the newsta color (BAD, etc...)
       else
           return (COLORS[PointId->newsta]);
    }`

    dialogue
    {
      event = `buttonPressed(Right) || shapeLeft()`;
      action = `{ClearPokeMessages(); update();}`;
    }

    dialogue
    {
      event = `buttonPressed(Left) || keyPressed(POKE) || shapeEntered()`;
      action = `{DisplayPokeMessages(PointId); update();}`;
    }

    rectangle
    {
      x = 1;
      y = 2;
      width = 20.5;
      height = 20.5;
      visibility = 1;
      foregroundColour = `GetforegroundColour()`;
      backgroundColour = -1;
      linePattern = `SolidPattern`;
      lineWidth = 3;
      foregroundFillColour = `GetforegroundFillColour()`;
      backgroundFillColour = -1;
      fillPattern = `SolidPattern`;
      xReference = 0;
      yReference = 5;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }
  }

