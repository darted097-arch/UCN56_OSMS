    RECORD* PointId = `&ERRORPID`;

    function `int SetBoxColor()
    {
    //
    // First, verify that the point id has been set.  If it is still set to
    // the default id, output an error value in the configuration error color.
    //
       if ( (strcmp("ERRORPID",PointId->pid) == 0) )
          return (COLOR_CONFIG_ERROR);
    //
    // BAD:
       else if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
          return (COLORS[PointId->newsta]);
    //
    // ON:
       else if (PointId->value > 0)
          return (COLORS[PointId->newsta]);
    //
    // OFF:
       else
          return (COLOR_STATIC_TEXT);
    }
    `

