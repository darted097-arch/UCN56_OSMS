      alignment = 0;
      visibility = 0;
      foregroundColour = `( (strcmp("ERRORPID",Valve_H->pid) == 0) || (strcmp("ERRORPID",Valve_L->pid) == 0) )?COLOR_CONFIG_ERROR:COLOR_STATIC_TEXT`;
      backgroundColour = 0;
      theFont = `font2`;
