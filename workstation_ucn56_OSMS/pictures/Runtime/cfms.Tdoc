library cfmsSymbols
{


  class BreakerVertical
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 90;
    worldHeight = 120;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 1;
    ySnap = 1;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 0;
    yReference = 0;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    RECORD* PointId = `&ERRORPID`;

    function `int GetOpenLineColor()
    {
    // Verify that the point id has been set.
    // If it is still set to the default id, output
    // the breaker in the configuration error color
       if (strcmp("ERRORPID",PointId->pid) == 0)
           return (COLOR_CONFIG_ERROR);
    
    // BAD:
       else if ( (PointId->newsta == BDNAK) || (PointId->newsta == BDACK) )
           return (COLORS[PointId->newsta]);
    //
    // CLOSED: invisible
    // OPEN:
       else
           return (COLOR_INACTIVE_OFF_CLOSED);
    }
    `

    function `int GetOpenVisibility()
    {
    //
    // Visible: Point Id not net, BAD, or 0
       if ( (strcmp("ERRORPID",PointId->pid) == 0) ||(PointId->value <= 0.0) ||
            (PointId->newsta == BDNAK) ||(PointId->newsta == BDACK) )
               return (VISIBLE);
    //
    	else
               return(INVISIBLE);
    }
    `

    dialogue
    {
      event = `buttonPressed(Left) || keyPressed(POKE) || shapeEntered()`;
      action = `{ DisplayPokeMessages(PointId); update();}`;
    }

    dialogue
    {
      event = `buttonPressed(Right) || shapeLeft()`;
      action = `{ClearPokeMessages(); update();}`;
    }

    line
    {
      numberOfPoints = 2;
      point[0] = ( 30, 100 );
      point[1] = ( 30, 20 );
      visibility = 1;
      foregroundColour = 1;
      backgroundColour = -1;
      lineStyle = 1;
      lineWidth = 1;
      xReference = 30;
      yReference = 65;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }

