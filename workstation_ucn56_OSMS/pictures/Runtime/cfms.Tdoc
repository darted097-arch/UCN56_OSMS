  class PumpCentrifugal
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 129;
    worldHeight = 80;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 1;
    ySnap = 1;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 0;
    yReference = 0;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    int LeftPump = 1;

    RECORD* PointId = `&ERRORPID`;

    char Temp1[7] = "STATE ";

    char Temp2[7] = "OFF ";

    function `int GetforegroundColour()
    {
    // if the pump is bad (ack or not ack'd) then return the
    // appropriate bad color
       if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
          return (COLORS[PointId->newsta]);

    // CORENET 2017.0606
       else if ( !(PointId->newsta < HACK))
          return (COLORS[PointId->newsta]);
    //
    // if the pump is running, return the ON color
       else if (PointId->value > 0)
       {
          strncpy(Temp1, PointId->message1, 7);
    //
          if(!strcmp(Temp1, "START ") || !strcmp(Temp1, "ON    ") || !strcmp(Temp1, "NOT OF"))
             return (COLOR_ACTIVE_ON_OPEN);
          else if (!strcmp(Temp1, "STOP  ") || !strcmp(Temp1, "OFF   ") || !strcmp(Temp1, "NOT ON"))
             return(COLOR_INACTIVE_OFF_CLOSED);
        }
        else
        {
          strncpy(Temp2, PointId->message2, 7);
    //
          if(!strcmp(Temp2, "START ") || !strcmp(Temp2, "ON    ") || !strcmp(Temp2, "NOT OF"))
             return (COLOR_ACTIVE_ON_OPEN);
          else if (!strcmp(Temp2, "STOP  ") || !strcmp(Temp2, "OFF   ") || !strcmp(Temp2, "NOT ON"))
             return(COLOR_INACTIVE_OFF_CLOSED);
        }
    }`

    function `int GetforegroundFillColour()
    {
    // if the pump is bad (ack or not ack'd) then return the
    // appropriate bad color
       if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
          return (COLORS[PointId->newsta]);

    // CORENET 2017.0606
       else if ( !(PointId->newsta < HACK))
          return (COLORS[PointId->newsta]);
    //
    // if the pump is running, return the ON color
       else if (PointId->value > 0)
       {
          strncpy(Temp1, PointId->message1, 7);
    //
          if(!strcmp(Temp1, "START ") || !strcmp(Temp1, "ON    ") || !strcmp(Temp1, "NOT OF"))
             return (COLOR_PICTURE_BACKGROUND);
          else if (!strcmp(Temp1, "STOP  ") || !strcmp(Temp1, "OFF   ") || !strcmp(Temp1, "NOT ON"))
             return(COLOR_INACTIVE_OFF_CLOSED);
        }
        else
        {
          strncpy(Temp2, PointId->message2, 7);
    //
          if(!strcmp(Temp2, "START ") || !strcmp(Temp2, "ON    ") || !strcmp(Temp2, "NOT OF"))
             return (COLOR_PICTURE_BACKGROUND);
          else if (!strcmp(Temp2, "STOP  ") || !strcmp(Temp2, "OFF   ") || !strcmp(Temp2, "NOT ON"))
             return(COLOR_INACTIVE_OFF_CLOSED);
        }
    }`

    dialogue
    {
      event = `buttonPressed(Left) || keyPressed(POKE) || shapeEntered()`;
      action = `{ DisplayPokeMessages(PointId); update();}`;
    }

    dialogue
    {
      event = `buttonPressed(Right) || shapeLeft()`;
      action = `{ClearPokeMessages(); update();}`;
    }

    line
    {
      numberOfPoints = 2;
      point[0] = ( 1, 27 );
      point[1] = ( 129, 27 );
      visibility = 1;
      foregroundColour = 1;
      backgroundColour = -1;
      lineStyle = 1;
      lineWidth = 0;
      xReference = 1;
      yReference = 27;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }

    polygon
