  class CEAStatePhrase1
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 100;
    worldHeight = 35;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 5;
    ySnap = 5;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 500;
    yReference = 500;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    char ChangedText[10] = "BD -";

    int curval = 9;

    int newsta = 13;

    RECORD* PointId = `&RCP102A`;

    function `int ChangeTextColors()
    {
    
    //FOR foreground colors
    
    if (PointId->newsta == BDNAK)
       return(COLOR_BAD_OOR_UNACK);
    
    else if (PointId->newsta == BDACK)
       return(COLOR_BAD_OOR_ACK);
    
    else if (PointId->newsta == HHNAK)
       return(COLOR_DANGER_UNACK);
    
    else if (PointId->newsta == HHACK)
        return(COLOR_DANGER_ACK);
    
    //else if (PointId->newsta == RALNAK)
    //    return(COLOR_CEA_RALNAK_BLINK);
    
    //else if (curval==1)
    //    return(COLOR_DATA_NORMAL);
    else
        return(COLOR_DATA_NORMAL);
    
        printf(" ChangeTextColors() done..");
    
    }`

    function `int CheckVisBAD()
    {
    
    if ((PointId->newsta == BDNAK) || (PointId->newsta == BDACK))
          return(1);
    else
          return(0);
    
          printf(" ChangeText() done..");
    }
    `

    function `int CheckVisNO()
    {
    if ((PointId->newsta != BDNAK) && (PointId->newsta != BDACK) &&
        (PointId->newsta != HHNAK)  && (PointId->newsta != HHACK) || (PointId->newsta == RALNAK))
          return(1);
    else
          return(0);
    
          printf(" ChangeText() done..");
    }
    `

    function `int CheckVisYES()
    {
    
    //if ((PointId->newsta == CNAK) || (PointId->newsta == CACK))
    if ((PointId->newsta == HHNAK) || (PointId->newsta == HHACK))
          return(1);
    else
          return(0);
    
          printf(" ChangeText() done..");
    }
    `

    dialogue
    {
      event = `buttonPressed(1)`;
      action = `{
      //printf("dsklaf456456jklsd %d",newsta);
      }`;
    }

    text BadText
    {
      x = 22;
      y = 23;
      format = "%s";
      theText = `ChangedText`;
      alignment = 0;
      visibility = `CheckVisBAD()`;
      foregroundColour = `ChangeTextColors()`;
      backgroundColour = -1;
      theFont = 4;
      xReference = 23;
      yReference = 52;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }

    text YesText
    {
      x = 23;
      y = 23;
      format = "%s";
      theText = "YES";
      alignment = 0;
      visibility = `CheckVisYES()`;
      foregroundColour = `ChangeTextColors()`;
      backgroundColour = -1;
      theFont = `font4`;
      xReference = 23;
      yReference = 23;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }

    text NoText
    {
      x = 24;
      y = 23;
      format = "%s";
      theText = "NO";
      alignment = 0;
      visibility = `CheckVisNO()`;
      foregroundColour = `ChangeTextColors()`;
      backgroundColour = -1;
      theFont = `font4`;
      xReference = 24;
      yReference = 23;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }
  }

