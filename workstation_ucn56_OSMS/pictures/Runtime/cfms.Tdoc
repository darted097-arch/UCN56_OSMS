  class ValueAndState_CAline
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 225;
    worldHeight = 38;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 5;
    ySnap = 5;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 500;
    yReference = 500;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;

    int DisplayUnits = 1;

    RECORD* hAlm = 0;

    RECORD* lAlm = 0;

    RECORD* PointId = `&ERRORPID`;

    function `int ColorBlinkBox()
    {
       if ((PointId->pisabitmap & bOOSCAN) > 0)
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else if (PointId->newsta == NORMAL ||
                PointId->newsta == RALACK ||
                PointId->newsta == RORACK ||
                PointId->newsta == RBDACK ||
                PointId->newsta == RALNAK ||
                PointId->newsta == RORNAK ||
                PointId->newsta == RBDNAK)
       {
          return (COLOR_PICTURE_BACKGROUND);
       }
       else
       {
          return(COLORS[PointId->newsta]);
       }
    }`

    function `float getValue()
    {
      if (PointId->newsta == HACK || PointId->newsta == HNAK)
    
         {
           if (IsAnalog(PointId)  &&  0 != PointId->hIPN)
               {
    	      execute ("{hAlm = \`&::UCN5and6.InterfaceToGUI.%s\`;}",PointId->message2);
    	      return(hAlm->value);
    	    }
           else
               {
                  if (Interface->System.displayedUnits==ENGLISH)
                     return (PointId->hval);
                  else
                     return (PointId->hmet);
               }
          }
      else if (PointId->newsta == LACK || PointId->newsta == LNAK)
          {
           if (IsAnalog(PointId)  &&  0 != PointId->lIPN)
               {
    	      execute ("{lAlm = \`&::UCN5and6.InterfaceToGUI.%s\`;}",PointId->message1);
    	      return(lAlm->value);
    	    }
           else
               {
                  if (Interface->System.displayedUnits==ENGLISH)
                     return (PointId->lval);
                  else
                     return (PointId->lmet);
               }
          }
      else if (PointId->newsta == HHACK || PointId->newsta == HHNAK)
          { if (Interface->System.displayedUnits==ENGLISH)
                return (PointId->hhval);
            else
                return (PointId->hhmet);
           }
      else if (PointId->newsta == LLACK || PointId->newsta == LLNAK)
           { if  (Interface->System.displayedUnits==ENGLISH)
                return (PointId->llval);
             else
                return (PointId->llmet);
           }
      else
         return(0);
      }
    `

    function `int VisibilityDashes()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
       if (PointId != 0)
    // Determine symbol visibility
       {
          if (  (PointId->newsta == ORHACK) ||	               // Out of range high - acknowledged
    	      (PointId->newsta == ORLACK) ||	       // Out of range low - acknowledged
    	      (PointId->newsta == BDACK)  ||	       // Bad data - acknowledged
    	      (PointId->newsta == ORHNAK) ||	       // Out of range high - unacknowledged
    	      (PointId->newsta == ORLNAK) ||	       // Out of range low - unacknowledged
    	      (PointId->newsta == BDNAK)  ||	       // Bad data - unacknowledged
    	     ((PointId->pisabitmap & bOOSCAN) > 0) )   // out of scan
    //
    	   return(VISIBLE);		               // return invisible
    //
           else if (PointId->sig_type >= MinimumDigitalType)   // A Digital Point
               return(INVISIBLE);
           else				                       // all others, set invisible
    	   return(INVISIBLE);
    //
       }
        else				                       // all others, set invisible
          return(INVISIBLE);
    }`

    function `int VisibilityNumber()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
            if (PointId != 0)
    //	Determine symbol visibility
    	{
              if (  (PointId->newsta == ORHACK) ||	       // Out of range high - acknowledged
    	      (PointId->newsta == ORLACK) ||	       // Out of range low - acknowledged
    	      (PointId->newsta == BDACK)  ||	       // Bad data - acknowledged
    	      (PointId->newsta == ORHNAK) ||	       // Out of range high - unacknowledged
    	      (PointId->newsta == ORLNAK) ||	       // Out of range low - unacknowledged
    	      (PointId->newsta == BDNAK)  ||	       // Bad data - unacknowledged
    	      ((PointId->pisabitmap & bOOSCAN) > 0) )   // out of scan
    //
    	     return(INVISIBLE);		 // return invisible
    //
               else if (PointId->sig_type >= MinimumDigitalType) // A Digital Point
                  return(INVISIBLE);
    //
           	   else				 // all others, set invisible
    	     return(VISIBLE);
             }
            else
              return(INVISIBLE);
    }`

    function `int VisibilityNumber1()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
            if (PointId != 0 && PointId->sig_type < MinimumDigitalType)
              {
                if (  (PointId->newsta == ORHACK)  ||	          // Out of range high - acknowledged
    	        (PointId->newsta == ORLACK)  ||	          // Out of range low - acknowledged
    	        (PointId->newsta == ORHNAK)  ||	          // Out of range high - unacknowledged
    	        (PointId->newsta == ORLNAK)  ||	          // Out of range low - unacknowledged
                    (PointId->newsta == HACK)    ||             // High Alarm - ackknowledged
                    (PointId->newsta == HNAK)    ||             // High Alarm - unackknowledged
                    (PointId->newsta == LACK)    ||             // Low Alarm - ackknowledged
                    (PointId->newsta == LNAK)    ||             // Low Alarm - unackknowledged
                    (PointId->newsta == HHACK)   ||             // HiHi Alarm - ackknowledged
                    (PointId->newsta == HHNAK)   ||             // HiHi Alarm - unackknowledged
                    (PointId->newsta == LLACK)   ||             // LoLo Alarm - ackknowledged
                    (PointId->newsta == LLNAK)      )         // LoLo Alarm - unackknowledged
    
    		return(VISIBLE);		 // return visible
    //
    	    else				 // all others, set invisible
    	       return(INVISIBLE);
             }
             else
                return(INVISIBLE);
    }`

    function `int VisibilityStatePhrase()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
            if (PointId != 0)
    //	Determine symbol visibility
            {
    //         printf  ( " Newsta is %d",PointId->newsta );
    	   if ((PointId->newsta == ORHACK) ||	       // Out of range high - acknowledged
    	      (PointId->newsta == ORLACK) ||	       // Out of range low - acknowledged
    	      (PointId->newsta == BDACK)  ||	       // Bad data - acknowledged
    	      (PointId->newsta == ORHNAK) ||	       // Out of range high - unacknowledged
    	      (PointId->newsta == ORLNAK) ||	       // Out of range low - unacknowledged
    	      (PointId->newsta == BDNAK)  ||	       // Bad data - unacknowledged
    	      ((PointId->pisabitmap & bOOSCAN) > 0) )   // out of scan
    //
    	   return(INVISIBLE);		 // return invisible
    //
              else if (PointId->sig_type < MinimumDigitalType) // An Analog Point
                 return(INVISIBLE);
    //
              else				 // all others, set invisible
                 return(VISIBLE);
             }
            else
             return(INVISIBLE);
    }   `

    function `int XXX()
    {
    //FOR background colors of the NumericValue
    // NORMAL = 0, RBDNAK = 3
    if ((PointId->newsta >= NORMAL) &&
        (PointId->newsta <= RBDNAK))
       {
          if ((pisabitmap & bOOSCAN) > 0)
               return(COLOR_BAD_OOR_ACK);
    
          else
               return(COLOR_PICTURE_BACKGROUND);
    //           return(Colour49);
    
       }
    else if ((PointId->pisabitmap & bOOSCAN) > 0)
              return(COLOR_BAD_OOR_ACK);
          else
              return(COLORS[PointId->newsta]);
    
    }`

