       if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
          return (COLORS[PointId->newsta]);
    //
    // if the pump is running, return the ON color
       else if (PointId->value > 0)
          return (COLOR_ACTIVE_ON_OPEN);
       else
    //
    // otherwise return the OFF color
       return (COLOR_PICTURE_BACKGROUND);
    } `

