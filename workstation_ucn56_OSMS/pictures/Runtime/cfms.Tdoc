  class Valve2StateHorizontal
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 128;
    worldHeight = 58;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 1;
    ySnap = 1;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 0;
    yReference = 0;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    int FLOW_RIGHT = 1;

    RECORD* Valve_H = `&ERRORPID`;

    char Temp1[7] = "STATE ";  // CORENET 2017.0606

    function `int GetFgroundColour()
    {
    //
    // The H valves are: OPEN, NOT FOPN, or BAD.
    // The L valves are: CLOSED, NOT FCLS, or BAD
    //
    //   int H_val;		// H valve state after being unmasked
    //   int H_bad;		// bad status for H valve
    //
    //   H_val    = (Valve_H->value < 1.0);
    //   H_bad    = (Valve_H->newsta == BDACK) || (Valve_H->newsta == BDNAK);
    //

       strncpy(Temp1, Valve_H->message1, 7);

       //printf("------------------------------------------");
       //printf("PID = %s, MSG = %s ", Valve_H->pid, Temp1);
       //printf("Message 1 = %s", Valve_H->message1);
       //printf("Message 2 = %s", Valve_H->message2);

    // BAD:
       if ((Valve_H->pisabitmap & bOOSCAN) > 0)
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else
       {
          if ( Valve_H->newsta == BDNAK )
             return(COLOR_BAD_OOR_UNACK);
    
          else if ( Valve_H->newsta == BDACK )
             return (COLOR_BAD_OOR_ACK);
// ALARM....

          else if (( Valve_H->value == 0) && !(Valve_H->newsta < ORHACK)) 
             return (COLORS[Valve_H->newsta]);
          else if (( Valve_H->value == 1) && !(Valve_H->newsta < ORHACK)) 
             return (COLORS[Valve_H->newsta]);
    
    // ********CORENET 20170607 ***************************************
    //
    // OPEN: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
	   else if (!strcmp(Temp1, "OPEN  "))
	     if (Valve_H->value == 1)
	       return (COLOR_ACTIVE_ON_OPEN); 
	     else
	       return (COLOR_INACTIVE_OFF_CLOSED); 
	       

           //else if (( Valve_H->value == 0) && (Valve_H->newsta < ORHACK))
           //  return (COLOR_ACTIVE_ON_OPEN);
    
           //else if (( Valve_H->value == 0) && !(Valve_H->newsta < ORHACK))
           // return (COLORS[Valve_H->newsta]);
    
    //
    // CLOSED: if the H valve is NOT FOPN and the L valve is CLOSED
    //         if the H valve is BAD abd the L valve is CLOSED
	   else if (!strcmp(Temp1, "CLOSED"))
	     if (Valve_H->value == 1)
	       return (COLOR_INACTIVE_OFF_CLOSED); 
	     else
	       return (COLOR_ACTIVE_ON_OPEN); 

       	   //else if ( Valve_H->value == 1 )
           //  return (COLOR_INACTIVE_OFF_CLOSED);
    
    //
    // NOT FULL CLOSED: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
//	   else if (!strcmp(Temp1, "NOT FC"))
//	     return (COLOR_ACTIVE_ON_OPEN); 

    //
    // NOT FULL OPEN: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
//	   else if (!strcmp(Temp1, "NOT FO"))
//	     return (COLOR_INACTIVE_OFF_CLOSED); 

    //
    // otherwise return an error alert color
       else
    
             return(COLOR_CONFIG_ERROR);
       }
    //
    }
    `

    function `int GetLeftFgroundFillColour()
    {
    //
    // The H valves are: OPEN, NOT FOPN, or BAD.
    // The L valves are: CLOSED, NOT FCLS, or BAD
    //
    //   int H_val;		// H valve state after being unmasked
    //   int H_bad;		// bad status for H valve
    //
    // First make sure that the FLOW_RIGHT flag has been properly set.  If
    // not return the error color.
       if (FLOW_RIGHT != 0 && FLOW_RIGHT != 1)
          return (COLOR_CONFIG_ERROR);
    //
    //   H_val    = (Valve_H->value > 0.0);
    //   H_bad    = (Valve_H->newsta == BDACK) || (Valve_H->newsta == BDNAK);
    //
    // The 4 state valve can take on 4 different values:
    // BAD, OPEN, CLOSED, or THROTTLED.

       strncpy(Temp1, Valve_H->message1, 7);
    
    // BAD:
       if ((Valve_H->pisabitmap & bOOSCAN) > 0)
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else
       {
// BAD..   
          if ( Valve_H->newsta == BDNAK )
             if (!FLOW_RIGHT)
                return(COLOR_PICTURE_BACKGROUND);
             else
                return(COLOR_BAD_OOR_UNACK);
          if  ( Valve_H->newsta == BDACK )
             if (!FLOW_RIGHT)
                return(COLOR_PICTURE_BACKGROUND);
             else
                return(COLOR_BAD_OOR_ACK);

// ALARM...
          //if ( ( Valve_H->value == 0) && !(Valve_H->newsta < ORHACK) ) {
          if ( !(Valve_H->newsta < ORHACK) ) {
  	    if (!strcmp(Temp1, "OPEN  ")) {
	        if (Valve_H->value == 1) // FULL OPEN
	          return (COLOR_PICTURE_BACKGROUND); 
	        else {  // NOT FOPN
                  if (!FLOW_RIGHT)
	            return (COLOR_PICTURE_BACKGROUND); 
	          else
             	    return (COLORS[Valve_H->newsta]);
	        }
	    }

	    else if (!strcmp(Temp1, "CLOSED")) { // FULL CLOSE
	        if (Valve_H->value == 1)
             	    return (COLORS[Valve_H->newsta]);
	        else {  // NOT FCLS
                  if (!FLOW_RIGHT)
	            return (COLOR_PICTURE_BACKGROUND); 
	          else
             	    return (COLORS[Valve_H->newsta]);
	        }
	   }


//             if (!FLOW_RIGHT)
//                return(COLOR_PICTURE_BACKGROUND);
//             else
//             	return (COLORS[Valve_H->newsta]);
 	  }

    // ********CORENET 20170607 ***************************************
    //
    // OPEN: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
	 else if (!strcmp(Temp1, "OPEN  ")) {
	     if (Valve_H->value == 1)
	       return (COLOR_PICTURE_BACKGROUND); 
	     else {
               if (!FLOW_RIGHT)
	         return (COLOR_PICTURE_BACKGROUND); 
	       else
	         return (COLOR_INACTIVE_OFF_CLOSED); 
	     }
	 }
	   
    //
    // CLOSED: if the H valve is NOT FOPN and the L valve is CLOSED
    //         if the H valve is BAD abd the L valve is CLOSED
	 else if (!strcmp(Temp1, "CLOSED")) {
	     if (Valve_H->value == 1)
	       return (COLOR_INACTIVE_OFF_CLOSED); 
	     else {
               if (!FLOW_RIGHT)
	         return (COLOR_PICTURE_BACKGROUND); 
	       else
	         return (COLOR_ACTIVE_ON_OPEN); 
	     }
	}

    //
    // NOT FULL CLOSED: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
//	 else if (!strcmp(Temp1, "NOT FC"))
//           if (!FLOW_RIGHT)
//	     return (COLOR_PICTURE_BACKGROUND); 
//	   else
//	     return (COLOR_ACTIVE_ON_OPEN); 

    //
    // NOT FULL OPEN: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
//	 else if (!strcmp(Temp1, "NOT FO"))
//           if (!FLOW_RIGHT)
//	     return (COLOR_PICTURE_BACKGROUND); 
//	   else
//	     return (COLOR_INACTIVE_OFF_CLOSED); 

    
    //
    // otherwise return an error alert color
       else
    //            return(COLORS[Valve_H->newsta]);
                return(COLOR_CONFIG_ERROR);
      }
    }
    `

    function `int GetRightFgroundFillColour()
    {
    //
    // The H valves are: OPEN, NOT FOPN, or BAD.
    // The L valves are: CLOSED, NOT FCLS, or BAD
    //
    //   int H_val;		// H valve state after being unmasked
    //   int H_bad;		// bad status for H valve
    //
    // First make sure that the FLOW_RIGHT flag has been properly set.  If
    // not return the error color.
       if (FLOW_RIGHT != 0 && FLOW_RIGHT != 1)
          return (COLOR_CONFIG_ERROR);
    //
    //   H_val    = (Valve_H->value > 0.0);
    //   H_bad    = (Valve_H->newsta == BDACK) || (Valve_H->newsta == BDNAK);
    //
    // The 4 state valve can take on 4 different values:
    // BAD, OPEN, CLOSED, or THROTTLED.

       strncpy(Temp1, Valve_H->message1, 7);
    
    // BAD:
       if ((Valve_H->pisabitmap & bOOSCAN) > 0)
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else
       {
          if ( Valve_H->newsta == BDNAK )
             if (FLOW_RIGHT)
                return(COLOR_PICTURE_BACKGROUND);
             else
                return(COLOR_BAD_OOR_UNACK);
          if  ( Valve_H->newsta == BDACK )
             if (FLOW_RIGHT)
                return(COLOR_PICTURE_BACKGROUND);
             else
                return(COLOR_BAD_OOR_ACK);

// ALARM...
          //if ( ( Valve_H->value == 0) && !(Valve_H->newsta < ORHACK) ) {
          if ( !(Valve_H->newsta < ORHACK) ) {
  	    if (!strcmp(Temp1, "OPEN  ")) {
	        if (Valve_H->value == 1) // FULL OPEN
	          return (COLOR_PICTURE_BACKGROUND); 
	        else {  // NOT FOPN
                  if (FLOW_RIGHT)
	            return (COLOR_PICTURE_BACKGROUND); 
	          else
             	    return (COLORS[Valve_H->newsta]);
	        }
	    }

	    else if (!strcmp(Temp1, "CLOSED")) { // FULL CLOSE
	        if (Valve_H->value == 1)
             	    return (COLORS[Valve_H->newsta]);
	        else {  // NOT FCLS
                  if (FLOW_RIGHT)
	            return (COLOR_PICTURE_BACKGROUND); 
	          else
             	    return (COLORS[Valve_H->newsta]);
	        }
	   }
	 }




//             if (FLOW_RIGHT)
//                return(COLOR_PICTURE_BACKGROUND);
//             else
//             	return (COLORS[Valve_H->newsta]);


    // ********CORENET 20170607 ***************************************
    //
    // OPEN: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
//	 else if (!strcmp(Temp1, "OPEN  "))
//	    return (COLOR_PICTURE_BACKGROUND); 

	 else if (!strcmp(Temp1, "OPEN  ")) {
	     if (Valve_H->value == 1)
	       return (COLOR_PICTURE_BACKGROUND); 
	     else {
               if (FLOW_RIGHT)
	         return (COLOR_PICTURE_BACKGROUND); 
	       else
	         return (COLOR_INACTIVE_OFF_CLOSED); 
     	    }
	 }

    //
    // CLOSED: if the H valve is NOT FOPN and the L valve is CLOSED
    //         if the H valve is BAD abd the L valve is CLOSED
//	 else if (!strcmp(Temp1, "CLOSED"))
//	    return (COLOR_INACTIVE_OFF_CLOSED); 

	 else if (!strcmp(Temp1, "CLOSED")) {
	     if (Valve_H->value == 1)
	       return (COLOR_INACTIVE_OFF_CLOSED); 
	     else {
               if (FLOW_RIGHT)
	         return (COLOR_PICTURE_BACKGROUND); 
	       else
	         return (COLOR_ACTIVE_ON_OPEN); 
	     }
	}

    //
    // NOT FULL CLOSED: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
//	 else if (!strcmp(Temp1, "NOT FC"))
//           if (FLOW_RIGHT)
//	     return (COLOR_PICTURE_BACKGROUND); 
//	   else
//	     return (COLOR_ACTIVE_ON_OPEN); 

    //
    // NOT FULL OPEN: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
//	 else if (!strcmp(Temp1, "NOT FO"))
//           if (FLOW_RIGHT)
//	     return (COLOR_PICTURE_BACKGROUND); 
//	   else
//	     return (COLOR_INACTIVE_OFF_CLOSED); 



    //
    // OPEN: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
    //    if ( Valve_H->value == 0 )
   // 
    //            return(COLOR_PICTURE_BACKGROUND);
   // 
    //
    // CLOSED: if the H valve is NOT FOPN and the L valve is CLOSED
    //         if the H valve is BAD abd the L valve is CLOSED
    //   else if ( Valve_H->value == 1 )
   // 
    //            return(COLOR_INACTIVE_OFF_CLOSED);
   // 
    //
    // otherwise return an error alert color
       else
    
                return(COLOR_CONFIG_ERROR);
      }
    }
    `

