    function `int CheckVisBAD()
    {
    
    if ((PointId->newsta == BDNAK) || (PointId->newsta == BDACK))
          return(1);
    else
          return(0);
    
          printf(" ChangeText() done..");
    }
    `

    function `int CheckVisNO()
    {
    if ((PointId->newsta != BDNAK)  && (PointId->newsta != BDACK) &&
        (PointId->newsta != HHNAK)  && (PointId->newsta != HHACK) &&
        (PointId->value  != 1)      || (PointId->newsta == RALNAK))
          return(1);
    else
          return(0);
    
          printf(" ChangeText() done..");
    }
    `

    function `int CheckVisYES()
    {
    
    //if ((PointId->newsta == CNAK) || (PointId->newsta == CACK))
    if ((PointId->newsta == HHNAK) || (PointId->newsta == HHACK) || ((PointId->value == 1) &&
        (PointId->newsta != BDNAK)  && (PointId->newsta != BDACK)))
    //if ((newsta == HHNAK) || (newsta == HHACK) || (value == 1))
    
       return(1);
    
    else
       return(0);
    
          printf(" ChangeText() done..");
    }
    `

