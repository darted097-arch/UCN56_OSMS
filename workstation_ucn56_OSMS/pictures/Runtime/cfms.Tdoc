  class DynamicTextPhrase
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 300;
    worldHeight = 30;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 1;
    ySnap = 1;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 0;
    yReference = 0;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    RECORD* PointId = `&ERRORPID`;

    char* TheText = "INSERT A TEXT PHRASE";

    dialogue
    {
      event = `buttonPressed(Left) || keyPressed(POKE) || shapeEntered()`;
      action = `{ DisplayPokeMessages(PointId); update(); }`;
    }

    dialogue
    {
      event = `buttonPressed(Right) || shapeLeft()`;
      action = `{ ClearPokeMessages(); update(); }`;
    }

    text
    {
      x = 1;
      y = 20;
      format = "%s";
      theText = `TheText`;
      alignment = 0;
      visibility = `(!(PointId->newsta < HACK) || (PointId->newsta == BDACK) || (PointId->newsta == BDNAK))`;
      foregroundColour = `(COLORS[PointId->newsta])`;
      backgroundColour = -1;
      theFont = `font4`;
      xReference = 10;
      yReference = 19;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }
  }

  class DynamicTextPhrase2
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 300;
    worldHeight = 30;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 1;
    ySnap = 1;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 0;
    yReference = 0;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    RECORD* PointId = `&ERRORPID`;

    function `int ChangeColors()
    {
     //FOR foreground colors
    
     if (PointId->newsta == BDNAK)
          return(COLOR_BAD_OOR_UNACK);
     else if (PointId->newsta == BDACK)
          return(COLOR_BAD_OOR_ACK);
     else if (PointId->newsta == CNAK)
          return(COLOR_DANGER_UNACK);
     else if (PointId->newsta == CACK)
          return(COLOR_DANGER_ACK);
     else
          return(COLORS[PointId->newsta]);
    }
    `

    function `char *TheText()
    {
       if(PointId->newsta == BDNAK || PointId->newsta == BDACK)
           return("BD  -----");
       else if(PointId->value > 0)
           return("YES");
       else
           return("NO");
    }`

    dialogue
    {
      event = `buttonPressed(Left) || keyPressed(POKE) || shapeEntered()`;
      action = `{ DisplayPokeMessages(PointId); update(); }`;
    }

    dialogue
    {
      event = `buttonPressed(Right) || shapeLeft()`;
      action = `{ ClearPokeMessages(); update(); }`;
    }

    text
    {
      x = 1;
      y = 20;
      format = "%s";
      theText = `TheText()`;
      alignment = 0;
      visibility = 1;
      foregroundColour = `ChangeColors()`;
      backgroundColour = -1;
      theFont = `font4`;
      xReference = 10;
      yReference = 19;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }
  }

  class Fan
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 129;
    worldHeight = 80;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 1;
    ySnap = 1;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 0;
    yReference = 0;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    int LeftPump = 1;

    RECORD* PointId = `&ERRORPID`;

    function `int GetforegroundColour()
    {
    // if the pump is bad (ack or not ack'd) then return the
    // appropriate bad color
       if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
          return (COLORS[PointId->newsta]);
    //
    // if the pump is running, return the ON color
       else if (PointId->value > 0)
          return (COLOR_ACTIVE_ON_OPEN);
       else
    //
    // otherwise return the OFF color
       return (COLOR_INACTIVE_OFF_CLOSED);
    }`

    function `int GetforegroundFillColour()
    {
    // if the pump is bad (ack or not ack'd) then return the
    // appropriate bad color
       if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
          return (COLORS[PointId->newsta]);
    //
    // if the pump is running, return the ON color
       else if (PointId->value > 0)
          return (COLOR_PICTURE_BACKGROUND);
       else
    //
    // otherwise return the OFF color
       return (COLOR_INACTIVE_OFF_CLOSED);
    }`

    dialogue
    {
      event = `buttonPressed(Left) || keyPressed(POKE) || shapeEntered()`;
      action = `{DisplayPokeMessages(PointId); update();}`;
    }

    dialogue
