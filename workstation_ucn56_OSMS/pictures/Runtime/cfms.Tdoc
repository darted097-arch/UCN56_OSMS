  class HeaderESFASMessage
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 80;
    worldHeight = 20;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 0;
    ySnap = 0;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 500;
    yReference = 500;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;

    RECORD* PointId = `&ERRORPID`;

    char* TheText = "INSERT";

    function `int VisibilityESFAS()
    {
    //
    //	The representation of a number can take on scenarios:
    //        visible for: data bad, data in alarm
    //      else
    //        invisible
    //
    //printf(" newsta=%d, %s ,%d, %d \\n",PointId->newsta,PointId->pid,VISIBLE,INVISIBLE);
    //
    // Determine symbol visibility
       if (  (PointId->newsta == BDACK)  ||	       // Bad data - acknowledged
    	 (PointId->newsta == BDNAK)  ||	       // Bad data - unacknowledged
    	 (PointId->newsta == CNAK) ||	       // Out of range high - unacknowledged
    	 (PointId->newsta == CACK) )	       // Out of range low - unacknowledged
    //
    	   return(VISIBLE);		               // return invisible
    //
       else				                       // all others, set invisible
    	   return(INVISIBLE);
    }`

    rectangle
    {
      x = 1;
      y = 2;
      width = 67;
      height = 15;
      visibility = `VisibilityESFAS()`;
      foregroundColour = `COLORS[PointId->newsta]`;
      backgroundColour = `COLORS[PointId->newsta]`;
      linePattern = `SolidPattern`;
      lineWidth = 0;
      foregroundFillColour = `COLORS[PointId->newsta]`;
      backgroundFillColour = -1;
      fillPattern = `SolidPattern`;
      xReference = 2;
      yReference = 3;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }

    text
    {
      x = 5;
      y = 14;
      format = "%s";
      theText = `TheText`;
      alignment = 0;
      visibility = `VisibilityESFAS()`;
      foregroundColour = `COLOR_PICTURE_BACKGROUND`;
      backgroundColour = -1;
      theFont = `font0`;
      xReference = 7;
      yReference = 14;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }

