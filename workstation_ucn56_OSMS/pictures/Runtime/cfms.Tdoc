  class Valve3WayHorizontal
  {
    worldX = 0;
    worldY = -25;
    worldWidth = 128;
    worldHeight = 81;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 1;
    ySnap = 1;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 0;
    yReference = 0;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    RECORD* Valve_H = `&ERRORPID`;

    RECORD* Valve_L = `&ERRORPID`;

    function `int GetBottomforegroundColour()
    {
    // if either input is bad:
    //    Output BDNAK if at least one is unacknowledged
    //    Otherwise output BDACK
    //
       if ((Valve_L->pisabitmap & bOOSCAN) > 0)
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else
        {
       if ( (Valve_L->newsta==BDNAK) || (Valve_L->newsta==BDACK) )
          return (COLORS[Valve_L->newsta]);
    // if the L valve is OPEN
       else if ((Valve_L->value>0) && (Valve_L->newsta < ORHACK))
          return (COLOR_ACTIVE_ON_OPEN);
       else if ((Valve_L->value>0) && !(Valve_L->newsta < ORHACK))
          return (COLORS[Valve_L->newsta]);
       else
    // otherwise, it's CLOSED
          return (COLOR_INACTIVE_OFF_CLOSED);
      }
    }`

    function `int GetBottomforegroundFillColour()
    {
    // if either input is bad or the L valve is a OPEN:
    //    Output the background color
    //    Otherwise output thr CLOSED
    //
       if ((Valve_L->pisabitmap & bOOSCAN) > 0)
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else
       {
       if ( (Valve_L->newsta==BDNAK) || (Valve_L->newsta==BDACK) || (Valve_L->value>0) )
          return (COLOR_PICTURE_BACKGROUND);
       else
          return (COLOR_INACTIVE_OFF_CLOSED);
       }
    }`

    function `int GetLeftforegroundColour()
    {
    // if either input is bad:
    //    Output BDNAK if at least one is unacknowledged
    //    Otherwise output BDACK
    //
       if ((Valve_H->pisabitmap & bOOSCAN) > 0)
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else
       {
       if ( (Valve_H->newsta==BDNAK) || (Valve_H->newsta==BDACK) )
          return (COLORS[Valve_H->newsta]);
    // if the H valve is OPEN
       else if ((Valve_H->value>0) && (Valve_H->newsta < ORHACK))
          return (COLOR_ACTIVE_ON_OPEN);
       else if ((Valve_H->value>0) && !(Valve_H->newsta < ORHACK))
          return (COLORS[Valve_H->newsta]);
       else
    // otherwise, it's CLOSED
          return (COLOR_INACTIVE_OFF_CLOSED);
      }
    }`

    function `int GetLeftforegroundFillColour()
    {
    // if either input is bad or the H valve is a OPEN:
    //    Output the background color
    //    Otherwise output thr CLOSED
    //
       if ((Valve_H->pisabitmap & bOOSCAN) > 0)
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else
       {
       if ( (Valve_H->newsta==BDNAK) || (Valve_H->newsta==BDACK) || (Valve_H->value>0) )
          return (COLOR_PICTURE_BACKGROUND);
       else
          return (COLOR_INACTIVE_OFF_CLOSED);
      }
    }`

    function `int GetRightforegroundColour()
    {
    // if either input is bad:
    //    Output BDNAK if at least one is unacknowledged
    //    Otherwise output BDACK
    //
       if ( (Valve_H->newsta==BDNAK) || (Valve_L->newsta==BDNAK) || ((Valve_H->pisabitmap & bOOSCAN) > 0) ||
            ((Valve_L->pisabitmap & bOOSCAN) > 0) )
          return (COLOR_BAD_OOR_UNACK);
       else if ( (Valve_H->newsta==BDACK) || (Valve_L->newsta==BDACK) )
          return (COLOR_BAD_OOR_ACK);
       else if ((Valve_H->newsta < ORHACK) && (Valve_L->newsta < ORHACK))
          return (COLOR_ACTIVE_ON_OPEN);
       else if (!(Valve_H->newsta < ORHACK) && (Valve_L->newsta < ORHACK))
          return (COLORS[Valve_H->newsta]);
       else if ((Valve_H->newsta < ORHACK) && !(Valve_L->newsta < ORHACK))
          return (COLORS[Valve_L->newsta]);
       else
        {
           if (Valve_H->newsta > Valve_L->newsta)
               return (COLORS[Valve_H->newsta]);
           else
               return (COLORS[Valve_L->newsta]);
         }
    
    }`

    dialogue
    {
      event = `buttonPressed(Left) || keyPressed(POKE) || shapeEntered()`;
      action = `{ DisplayPokeMessages(Valve_H); update();}`;
