    function `int ColorBlinkBox()
    {
       if ( (PointId->pisabitmap & bOOSCAN) && (!(PointId->pisabitmap & bENVAL)) )
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else if ((PointId->newsta >= NORMAL) && (PointId->newsta <= RBDNAK))
       {
          return (COLOR_PICTURE_BACKGROUND);
       }
       else
          return(COLORS[PointId->newsta]);
    }`

    function `int Get_Digital_F_Color()
    {
    
       if ( (PointId->pisabitmap & bOOSCAN) && (!(PointId->pisabitmap & bENVAL)) )
       {
          return(COLOR_PICTURE_BACKGROUND);
       }
       else if(!strcmp(PointId->pid, "CVYQCH1") || !strcmp(PointId->pid, "CVYQCH2") || !strcmp(PointId->pid, "CVYQCH3"))
       {
           if(PointId->value == 1)
              return(COLOR_ACTIVE_ON_OPEN);
           else
              return(COLOR_INACTIVE_OFF_CLOSED);
       }
       else
       {
          if(PointId->newsta < HACK)
             return(COLOR_DATA_NORMAL);
          else
             return(COLOR_PICTURE_BACKGROUND);
       }
    }`

    function `int GetNumericFgColor()
    {
    // FOR foreground colors
    
       if ( (PointId->pisabitmap & bOOSCAN) && (!(PointId->pisabitmap & bENVAL)) )
       {
          return(COLOR_PICTURE_BACKGROUND);
       }
       else if ((PointId->newsta >= NORMAL) && (PointId->newsta <= RBDNAK))
       {
          return(COLORS[PointId->newsta]);
       }
       else
          return(COLOR_PICTURE_BACKGROUND);
    }
    `

    function `int VisibilityBlinkBox()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
    //	Determine symbol visibility
    
          if (PointId->pisabitmap & bOOSCAN)               // out of scan
             return(VISIBLE);
          else
          {
    	  if ((PointId->newsta == ORHACK)  ||	          // Out of range high - acknowledged
    	      (PointId->newsta == ORLACK)  ||	          // Out of range low - acknowledged
    	      (PointId->newsta == BDACK)   ||	          // Bad data - acknowledged
    	      (PointId->newsta == ORHNAK)  ||	          // Out of range high - unacknowledged
    	      (PointId->newsta == ORLNAK)  ||	          // Out of range low - unacknowledged
    	      (PointId->newsta == BDNAK)   ||	          // Bad data - unacknowledged
                  (PointId->newsta == HACK)    ||             // High Alarm - ackknowledged
                  (PointId->newsta == HNAK)    ||             // High Alarm - unackknowledged
                  (PointId->newsta == LACK)    ||             // Low Alarm - ackknowledged
                  (PointId->newsta == LNAK)    ||             // Low Alarm - unackknowledged
                  (PointId->newsta == HHACK)   ||             // HiHi Alarm - ackknowledged
                  (PointId->newsta == HHNAK)   ||             // HiHi Alarm - unackknowledged
                  (PointId->newsta == LLACK)   ||             // LoLo Alarm - ackknowledged
                  (PointId->newsta == LLNAK))                 // LoLo Alarm - unackknowledged
              {
                 return(VISIBLE);		 // return visible
              }
    	  else				 // all others, set invisible
    	     return(INVISIBLE);
          }
    }
    `

    function `int VisibilityDashes()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
    // Determine symbol visibility
    
       if (PointId->pisabitmap & bOOSCAN)               // out of scan
          return(INVISIBLE);
       else
       {
          if ((PointId->newsta == ORHACK) ||	               // Out of range high - acknowledged
              (PointId->newsta == ORLACK) ||	       // Out of range low - acknowledged
              (PointId->newsta == BDACK)  ||	       // Bad data - acknowledged
              (PointId->newsta == ORHNAK) ||	       // Out of range high - unacknowledged
              (PointId->newsta == ORLNAK) ||	       // Out of range low - unacknowledged
              (PointId->newsta == BDNAK) )    	       // Bad data - unacknowledged
          {
             return(VISIBLE);		               // return invisible
          }
          else				                       // all others, set invisible
             return(INVISIBLE);
       }
    }`

    function `int VisibilityNumber()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
    //	Determine symbol visibility
    
       if(!strcmp(PointId->pid,"ERRORPID"))                  // ERRORPID
          return(INVISIBLE);
       else
       {
          if (PointId->sig_type < MinimumDigitalType)        // Analog Point
          {
             if (PointId->pisabitmap & bOOSCAN)              // out of scan
                return(VISIBLE);
             else
             {
      	    if ((PointId->newsta == ORHACK) ||	       // Out of range high - acknowledged
    	        (PointId->newsta == ORLACK) ||	       // Out of range low - acknowledged
    	        (PointId->newsta == BDACK)  ||	       // Bad data - acknowledged
    	        (PointId->newsta == ORHNAK) ||	       // Out of range high - unacknowledged
    	        (PointId->newsta == ORLNAK) ||	       // Out of range low - unacknowledged
    	        (PointId->newsta == BDNAK)) 	       // Bad data - unacknowledged
                {
    	       return(INVISIBLE);		       // Abnormal State
                }
                else
                {
                   return(VISIBLE);                        // Normal State
                }
             }
          }
          else
          {
             return(INVISIBLE);                           // Digital PID
          }
       }
    } `

    function `int VisibilityStatePhrase()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
    //	Determine symbol visibility
    
       if (PointId->sig_type >= MinimumDigitalType)        // Digital Point
       {
          if (PointId->pisabitmap & bOOSCAN)               // out of scan
             return(VISIBLE);
          else
          {
      	 if ((PointId->newsta == ORHACK) ||	       // Out of range high - acknowledged
    	     (PointId->newsta == ORLACK) ||	       // Out of range low - acknowledged
    	     (PointId->newsta == BDACK)  ||	       // Bad data - acknowledged
    	     (PointId->newsta == ORHNAK) ||	       // Out of range high - unacknowledged
    	     (PointId->newsta == ORLNAK) ||	       // Out of range low - unacknowledged
    	     (PointId->newsta == BDNAK)) 	       // Bad data - unacknowledged
             {
    	    return(INVISIBLE);		 // return invisible
             }
             else
                return(VISIBLE);
          }
       }
       else
       {
          return(INVISIBLE);		 // return invisible
       }
    }`

