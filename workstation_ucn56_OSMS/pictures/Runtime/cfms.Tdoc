  class CSFBarSize1
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 100;
    worldHeight = 250;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 1;
    ySnap = 1;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 0;
    yReference = 0;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    RECORD* PointId = `&ERRORPID`;

    char* SectoringPage = " ";

    char* SectorNumber = "-1";

    function `int DisplaySector()
    {
    // If the Sector number is less than 0, then it has not
    // been properly configured
       if (strcmp("-1",SectorNumber)==0)
           return(VISIBLE);
    
    // If the SECTOR key is pressed and the point is normal
       else if (SectorInfo_Active && PointId->newsta < HACK)
           return(VISIBLE);
    
    // If the SECTOR key is not pressed and the point is normal
       else if ((!SectorInfo_Active) && (PointId->newsta < HACK) && (PointId->newsta != BDACK) && (PointId->newsta != BDNAK))
    //   else if (!SectorInfo_Active && PointId->newsta < HACK)
           return(INVISIBLE);
       else if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
           return(VISIBLE);
    // otherwise, sector key is active in the alarm color
       else
           return(VISIBLE);
    }`

    function `int SectorColor()
    {
    // If the Sector number is less than 0, then it has not
    // been properly configured
       if (strcmp("-1",SectorNumber)==0)
           return(COLOR_CONFIG_ERROR);
    
    // If the SECTOR key is pressed and the point is normal
       else if ((SectorInfo_Active) && (PointId->newsta < HACK) && (PointId->newsta != BDACK) && (PointId->newsta != BDNAK))
           return(COLOR_DATA_NORMAL);
       else if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
          return (COLORS[PointId->newsta]);
    // If the SECTOR key is not pressed and the point is normal
    // This does not matter-it will be invisible
       else if ((!SectorInfo_Active) && (PointId->newsta < HACK) && (PointId->newsta != BDACK) && (PointId->newsta != BDNAK))
           return(COLOR_STATIC_TEXT);
    
    // otherwise, sector key is active in the alarm color
       else
           return(COLORS[PointId->newsta]);
    }`

    dialogue
    {
      event = `buttonPressed(1)`;
      action = `{
      // if sector bar is displayed, left-button click allowed
      if (PointId->newsta >= HACK)
         execute("{DisplayPage(Page%s);}", SectoringPage);
      else if ( (PointId->newsta == BDACK) || (PointId->newsta == BDNAK) )
         execute("{DisplayPage(Page%s);}", SectoringPage);
      }`;
    }

    line
    {
      numberOfPoints = 2;
      point[0] = ( 10, 19 );
      point[1] = ( 10, 38 );
      visibility = `DisplaySector()`;
      foregroundColour = `SectorColor()`;
      backgroundColour = -1;
      lineStyle = 1;
      lineWidth = 5;
      xReference = 10;
      yReference = 9;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }

    text
    {
      x = 21;
      y = 37;
      format = "%s";
      theText = `SectorNumber`;
      alignment = 0;
      visibility = `DisplaySector()`;
      foregroundColour = `SectorColor()`;
      backgroundColour = -1;
      theFont = 7;
      xReference = 21;
      yReference = 37;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }
  }

