  class Valve4StateHorizontal
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 128;
    worldHeight = 58;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 1;
    ySnap = 1;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 0;
    yReference = 0;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    int FLOW_RIGHT = 1;

    char Temp1[7] = "STATE ";  // CORENET 2017.0606
    char Temp2[7] = "STATE ";  // CORENET 2017.0606

    RECORD* Valve_H = `&ERRORPID`;

    RECORD* Valve_L = `&ERRORPID`;

    function `int GetforegroundColour()
    {
    //
    // The H valves are: OPEN, NOT FOPN, or BAD.
    // The L valves are: CLOSED, NOT FCLS, or BAD
    //
       int H_val;		// H valve state after being unmasked
       int L_val;		// L valve state after being unmasked
       int H_bad;		// bad status for H valve
       int L_bad;		// bad status for L valve
       int activeColor;	// The triangle which indicates flow to
       int passiveColor;	// The triangle which indicates flow from

       if (Valve_H->value == 1)
          strncpy(Temp1, Valve_H->message1, 7);	//CORENET 20170608	
       else 
          strncpy(Temp1, Valve_H->message2, 7);	//CORENET 20170608	

       if (Valve_L->value == 1)
          strncpy(Temp2, Valve_L->message1, 7);	//CORENET 20170608	
       else 
          strncpy(Temp2, Valve_L->message2, 7);	//CORENET 20170608	

       H_val = !strcmp(Temp1, "OPEN  ");	//CORENET 20170608
       L_val = !strcmp(Temp2, "CLOSED");	//CORENET 20170608

    //
    // ujson   H_val    = (Valve_H->value) > 0.0;
       H_bad    = (Valve_H->newsta == BDACK) || (Valve_H->newsta == BDNAK);
    //
    // ujson   L_val    = (Valve_L->value) > 0.0;
       L_bad    = (Valve_L->newsta == BDACK) || (Valve_L->newsta == BDNAK);

    //
    // The 4 state valve can take on 4 different values:
    // BAD, OPEN, CLOSED, or THROTTLED.
    
    // BAD: if both valves are BAD
    //      if the H valve is OPEN and the L valve is CLOSED
    //      if the H valve is NOT FOPN and the L valve is BAD
    //      if the H valve is BAD and the L valve is NOT FCLS
    //   if (strcmp("ERRORPID",Valve_H->pid)==0)
    //      return (COLOR_CONFIG_ERROR);
       if (((Valve_H->pisabitmap & bOOSCAN) > 0) || ((Valve_L->pisabitmap & bOOSCAN) > 0))
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else
       {
         if ( ( H_bad &&  L_bad) || ( H_val && !H_bad && L_val && !L_bad) ||
            (!H_val && !H_bad &&  L_bad) || ( H_bad && !L_val && !L_bad) )
         {
          if ( (Valve_H->newsta == BDNAK) || (Valve_L->newsta == BDNAK) )
             return(COLOR_BAD_OOR_UNACK);
          else
             return (COLOR_BAD_OOR_ACK);
         }

    
    // Alarm Colour
    
    //   if (!(Valve_H->newsta < HACK) || !(Valve_L->newsta < HACK))
    //       return(COLORS[Valve_H->newsta]);


     //  else if ( ((H_val && !H_bad && !L_val && !L_bad) || (H_val && !H_bad && L_bad)) &&
     //             !(Valve_L->newsta < ORHACK) && !(Valve_H->newsta < ORHACK ))

     //***************************CORENET 20170608 *************************************
       else if (!(Valve_L->newsta < ORHACK) && !(Valve_H->newsta < ORHACK ))
       {
                if (Valve_H->newsta > Valve_L->newsta)
                   return(COLORS[Valve_H->newsta]);
                else
                   return(COLORS[Valve_L->newsta]);
       }
    
       //else if ( ((H_val && !H_bad && !L_val && !L_bad) || (H_val && !H_bad && L_bad)) &&
       //           (Valve_L->newsta < ORHACK) && !(Valve_H->newsta < ORHACK ))

       else if ((Valve_L->newsta < ORHACK) && !(Valve_H->newsta < ORHACK ))
               return(COLORS[Valve_H->newsta]);
    
       //else if ( ((H_val && !H_bad && !L_val && !L_bad) || (H_val && !H_bad && L_bad)) &&
       //           !(Valve_L->newsta < ORHACK) && (Valve_H->newsta < ORHACK ))
       else if ( !(Valve_L->newsta < ORHACK) && (Valve_H->newsta < ORHACK ))
               return(COLORS[Valve_L->newsta]);

    //
    // OPEN: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD

//     else if ( ((H_val && !H_bad && !L_val && !L_bad) || (H_val && !H_bad && L_bad)) &&
//                  (Valve_L->newsta < ORHACK) && (Valve_H->newsta < ORHACK ))
       else if ( H_val && !L_val ) 
    
             return (COLOR_ACTIVE_ON_OPEN);
    
    
    //
    // CLOSED: if the H valve is NOT FOPN and the L valve is CLOSED
    //         if the H valve is BAD abd the L valve is CLOSED
//       else if ( (!H_val && !H_bad && L_val && !L_bad) || (H_bad && L_val && !L_bad) )
       else if ( !H_val  && L_val )
    
             return (COLOR_INACTIVE_OFF_CLOSED);
    
    //
    // THROTTLED: if the H valve is NOT FOPN and the L valve is NOT FCLS
    //   else if (!H_val && !H_bad && !L_val && !L_bad && (Valve_L->newsta < ORHACK) && (Valve_H->newsta < ORHACK))

       else if (!H_val && !L_val && (Valve_L->newsta < ORHACK) && (Valve_H->newsta < ORHACK))
    
             return(COLOR_THROTTLING);
    
    /*
       else if (!H_val && !H_bad && !L_val && !L_bad && (Valve_L->newsta < ORHACK) && !(Valve_H->newsta < ORHACK))
                return(COLORS[Valve_H->newsta]);
    
       else if (!H_val && !H_bad && !L_val && !L_bad && !(Valve_L->newsta < ORHACK) && (Valve_H->newsta < ORHACK))
                return(COLORS[Valve_L->newsta]);
    
       else if (!H_val && !H_bad && !L_val && !L_bad && !(Valve_L->newsta < ORHACK) && !(Valve_H->newsta < ORHACK))
            {
                if (Valve_H->newsta > Valve_L->newsta)
                   return(COLORS[Valve_H->newsta]);
                else
                   return(COLORS[Valve_L->newsta]);
             }
     */ 
    // ********END CORENET 20170608*******************************************************
    //
    // otherwise return an error alert color
       else
    
             return(COLOR_CONFIG_ERROR);
    //           return(COLORS[Valve_H->newsta]);
      }
    // }
    //
    }
    `

    function `int GetLeftforegroundFillColour()
    {
    //
    // The H valves are: OPEN, NOT FOPN, or BAD.
    // The L valves are: CLOSED, NOT FCLS, or BAD
    //
       int H_val;		// H valve state after being unmasked
       int L_val;		// L valve state after being unmasked
       int H_bad;		// bad status for H valve
       int L_bad;		// bad status for L valve

       if (Valve_H->value == 1)
          strncpy(Temp1, Valve_H->message1, 7);	//CORENET 20170608	
       else 
          strncpy(Temp1, Valve_H->message2, 7);	//CORENET 20170608	

       if (Valve_L->value == 1)
          strncpy(Temp2, Valve_L->message1, 7);	//CORENET 20170608	
       else 
          strncpy(Temp2, Valve_L->message2, 7);	//CORENET 20170608	

       H_val = !strcmp(Temp1, "OPEN  ");	//CORENET 20170608	
       L_val = !strcmp(Temp2, "CLOSED");	//CORENET 20170608

    //
    // First make sure that the FLOW_RIGHT flag has been properly set.  If
    // not return the error color.
       if (FLOW_RIGHT != 0 && FLOW_RIGHT != 1)
          return (COLOR_CONFIG_ERROR);
    //
    // ujson   H_val    = (Valve_H->value > 0);
       H_bad    = (Valve_H->newsta == BDACK) || (Valve_H->newsta == BDNAK);
    //
    // ujson   L_val    = (Valve_L->value > 0.0);
       L_bad    = (Valve_L->newsta == BDACK) || (Valve_L->newsta == BDNAK);
    //
    // The 4 state valve can take on 4 different values:
    // BAD, OPEN, CLOSED, or THROTTLED.
    
    // BAD: if both valves are BAD
    //      if the H valve is OPEN and the L valve is CLOSED
    //      if the H valve is NOT FOPN and the L valve is BAD
    //      if the H valve is BAD and the L valve is NOT FCLS
       if (((Valve_H->pisabitmap & bOOSCAN) > 0) || ((Valve_L->pisabitmap & bOOSCAN) > 0))
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else
       {
          if ( ( H_bad &&  L_bad) || ( H_val && !H_bad && L_val && !L_bad) ||
              (!H_val && !H_bad &&  L_bad) || ( H_bad && !L_val && !L_bad) )
          {
          if ( (Valve_H->newsta == BDNAK) || (Valve_L->newsta == BDNAK) )
             if (!FLOW_RIGHT)
                return(COLOR_PICTURE_BACKGROUND);
             else
                return(COLOR_BAD_OOR_UNACK);
          else
             if (!FLOW_RIGHT)
                return(COLOR_PICTURE_BACKGROUND);
             else
                return(COLOR_BAD_OOR_ACK);
          }
    // Alarm Colour
    // **************************CORENET 20170608****************************************

         else if (!(Valve_L->newsta < ORHACK) || !(Valve_H->newsta < ORHACK ))
	 {
            if ( (H_val && !H_bad && !L_val && !L_bad) || (H_val && !H_bad && L_bad) )
                return(COLOR_PICTURE_BACKGROUND);
            else if ( (!H_val && !H_bad && L_val && !L_bad) || (H_bad && L_val && !L_bad) )
	    {
                if (Valve_H->newsta > Valve_L->newsta)
                   return(COLORS[Valve_H->newsta]);
                else
                   return(COLORS[Valve_L->newsta]);
	    }

	 }
    
    //   if (!(Valve_H->newsta < HACK) || !(Valve_L->newsta < HACK))
    //            return(COLOR_PICTURE_BACKGROUND);
    //   else
    //   {
    //
    // OPEN: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
    //   else if ( (H_val && !H_bad && !L_val && !L_bad) ||
    //             (H_val && !H_bad && L_bad) )
       else if ( (H_val && !L_val ))
    
                return(COLOR_PICTURE_BACKGROUND);
    
    //
    // CLOSED: if the H valve is NOT FOPN and the L valve is CLOSED
    //         if the H valve is BAD and the L valve is CLOSED
    //   else if ( (!H_val && !H_bad && L_val && !L_bad) ||
    //             (H_bad && L_val && !L_bad) )
       else if ( (!H_val && L_val ) )
    
                return(COLOR_INACTIVE_OFF_CLOSED);
    
    //
    // THROTTLED: if the H valve is NOT FOPN and the L valve is NOT FCLS
    //   else if (!H_val && !H_bad && !L_val && !L_bad)
    //
    //         if (!FLOW_RIGHT)
    //            return(COLOR_THROTTLING);
    //         else
    //            return(COLOR_PICTURE_BACKGROUND);
    //   else if ((!H_val && !H_bad && !L_val && !L_bad) && (Valve_H->newsta < ORHACK) && (Valve_L->newsta < ORHACK))
       else if ((!H_val && !L_val ) && (Valve_H->newsta < ORHACK) && (Valve_L->newsta < ORHACK))     {
             if (!FLOW_RIGHT)
                return(COLOR_THROTTLING);
             else
                return(COLOR_PICTURE_BACKGROUND);
       }
    /* 
       else if ((!H_val && !H_bad && !L_val && !L_bad) && !(Valve_H->newsta < ORHACK) && (Valve_L->newsta < ORHACK))
    
             if (!FLOW_RIGHT)
                return(COLORS[Valve_H->newsta]);
             else
                return(COLOR_PICTURE_BACKGROUND);
    
       else if ((!H_val && !H_bad && !L_val && !L_bad) && (Valve_H->newsta < ORHACK) && !(Valve_L->newsta < ORHACK))
    
             if (!FLOW_RIGHT)
                return(COLORS[Valve_L->newsta]);
             else
                return(COLOR_PICTURE_BACKGROUND);
    
       else if ((!H_val && !H_bad && !L_val && !L_bad) && !(Valve_H->newsta < ORHACK) && !(Valve_L->newsta < ORHACK))
    
             if (!FLOW_RIGHT)
                if (Valve_H->newsta > Valve_L->newsta)
                   return(COLORS[Valve_H->newsta]);
                else
                   return(COLORS[Valve_L->newsta]);
             else
                return(COLOR_PICTURE_BACKGROUND);

    */ 
    //************END CORENET 20170608**************************************************
    //
    // otherwise return an error alert color
       else
    
                return(COLOR_CONFIG_ERROR);
      }
    // }
    }
    `

    function `int GetRightforegroundFillColour()
    {
    //
    // The H valves are: OPEN, NOT FOPN, or BAD.
    // The L valves are: CLOSED, NOT FCLS, or BAD
    //
       int H_val;		// H valve state after being unmasked
       int L_val;		// L valve state after being unmasked
       int H_bad;		// bad status for H valve
       int L_bad;		// bad status for L valve

       if (Valve_H->value == 1)
          strncpy(Temp1, Valve_H->message1, 7);	//CORENET 20170608	
       else 
          strncpy(Temp1, Valve_H->message2, 7);	//CORENET 20170608	

       if (Valve_L->value == 1)
          strncpy(Temp2, Valve_L->message1, 7);	//CORENET 20170608	
       else 
          strncpy(Temp2, Valve_L->message2, 7);	//CORENET 20170608	

       H_val = !strcmp(Temp1, "OPEN  ");	//CORENET 20170608
       L_val = !strcmp(Temp2, "CLOSED");	//CORENET 20170608
    //
    // First make sure that the FLOW_RIGHT flag has been properly set.  If
    // not return the error color.
       if (FLOW_RIGHT != 0 && FLOW_RIGHT != 1)
          return (COLOR_CONFIG_ERROR);
    //
    //   H_val    = (Valve_H->value > 0.0);
       H_bad    = (Valve_H->newsta == BDACK) || (Valve_H->newsta == BDNAK);
    //
    //   L_val    = (Valve_L->value > 0.0);
       L_bad    = (Valve_L->newsta == BDACK) || (Valve_L->newsta == BDNAK);
    //
    // The 4 state valve can take on 4 different values:
    // BAD, OPEN, CLOSED, or THROTTLED.
    
    // BAD: if both valves are BAD
    //      if the H valve is OPEN and the L valve is CLOSED
    //      if the H valve is NOT FOPN and the L valve is BAD
    //      if the H valve is BAD and the L valve is NOT FCLS
       if (((Valve_H->pisabitmap & bOOSCAN) > 0) || ((Valve_L->pisabitmap & bOOSCAN) > 0))
       {
          return(COLOR_BAD_OOR_ACK);
       }
       else
       {
       if ( ( H_bad &&  L_bad) || ( H_val && !H_bad && L_val && !L_bad) ||
            (!H_val && !H_bad &&  L_bad) || ( H_bad && !L_val && !L_bad) )
       {
          if ( (Valve_H->newsta == BDNAK) || (Valve_L->newsta == BDNAK) )
             if (FLOW_RIGHT)
                return(COLOR_PICTURE_BACKGROUND);
             else
                return(COLOR_BAD_OOR_UNACK);
          else
             if (FLOW_RIGHT)
                return(COLOR_PICTURE_BACKGROUND);
             else
                return(COLOR_BAD_OOR_ACK);
       }

       // *****************************CORENET 20170608**********************************
    // Alarm Colour
        // if (!(Valve_H->newsta < HACK) || !(Valve_L->newsta < HACK)) 
	// {
         //   else if ( (H_val && !H_bad && !L_val && !L_bad) || (H_val && !H_bad && L_bad) )
         //       return(COLORS[Valve_H->newsta]);
    

//	 }

         else if (!(Valve_L->newsta < ORHACK) || !(Valve_H->newsta < ORHACK ))
	 {
            if ( (H_val && !H_bad && !L_val && !L_bad) || (H_val && !H_bad && L_bad) )
                return(COLOR_PICTURE_BACKGROUND);
            else if ( (!H_val && !H_bad && L_val && !L_bad) || (H_bad && L_val && !L_bad) )
	    {
                if (Valve_H->newsta > Valve_L->newsta)
                   return(COLORS[Valve_H->newsta]);
                else
                   return(COLORS[Valve_L->newsta]);
	    }

	 }

    
    //   if (!(Valve_H->newsta < HACK) || !(Valve_L->newsta < HACK))
    //            return(COLOR_PICTURE_BACKGROUND);
    //   else
    //   {
    //
    // OPEN: if the H valve is open and the L valve is NOT FCLS
    //       if the H valve is open and the L valve is BAD
    //   else if ( (H_val && !H_bad && !L_val && !L_bad) ||
    //             (H_val && !H_bad && L_bad) )
       else if ( (H_val && !L_val ))
    
                return(COLOR_PICTURE_BACKGROUND);
    
    //
    // CLOSED: if the H valve is NOT FOPN and the L valve is CLOSED
    //         if the H valve is BAD abd the L valve is CLOSED
    //    else if ( (!H_val && !H_bad && L_val && !L_bad) ||
    //             (H_bad && L_val && !L_bad) )
       else if ( (!H_val && L_val )) 
    
                return(COLOR_INACTIVE_OFF_CLOSED);
    
    //
    // THROTTLED: if the H valve is NOT FOPN and the L valve is NOT FCLS
   //    else if ((!H_val && !H_bad && !L_val && !L_bad) && (Valve_H->newsta < ORHACK) && (Valve_L->newsta < ORHACK))
       else if ((!H_val &&  !L_val ) && (Valve_H->newsta < ORHACK) && (Valve_L->newsta < ORHACK))    {
    
