    char disfmt_temp[8] = "%6.1f  ";

    int DisplayUnits = 1;

    int ErrorText_foregroundColour = `ErrorText.foregroundColour`;

    int ErrorText_visibility = `ErrorText.visibility`;

    int Inserted_visibility = `Inserted.visibility`;

