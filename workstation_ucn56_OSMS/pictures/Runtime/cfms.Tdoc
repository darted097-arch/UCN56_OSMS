  class ValueColssCPUC
  {
    worldX = 0;
    worldY = 0;
    worldWidth = 500;
    worldHeight = 50;
    oneToOne = 1;
    backgroundColour = 0;
    xSnap = 5;
    ySnap = 5;
    radiusSnap = 0;
    angleSnap = 0;
    xReference = 500;
    yReference = 500;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    shapeFlags = "bboxDialogue";

    int BlinkBoxCondition = 1;

    int DisplayUnits = 1;

    int newsta = 19;

    int pisabitmap = 0;

    RECORD* PointId = `&ERRORPID`;

    float value = 0;

    function `char *DisplayEngineeringUnit()
    {
       if(strcmp(PointId->met_units,"PCT         ") == 0)
           return("% ");
       else if(strcmp(PointId->met_units,"A           ") == 0)
           return("AMP");
       else {
          if(Interface->System.displayedUnits==ENGLISH)
             return(PointId->eng_units);
          if(Interface->System.displayedUnits==METRIC)
             return(PointId->met_units);
       }
       return ("NO   UNIT");
    }`

    function `int VisibilityBlinkBox()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
    //	Determine symbol visibility
    	if (  (BlinkBoxCondition == 1)     &&
                 ((newsta == ORHACK)  ||	          // Out of range high - acknowledged
    	      (newsta == ORLACK)  ||	          // Out of range low - acknowledged
    	      (newsta == BDACK)   ||	          // Bad data - acknowledged
    	      (newsta == ORHNAK)  ||	          // Out of range high - unacknowledged
    	      (newsta == ORLNAK)  ||	          // Out of range low - unacknowledged
    	      (newsta == BDNAK)   ||	          // Bad data - unacknowledged
                  (newsta == HACK)    ||             // High Alarm - ackknowledged
                  (newsta == HNAK)    ||             // High Alarm - unackknowledged
                  (newsta == LACK)    ||             // Low Alarm - ackknowledged
                  (newsta == LNAK)    ||             // Low Alarm - unackknowledged
                  (newsta == HHACK)   ||             // HiHi Alarm - ackknowledged
                  (newsta == HHNAK)   ||             // HiHi Alarm - unackknowledged
                  (newsta == LLACK)   ||             // LoLo Alarm - ackknowledged
                  (newsta == LLNAK)   ||             // LoLo Alarm - unackknowledged
    	     ((pisabitmap & bOOSCAN)) > 0) )     // out of scan
    //
    	   return(VISIBLE);		 // return visible
    //
    	else				 // all others, set invisible
    	   return(INVISIBLE);
    }`

    function `int VisibilityDashes()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
    // Determine symbol visibility
       if (  (newsta == ORHACK) ||	               // Out of range high - acknowledged
    	      (newsta == ORLACK) ||	       // Out of range low - acknowledged
    	      (newsta == BDACK)  ||	       // Bad data - acknowledged
    	      (newsta == ORHNAK) ||	       // Out of range high - unacknowledged
    	      (newsta == ORLNAK) ||	       // Out of range low - unacknowledged
    	      (newsta == BDNAK)  ||	       // Bad data - unacknowledged
    	     ((pisabitmap & bOOSCAN) > 0) )   // out of scan
    //
    	   return(VISIBLE);		               // return invisible
    //
       else if (PointId->sig_type >= MinimumDigitalType)   // A Digital Point
               return(INVISIBLE);
    //
       else				                       // all others, set invisible
    	   return(INVISIBLE);
    }`

    function `int VisibilityNumber()
    {
    //
    //	The representation of a number can take on 5 scenarios: data,
    //	out of scan data, bad data, out of range high data, and out of range low data.
    //
    //	The dashes are present for out of scan data, bad data, out of range high data,
    //	and out of range low data.
    //
    //	Determine symbol visibility
    	if (  (newsta == ORHACK) ||	       // Out of range high - acknowledged
    	      (newsta == ORLACK) ||	       // Out of range low - acknowledged
    	      (newsta == BDACK)  ||	       // Bad data - acknowledged
    	      (newsta == ORHNAK) ||	       // Out of range high - unacknowledged
    	      (newsta == ORLNAK) ||	       // Out of range low - unacknowledged
    	      (newsta == BDNAK)  ||	       // Bad data - unacknowledged
    	     ((pisabitmap & bOOSCAN) > 0) )   // out of scan
    //
    	   return(INVISIBLE);		 // return invisible
    //
            else if (PointId->sig_type >= MinimumDigitalType) // A Digital Point
               return(INVISIBLE);
    //
    	else				 // all others, set invisible
    	   return(VISIBLE);
    }`

