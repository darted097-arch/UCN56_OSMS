// ******************* RCSLEAK(ON-LINE,OFF-LINE) VARIABLES ********************
//
//
struct CCUR_On_Data {
// CALCULATION TIME
   int   NEWTIME;    // 1: 10 MIN, 2: 30 MIN, 3: 1 HOUR, 4: 2 HOURS
// EVENT STATUS - FALSE:0, TRUE: 1 (!=0)
   int   SITEVENT;   // IF SITEVENT != 0 THEN CRT DISPLAY: 'VCT MAKEUP'
   int   VCTEVENT;   // IF VCTEVENT != 0 THEN CRT DISPLAY: 'VCT DIVERT' 
   int   HPSION;     // IF HPSION != 0 THEN CRT DISPLAY: 'HPSIP START'
   int   INPUTSTS;   // IF INPUTSTS = 0 THEN CRT DISPLAY: 'BAD DATA CALC.'
// TOTAL 20 BYTES
};
//
