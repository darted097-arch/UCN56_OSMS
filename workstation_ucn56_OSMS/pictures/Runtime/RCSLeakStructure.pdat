struct WS_PRN_Data {
  int 		PAGENUM;
  char	 	WSNAME[12];
};
//
struct CCUR_ON_Message {
  WSmessageHeader	header;		// message information	    (24-byte)
  CCUR_On_Data          HostOnData;     // online host information  (20-byte)         
};
//
struct CCUR_Off_Message {
  WSmessageHeader	header;		// message information	    (24-byte)
  CCUR_Off_Data         HostOffData;    // offline host information (190-byte)
};
//
struct WS_On_Message {
  WSmessageHeader       header;         // message information      (24-byte)
  WS_On_Data            WSOnData;
};
//

struct WS_Off_Message {
  WSmessageHeader	header;		// message information	    (24-byte)
  WS_Off_Data           WSOffData;      // offline ws information   (148-byte)
};
//
struct WS_Prn_Message {
  WSmessageHeader	header;		// message information	    (24-byte)
  WS_PRN_Data           WSPrnData;      // ws prnit information     (10-byte)
};


//
// CORENET 2017.02.16 for RCS MASS FLOW CALCULATION by Philkyu Kwon.============================
//
struct WS_Mass_Calc_Data {
  int		PAGENUM;		// PAGENUM : 645
  char		WSNAME[12];
};
//
struct CCUR_Mass_Calc_Msg {
  char	message1[40];
  char	message2[40];
  char	message3[40];
};
//
struct CCUR_Mass_Calc_Data {
  // CALCULATION VALUE
  float		minDesignMF;		// MINIMUM DESIGN MASS FLOW
  float		maxDesignMF;		// MAXIMUM DESIGN MASS FLOW
  float		minCorrMF;		// MINIMUM CORR. MASS FLOW
  float		maxCorrMF;		// MAXIMUM CORR. MASS FLOW
  float		rcsVolF;		// MEASURED RCS VOLUMETRIC FLOW
  float		colssVolF;		// COLSS VOLUMETRIC FLOW
  float		colssMassF;		// COLSS MASS FLOW VALUE
  float		cpcCHA;			// CPC CH.A MDBAR VALUE
  float		cpcCHB;			// CPC CH.B MDBAR VALUE
  float		cpcCHC;			// CPC CH.C MDBAR VALUE
  float		cpcCHD;			// CPC CH.D MDBAR VALUE
  // CALCULATION RESULT
  float		techResult;		// TECHNICAL SPEC. ACCEPTANCE RESULT
  float		rcsResult;		// RCS VOLUMETRIC ACCEPTANCE RESULT
  float		cpcCHAResult;		// CPC CH.A MDBAR RESULT
  float		cpcCHBResult;		// CPC CH.B MDBAR RESULT
  float		cpcCHCResult;		// CPC CH.C MDBAR RESULT
  float		cpcCHDResult;		// CPC CH.D MDBAR RESULT
  // MESSAGE
  // CCUR_Mass_Calc_Msg 	hostMassCalcMsg;
};
//
struct WS_Mass_Calc_Message {
  WSmessageHeader	header;		// message information		(24-bit)
  WS_Mass_Calc_Data	wsMassCalcData;	// ws start calc. message	(16-bit)
};
//
struct CCUR_Mass_Calc_Message {
  WSmessageHeader		header;		// message information		(24-bit)
  CCUR_Mass_Calc_Data		hostMassCalcData;	// host calc. information (192-bit)
};

struct CCUR_Mass_Calc_Message1 {
  WSmessageHeader		header;		// message information		(24-bit)
  CCUR_Mass_Calc_Msg		hostMassCalcMsg;	// host calc. information (192-bit)
};

