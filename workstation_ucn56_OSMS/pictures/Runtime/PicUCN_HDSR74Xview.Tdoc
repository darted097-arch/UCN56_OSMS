  function `int DDisplayTrend()
  {
     int i;
  
     if( gView_x.pointType_1 == 1 )
        DisplayAnalogTrend(1);
     else      // DI or DL
        DisplayDigitalTrend(1);
  
     if( gView_x.pointType_2 == 1 )
        DisplayAnalogTrend(2);
     else
        DisplayDigitalTrend(2);
  
     if( gView_x.pointType_3 == 1 )
        DisplayAnalogTrend(3);
     else
        DisplayDigitalTrend(3);
  
     if( gView_x.pointType_4 == 1 ) {
        for(i=0;i<1200;i++){
        }
        DisplayAnalogTrend(4);
        DisplayAnalogTrend(4);
     }
     else
        DisplayDigitalTrend(4);
  }`

  function `void DisappearScale()
  {
     t_time2.visibility = 0;
     t_time3.visibility = 0;
     t_time4.visibility = 0;
  
