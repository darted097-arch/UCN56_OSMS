  function `int DisplayAnalogTrend(int num)
  {
     execute("{ trend_%d.DrawAnalogTrend(); }", num);
     return 1;
  }`

  function `int DisplayDigitalTrend(int num)
  {
     execute("{ strcpy(trend_%d.On, gView_x.onScale_%d); }", num, num);
     execute("{ strcpy(trend_%d.Off, gView_x.offScale_%d); }", num, num);
     execute("{ trend_%d.DigitalValues = gView_x.iValue_%d; }", num, num);
     execute("{ trend_%d.DrawDigitalTrend(); }", num);
     return 1;
  }`

  function `int DisplayTrend( int num )
  {
     execute( "Type = gView_x.pointType_%d", num);
  
     if( Type == 1 )
        execute( "DisplayAnalogTrend(%d)", num);
     else      // DI or DL
        execute( "DisplayDigitalTrend(%d)", num);
  
  }`

  function `int DownSectoring()
  {
     if( Level == 4 )
        return -1;
     else {
        Level++;
        Sector = 1;
     }
  
     if( Level == 4 )
           DisappearScale();
     else
           AppearScale();
  
  // scaling
     if( Sector_1 == 0 )
        Sector_1 = 1;
     else if( Sector_2 == 0 )
        Sector_2 = 1;
     else if( Sector_3 == 0 )
        Sector_3 = 1;
     else
        return -1;
  
  //  Scaling( Sector_1, Sector_2, Sector_3);
     return 1;
  }`

