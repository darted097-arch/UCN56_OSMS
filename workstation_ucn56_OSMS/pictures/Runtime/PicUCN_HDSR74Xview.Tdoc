    // sprintf( PictureTitle,"VIEW HDSR GRAPH %d", num);
    // sprintf( PictureNumber, "6%d", num);
      update();
  }`

  function `void NextSet()
  {
     if( gView_x.actMask == 1 ) {
        DisplayAdvisoryMessage1("PROCESSING...  WAIT");
        return;
     }
  
     if( gView_x.level == 1 || gView_x.useView == 1 ) {
     sendMessageToHost(GRAPH_VIEW_DONE);
  
        if( gView_x.whichView < 8 )
           gView_x.whichView++;
        else
           gView_x.whichView = 1;
  
        sprintf(gPage740.graphSet, "%d", gView_x.whichView);
  
        sendMessageToHost( HDSR_GRAPH_VIEW );
        DisplayPage(176);
     }
     else {
        if( strcmp(gView_x.resolution,"LOW") == 0 ) {
        DisplayAdvisoryMessage1("THIS GRAPH SET IS IN LOW RESOLUTION ");
           return;
        }
  
        if( gView_x.actMask == 1 ) {
           DisplayAdvisoryMessage1("PROCESSING...  WAIT");
           return;
        }
  
           gView_x.actNo = 2;
           gView_x.actMask = 1;
           RightSectoring();
           gView_x.level = Level;
           gView_x.sector = Sector;
  
           sendMessageToHost(GRAPH_VIEW_RIGHT);
        WaitTrend();
     }
  }`

  function `int PressSector()
  {
     if( gView_x.useView == 1 ) {
        DisplayAdvisoryMessage1("CANNOT USE THIS GRAPH SET NOW");
        DisplayAdvisoryMessage2("FOR TAPE ERROR, ESCAPE AND RETRY THIS GRAPH VIEW");
        DisplayAdvisoryMessage3(" AFTER CHECK THE TAPE DRIVER");
        return -1;
     }
  
     if( strcmp(gView_x.resolution,"LOW") == 0 ) {
        DisplayAdvisoryMessage1("THIS GRAPH SET IS IN LOW RESOLUTION ");
        return -1;
     }
  
     if( gView_x.actMask == 1 ) {
        DisplayAdvisoryMessage1("PROCESSING...  WAIT");
        return -1;
     }
  
  //   boxSector.fillPattern = NoPattern;
  //   update();
     return 0;
  }`

  function `void PrevSet()
  {
     if( gView_x.actMask == 1 ) {
        DisplayAdvisoryMessage1("PROCESSING...  WAIT");
        return;
     }
  
     if( gView_x.level == 1 || gView_x.useView == 1 ) {
     sendMessageToHost(GRAPH_VIEW_DONE);
  
        if( gView_x.whichView == 1 )
           gView_x.whichView = 8;
        else
           gView_x.whichView--;
  
        sprintf(gPage740.graphSet, "%d", gView_x.whichView);
  
        sendMessageToHost( HDSR_GRAPH_VIEW );
        DisplayPage(176);
     }
     else {
        if( strcmp(gView_x.resolution,"LOW") == 0 ) {
        DisplayAdvisoryMessage1("THIS GRAPH SET IS IN LOW RESOLUTION ");
           return;
     }
  
        if( gView_x.actMask == 1 ) {
           DisplayAdvisoryMessage1("PROCESSING...  WAIT");
           return;
        }
  
           gView_x.actNo = 1;
           gView_x.actMask = 1;
           LeftSectoring();
           gView_x.level = Level;
           gView_x.sector = Sector;
  
           sendMessageToHost(GRAPH_VIEW_LEFT);
        WaitTrend();
    }
  }`

  function `int ProcessActNo()
  {
     if( gView_x.actNo == 0 )   // no action
        return -1;
     else
       Scaling( Sector_1, Sector_2, Sector_3);
       gView_x.actNo = 0;
       return 0;
  }`

  function `void ProcessExit()
  {
     if( gView_x.useView == 0 )
        sendMessageToHost(GRAPH_VIEW_DONE);
  
  //   execute( "{ displayPicture(\\"Main\\", \\"./PicUCN_HDSR740.ppic\\"); }");
  }`

  function `int RightSectoring()
  {
     if( Sector == 4 )
        Sector = 1;
     else
        Sector++;
  
  //scaling
     if( Sector_1 == 0 )
        return -1;
     else if( Sector_2 == 0 ) {
        if( Sector_1 == 4 )
           Sector_1 = 1;
        else
           Sector_1++;
     }
     else if( Sector_3 == 0) {
        if( Sector_2 == 4 ) {
           if( Sector_1 == 4 )
              Sector_1 = 1;
           else
              Sector_1++;
  
           Sector_2 = 1;
        }
        else
           Sector_2++;
     }
     else {
        if( Sector_3 == 4 ) {
           if( Sector_2 == 4 ) {
              if( Sector_1 == 4 )
                 Sector_1 = 1;
              else
                 Sector_1++;
  
              Sector_2 = 1;
           }
           else
              Sector_2++;
  
           Sector_3 = 1;
        }
        else
           Sector_3++;
     }
  
  //  Scaling( Sector_1, Sector_2, Sector_3);
     return 1;
  }
  `

  function `int Scaling( int sector_1, int sector_2, int sector_3 )
  {
     int i, j, k;
  
        for( i=1; i<=4; i++ )
           for( j=1; j<=4; j++ )
              for( k=1; k<=4; k++ )
                 execute( "{ scale_%d%d%d.foregroundFillColour = 1; }", i, j, k);
  //               executeAsync( "::UCN5and6.HDSR74Xview", "{ scale_%d%d%d.foregroundFillColour = 0; }", i, j, k);
  
     if( sector_1 == 0 ) {
  // display
        for( i=1; i<=4; i++ )
           for( j=1; j<=4; j++ )
              for( k=1; k<=4; k++ )
                 execute( "{ scale_%d%d%d.foregroundFillColour = 9; }", i, j, k);
     }
     else  if( sector_2 == 0 ) {
  // display available region
        for( i=1; i<=4; i++ )
           for( j=1; j<=4; j++ )
              for( k=1; k<=4; k++ )
                 execute( "{ scale_%d%d%d.foregroundFillColour = 3; }", i, j, k);
  //
        for( i=1; i<=4; i++ )
           for( j=1; j<=4; j++ )
              for( k=1; k<=4; k++ )
                 execute("{ scale_%d%d%d.foregroundFillColour = 9; }", sector_1, j, k);
     }
     else  if( sector_3 == 0 ) {
  // display available region
        for( i=1; i<=4; i++ )
           for( j=1; j<=4; j++ )
              for( k=1; k<=4; k++ )
                 execute( "{ scale_%d%d%d.foregroundFillColour = 3; }", sector_1, j, k);
  //
        for( i=1; i<=4; i++ )
           for( j=1; j<=4; j++ )
              for( k=1; k<=4; k++ )
                 execute("{ scale_%d%d%d.foregroundFillColour = 9; }", sector_1, sector_2, k);
     }
     else {
  // display available region
        for( i=1; i<=4; i++ )
           for( j=1; j<=4; j++ )
              for( k=1; k<=4; k++ )
                 execute( "{ scale_%d%d%d.foregroundFillColour = 3; }", sector_1, sector_2, k);
  //
        for( i=1; i<=4; i++ )
           for( j=1; j<=4; j++ )
              for( k=1; k<=4; k++ )
                 execute("{ scale_%d%d%d.foregroundFillColour = 9; }", sector_1, sector_2, sector_3);
     }
  
     update();
  }`

  function `void SectorProcess()
  {
     int no;
  
     if( PressSector() == -1 )
        return;
  
     no = atoi( bSector.TheNewText );
  
     if ( no == 0 ) {
        if( gView_x.actMask == 1 ) {
           DisplayAdvisoryMessage1("PROCESSING...  WAIT");
           return;
        }
  
        if( Level != 1 ) {
           gView_x.actNo = 3;
           gView_x.actMask = 1;
           UpSectoring();
           gView_x.level = Level;
           gView_x.sector = Sector;
  
        update();
  
           sendMessageToHost(GRAPH_VIEW_UP);
        WaitTrend();
           AppearScale();
           return;
        }
        else {
           DisplayAdvisoryMessage1("YOU ARE ON LEVEL 1, CANNOT UP");
           return;
        }
     }
     else if( no < 1 || no > 4 ) {
        DisplayAdvisoryMessage1("WRONG SECTOR NO.");
        return;
     }
  //      boxSector.fillPattern = SolidPattern;
        update();
  
     if( Level == 4 ) {
        DisplayAdvisoryMessage1("YOU ARE ON LEVEL 4, CANNOT SECTOR DOWN");
        return;
     }
       Sector = no;
  
     if( Level == 3 || Level == 4 )
           DisappearScale();
     else
           AppearScale();
  
  //   if( Level != 4 ) {
        gView_x.actNo = 5;
        gView_x.actMask = 1;
        AllDownSectoring( Sector );
        gView_x.level = Level;
        gView_x.sector = Sector;
  
        sendMessageToHost(HDSR_SECTOR);
           DisplayAdvisoryMessage1("PROCESSING...  WAIT");
        WaitTrend();
  //   }
  //   else
  //      DisplayAdvisoryMessage1("YOU ARE ON LEVEL 4, CANNOT SECTOR DOWN");
  }`

  function `void SimulateTrend( int num )
  {
     int i;
  
     for( i=0; i<256; i++ )
        execute("{ gView_x.values_%d[%d] = random(700); }", num, i);
  //      execute("{ gView_x.values_%d[%d] = random(2)-1; }", num, i);
  
  //   execute("{ gView_x.baseline_%d = random(100); }", num);
  }`

  function `int tLeftSectoring()
  {
     if( Level == 1 )
        Sector = 1;
     else {
        if( Sector == 1 )
           Sector = 4;
        else
           Sector--;
     }
  
  // scaling
     if( Sector_1 == 0 )
        return -1;
     else if( Sector_2 == 0 ) {
        if( Sector_1 == 1 )
           Sector_1 = 4;
        else
           Sector_1--;
     }
     else if( Sector_3 == 0) {
        if( Sector_2 == 1 ) {
           Sector_2 = 4;
        }
        else
           Sector_2--;
     }
     else {
        if( Sector_3 == 1 ) {
           Sector_3 = 4;
        }
        else
           Sector_3--;
     }
  
    Scaling( Sector_1, Sector_2, Sector_3);
     return 1;
  }`

  function `int tRightSectoring()
  {
     if( Level == 1 )
        Sector = 1;
     else {
        if( Sector == 4 )
           Sector = 1;
        else
           Sector++;
     }
  
  //scaling
     if( Sector_1 == 0 )
        return -1;
     else if( Sector_2 == 0 ) {
        if( Sector_1 == 4 )
           Sector_1 = 1;
        else
           Sector_1++;
     }
     else if( Sector_3 == 0) {
        if( Sector_2 == 4 ) {
           Sector_2 = 1;
        }
        else
           Sector_2++;
     }
     else {
        if( Sector_3 == 4 ) {
           Sector_3 = 1;
        }
        else
           Sector_3++;
     }
  
    Scaling( Sector_1, Sector_2, Sector_3);
     return 1;
  }
  `

  function `int UpSectoring()
  {
     if( Level == 1 )
        return -1;
     else {
        Level--;
        if( Level == 1 )
           Sector = 1;
        else if( Level == 2 )
           Sector = Sector_1;
        else if( Level == 3 )
           Sector = Sector_2;
     }
  
     if( Level == 4 )
           DisappearScale();
     else
           AppearScale();
  
  // scaling
     if( Sector_1 == 0 )
        return -1;
     else if( Sector_2 == 0 )
        Sector_1 = 0;
     else if( Sector_3 == 0 )
        Sector_2 = 0;
     else
        Sector_3 = 0;
  
  //   Scaling( Sector_1, Sector_2, Sector_3);
     return 1;
  }`

