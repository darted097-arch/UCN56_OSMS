  {
    event = `keyPressed(0xFF54)`;
    action = `{
       if( gView_x.useView == 1 ) {
          DisplayAdvisoryMessage1("CANNOT USE THIS GRAPH SET NOW");
          DisplayAdvisoryMessage2("FOR TAPE ERROR, ESCAPE AND RETRY THIS GRAPH VIEW");
          DisplayAdvisoryMessage3(" AFTER CHECK THE TAPE DRIVER");
          return;
       }
    
       if( strcmp(gView_x.resolution,"LOW") == 0 ) {
          DisplayAdvisoryMessage1("THIS GRAPH SET IS IN LOW RESOLUTION ");
          return;
       }
    
       if( gView_x.actMask == 1 ) {
          DisplayAdvisoryMessage1("PROCESSING...  WAIT");
          return;
       }
    
       if( Level != 4 ) {
          gView_x.actNo = 4;
          gView_x.actMask = 1;
          DownSectoring();
          gView_x.level = Level;
          gView_x.sector = Sector;
    
          sendMessageToHost(GRAPH_VIEW_DOWN);
          DisplayAdvisoryMessage1("PROCESSING...  WAIT");
          WaitTrend();
       }
       else
          DisplayAdvisoryMessage1("YOU ARE ON LEVEL 4, CANNOT DOWN");
    }`;
  }

  dialogue
  {
    event = `keyPressed(0xFF53)`;
    action = `{
       if( gView_x.useView == 1 ) {
          DisplayAdvisoryMessage1("CANNOT USE THIS GRAPH SET NOW");
          DisplayAdvisoryMessage2("FOR TAPE ERROR, ESCAPE AND RETRY THIS GRAPH VIEW");
          DisplayAdvisoryMessage3(" AFTER CHECK THE TAPE DRIVER");
          return;
       }
    
       if( strcmp(gView_x.resolution,"LOW") == 0 ) {
          DisplayAdvisoryMessage1("THIS GRAPH SET IS IN LOW RESOLUTION ");
          return;
       }
    
       if( gView_x.actMask == 1 ) {
          DisplayAdvisoryMessage1("PROCESSING...  WAIT");
          return;
       }
    
       if( Level != 1 ) {
          gView_x.actNo = 2;
          gView_x.actMask = 1;
          RightSectoring();
          gView_x.level = Level;
          gView_x.sector = Sector;
    
          sendMessageToHost(GRAPH_VIEW_RIGHT);
          DisplayAdvisoryMessage1("PROCESSING...  WAIT");
          WaitTrend();
       }
       else
          DisplayAdvisoryMessage1("YOU ARE ON LEVEL 1, CANNOT SHIFT YO RIGHT");
    }`;
  }

  dialogue
  {
    event = `keyPressed(0xFF51)`;
    action = `{
       if( gView_x.useView == 1 ) {
          DisplayAdvisoryMessage1("CANNOT USE THIS GRAPH SET NOW");
          DisplayAdvisoryMessage2("FOR TAPE ERROR, ESCAPE AND RETRY THIS GRAPH VIEW");
          DisplayAdvisoryMessage3(" AFTER CHECK THE TAPE DRIVER");
          return;
       }
    
       if( strcmp(gView_x.resolution,"LOW") == 0 ) {
          DisplayAdvisoryMessage1("THIS GRAPH SET IS IN LOW RESOLUTION ");
          return;
       }
    
       if( strcmp(gView_x.resolution,"LOW") == 0 )
          return;
    
       if( gView_x.actMask == 1 ) {
          DisplayAdvisoryMessage1("PROCESSING...  WAIT");
          return;
       }
    
       if( Level != 1 ) {
          gView_x.actNo = 1;
          gView_x.actMask = 1;
          LeftSectoring();
          gView_x.level = Level;
          gView_x.sector = Sector;
    
          sendMessageToHost(GRAPH_VIEW_LEFT);
          DisplayAdvisoryMessage1("PROCESSING...  WAIT");
          WaitTrend();
       }
       else
          DisplayAdvisoryMessage1("YOU ARE ON LEVEL 1, CANNOT SHIFT TO LEFT");
    }`;
  }

