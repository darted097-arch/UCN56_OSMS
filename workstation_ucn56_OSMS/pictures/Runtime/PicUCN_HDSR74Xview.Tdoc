  function `int LeftSectoring()
  {
     if( Level == 1 )
        Sector = 1;
     else {
        if( Sector == 1 )
           Sector = 4;
        else
           Sector--;
     }
  
  // scaling
     if( Sector_1 == 0 || Level == 1)
        return -1;
     else if( Sector_2 == 0 ) {
        if( Sector_1 == 1 )
           Sector_1 = 4;
        else
           Sector_1--;
     }
     else if( Sector_3 == 0) {
        if( Sector_2 == 1 ) {
           if( Sector_1 == 1 )
              Sector_1 = 4;
           else
              Sector_1--;
  
           Sector_2 = 4;
        }
        else
           Sector_2--;
     }
     else {
        if( Sector_3 == 1 ) {
           if( Sector_2 == 1 ) {
              if( Sector_1 == 1 )
                 Sector_1 = 4;
              else
                 Sector_1--;
  
              Sector_2 = 4;
           }
           else
              Sector_2--;
  
           Sector_3 = 4;
        }
        else
           Sector_3--;
     }
  
  //  Scaling( Sector_1, Sector_2, Sector_3);
     return 1;
  }`

