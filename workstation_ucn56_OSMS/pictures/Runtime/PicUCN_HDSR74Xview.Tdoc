  function `int ActDisplay( int actNo )
  {
     switch( actNo ) {
        case 0:     // initialization
              Level = 1;
              Sector = 1;
              Sector_1 = 0;
              Sector_2 = 0;
              Sector_3 = 0;
              Scaling( Sector_1, Sector_2, Sector_3 );
              break;
        case 1:      // left
              tLeftSectoring();
              break;
        case 2:      // right
              tRightSectoring();
              break;
        case 3:      // up
              UpSectoring();
              break;
        case 4:      // down
              DownSectoring();
              break;
        default:
              DisplayAdvisoryMessage1("ERROR: Display Graphic Trends");
     }
  }`

  function `int AllDownSectoring(int sector)
  {
     if( Level == 4 )
        return -1;
     else {
        Level++;
        Sector = sector;
     }
  
  // scaling
     if( Sector_1 == 0 )
        Sector_1 = sector;
     else if( Sector_2 == 0 )
        Sector_2 = sector;
     else if( Sector_3 == 0 )
        Sector_3 = sector;
     else
        return -1;
  
  //  Scaling( Sector_1, Sector_2, Sector_3);
     return 1;
  }`

