  function `void ConvertToInt() //JHC 990419
  {
     if (strcmp(Correct.TheNewText, "Y") == 0)
     {
        yText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
        nText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     }
     else //if (strcmp(Correct.TheNewText, "N") == 0)
     {
        nText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
        yText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     }
  }`

  function `void DisplayUTDVData()
  {
  
     efph21.TheNewNumber = Interface->UtdvData.lastMidnight.efphFile;
     efph22.TheNewNumber = Interface->UtdvData.lastMidnight.efphRpcb;
     nlmBurnUp2.TheNewNumber = Interface->UtdvData.lastMidnight.rpcbBurnup;
  
     efph31.TheNewNumber = Interface->UtdvData.latestHourly.efphFile;
     efph32.TheNewNumber = Interface->UtdvData.latestHourly.efphRpcb;
     nlmBurnUp3.TheNewNumber = Interface->UtdvData.latestHourly.rpcbBurnup;
  
  // Note !!!!!!!!!!!!!
  // these two structure fields are used temporarily for UTENPRES and UTRPCBP values
     efph41.TheNewNumber = Interface->UtdvData.present.oldPresentEfph;
     nlmBurnUp4.TheNewNumber = Interface->UtdvData.present.pendingPresentEfph;
  // Note !!!!!!!!!!!!!
  
  //   TextProcessing.visibility = 0;
  
  }`

  function `void escape()
  {
  DisplayPage(Page681);
  }`

  function `int get_Vis_Hour()
  {
    if ( (UTDV681_option == 1) || (UTDV681_option == 3))
       return(1);
    else
       return(0);
  }`

  function `int get_Vis_Mid()
  {
    if ( (UTDV681_option == 1) || (UTDV681_option == 2))
       return(1);
    else
       return(0);
  }`

  function `void GettingData()
  {
     if (0 == UTDVDataWaitingTime)
     {
        TextProcessing.visibility = 0;
        WaitingUTDVData687 = 0;
        DisplayUTDVData();
     }
     else
     {
        UTDVDataWaitingTime = UTDVDataWaitingTime - 1;
     }
  }`

  function `void Initialize()
  {
     Current_Page = 687;
     CFMLevel =0;
     Current_page = 687;
  
     strcpy(Correct.TheNewText,"Y");
     strcpy(Correct.TheOriginalText, Correct.TheNewText);
     Correct.Flag = 2;
     yText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     nText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
  
     Interface->UtdvDialogue.option = 9;
     Interface->UtdvDialogue.current_page = Current_page;
  
     execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
  
     TextProcessing.visibility = 1;
     UTDVDataWaitingTime = 5;
     WaitingUTDVData687 = 1;
     processfiles.UnSelect(); //jsk
  }`

  function `void Process1()
  {
     if (strcmp(Correct.TheNewText, "Y") == 0)
     {
     Interface->UtdvDialogue.option = 1;
     }
     else if (strcmp(Correct.TheNewText, "N") == 0)
     {
     Interface->UtdvDialogue.option = 2;
     }
  
  //
     execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
  // printf("687():messages sending is done..");
  }`

