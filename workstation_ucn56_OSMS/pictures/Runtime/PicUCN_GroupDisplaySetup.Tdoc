        pid7.ERROR || pid8.ERROR || pid9.ERROR || pid10.ERROR || pid11.ERROR || pid12.ERROR ||
        pid13.ERROR || pid14.ERROR || pid15.ERROR || pid16.ERROR || pid17.ERROR || pid18.ERROR ||
        pid19.ERROR || pid20.ERROR || pid21.ERROR || pid22.ERROR || pid23.ERROR || pid24.ERROR ;
  
     pError |= PrintRate_btn.ERROR ;
     pError |= PrintDuration_btn.ERROR ;
  
     if(pError)
        PERROR.visibility = 1;
     else
     {
        procMsg.visibility = 1 ;
        PERROR.visibility = 0;
  
        k = Interface->GroupDisplay.data.group.groupNumber;
        Interface->GroupMember.data.groupNumber = k;
  
  //      initialize first, copy later
        strcpy(Interface->GroupMember.data.Title,"                     ");
        strcpy(Interface->GroupMember.data.Title,GR_NAME.TheOriginalText);
  
  //      Interface->GroupMember.data.displayRate = DisplayRate;	//CORENET 0704
  //      Interface->GroupMember.data.displayRate = 1;
  
  //    Interface->GroupMember.data.printRate    = PR_RATE.TheNewNumber;
        Interface->GroupMember.data.printRate    = PrintRate;
        Interface->GroupMember.data.displayRate = PrintRate;	//CORENET 0704
  
        Interface->GroupMember.data.timesToPrint = PrintNo;
        printf("PROCESS BTN Clicked After PrintNo = %d", Interface->GroupMember.data.timesToPrint);	//CORENET 2017
  
  //      GroupDisplay_CurrentTime = atoi(DIS_RATE.TheNewText);
  //    GroupDisplay_CurrentTime = DisplayRate;
  
  //    GR_DisplayRate = DisplayRate;
  //      GR_DisplayRate = atoi(DIS_RATE.TheNewText);
  
  //      printf("group no. : %d\\n",Interface->GroupMember.data.groupNumber);
  //      printf("display rate : %d\\n",Interface->GroupMember.data.displayRate);
  //      printf("print rate : %d\\n",Interface->GroupMember.data.printRate);
  //      printf("times to print : %d\\n",Interface->GroupMember.data.timesToPrint);
  
                     //initialize first, copy later
        for(i=1;i<=24;i++)
        {
           execute("{strcpy(Interface->GroupMember.data.Point%d,\\"          *\\");}",i);
           execute("{strcpy(Interface->GroupMember.data.Point%d,pid%d.TheOriginalText);}",i,i);
