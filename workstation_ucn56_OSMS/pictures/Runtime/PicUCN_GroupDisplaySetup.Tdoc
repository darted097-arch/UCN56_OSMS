picture PicUCN_GroupDisplaySetup
{
  worldX = 0;
  worldY = 0;
  worldWidth = 1280;
  worldHeight = 824;
  oneToOne = 1;
  backgroundColour = 0;
  updateMode = 2;
  resizeMode = 0;
  xSnap = 5;
  ySnap = 5;
  radiusSnap = 0;
  angleSnap = 0;
  crosshairStyle = 1;
  crosshairLength = 0;
  crosshairFollowSnap = `isInEditMode()`;
  crosshairVisibility = `isInEditMode()`;
  xReference = 500;
  yReference = 500;
  xScaleFactor = 1;
  yScaleFactor = 1;
  rotationAngle = 0;

  int GROUPNUMBER = 1;

  int Option = 2;

  char PictureNumber[50] = "831";

  char PictureTitle[50] = "                       ";	//CORENET 201705 by Philkyu Kwon

  int PrintDuration = 1;

  int PrintNo = 60;

  int PrintRate = 1;

  int Priority = 1;

  char TempTitle[50] = "";

