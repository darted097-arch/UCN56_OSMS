  function `void ResetPrintDuration()
  {
     PrintDuration = PrintDuration_btn.TheNewNumber;
  
     //if ((PrintDuration<1) || (PrintDuration>14400))	//CORENET 201705 by Philkyu Kwon
     if ((PrintDuration<1) || (PrintDuration>1440))
     {
        PrintDuration_btn.ERROR = 1;
     }
     else
     {
        PrintDuration_btn.ERROR = 0;
        if (PrintRate == 0)
           PrintNo = 0;
        else
           PrintNo = PrintDuration * 60 / PrintRate;
     }
  
     update();
  }`

  function `void ResetPrintRate()
  {
     PrintRate = PrintRate_btn.TheNewNumber;
  
     if ((PrintRate<0) || (PrintRate>600))
     {
        PrintRate_btn.ERROR = 1;
     }
     else
     {
        PrintRate_btn.ERROR = 0;
  
        if (PrintRate == 0)
           PrintNo = 0;
        else
           PrintNo = PrintDuration * 60 / PrintRate;
     }
  
     update();
  }`

