  function `void FlagReset(int Sel)
  {
  //   Set Flag for Using...
  //   int k ;
  
  //   k = Interface->GroupDisplay.data.group.groupNumber;
  
     Interface->FlagHandleMessage.data.requestOption = Sel ;
     Interface->FlagHandleMessage.data.flipflop1 = 0;   //for flag set
     execute("{sendMessageToHost(GROUP_RESET_REQUEST);}");
  
     printf("========================\\nGRDISP %d Flag = OFF\\n========================",Sel) ;
  }`

  function `void Initialize()
  {
     int i,k;
  
     CFMLevel = 0;
     Current_Page = 831;
  
     DisplayAdvisoryMessage(" ");
     DisplayAdvisoryMessage1(" ");
     DisplayAdvisoryMessage2(" ");
     DisplayAdvisoryMessage3(" ");
  
     Priority = !Interface->FlagHandleMessage.data.flipflop2 ;
  
     k = Interface->GroupDisplay.data.group.groupNumber;
  
  // ************* CORENET 201705 by Philkyu Kwon *******************************
     sprintf(TempTitle,"SETUP GROUP DISPLAY %d",k);
     strcpy(::UCN5and6.PicUCN_header.PictureTitle.theText, TempTitle);
  
     //execute("{strcpy(PictureTitle,\\"SETUP GROUP DISPLAY %d\\");}",k);
  // ******************************************************************************
  
  // printf("Group Number = %d", k);
  
  // Error messages are initialized.
  //   execute("{war1.visibility = 0;}");
     PERROR.visibility  = 0 ;
     procMsg.visibility = 0 ;
  
     for (i=1;i<=24;i++)
     {
       execute("{pid%d.ERROR = 0;}",i);
  //   execute("{errpid%d.visibility = 0;}",i);
     }
  
  // Initialize Title, PIDs, ...
   strcpy(GR_NAME.TheNewText,Interface->GroupDisplay.data.group.Title);
   strcpy(GR_NAME.TheOriginalText,Interface->GroupDisplay.data.group.Title);
  
  //>>>>>>>>>>>>>>>>>>>>. CORENET
  printf("--[%s]--", GR_NAME.TheNewText);
  printf("--[%s]--", GR_NAME.TheOriginalText);
  GR_NAME.SelectButton();
  GR_NAME.UnSelectButton();
  //<<<<<<<<<<<<<<<<<<<<<<<<<<<<
  
   for (i=1;i<=24;i++)
   {
     execute("{strcpy(pid%d.TheNewText,Interface->GroupDisplay.data.group.Point%d);}",i,i);
     execute("{strcpy(pid%d.TheOriginalText,Interface->GroupDisplay.data.group.Point%d);}",i,i);
   }
  
   PrintNo   = Interface->GroupDisplay.data.group.timesToPrint;
  
   PrintRate = Interface->GroupDisplay.data.group.printRate;
   PrintRate_btn.TheNewNumber = PrintRate;
   PrintRate_btn.TheOriginalNumber = PrintRate;
   //execute("{strcpy(PrintRate.TheNewText, PrintRate);}");
   //execute("{strcpy(PrintRate.TheOriginalText, PrintRate);}");
  
   //PrintDuration = PrintNo * PrintRate / 60;
   PrintDuration = 1;				//CORENET 20170620 by Philkyu Kwon
   PrintDuration_btn.TheNewNumber = PrintDuration;
   PrintDuration_btn.TheOriginalNumber = PrintDuration;
  
   //execute("{strcpy(PrintDuration.TheNewText, PrintDuration);}");
   //execute("{strcpy(PrintDuration.TheOriginalText, PrintDuration);}");
  
   update();
  }`

