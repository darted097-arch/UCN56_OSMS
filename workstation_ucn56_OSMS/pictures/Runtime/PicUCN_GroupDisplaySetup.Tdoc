  function `void Process1()
  {
    int i,k,m ;
    int pError ;
  //CORENET 20170421 by Philkyu Kwon
    if(PrintDuration == 0){
    	PrintDuration_btn.ERROR = 1;
   	PrintDuration_btn.TheNewNumber = PrintDuration;
   	PrintDuration_btn.TheOriginalNumber = PrintDuration;
      	strcpy(PrintDuration_btn.TheOriginalText , "0");
      	strcpy(PrintDuration_btn.TheNewText , "0");
  }
  
             // the display should already be loaded in the Initialize()
             // load ("PicUCN_GroupDisplayView.ppic");
             // Set the graph number and go
             // execute("{::UCN5and6.PicUCN_GroupDisplaySetup.GroupNumber = %d;}",Option);
             // displayPicture("Main","PicUCN_GroupDisplaySetup.ppic");
  
