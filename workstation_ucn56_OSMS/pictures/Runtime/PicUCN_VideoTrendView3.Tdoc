  function `int IsDigital(RECORD *pRECORD)
{
  int retval, sigtype;

// get a pointer to the record for the PID
//  execute("{pRECORD = &%s;}",PID);


  sigtype = pRECORD->sig_type;
  switch(sigtype)
  {
    case CI:
    case DI:
    case SOE:
    case BCI:
    case DL:
    case QD:
    case XD:
    case CO:
    case BCO:
      retval = 1;
      break;
    default:
      retval = 0;
      break;
  }//endswitch
  return(retval);
}`



