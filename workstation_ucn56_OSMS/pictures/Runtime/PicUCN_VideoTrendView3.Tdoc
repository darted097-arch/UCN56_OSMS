          Trend1.LowLimit =  Interface->VideoTrendData.Set3Point1.Minimum;
          Trend1.HighLimit = Interface->VideoTrendData.Set3Point1.Maximum;
       }
       else                               // For Analog PID
       {
          if ( (Interface->System.displayedUnits) && (!(StaPID1->pipbitmap & bMETUNIT)) )       
          {
             Trend1.Baseline =  Interface->VideoTrendData.Set3Point1.Baseline * StaPID1->mfactor + StaPID1->moffset;
             Trend1.BASE =      Interface->VideoTrendData.Set3Point1.Baseline * StaPID1->mfactor + StaPID1->moffset;
             Trend1.LowLimit =  Interface->VideoTrendData.Set3Point1.Minimum  * StaPID1->mfactor + StaPID1->moffset;
             Trend1.HighLimit = Interface->VideoTrendData.Set3Point1.Maximum  * StaPID1->mfactor + StaPID1->moffset;
          }
          else if ( (!Interface->System.displayedUnits) && (StaPID1->pipbitmap & bMETUNIT) )
          {
             Trend1.Baseline =  (Interface->VideoTrendData.Set3Point1.Baseline - StaPID1->moffset) / StaPID1->mfactor;
             Trend1.BASE =      (Interface->VideoTrendData.Set3Point1.Baseline - StaPID1->moffset) / StaPID1->mfactor;
             Trend1.LowLimit =  (Interface->VideoTrendData.Set3Point1.Minimum  - StaPID1->moffset) / StaPID1->mfactor;
             Trend1.HighLimit = (Interface->VideoTrendData.Set3Point1.Maximum  - StaPID1->moffset) / StaPID1->mfactor;
