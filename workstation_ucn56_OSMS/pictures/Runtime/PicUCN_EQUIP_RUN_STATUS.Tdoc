  function `int KludgeConfirm()
  {
  
    	//printf("sent: %d, received: %d", Interface->System.sentData, Interface->System.receivedData);
  
   	if(Interface->System.sentData && Interface->System.receivedData)
    	{
     		execute("{sendMessageToHost(REQUEST_EQUIPSTATUS);}");
  
    		//Interface->System.sentData = 0;
    		Interface->System.receivedData = 0;
    	}
  
  
  	//printf("KludgeConfirm() Call");
     	//execute("{sendMessageToHost(REQUEST_EQUIPSTATUS);}");
  
    	return (1);
  }`

  function `void ProcessingConfirmed()
  {
  	procMsg.visibility = 0;
  
  	DisplayAdvisoryMessage("              ");
  	DisplayAdvisoryMessage1("              ");
  	DisplayAdvisoryMessage2("              ");
  
  	DisplayAdvisoryMessage(pHostEquipStatusDataBuf->hostEquipMsg->message1);
  	DisplayAdvisoryMessage1(pHostEquipStatusDataBuf->hostEquipMsg->message2);
  	DisplayAdvisoryMessage2(pHostEquipStatusDataBuf->hostEquipMsg->message3);
  
  	UpdateLocalsFromInterface();
  }`

