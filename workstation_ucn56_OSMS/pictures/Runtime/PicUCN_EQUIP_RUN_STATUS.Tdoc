picture PicUCN_EQUIP_RUN_STATUS
{
  worldX = 0;
  worldY = 0;
  worldWidth = 1280;
  worldHeight = 824;
  oneToOne = 1;
  backgroundColour = 0;
  updateMode = 2;
  resizeMode = 0;
  xSnap = 5;
  ySnap = 5;
  radiusSnap = 0;
  angleSnap = 0;
  crosshairStyle = 1;
  crosshairLength = 0;
  crosshairFollowSnap = `isInEditMode()`;
  crosshairVisibility = `isInEditMode()`;
  xReference = 500;
  yReference = 500;
  xScaleFactor = 1;
  yScaleFactor = 1;
  rotationAngle = 0;

  CCUR_EquipStatus_Data_BUF* pHostEquipStatusDataBuf = `&Interface->hostEquipStatusDataBuf`;

  char PictureNumber[50] = "637";

  char PictureTitle[50] = "EQUIPMENT   RUNNING   STATUS";

  char TheDisplayPage[50] = "PicUCN_EQUIP_RUNTIME_MENU.ppic";

  int TheFontColor = 4;

  int TheTextFont = `font4`;

  function `void escape()
  {
     execute("{DisplayPage(\\"%s\\");}",TheDisplayPage);
     update();
  }`

  function `void Initialize()
  {
     CFMLevel = 0;
     Current_Page = 637;
  
     procMsg.visibility = 1;
     InitilizeText();
  
     execute("{sendMessageToHost(REQUEST_EQUIPSTATUS);}");
  
     DisplayAdvisoryMessage("DATA REQUESTED");
  
     //UpdateLocalsFromInterface();
  
     update();
  
  }`

