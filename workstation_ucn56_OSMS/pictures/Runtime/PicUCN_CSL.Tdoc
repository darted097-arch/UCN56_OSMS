picture PicUCN_CSL
{

  char PictureNumber[50] = "180";
  char PictureTitle[50] = "COMPUTER STATUS";

  function `void Initialize()
   {
   CFMLevel = 0;
   Current_Page = 180;
//
   execute("{sendMessageToHost(REQUEST_CSL_DISPLAY);}");      
   displayCSL();
   }`



  function `void displayCSL()
{
      int lst;
      for(lst=1;lst<=33;lst++) {
      execute("{DATIM%d.theText=\\\`Interface->CSL_Template.Csl_datim.Datim%d\\\`;}",lst,lst);
      execute("{TSKID%d.theText=\\\`Interface->CSL_Template.Csl_tskid.Tskid%d\\\`;}",lst,lst);
      execute("{CSLMSG%d.theText=\\\`Interface->CSL_Template.Csl_msg.CslMsg%d\\\`;}",lst,lst);
   }
      update();
}
`



  function `void ExitCSL()
   {
//
   execute("{sendMessageToHost(EXIT_CSL_DISPLAY);}");      
   }`



