    char On[10] = "CLOSE";

    char* PointID = "RCXX1234";

    float Tval[20] = {10, 23, 34, 45, 56, 67, 78
, 89, 20, 90, 10, 23, 34, 45, 56
, 67, 78, 89, 20, 90};

    function `int CreateInitialTrend()
{
   float minX, maxX, minY, maxY;
   float x,y;
   int i;

   maxX = r_trend.x + r_trend.width;
   minX = r_trend.x;

   maxY = r_trend.y + r_trend.height;
   minY = r_trend.y;

   x = 180;
   y = 80;
   for( i=0; i<254; i++ ) {
      l_trend.addPoint( 186+3*i, y);
   }
   update();
}`

    function `int DrawAnalogTrend()
{
   float baseX, baseY, bline, x, y;
   float factor, aValue;
   int  i;

// disappear digital text
   t_on.visibility = 0;
   t_off.visibility = 0;

// appear analog text
   l_trend.visibility =1;
   l_trend.foregroundColour = COLOR_FEEDBACK_MESSAGES;
   t_max.visibility = 1;
   t_maxText.visibility = 1;
   t_min.visibility = 1;
   t_minText.visibility = 1;
   t_baseline.visibility = 1;
   t_baseText.visibility = 1;

   factor = 100 / (*Maximum-*Minimum);
   baseX = r_trend.x;
   baseY = r_trend.y + r_trend.height;

   for( i=0; i<256; i++ ) {
        aValue = (*(AnalogValues+i) - *Minimum) * factor;
        if( *(AnalogValues+i) == -9991 ) {
             aValue = 0;
        }
        else if( aValue > 100 )
              aValue = 100;
        else if( aValue < 0 )
           aValue = 0;

        l_trend.setY( i, baseY - aValue);
   }

   bline = factor * (*Baseline - *Minimum);
   l_baseline.setY( 0, baseY - bline);
   l_baseline.setY( 1, baseY - bline);

   update();
   return 0;
}`

    function `int DrawDigitalTrend()
{
   float baseX, baseY;
   int i;

// appear digital text
   t_on.visibility = 1;
   t_off.visibility = 1;
   l_trend.visibility = 1;
   l_trend.foregroundColour = COLOR_FEEDBACK_MESSAGES;

// disappear analog text
   t_max.visibility = 0;
   t_maxText.visibility = 0;
   t_min.visibility = 0;
   t_minText.visibility = 0;
   t_baseline.visibility = 0;
   t_baseText.visibility = 0;

   baseX = r_trend.x;
   baseY = r_trend.y + r_trend.height;

   for( i=0; i<256; i++ ) {
        if( *(DigitalValues + i) == -1 )
           l_trend.setY( i, baseY);
        else if( *(DigitalValues + i) == 1 )
           l_trend.setY( i, baseY - 70);
        else
           l_trend.setY( i, baseY - 30);
   }

   l_baseline.setY( 0, baseY - 50);
   l_baseline.setY( 1, baseY - 50);

   update();
   return 0;
}`

    function `void Reset()
{
   t_max.visibility = 0;
   t_maxText.visibility = 0;
   t_min.visibility = 0;
   t_minText.visibility = 0;
   t_baseline.visibility = 0;
   t_baseText.visibility = 0;
   t_on.visibility = 0;
   t_off.visibility = 0;
   l_trend.visibility =0;
}`

    function `void ResetTrend()
{
   l_trend.foregroundColour = 2;
   update();
}`

