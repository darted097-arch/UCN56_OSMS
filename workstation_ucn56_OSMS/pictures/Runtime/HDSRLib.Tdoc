      yScaleFactor = 1;
      rotationAngle = 0;
      classElementFlag = "BackgroundColour, BottomShadow, ERROR, ExecuteSelect, ExecuteUnSelect, Height, MaxCharacters, ReturnAction, Scope, SelectColour, Selected, TextColour, TextFont, TextX, TextY, TheNewText, TheOriginalText, TopShadow, Width, isDown, isInside, vis";
    }  // end of instance b_sector



