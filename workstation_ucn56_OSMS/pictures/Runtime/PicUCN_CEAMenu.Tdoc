  function `void Interval_to_get_CEAAlarmData()
  {
     waitingtime = waitingtime - 1 ;
     if (0 == waitingtime)
     {
        CEAAdvisory.visibility = 0;
        CEAAlarmDisplayFlag = 0;
        execute("{DisplayPage(\\"%s\\");}","PicUCN_CEAAlmLimitDisp.ppic");
     }
  }`

  function `void Option_1()
  {
  //
     MenuInput2.visibility = 0;
     Option2.visibility = 0;
  
     MenuInput3.visibility = 0;
     Option3.visibility = 0;
     Option3_1.visibility = 0;
     Option3_2.visibility = 0;
     Option3_3.visibility = 0;
     processCEA.visibility = 0;
  //
     Option = 1;
     strcpy(Choice,"1\\0");
  //   CEAAlarmDisplay();
     Interface->GenericRequestMessage.data.requestOption = 0;
     execute("{sendMessageToHost(CEA_ALM_LIMIT_REQUEST);}");
     DisplayPage("PicUCN_CEAAlmLimitDisp.ppic");
     update();
  }`

