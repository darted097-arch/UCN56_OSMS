  function `void VInputDo_2()
  {
  // CORENET 20170330 by Philkyu Kwon
     if(MenuInput2.TheNewNumber < 1 || MenuInput2.TheNewNumber > 73)
     {
	DisplayAdvisoryMessage("CEA NO. INPUT MUST BE 1 TO 73");
     }
     else
     {
    	Interface->GenericRequestMessage.data.requestOption = MenuInput2.TheNewNumber;
  // 	Send data request message to the host
     	execute("{sendMessageToHost(ONE_CEA_POSITION_REPT);}");
     	update();
  
     	Option3.visibility = 0;
     	MenuInput3.visibility = 0;
     	Option3_1.visibility = 0;
     	Option3_2.visibility = 0;
     	Option3_3.visibility = 0;
     	processCEA.visibility = 0;
  	// Op3_Box.visibility = 0;
  
     	Option2.visibility = 0;
     	MenuInput2.visibility = 0;
  //   Op2_Box.visibility = 0;
     } 
  
  }`

  function `void VInputDo_3()
  {
     int i;
     if ( strcmp(MenuInput3.TheNewText, PText) == 0) i=0;
     else if ( strcmp(MenuInput3.TheNewText, AText) == 0) i=6;
     else if ( strcmp(MenuInput3.TheNewText, BText) == 0) i=7;
     else
        i = atoi(MenuInput3.TheNewText);
  //
        printf("**option i = %d**********", i);
  //
  //
     Interface->GenericRequestMessage.data.requestOption = i;
  // Send data request message to the host
     execute("{sendMessageToHost(ONE_CEA_GROUP_POSITION_REPT);}");
  
     Option2.visibility = 0;
     MenuInput2.visibility = 0;
  //   Op2_Box.visibility = 0;
     processCEA.visibility = 0;
  
     Option3.visibility = 0;
     MenuInput3.visibility = 0;
     Option3_1.visibility = 0;
     Option3_2.visibility = 0;
     Option3_3.visibility = 0;
  //   Op3_Box.visibility = 0;
  
     update();
  
  }`

