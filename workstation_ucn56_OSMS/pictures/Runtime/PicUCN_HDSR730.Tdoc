  function `void UpdateDataRange()
  {
  //
  // update validate start/end date if disk high/low resoultion
  //
           if( strcmp( gPage730.dataSource, "D") == 0 && strcmp( gPage730.resolution, "H") == 0 ) {
              strcpy( gPage730.validStartDate, gPage730.highDiskDate_1);
              strcpy( gPage730.validEndDate, gPage730.highDiskDate_2);
              strcpy( gPage730.validStartTime, gPage730.highDiskTime_1);
              strcpy( gPage730.validEndTime, gPage730.highDiskTime_2);
           }
           else if( strcmp( gPage730.dataSource, "D") == 0 && strcmp( gPage730.resolution, "L") == 0 ) {
              strcpy( gPage730.validStartDate, gPage730.lowDiskDate_1);
              strcpy( gPage730.validEndDate, gPage730.lowDiskDate_2);
              strcpy( gPage730.validStartTime, gPage730.lowDiskTime_1);
              strcpy( gPage730.validEndTime, gPage730.lowDiskTime_2);
           }
            else if( strcmp( gPage730.dataSource, "T") == 0  ) {
  // Update tape saving time
              if( (strcmp(gPage730.resolution, "H") == 0 && gPage750.iResolution == 1 ) ||
                  (strcmp(gPage730.resolution, "L") == 0 && gPage750.iResolution == 2 ) ||
                  strcmp(gPage730.resolution, "R") == 0 ) {
                  strcpy( gPage730.validStartDate, gPage750.startDate);
                 strcpy( gPage730.validEndDate, gPage750.endDate);
                 strcpy( gPage730.validStartTime, gPage750.startTime);
                 strcpy( gPage730.validEndTime, gPage750.endTime);
              }
              else {
                 strcpy( gPage730.validStartDate, "--/--/--");
                 strcpy( gPage730.validEndDate, "--/--/--");
                 strcpy( gPage730.validStartTime, "--:--:--");
                 strcpy( gPage730.validEndTime, "--:--:--");
              }
           }
          update();
  }`

  function `int ValidateDateTime()
  {
     int i = 0;
  
        if( gPage730.startTime[2] == ':' && gPage730.startTime[5] == ':' && strcmp(gPage730.startTime,"") != 0 )
           i = 1;
        else {
           DisplayAdvisoryMessage1("INVALID FORMAT FOR START TIME");
           i = -1;
        }
  
        if( gPage730.endTime[2] == ':' && gPage730.endTime[5] == ':' && strcmp(gPage730.endTime,"") != 0 )
           i = 1;
        else {
           DisplayAdvisoryMessage1("INVALID FORMAT FOR END TIME");
           i = -1;
        }
  
        if( gPage730.startDate[2] == '/' && gPage730.startDate[5] == '/' && strcmp(gPage730.startDate,"") != 0 )
           i = 1;
        else {
           DisplayAdvisoryMessage1("INVALID FORMAT FOR START DATE");
           i = -1;
        }
  
        if( gPage730.endDate[2] == '/' && gPage730.endDate[5] == '/' && strcmp(gPage730.endDate,"") != 0 )
           i = 1;
        else {
           DisplayAdvisoryMessage1("INVALID FORMAT FOR END DATE");
           i = -1;
        }
  
        if( i == -1 )
           return -1;
        else
           return 1;
  }`

