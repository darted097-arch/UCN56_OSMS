  function `int Process1()
  {
     // ************* CORENET 201705 by Philkyu Kwon ****************
   //  if( ValidateDateTime() == -1 ) {
   //  TheTimer.atTimeDo( 50,0,0,1,0, "::UCN5and6.PicUCN_HDSR730", "{ bProcess.UnSelect(); }");
   //     return -1;
   //  }
  
     int x = -1;
  
     x = ValidateDateTime();
     if( x == -1 ) {
     TheTimer.atTimeDo( 50,0,0,1,0, "::UCN5and6.PicUCN_HDSR730", "{ bProcess.UnSelect(); }");
        return -1;
     }
  
  // ******************************************************************
  
     if( Checkup(1) == 0 ) {
        if( strcmp( gPage730.dataSource, "C") == 0 )
           sendMessageToHost(HDSR_CANCEL_LOG);
        else if( strcmp( gPage730.dataSource, "T") == 0 &&
                 strcmp( gPage730.resolution, "R") == 0 )
           sendMessageToHost(HDSR_TAPE_HEADER);
        else
           sendMessageToHost(HDSR_LOG);
     }
  
     TheTimer.atTimeDo( 50,0,0,1,0, "::UCN5and6.PicUCN_HDSR730", "{ bProcess.UnSelect(); }");
     return 0;
  }`

  function `void ReturnAction(int no)
  {
     int i;
  
     execute("{ strcpy(TempString, bPoint_%d.TheOriginalText); }", no);
           for( i=0; i< 8; i++ ) {
             if( TempString[i] == ' ' )
                break;
  
                 TempPid[i] = TempString[i];
           }
          TempPid[i] =  '\\0';
  
     if( strcmp(TempPid,"") == 0 ) {
              execute("{ strcpy(gPage730.point_%d, \\"\\"); }", no);
              execute("{ strcpy(bPoint_%d.TheOriginalText, \\"\\"); }", no);
              execute("{ strcpy(bPoint_%d.TheNewText, \\"\\"); }", no);
              update();
              return;
     }
  
     if( FindPointId(TempString) == 0 ) {
          execute("{ SigType = %s->sig_type; }", TempPid);
  
  
           if( SigType == AI || SigType == CI ||SigType == PI ||SigType == FI ||SigType == AL ||SigType == DL ||SigType == SOE ) {
              execute("{ strcpy(gPage730.point_%d, bPoint_%d.TheOriginalText); }", no, no);
           }
           else {
              sprintf( TempString, "INVALID PID TYPE: %s", TempPid);
              DisplayAdvisoryMessage1(TempString);
              execute("{ strcpy(gPage730.point_%d, \\"\\"); }", no);
              execute("{ strcpy(bPoint_%d.TheOriginalText, \\"\\"); }", no);
              execute("{ strcpy(bPoint_%d.TheNewText, \\"\\"); }", no);
           }
     }
     else {
              sprintf( TempString, "INVALID PID: %s", TempPid);
              DisplayAdvisoryMessage1(TempString);
  
              execute("{ strcpy(bPoint_%d.TheOriginalText, gPage730.point_%d); }", no, no);
              execute("{ strcpy(bPoint_%d.TheNewText, gPage730.point_%d); }", no, no);
     }
     update();
  }`

  function `void ReturnActionForEndDate()
  {
     int i;
  
     strcpy(TempString, bEndDate.TheOriginalText);
           for( i=0; i< 8; i++ ) {
             if( TempString[i] == ' ' )
                break;
  
                 TempPid[i] = TempString[i];
           }
          TempPid[i] =  '\\0';
  
     if( TempPid[2] == '/' && TempPid[5] == '/' && strcmp(TempPid,"") != 0 )
        strcpy(gPage730.endDate, bEndDate.TheOriginalText);
     else {
              strcpy(gPage730.endDate, "");
              strcpy(bEndDate.TheOriginalText, "");
              strcpy(bEndDate.TheNewText, "");
            DisplayAdvisoryMessage1("INVALID FORMAT FOR END DATE");
             update();
     }
     return;
  }`

