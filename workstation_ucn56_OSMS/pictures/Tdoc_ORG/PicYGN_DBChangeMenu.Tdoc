SetupViewData.downright.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;
SetupViewData.down.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
SetupViewData.down.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;

execute("{DisplayPage(\\"%s\\");}",db1.TheDisplayPage);

}`;
  }

  dialogue
  {
    event = `keyReleased(0x32) || keyReleased(0xFFB2)`;
    action = statement `{
ModifyDatabase.mbox.foregroundColour = COLOR_BUTTON_BACKGROUND;
ModifyDatabase.mbox.foregroundFillColour = COLOR_BUTTON_BACKGROUND;

ModifyDatabase.upleft.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
