  dialogue
  {
    event = `keyReleased(0x31) || keyReleased(0xFFB1)`;
    action = statement `{
SetupViewData.mbox.foregroundColour = COLOR_BUTTON_BACKGROUND;
SetupViewData.mbox.foregroundFillColour = COLOR_BUTTON_BACKGROUND;

SetupViewData.upleft.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
