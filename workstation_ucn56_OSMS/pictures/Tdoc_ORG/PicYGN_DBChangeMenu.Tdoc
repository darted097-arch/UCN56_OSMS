ModifyDatabase.downright.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
ModifyDatabase.downright.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;
ModifyDatabase.down.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
ModifyDatabase.down.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;

   CascadeMenuActive = 1;
   if (CascadeEnter.isMapped())
       CascadeEnter.unmap();
   execute("{DisplayCascadeEnter(\\"%s\\",%d,%d,%f,%f);}",m5.TheDisplayPage,m5.CascadeX,m5.CascadeY,10.0,10.0);
/*
   execute("{DisplayCascadeEnter(\\"%s\\",%d,%d,%f,%f);}",ModifyDatabase.TheDisplayPage,ModifyDatabase.CascadeX,ModifyDatabase.CascadeY,10.0,10.0);
//   execute("{DisplayPage(\\"%s\\");}",ModifyDatabase.TheDisplayPage);
*/
}`;
  }

  dialogue
  {
    event = `keyReleased(0x33) || keyReleased(0xFFB3)`;
    action = statement `{
m3.mbox.foregroundColour = COLOR_BUTTON_BACKGROUND;
m3.mbox.foregroundFillColour = COLOR_BUTTON_BACKGROUND;

m3.upleft.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
m3.upleft.foregroundFillColour = COLOR_BUTTON_TOP_SHADOW;
m3.up.foregroundColour = COLOR_BUTTON_TOP_SHADOW;
