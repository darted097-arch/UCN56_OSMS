   update();
}`



  function `void ClearWait()
{
   ReqMsg.visibility=0;
   update();
}`



  function `void ProcessOpt1()
{
      //CORENET 0704
 	if( Interface->System.slaveUpdating!=0 )
	{
	        DisplayAdvisoryMessage("CHANGE FROM MASTER CPU ONLY") ;
	        return;
        }
	else
	{
		option=1;
		ProcessThis();
		ReqMsg.visibility=1;
		update();
       	}
}`



