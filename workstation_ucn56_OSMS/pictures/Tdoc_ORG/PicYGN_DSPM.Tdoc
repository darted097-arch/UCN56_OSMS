  function `void DspmErrMsg(){
DisplayAdvisoryMessage(Interface->GenericConfirmMessage.data.message1);
//CORENET 20170621 *********************************************************
DisplayAdvisoryMessage1(Interface->GenericConfirmMessage.data.message2);
DisplayAdvisoryMessage2(Interface->GenericConfirmMessage.data.message3);
}`



  function `void ProcessThis()
{
   switch(option) {
      case 1:
       	 Interface->GenericRequestMessage.data.requestOption=1;
       	 execute("{sendMessageToHost(REQUEST_DSPM_REPORT);}");
       	 DisplayAdvisoryMessage("");
       	 DisplayAdvisoryMessage1("");
       	 break;
      case 2:
         Interface->GenericRequestMessage.data.requestOption=2;
         execute("{sendMessageToHost(REQUEST_DSPM_REPORT);}");
         DisplayAdvisoryMessage("");
         DisplayAdvisoryMessage1("");
         break;
      case 3:
         Interface->GenericRequestMessage.data.requestOption=3;
         execute("{sendMessageToHost(REQUEST_DSPM_REPORT);}");
         DisplayAdvisoryMessage("");
         DisplayAdvisoryMessage1("");
         break;
      case 4:
         Interface->GenericRequestMessage.data.requestOption=4;
         execute("{sendMessageToHost(REQUEST_DSPM_REPORT);}");
         DisplayAdvisoryMessage("");
         DisplayAdvisoryMessage1("");
         break;
      case 5:
         Interface->GenericRequestMessage.data.requestOption=5;
         execute("{sendMessageToHost(REQUEST_DSPM_REPORT);}");
         DisplayAdvisoryMessage("");
         DisplayAdvisoryMessage1("");
         break;
   }
}
`



  function `void escape()
{
