}`



  function `void ProcessingConfirmed()
{
   processingText.visibility=0;
   update();
}`



  function `void SendMsgToHost()
{
  Interface->UtdvDialogue.option=option;
  Interface->UtdvDialogue.current_page=Current_page;
//
//copy to filenames in YGN3and4.Tdoc, used for escape keys from page 693, 694
  strcpy(Interface->UtdvDialogue.filename2, midnightfile.TheNewText);
  strcpy(Interface->UtdvDialogue.filename3, ceafile.TheNewText);

  execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
  processingText.visibility=1;
  update();
//
//  printf(" file222 = %s",Interface->UtdvDialogue.filename2); 
//  printf(" file333 = %s",Interface->UtdvDialogue.filename3);
//  printf(" cea_with = %s",Interface->UtdvDialogue.cea_with);
//
//copy to filenames in YGN3and4.Tdoc, used for escape keys from page 693, 694
  strcpy(UtdvPg692_midnightfile,Interface->UtdvDialogue.filename2);
  strcpy(UtdvPg692_ceafile,Interface->UtdvDialogue.filename3);
}`



  function `void CEAWith()
{
   execute("{strcpy(Interface->UtdvDialogue.cea_with,ceaw.TheNewText);}");
   option=2;
   SendMsgToHost();
}`



  function `void escape()
{
 DisplayPage(Page650);
}`



  function `void Process1()
{
if (OPT_SELECTED == 0) {DisplayAdvisoryMessage1("SELECT ONE OPTION OF 1 - 3"); return;}
else if (OPT_SELECTED == 1)
{
   if (option == 1)
   {
      if (INPUTERR2 && INPUTERR3)
      {
         FileERR.visibility = 1;
         DisplayAdvisoryMessage("AT LEAST ONE FILE MUST BE SPECIFIED");
         return;
      }
      else
      {
         FileERR.visibility = 0;
         Interface->UtdvDialogue.option=option;
         Interface->UtdvDialogue.current_page=Current_page;
         //   copy to filenames in YGN3and4.Tdoc, used for escape keys from page 693, 694
         strcpy(Interface->UtdvDialogue.filename2, midnightfile.TheNewText);
         strcpy(Interface->UtdvDialogue.filename3, ceafile.TheNewText);
//
         execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
         processingText.visibility=1;
         update();
//
         //   printf(" file222 = %s",Interface->UtdvDialogue.filename2); 
         //   printf(" file333 = %s",Interface->UtdvDialogue.filename3);
//
         strcpy(utlmid692,  midnightfile.TheNewText);
         strcpy(utlhcea692, ceafile.TheNewText);

         //   copy to filenames in YGN3and4.Tdoc, used for escape keys from page 693, 694
         strcpy(UtdvPg692_midnightfile,Interface->UtdvDialogue.filename2);
         strcpy(UtdvPg692_ceafile,Interface->UtdvDialogue.filename3);
      }
   }
   else if (option == 2)
   {
        if (ceaw.ERROR == 1) { DisplayAdvisoryMessage1("CONFIRM CEA VALUE OF OPTION  2"); return;}
        Interface->UtdvDialogue.option=option;
        Interface->UtdvDialogue.current_page=Current_page;
        execute("{Interface->UtdvDialogue.cea_average = ceaw.TheNewNumber;}");
        //printf(" *** cea pos. = %f",Interface->UtdvDialogue.cea_average); 

        option=2;
        SendMsgToHost();
   } 
   else if (option == 3)
   {
        Interface->UtdvDialogue.option=option;
        Interface->UtdvDialogue.current_page=Current_page;
        SendMsgToHost();
   } 
}  
}`



