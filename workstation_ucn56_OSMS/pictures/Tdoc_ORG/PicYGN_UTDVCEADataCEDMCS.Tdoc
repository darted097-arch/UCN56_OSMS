  function `void Initialize()
{
   int k;
   ClearAdvisoryMessage();
   Current_Page = 692;
   CFMLevel = 0;
   Current_page = 692;
//
   printf("Display Units = %d,  0 <= ENGLISH, 1 <= METRIC",Interface->System.displayedUnits);
   //JHC 990418
   if(Interface->System.displayedUnits==ENGLISH)
      { TextE.visibility=1;TextM.visibility=0; update();}
   else
      { TextE.visibility=0;TextM.visibility=1; update();}
//
   FileERR.visibility = 0;
   OPT_SELECTED = 0;
   UnselectAllButton()  ;  
   k = Interface->System.cpuNum;

   if (k == 1) {
      strncpy(midnightfile.TheNewText,"LOG1:UTLMID.DAT     ",20);
      strncpy(ceafile.TheNewText,     "LOG1:UTLHCEA.DAT    ",20);
      strncpy(midnightfile.TheOriginalText, midnightfile.TheNewText,20);
      strncpy(ceafile.TheOriginalText, ceafile.TheNewText,20);
      }
     else {
      strncpy(midnightfile.TheNewText,"LOG2:UTLMID.DAT",20);
      strncpy(ceafile.TheNewText,     "LOG2:UTLHCEA.DAT",20);
      strncpy(midnightfile.TheOriginalText, midnightfile.TheNewText,20);
      strncpy(ceafile.TheOriginalText, ceafile.TheNewText,20);
      }
   ProcessFileName2();
   ProcessFileName3();
//   printf(" %s %s",midnightfile.TheNewText,ceafile.TheNewText);
   strcpy(UtdvPg692_midnightfile, midnightfile.TheNewText);
   strcpy(UtdvPg692_ceafile, ceafile.TheNewText);
//
   processingText.visibility=0;
   update();
}`



  function `void Option1()
{
   option=1; 
   KeepSelected();
   OPT_SELECTED = 1;
}`



  function `void Option2()
{
   option=2;
   KeepSelected();
   OPT_SELECTED = 1;
}`



  function `void Option3()
{
   option=3; 
   KeepSelected();
//   SendMsgToHost();
