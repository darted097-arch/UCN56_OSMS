  function `void IsFileBlank(char *fileInput)
{
   int i=0;
   fileCharsEntered=0;

     while (fileInput[i] != '\\0')
     {
//      if (inputFileName.TheNewText[i] != ' ')
        if (fileInput[i] != ' ')
           { 
           ++fileCharsEntered;
           }
        ++i;    
     }
//   printf(" file chars = %d",fileCharsEntered);
}`



