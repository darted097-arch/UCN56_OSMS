  function `void escape()
  {
     if(SETUP)
        Reset() ;
     else
        execute("{DisplayPage(\\"%s\\");}",TheDisplayPage);
  
  //   displayPicture("Main","PicYGN_SetupViewMenu.ppic");
  //   update();
  }`

  function `void Initialize()
  {
     CFMLevel = 0;
     Current_Page = 642;
  //   init = 1 ;
  
     procMsg.visibility = 0 ;
  
     DisplayAdvisoryMessage(" ");
     DisplayAdvisoryMessage1(" ");
     DisplayAdvisoryMessage2(" ");
     DisplayAdvisoryMessage3(" ");
  //   Reset() ;
     update();
  }`

  function `int IsAllBlank(char * cptr)
  {
    // Return 0 if one non-blank character is found, 1 otherwise
    int blank = 1;
    int i;
  
    for (i=0; i<strlen(cptr); i++, cptr++)
    {
      if (*cptr != ' ')
      {
        blank = 0;
        break;
      }//endif
    }//endfor
    return (blank);
  }`

  function `void Reset()
  {
  //  printf("%s Resetting", PictureTitle);
  //  UpdateLocalsFromInterface();
  
    execute("{sendMessageToHost(REQUEST_BAR_DATA);}");
    ErrorMsgReset() ;
    SETUP = 0 ;
  }`

  function `void SetupNcancel()
  {
     if (!SETUP)         // For SETUP
     {
        if (accesslevel<5)
           SETUP = 1 ;
        else
           DisplayAdvisoryMessage("ACCESS LEVEL 3 OR 4 REQUIRED");
     }
     else                     // For CANCEL
     {
        SETUP = 0 ;
        procMsg.visibility = 1 ;
        Reset() ;
     }
  
     update() ;
  }`

  function `void UpdateLocalsFromInterface()
  {
    procMsg.visibility = 0;
    execute("{DisplayPage(\\"%s\\");}",TheDisplayPage);
    update();
  }`

  function `void Wsrequest()
  {
  
    procMsg.visibility = 1;
  
   Interface->WSOffData.CURPAGE = 642;
  
   strcpy(Interface->WSOffData.INITIME, INITIME.TheNewText);
   strcpy(Interface->WSOffData.FINTIME, FINTIME.TheNewText);
  
  printf("---[%s]---[%s]---", Interface->WSOffData.INITIME, INITIME.TheNewText);
