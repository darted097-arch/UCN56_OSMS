picture PicYGN_MajorDbChange
{
  worldX = 0;
  worldY = 0;
  worldWidth = 1280;
  worldHeight = 824;
  oneToOne = 1;
  backgroundColour = 0;
  updateMode = 2;
  resizeMode = 0;
  xSnap = 5;
  ySnap = 5;
  radiusSnap = 0;
  angleSnap = 0;
  crosshairStyle = 1;
  crosshairLength = 0;
  crosshairFollowSnap = `isInEditMode()`;
  crosshairVisibility = `isInEditMode()`;
  xReference = 500;
  yReference = 500;
  xScaleFactor = 1;
  yScaleFactor = 1;
  rotationAngle = 0;

  int Analog = `(PicturePointId->sig_type<MinimumDigitalType)`;

  int AnalogAlarm = `Analog && (PicturePointId->pipbitmap&0x0F00)`;

  int ChangeAlarmState = `ChangeSelected_Alarm`;

  int ChangeLimitState = 0;

  int ChangeScanState = `ChangeSelected_Scan`;

  int ChangeSelected_Alarm = 0;

  int ChangeSelected_Scan = 0;

  int Composed = `(PicturePointId->sig_type==QA)||(PicturePointId->sig_type==QD)
||(PicturePointId->sig_type==XA)||(PicturePointId->sig_type==XD)`;

  int DEBUG = 0;

  int Digital = `(PicturePointId->sig_type>=MinimumDigitalType)`;

  int DigitalAlarm = `Digital && (PicturePointId->pipbitmap&bALMTYP)`;

  int ERROR = `ValueEntry.ERROR || HiHiLimitEntry.ERROR || HiLimitEntry.ERROR || LoLimitEntry.ERROR || LoLoLimitEntry.ERROR`;

  int InsertValid = `(PicturePointId->sig_type==AI)||(PicturePointId->sig_type==CI)
||(PicturePointId->sig_type==DI)||(PicturePointId->sig_type==AL)
||(PicturePointId->sig_type==DL)||(PicturePointId->sig_type==KO)`;

  int InsertValueState = 0;

  int NoAlarm = `!Protected && !(AnalogAlarm||DigitalAlarm)`;

  int NoOfChanges = 0;

  int NotInputPoint = `(PicturePointId->sig_type==QA)||(PicturePointId->sig_type==QD)
||(PicturePointId->sig_type==XA)||(PicturePointId->sig_type==XD)||(PicturePointId->sig_type==KO)`;

  char* PageBack = "";

  char* PageForward = "";

  DB_CHANGE_DATA* pDBC_DATA = `&Interface->DatabaseDisplaysData`;

  RECORD* PictureHighAlarmPID = 0;

  RECORD* PictureLowAlarmPID = 0;

  char* PictureNumber = "511";

  RECORD* PicturePointId = `&CXYKMETD`;		

  char PictureScope[80] = "::YGN3and4.PicYGN_MajorDbChange.PID.InputArea";

  char* PictureTitle = "DATABASE CHANGE";

  int Protected = `(PicturePointId->pipbitmap&bCHGPROT)||(PicturePointId->sig_type==SOE)`;

  float Range_hi = `(PicturePointId->sig_type < MinimumDigitalType)?EngRangeHi(PicturePointId):1`;

  float Range_lo = `(PicturePointId->sig_type < MinimumDigitalType)?EngRangeLo(PicturePointId):0`;

  char ThePictureScope[80] = "::YGN3and4.PicYGN_MajorDbChange";

  function `void escapeToMenu()
  {
        displayPicture("Main","PicYGN_DBChangeMenu.ppic");
  }`

  function `void Initialize()
  {
    //CORENET 201705 by Philkyu Kwon
    Current_Page = 511;
    CFMLevel = 0;
  
  // DBCinfo.pPID = PicturePointId;
  // strcpy(pDBC_DATA->PID,PicturePointId->pid);
  
    NoChange.visibility = 0;
    NoOfChanges = 0;
  
    ProcessingMsg.visibility = 0;
    execute ("{ manageTempShopList(TEMP_SHOP_INIT_ADD,PID.TheOriginalText); }");
  
    InitPid();
  
     InsertValueState = 0;
     ChangeScanState = \`ChangeSelected_Scan\`;
     ChangeAlarmState = \`ChangeSelected_Alarm\`;
     ChangeLimitState = 0;
  
  // CHGSCN
  
    ChangeSelected_Scan = 0;
    CheckButton_Scan.UnSelect();
  
  
  // CHGALM
  
     ChangeSelected_Alarm = 0;
     CheckButton_Alarm.UnSelect();
  
  //INSVAL
  
     ProcessingErrorMsg.visibility = 0;
     ValueEntry.ERROR = 0;
  
  
  // CHGLIM
  
     HiHiLimitEntry.ERROR = 0 ;
     HiLimitEntry.ERROR = 0 ;
     ChangeLimitState = 0;
     LoLimitEntry.ERROR = 0 ;
     LoLoLimitEntry.ERROR = 0 ;
  
  /*
    if(PicturePointId->sig_type==KO)
     {
        Text1.visibility = 0 ;
        CheckButton_Alarm.visibility = 0 ;
        AlarmStatus.visibility = 0 ;
  
  //      ProcessBtn.visibility = 0 ;
  //      CurPointInfo.visibility = 0 ;
  
  //      ChangeProtected.visibility = 0 ;
  //      NoAlarm.visibility = 0 ;
  //      NotApplyMsg.visibility = 1 ;
     }
     else if((PicturePointId->pipbitmap&bCHGPROT)||(PicturePointId->sig_type==SOE))
     {
        Text1.visibility = 0 ;
        CheckButton.visibility = 0 ;
        Text2.visibility = 0 ;
        AlarmStatus.visibility = 0 ;
  
        ProcessBtn.visibility = 0 ;
        CurPointInfo.visibility = 0 ;
  
        ChangeProtected.visibility = 1 ;
        NoAlarm.visibility = 0 ;
        NotApplyMsg.visibility = 0 ;
     }
     else if(!((PicturePointId->pipbitmap&bALMTYP)||(PicturePointId->pipbitmap&(bLLE|bLE|bHE|bHHE))))
     {
        Text1.visibility = 0 ;
        CheckButton.visibility = 0 ;
        Text2.visibility = 0 ;
        AlarmStatus.visibility = 0 ;
  
        ProcessBtn.visibility = 0 ;
        CurPointInfo.visibility = 0 ;
  
        ChangeProtected.visibility = 0 ;
        NoAlarm.visibility = 1 ;
        NotApplyMsg.visibility = 0 ;
     }
     else
     {
        Text1.visibility = 1 ;
        CheckButton.visibility = 1 ;
        Text2.visibility = 1 ;
        AlarmStatus.visibility = 1 ;
  
        ProcessBtn.visibility = 1 ;
        CurPointInfo.visibility = 1 ;
  
        ChangeProtected.visibility = 0 ;
        NoAlarm.visibility = 0 ;
        NotApplyMsg.visibility = 0 ;
     }
  */
  
     if(IsAnalog(PicturePointId))
     {
        if(0 != PicturePointId->lIPN)
        {
           execute ("{PictureLowAlarmPID = \`&::YGN3and4.InterfaceToGUI.%s\`;}",PicturePointId->message1);
        }
        else
        {
           PictureLowAlarmPID = 0;
        }
  
        if(0 != PicturePointId->hIPN)
        {
           execute ("{PictureHighAlarmPID = \`&::YGN3and4.InterfaceToGUI.%s\`;}",PicturePointId->message2);
        }
        else
        {
           PictureHighAlarmPID = 0;
        }
     }
  
    update();
  }`

