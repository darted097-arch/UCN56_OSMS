  function `void InitPid()
  {
  
  // CHGLIM
  
    execute ("{PicturePointId = \\\`&%s\\\`;}",PID.TheOriginalText);
  
    DBCinfo.pPID = PicturePointId;
    strcpy(pDBC_DATA->PID,PicturePointId->pid);
    execute ("{ manageTempShopList(TEMP_SHOP_INIT_ADD,PID.TheOriginalText); }");
  
    HiHiLimitEntry.TheNewNumber =\`(Interface->System.displayedUnits)?PicturePointId->hhmet:PicturePointId->hhval\`;
    HiLimitEntry.TheNewNumber =\`(Interface->System.displayedUnits)?PicturePointId->hmet:PicturePointId->hval\`;
    LoLimitEntry.TheNewNumber =\`(Interface->System.displayedUnits)?PicturePointId->lmet:PicturePointId->lval\`;
    LoLoLimitEntry.TheNewNumber =\`(Interface->System.displayedUnits)?PicturePointId->llmet:PicturePointId->llval\`;
  
  
  // INSVAL
  
    ProcessingErrorMsg.visibility = 0;
    // **********CORENET 2017 by Philkyu Kwon *********************
    //ValueEntry.TheNewNumber = \`ValueEntry.TheOriginalNumber\`;
    ValueEntry.TheNewNumber = 0;
    ValueEntry.TheOriginalNumber = 0;
    strcpy(ValueEntry.TheNewText, "0");
    strcpy(ValueEntry.TheOriginalText , "0");
    // ***********************************************************
  
  
  // CHGALM
    ChangeSelected_Alarm = 0;
    CheckButton_Alarm.UnSelect();
  
  // CHGSCN
  
    ChangeSelected_Scan = 0;
    CheckButton_Scan.UnSelect();
  
    update();
  }`

  function `int isValidPointType()
  {
    int retval = 0;
  
    switch(PicturePointId->sig_type)
    {
      case AI:
      case KO:
      case AL:
      case CI:
      case DI:
      case DL:
        retval = 1;
        break;
      default: // everything else
        retval = 0;
        break;
    } // endswitch
    return(retval);
  }
  `

  function `void Process1()
  {
  
    if (ERROR==0)
    {
  
  //     NoOfChanges = ChangeLimitState + ChangeScanState + ChangeAlarmState + InsertValueState ;
  //     if((PicturePointId->sig_type!=KO)&&(!(PicturePointId->pisabitmap&bOOSCAN)) && InsertValueState) NoOfChanges ++;
  
       NoOfChanges = 0;
       ProcessingMsg.visibility = 1;
  
       if (ChangeScanState)      // CHGSCN
       {
          // If the point is in scan indicate in message to take it out,
          // else indicate to put it into scan.
          if((PicturePointId->pisabitmap&bOOSCAN)>0)
             pDBC_DATA->ChgScnStatus = 0;
          else
             pDBC_DATA->ChgScnStatus = 1;
          execute("{sendMessageToHost(PROCESS_CHGSCN_DATA);}");
          NoOfChanges ++;	//CORENET 170718
          printf("pDBC_DATA->ChgScnStatus = %d",pDBC_DATA->ChgScnStatus);
       }
  
       if (ChangeAlarmState)      // CHGALM
       {
          // If the alarm state is being checked, indicate
          // to take it out of alarm checking
          // else indicate to put it into alarm checking.
          if((PicturePointId->pisabitmap&bOCHEK)>0)
             pDBC_DATA->ChgAlmStatus = 0;
          else
             pDBC_DATA->ChgAlmStatus = 1;
          execute("{sendMessageToHost(PROCESS_CHGALM_DATA);}");
          NoOfChanges ++;	//CORENET 170718
          printf("pDBC_DATA->ChgAlmStatus = %d",pDBC_DATA->ChgAlmStatus);
       }
  
       if(ChangeLimitState)      // CHGLIM
       {
          if(PicturePointId->sig_type >= MinimumDigitalType)      // FOR DIGITAL
          {
             if(PicturePointId->pipbitmap & bALMTYP)
                pDBC_DATA->LoLoLim = LoLoLimitEntry.TheNewNumber;
             else
                pDBC_DATA->LoLoLim = 0.0;
          }
          else                                                    // FOR ALALOG
          {
             if((PicturePointId->sig_type < MinimumDigitalType) && (PicturePointId->pipbitmap & bLLE) )
             {
  //              pDBC_DATA->LoLoLim = (Interface->System.displayedUnits)? LoLoLimitEntry.TheNewNumber :
  //                                   LoLoLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
  
                if ( (Interface->System.displayedUnits) && (!(PicturePointId->pipbitmap & bMETUNIT)) )
                   pDBC_DATA->LoLoLim = (LoLoLimitEntry.TheNewNumber - PicturePointId->moffset) / PicturePointId->mfactor ;
                else if ( (!Interface->System.displayedUnits) && (PicturePointId->pipbitmap & bMETUNIT) )
                   pDBC_DATA->LoLoLim = LoLoLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
                else
                   pDBC_DATA->LoLoLim = LoLoLimitEntry.TheNewNumber ;
             }
             else
               pDBC_DATA->LoLoLim = 0.0;
  
             if((PicturePointId->sig_type < MinimumDigitalType) && (PicturePointId->pipbitmap & bLE) )
             {
  
  //              pDBC_DATA->LoLim = (Interface->System.displayedUnits)? LoLimitEntry.TheNewNumber :
  //                                 LoLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
  
                if ( (Interface->System.displayedUnits) && (!(PicturePointId->pipbitmap & bMETUNIT)) )
                   pDBC_DATA->LoLim = (LoLimitEntry.TheNewNumber - PicturePointId->moffset) / PicturePointId->mfactor ;
                else if ( (!Interface->System.displayedUnits) && (PicturePointId->pipbitmap & bMETUNIT) )
                   pDBC_DATA->LoLim = LoLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
                else
                   pDBC_DATA->LoLim = LoLimitEntry.TheNewNumber ;
             }
             else
               pDBC_DATA->LoLim   = 0.0;
  
             if((PicturePointId->sig_type < MinimumDigitalType) && (PicturePointId->pipbitmap & bHE) )
             {
  //              pDBC_DATA->HiLim = (Interface->System.displayedUnits)? HiLimitEntry.TheNewNumber :
  //                                 HiLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
  
                if ( (Interface->System.displayedUnits) && (!(PicturePointId->pipbitmap & bMETUNIT)) )
                   pDBC_DATA->HiLim = (HiLimitEntry.TheNewNumber - PicturePointId->moffset) / PicturePointId->mfactor ;
                else if ( (!Interface->System.displayedUnits) && (PicturePointId->pipbitmap & bMETUNIT) )
                   pDBC_DATA->HiLim = HiLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
                else
                   pDBC_DATA->HiLim = HiLimitEntry.TheNewNumber ;
             }
             else
               pDBC_DATA->HiLim   = 0.0;
  
             if((PicturePointId->sig_type < MinimumDigitalType) && (PicturePointId->pipbitmap & bHHE) )
             {
  //              pDBC_DATA->HiHiLim = (Interface->System.displayedUnits)? HiHiLimitEntry.TheNewNumber :
  //                                   HiHiLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
  
                if ( (Interface->System.displayedUnits) && (!(PicturePointId->pipbitmap & bMETUNIT)) )
                   pDBC_DATA->HiHiLim = (HiHiLimitEntry.TheNewNumber - PicturePointId->moffset) / PicturePointId->mfactor ;
                else if ( (!Interface->System.displayedUnits) && (PicturePointId->pipbitmap & bMETUNIT) )
                   pDBC_DATA->HiHiLim = HiHiLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
                else
                   pDBC_DATA->HiHiLim = HiHiLimitEntry.TheNewNumber ;
             }
             else
               pDBC_DATA->HiHiLim = 0.0;
          }
          execute("{sendMessageToHost(PROCESS_CHGLIM_DATA);}");
          NoOfChanges ++;	//CORENET 170718
       }
  
       if (InsertValueState)      // INSVAL
       {
           ProcessingErrorMsg.visibility = 0;
  
           // If PID status is in-scan, set the status to out-of-scan first.
           if((!NotInputPoint) &&(!(PicturePointId->pisabitmap&bOOSCAN)))                     // yrlee 981112
           {
              pDBC_DATA->ChgScnStatus = 1;
              execute("{sendMessageToHost(PROCESS_CHGSCN_DATA);}");
              NoOfChanges ++;		//CORENET 170718
           }
  
           if(PicturePointId->sig_type >= MinimumDigitalType)      // FOR DIGITAL
           {
              pDBC_DATA->InsValue = ValueEntry.TheNewNumber ;
           }
           else                                                    // FOR ANALOG
           {
              //if(!strcmp(PicturePointId->pid,"CXYKMETD"))
              if(!strcmp(PicturePointId->pid,"METDISP"))	// for Y34 (CORENET 2013.10.30)
                 pDBC_DATA->InsValue = ValueEntry.TheNewNumber ;
              else
              {
  //               pDBC_DATA->InsValue = (Interface->System.displayedUnits)? ValueEntry.TheNewNumber :
  //               ValueEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
  
                if ( (Interface->System.displayedUnits) && (!(PicturePointId->pipbitmap & bMETUNIT)) )
                   pDBC_DATA->InsValue = (ValueEntry.TheNewNumber - PicturePointId->moffset) / PicturePointId->mfactor ;
                else if ( (!Interface->System.displayedUnits) && (PicturePointId->pipbitmap & bMETUNIT) )
                   pDBC_DATA->InsValue = ValueEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
                else
                   pDBC_DATA->InsValue = ValueEntry.TheNewNumber ;
  
                 printf("************* INSVAL : %f\\n", pDBC_DATA->InsValue);
  
              }
           }
           execute("{sendMessageToHost(PROCESS_INSVAL_DATA);}");
           NoOfChanges ++;	//CORENET 170718
       }
  
       NoChange.visibility = !(ChangeScanState||ChangeAlarmState||InsertValueState||ChangeLimitState) ;
       if(NoChange.visibility) ProcessingMsg.visibility = 0;
    }
    else
    {
      ProcessingErrorMsg.visibility = 1;
    }
  
    printf("************* INSVAL : %f\\n, ********InserValueState = %d", pDBC_DATA->InsValue,InsertValueState );	//CORENET 2017 by Philkyu Kwon
    update();
  
  }`

  function `void ProcessingConfirmed()
    {
  
    printf("PrecessingConfirmed() Call!!!!!!!!!!!!!!!##############");

    //CORENET 20170629
    printf("========NoOfChanges = %d", NoOfChanges);

    //NoOfChanges = NoOfChanges - 1;
  
    if(--NoOfChanges <= 0)	//CORENET 170718
    {
  //     ProcessingMsg.visibility = 0;
  //     NoOfChanges=0;
         Initialize();
    }
  
    update();
  
  }`

  function `void ProcessingConfirmed1(int opcode)
  {
    printf("PrecessingConfirmed111111111() Call#########################");
  
    //CORENET 20170629
    printf("Confirmed1========NoOfChanges = %d", NoOfChanges);

    {
       switch(opcode)
       {
  	case CHGSCN_PROCESSING_CONFIRMED:
  //                ChangeSelected_Scan = 0;
                  CheckButton_Scan.UnSelect();
  		printf("*** CHGSCN completed....");
    		//NoOfChanges = NoOfChanges - 1;
  		break;
          case CHGALM_PROCESSING_CONFIRMED:
  //                ChangeSelected_Alarm = 0;
                  CheckButton_Alarm.UnSelect();
  		printf("*** CHGALM completed....");
    		//NoOfChanges = NoOfChanges - 1;
  		break;
          case CHGLIM_PROCESSING_CONFIRMED:
                  ChangeLimitState = 0;
  		printf("*** CHGLIM completed....");
    		//NoOfChanges = NoOfChanges - 1;
  		break;
          case INSVAL_PROCESSING_CONFIRMED:
  		InsertValueState = 0;
  		printf("*** INSVAL completed....");
    		//NoOfChanges = NoOfChanges - 1;	//CORENET 170718
  		break;
       }
    }
  
    if(--NoOfChanges <= 0)	//CORENET 170718
    {
  //     ProcessingMsg.visibility = 0;
  //     NoOfChanges=0;
         Initialize();
    }
  
    update();
  
  }`

  function `void VerifyLimits()
  {
     if(PicturePointId->sig_type < MinimumDigitalType)  //for Analog
     {
        if(PicturePointId->pipbitmap&bHHE)
        {
            if((HiHiLimitEntry.TheNewNumber >= Range_lo) && (HiHiLimitEntry.TheNewNumber <= Range_hi))
                 HiHiLimitEntry.ERROR = 0;
            else
                 HiHiLimitEntry.ERROR = 1;
        }
  
        if(PicturePointId->pipbitmap&bHE)
        {
            if((HiLimitEntry.TheNewNumber >= Range_lo) && (HiLimitEntry.TheNewNumber <= Range_hi))
                 HiLimitEntry.ERROR = 0;
            else
                 HiLimitEntry.ERROR = 1;
        }
  
        if(PicturePointId->pipbitmap&bLE)
        {
            if((LoLimitEntry.TheNewNumber >= Range_lo) && (LoLimitEntry.TheNewNumber <= Range_hi))
                 LoLimitEntry.ERROR = 0;
            else
                 LoLimitEntry.ERROR = 1;
        }
  
        if(PicturePointId->pipbitmap&bLLE)
        {
            if((LoLoLimitEntry.TheNewNumber >= Range_lo) && (LoLoLimitEntry.TheNewNumber <= Range_hi))
                 LoLoLimitEntry.ERROR = 0;
            else
                 LoLoLimitEntry.ERROR = 1;
        }
  
  //      ValueErrorMsg.visibility = HiHiLimitEntry.ERROR || HiLimitEntry.ERROR || LoLimitEntry.ERROR || LoLoLimitEntry.ERROR ;
     }
     else       // for Digital
     {
        if(((LoLoLimitEntry.TheNewNumber==0)||(LoLoLimitEntry.TheNewNumber==1)) && (PicturePointId->pipbitmap&bALMTYP))
            LoLoLimitEntry.ERROR = 0;
        else
            LoLoLimitEntry.ERROR = 1;
  
  //      ValueErrorMsg.visibility = LoLoLimitEntry.ERROR ;
     }
  
     ChangeLimitState = 1;
  
     ProcessingErrorMsg.visibility = 0 ;
  }`

  function `void VerifyLimits_INSVAL()
  {
  //   float erange_lo = EngRangeLo(PicturePointId) ;
  //  float erange_hi = EngRangeHi(PicturePointId) ;
  
     ValueEntry.TheNewNumber = atof(ValueEntry.TheNewText);
     printf("ValueEntry.TheNewNumber = %f",ValueEntry.TheNewNumber);	//CORENET 2017 by Philkyu Kwon
  
     printf("%f  %f", Range_lo, Range_hi);
  
     if(PicturePointId->sig_type < MinimumDigitalType)  //for Analog
     {
        if ((0 == Range_lo) && (0 == Range_hi))
           ValueEntry.ERROR = 0;
        else
        {
           if ((ValueEntry.TheNewNumber >= Range_lo) &&
              (ValueEntry.TheNewNumber <= Range_hi) )
              ValueEntry.ERROR = 0;
           else
              ValueEntry.ERROR = 1;
        }
     }
     else       // for Digital
     {
        if((ValueEntry.TheNewNumber==0)||(ValueEntry.TheNewNumber==1))
            ValueEntry.ERROR = 0;
        else
            ValueEntry.ERROR = 1;
     }
  
  
        InsertValueState = 1;
        CheckButton_Scan.UnSelect();
  }`

