}`



  function `void escape() 
{
   displayPicture("Main","PicYGN_NSSSBOPApplication.ppic");
   update(); 
}`



  function `void Option_1()
{

   Option = 1;
   strcpy(Choice,"1\\0");
//
   ProcessOption();
   update();
}`



  function `void Option_2()
{

   Option = 2;
   strcpy(Choice,"2\\0");
//
   ProcessOption();
