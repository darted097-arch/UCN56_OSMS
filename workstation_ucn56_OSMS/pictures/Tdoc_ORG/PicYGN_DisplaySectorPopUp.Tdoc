  text PopUpInput
  {
    dialogue
    {
      event = `isInEditMode() && (keyPressed(RETURN) || keyPressed(0xFF8D))`;
      action = statement `{
//--------------------------------------------------------------------------
// Keep display page navigation from working !!!
   if (0 == Interface->System.connected)
   {
      DisplayAdvisoryMessage("CONNECTION LOST. NO PAGING ALLOWED");
      DisplayProcessing = 0 ;
      return;
   }
//--------------------------------------------------------------------------

       Current_Page = ReturnPage;
       CFMLevel = ReturnLevel;
   int   NumberOfChars;	
// number of characters from the input buffer
//
   NumberOfChars = strlen(buffer());			// see how long the input string was
//
// The prompt starts as 3 underscore characters (_).  The input buffer adds 
// to this string and does not overwrite it.  Therefore, if the user enters
// a 3 character page number, the number of characters will equal 6.  A page number
// of 4 characters is too long and therefore illegal.
//
   if (4 < NumberOfChars)				// Page number > 3 characters
   {
      DisplayPopUpErrorMessage("ILLEGAL SECTOR NUMBER\\0");
   }
   else if (3 >= NumberOfChars)				// Nothing entered
   {
      DisplayPopUpErrorMessage("NO INPUT, RE-ENTER SECTOR NUMBER\\0");
   }
   else							// Something valid entered
   {
//=========================================================================================== 
      if (CFMLevel == 1)
      {
      strcpy(InputField,"");				// Initialize to the null string
      strncpy(InputField,buffer(),(NumberOfChars-3));	// copy just the inputted characters
      InputField[NumberOfChars-3] = '\\0';		// and terminate with the null char
//
         strcpy(DesiredPage,"");				// Initialize 
         strcat(DesiredPage,"Page2");			// Start with Page
         strcat(DesiredPage,InputField);			// always 0 in CFMLevel 1
         strcat(DesiredPage,"0");			// always freom 1 to 7 -->Page21-27
//    if the variable/page exists, then display it
      if (containsName("::YGN3and4.PicYGN_DisplaySectorPopUp",DesiredPage) > 0)
      { 
// for escape key function
         Last_Page = Current_Page;
//
         execute ("{strcpy(PageNumber,%s); }",DesiredPage);
         execute( "{ load( \\"./%s\\" ); }",PageNumber);
         execute( "{ displayPicture( \\"Main\\", \\"./%s\\" ); }",PageNumber);
      }
      else
      {   						// otherwise, output an error message
         DisplayPopUpErrorMessage("INVALID SECTOR NUMBER\\0");
      }
//
      edit(OFF);					// turn the edit mode of
      } //end if (CFMLevel == 1)
//=========================================================================================== 
      if (CFMLevel == 2)
      {
      strcpy(InputField,"");				// Initialize to the null string
      strncpy(InputField,buffer(),(NumberOfChars-3));	// copy just the inputted characters
      InputField[NumberOfChars-3] = '\\0';		// and terminate with the null char
//
//    modified by hspark for sector 0
   if (atoi(InputField) != 0)
   {
      strcpy(DesiredPage,"");				// Initialize 
      strcat(DesiredPage,"Page3");                      
//        
      if (SectoringPage == 1)                      // Start with Page
         strcat(DesiredPage,"1");			// Start with Page
      else if (SectoringPage == 2)
         strcat(DesiredPage,"2");			// Start with Page
      else if (SectoringPage == 3)
         strcat(DesiredPage,"3");			// Start with Page
      else if (SectoringPage == 4)
         strcat(DesiredPage,"4");			// Start with Page
      else if (SectoringPage == 5)
         strcat(DesiredPage,"5");			// Start with Page
      else if (SectoringPage == 6)
         strcat(DesiredPage,"6");			// Start with Page
      else if (SectoringPage == 7)
         strcat(DesiredPage,"7");			// Start with Page
      else printf("No Valid Sector Number !!!!!!");
      strcat(DesiredPage,InputField); // and add ###
   }
   else
   {
      strcpy(DesiredPage,"");
      strcat(DesiredPage,"Page11");
      strcat(DesiredPage,InputField);
   }  
      printf("DesiredPage=%s",DesiredPage );

//    if the variable/page exists, then display it
      if (containsName("::YGN3and4.PicYGN_DisplaySectorPopUp",DesiredPage) > 0)
      { 
         execute ("{strcpy(PageNumber,%s); }",DesiredPage);
         execute( "{ load( \\"./%s\\" ); }",PageNumber);
         execute( "{ displayPicture( \\"Main\\", \\"./%s\\" ); }",PageNumber);
      }
      else
      {   						// otherwise, output an error message
         DisplayPopUpErrorMessage("INVALID SECTOR NUMBER\\0");
      }
//

      edit(OFF);					// turn the edit mode of
      } //end if (CFMLevel == 2)
//==========================================================================================
//    modified by hspark for sector 0
      if (CFMLevel == 3)
      {
      strcpy(InputField,"");				// Initialize to the null string
      strncpy(InputField,buffer(),(NumberOfChars-3));	// copy just the inputted characters
      InputField[NumberOfChars-3] = '\\0';		// and terminate with the null char
//
      strcpy(DesiredPage,"");				// Initialize 
      strcat(DesiredPage,"Page2");
//        
      if (SectoringPage == 1)                      // Start with Page
         strcat(DesiredPage,"1");			// Start with Page
      else if (SectoringPage == 2)
         strcat(DesiredPage,"2");			// Start with Page
      else if (SectoringPage == 3)
         strcat(DesiredPage,"3");			// Start with Page
      else if (SectoringPage == 4)
         strcat(DesiredPage,"4");			// Start with Page
      else if (SectoringPage == 5)
         strcat(DesiredPage,"5");			// Start with Page
      else if (SectoringPage == 6)
         strcat(DesiredPage,"6");			// Start with Page
      else if (SectoringPage == 7)
         strcat(DesiredPage,"7");			// Start with Page
      else printf("No Valid Sector Number !!!!!!");
      strcat(DesiredPage,InputField);			// and add ###
      printf("DesiredPage=%s",DesiredPage );

//    if the variable/page exists, then display it
      if (containsName("::YGN3and4.PicYGN_DisplaySectorPopUp",DesiredPage) > 0)
      { 
         execute ("{strcpy(PageNumber,%s); }",DesiredPage);
         execute( "{ load( \\"./%s\\" ); }",PageNumber);
         execute( "{ displayPicture( \\"Main\\", \\"./%s\\" ); }",PageNumber);
      }
      else
//==========================================================================================
      {   						// otherwise, output an error message
         DisplayPopUpErrorMessage("INVALID SECTOR NUMBER\\0");
      }
//
      edit(OFF);					// turn the edit mode of
      } //end if (CFMLevel == 3)
//
//    end of hspark's modification

   }  // end of else
      edit(OFF);					// turn the edit mode of
}`;
    }
    dialogue
