  function `void nextView()
  {
     DTrendTimer_Active = 0;
     DTrendCounter_Active = 0;
     Value_idx = 1;
     nextView_Active = 1;
  
     int m;
  //   m = Interface->GenericRequestMessage.data.requestOption;
     m =   DTrendSet;
     printf("nextView DTrendSet : %d",DTrendSet);	//CORENET 2017 by Philky Kwon
  
     if ( 1 == m)
  //   Interface->GenericRequestMessage.data.requestOption = 2;
       {
        DTrendSet  = 2;
        Current_Page = 822;
       }
     else
  //   Interface->GenericRequestMessage.data.requestOption = 1;
        {
        DTrendSet  = 1;
        Current_Page = 821;
        }
     Initialize();
  }`

  function `void ProcessDTrendInfo()
  {
     printf("ProcessDTrendInfo(): ...........................................");
  
