       Value_invis = Value_idx+1;
  
  //     execute("{strcpy(Time%d.theText, Interface->System.timeString);}",Value_idx);	// CORENET 2012.07.18
       execute("{strncpy(currtime%d, Interface->System.timeString, 8);}",Value_idx);
       execute("{Time%d.visibility = 1;}",Value_idx);
  
      for (j=1; j<=NUM_DTREND_PER_SET; j++)
      {
  
         if (!Blank[j])
         {
  
  // by yrlee
  
            execute("{Set%dTrd%dValue%d.value = Set%dTrd%dCurrent.PointId->value;}",i,j,Value_idx,i,j);
            execute("{strcpy(Set%dTrd%dValue%d.disfmt, Set%dTrd%dCurrent.PointId->disfmt);}",i,j,Value_idx,i,j);
  
            execute("{Set%dTrd%dValue%d.BlinkBox_foregroundFillColour = Set%dTrd%dCurrent.BlinkBox_foregroundFillColour;}",i,j,Value_idx,i,j);
  //          execute("{Set%dTrd%dValue%d.BlinkBox_foregroundColour = Set%dTrd%dCurrent.BlinkBox_foregroundColour;}",i,j,Value_idx,i,j);
            execute("{Set%dTrd%dValue%d.OOR_High_visibility = Set%dTrd%dCurrent.OOR_High_visibility;}",i,j,Value_idx,i,j);
            execute("{Set%dTrd%dValue%d.Bad_Text_visibility = Set%dTrd%dCurrent.Bad_Text_visibility;}",i,j,Value_idx,i,j);
            execute("{Set%dTrd%dValue%d.OOR_Low_visibility = Set%dTrd%dCurrent.OOR_Low_visibility;}",i,j,Value_idx,i,j);
  
            execute("{Set%dTrd%dValue%d.NumericValue_visibility = Set%dTrd%dCurrent.NumericValue_visibility;}",i,j,Value_idx,i,j);
            execute("{Set%dTrd%dValue%d.NumericValue_foregroundColour = Set%dTrd%dCurrent.NumericValue_foregroundColour;}",i,j,Value_idx,i,j);
  //          execute("{Set%dTrd%dValue%d.NumericValue_backgroundColour = Set%dTrd%dCurrent.NumericValue_backgroundColour;}",i,j,Value_idx,i,j);
  
            execute("{Set%dTrd%dValue%d.OOS_Text_visibility = Set%dTrd%dCurrent.OOS_Text_visibility;}",i,j,Value_idx,i,j);
  //          execute("{Set%dTrd%dValue%d.OOS_Text_foregroundColour = Set%dTrd%dCurrent.OOS_Text_foregroundColour;}",i,j,Value_idx,i,j);
  
            execute("{Set%dTrd%dValue%d.Inserted_visibility = Set%dTrd%dCurrent.Inserted_visibility;}",i,j,Value_idx,i,j);
  
            execute("{Set%dTrd%dValue%d.Dashes_visibility = Set%dTrd%dCurrent.Dashes_visibility;}",i,j,Value_idx,i,j);
            execute("{Set%dTrd%dValue%d.Dashes_foregroundColour = Set%dTrd%dCurrent.Dashes_foregroundColour;}",i,j,Value_idx,i,j);
  
  
            execute("{Set%dTrd%dValue%d.StatePhrase_visibility = Set%dTrd%dCurrent.StatePhrase_visibility;}",i,j,Value_idx,i,j);
  
  //>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
  /*--------------------------
            execute("{
     	     if(Set%dTrd%dValue%d.StatePhrase.visibility==1)
  	     {
                  Set%dTrd%dValue%d.StatePhrase_foregroundColour = Set%dTrd%dCurrent.StatePhrase_foregroundColour;
  //                Set%dTrd%dValue%d.StatePhrase_backgroundColour = Set%dTrd%dCurrent.StatePhrase_backgroundColour;
  
                  strcpy(Set%dTrd%dValue%d.message1, Set%dTrd%dCurrent.PointId->message1);
                  strcpy(Set%dTrd%dValue%d.message2, Set%dTrd%dCurrent.PointId->message2);
  	     };
  	  }",i,j,Value_idx, i,j,Value_idx,i,j, i,j,Value_idx,i,j, i,j,Value_idx,i,j, i,j,Value_idx,i,j);
  --------------------------*/
            execute("{ if(Set%dTrd%dValue%d.StatePhrase.visibility==1) { Set%dTrd%dValue%d.StatePhrase_foregroundColour = Set%dTrd%dCurrent.StatePhrase_foregroundColour; strcpy(Set%dTrd%dValue%d.message1, Set%dTrd%dCurrent.PointId->message1); strcpy(Set%dTrd%dValue%d.message2, Set%dTrd%dCurrent.PointId->message2); }; }",i,j,Value_idx, i,j,Value_idx,i,j, i,j,Value_idx,i,j, i,j,Value_idx,i,j, i,j,Value_idx,i,j);
  //<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
  
            execute("{Set%dTrd%dValue%d.ErrorText_visibility = Set%dTrd%dCurrent.ErrorText_visibility;}",i,j,Value_idx,i,j);
            execute("{Set%dTrd%dValue%d.ErrorText_foregroundColour = Set%dTrd%dCurrent.ErrorText_foregroundColour;}",i,j,Value_idx,i,j);
            execute("{Set%dTrd%dValue%d.visibility = 1;}",i,j,Value_idx);
        }
  
  //      printf("%s",Set1Trd1Current.StatePhrase_theText) ;
  
        if (Value_idx < 20)
        {
           execute("{Set%dTrd%dValue%d.visibility = 0;}",i,j,Value_invis);
  //         execute("{Set%dTrd%dValue%d.MakInvisible();}",i,j,Value_invis);
           execute("{Time%d.visibility = 0;}",Value_invis);
        }
     }   //end-for
  
     if (Value_idx == 20) Value_idx = 0;
     Value_idx++;
  }`

  function `void ProcessDTrendTimer()
  {
  // This function is called by the OneSecondTimer() in every second and then make a time
  // interval based on the DTrendRate provided by Operator.
  // At the time interval this function calls the function of ProcessDTrendInfo()
  // in PicYGN_DigitalTrendView.ppic.
  
  // Decrement the DTrendRate timer
  //   printf(" 1-ProcessDTrendTimer()--DTrendCounter %d",DTrendCounter);
  
   if (DTrendRate == 1) // Only when the DTrendRate input is 1
      {
  //    printf("Processing the Set-1 Information..........");
        ProcessDTrendInfo();
        DTrendCounter = DTrendRate; // From PicYGN_DigitalTrendManu.ppic
      }
  
   else
   {
      if (DTrendCounter_Active == 0) // Initially do this statements
        {
          DTrendCounter = DTrendRate;
          DTrendCounter_Active = 1;
          DTrendCounter--;
  //      printf(" 2-ProcessDTrendTimer()--DTrendCounter %d",DTrendCounter);
        }
  
      else // After the if statement done, execute this else statements
        {
          DTrendCounter--;
  //      printf(" 3-ProcessDTrendTimer()--DTrendCounter %d",DTrendCounter);
  
  //      If the timer has expired, execute ProcessDTrendInfo()
  
          if (DTrendCounter == 0)
            {
  //         printf("YGN3and4- Processing the Set-1 Information..........");
             ProcessDTrendInfo();
             DTrendCounter = DTrendRate;
             }
  
        }// end of else (DTrendCounter_Active == 0)
  
    }
  
  //  update();
  //  return;
  }`

  function `void UpdateLocalsFromInterface()
  {
     int k ;
  // Set visibility for Print Processing
  
  //   ProcessReqMsg.visibility = 0;
  //   PrintProcessMsg.visibility = 1;
  
     int i,j,m;      // loop variables
  
     m =   DTrendSet;
  
     i = 1 ;
  
     for (j=1;j<=NUM_DTREND_PER_SET;j++)
     {
        execute("{strcpy(Set%dTrd%dPidNo.TheNewText,pDigitalTrendData->Set%dPoint%d);}",i,j,m,j);
  
       for (k=1;k<=20;k++)
       {
        execute("{strcpy(Set%dTrd%dValue%d.disfmt, Set%dTrd%dCurrent.PointId->disfmt);}",i,j,k,i,j);
  
       }//end of k++
  
      }
  
     update();
  }`

  function `void UpdateLocalsFromInterfacePrint()
