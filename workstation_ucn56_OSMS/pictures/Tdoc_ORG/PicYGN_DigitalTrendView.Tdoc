  function `PidInputButton * GetpoPID(int Set, int Trd)
  {
    // Returns a pointer to the object that holds the PID
    // for Set #, Trd #
  
    execute("{poPID = &Set%dTrd%dPidNo;}", Set, Trd);
    return(poPID);
  
  }`

  function `char * GetstrPID(int Set, int Trd)
  {
  // Returns the string of the PID for Set #, Trd #
    PidInputButton * idt = 0;
  
    idt = GetpoPID(Set, Trd);
    return(idt->TheNewText);
  }`

  function `void Initialize()
  {
  
     DisplayAdvisoryMessage(" ");
     DisplayAdvisoryMessage1(" ");
     DisplayAdvisoryMessage2(" ");
     DisplayAdvisoryMessage3(" ");
  
     if(nextView_Active == 0)
     {
       PrintProcessMsg.visibility = 0;
  /*   if(!DTrendInUse)
         ProcessReqMsg.visibility = 1;
       else
         ProcessReqMsg.visibility = 0;
  */
     }
  
     int i,j,k,m;      // loop variables
  
     m =   DTrendSet;
  
     printf("Initialize DTrendSet : %d",DTrendSet);	//CORENET 2017 by Philky Kwon
  
     i = 1;
  
     CFMLevel = 0;
  
     if (DTrendSet == 1)
     {
        Current_Page = 821;
        ::YGN3and4.PicYGN_header.PictureNumber.theText= PicNumber1;
        ::YGN3and4.PicYGN_header.PictureTitle.theText= "DIGITAL TREND 1";	//CORENET 201705 by Philkyu Kwon
        DT_Rate = DT_ScanRate;	//CORENET 0704
        //strcpy(PictureTitle, "DIGITAL  TREND  1");
        update();
        //execute("{strcpy(PictureTitle,\\"DIGITAL  TREND  1\\");}");
     }
     else
     {
        Current_Page = 822;
        ::YGN3and4.PicYGN_header.PictureNumber.theText= PicNumber2;;
        ::YGN3and4.PicYGN_header.PictureTitle.theText= "DIGITAL TREND 2";	//CORENET 201705 by Philkyu Kwon
        DT_Rate = DT_ScanRate;		//CORENET 0704
        //strcpy(PictureTitle, "DIGITAL  TREND  2");
        update();
       // execute("{strcpy(PictureTitle,\\"DIGITAL  TREND  2\\");}");
     }
  
     sprintf(dtime,"%d",pDigitalTrendData->displayRate);
     //strcpy(tbase.theText,dtime);	//CORENET 20170629
     DTrendRate = pDigitalTrendData->displayRate;
  
  //   execute("{strcpy(PictureTitle,\\"DIGITAL  TREND  %d\\");}",m);
  //   printf("%s Initialize()",PictureTitle);
  
     for (j=1;j<=NUM_DTREND_PER_SET;j++)
     {
       for (k=1;k<=20;k++)
       {
        execute("{Set%dTrd%dValue%d.visibility = 0;}",i,j,k);
        execute("{Time%d.visibility = 0;}",k);
  
        if (IsAllBlank(GetstrPID(i, j)))
        {
           execute("{Set%dTrd%dValue%d.visibility = 0;}",i,j,k);
        }
  
        }//end of k++
  
        execute("{Set%dTrd%dDesc.visibility = 1;}",i,j);
        execute("{Set%dTrd%dPidNo.visibility = 1;}",i,j);
  
  //   Get the PID stuff
  
        execute("{strcpy(Set%dTrd%dPidNo.TheOriginalText,pDigitalTrendData->Set%dPoint%d);}",i,j,m,j);
        execute("{strcpy(Set%dTrd%dPidNo.TheNewText,Set%dTrd%dPidNo.TheOriginalText);}",i,j,i,j);
        execute("{strcpy(Set%dTrd%dPidNo.TheNewText,pDigitalTrendData->Set%dPoint%d);}",i,j,m,j);
  
       Blank[j] = IsAllBlank(GetstrPID(i, j)) ;
       if (Blank[j])
       {
        execute("{Set%dTrd%dDesc.visibility = 0;}",i,j);
        execute("{Set%dTrd%dPidNo.visibility = 0;}",i,j);
        continue;
       }
        execute("{ strcpy(TempPid,Set%dTrd%dPidNo.TheNewText);}" ,i,j);
        execute("{pRECORD = \\\`&%-8s\\\`;}" , TempPid);
        execute("{Set%dTrd%dDesc.ThePointId = pRECORD;}",i,j);
        execute("{Set%dTrd%dCurrent.PointId = pRECORD;}",i,j);
  //      printf("ProcessDTrendInfo(1) PID:%s",TempPid);
     }//end of j++
  
     update();
  
     DTrendTimer_Active = 1;
     DTrendCounter_Active = 0;
     Value_idx = 1;
  }`

  function `int IsAllBlank(char * cptr)
  {
    // Return 0 if one non-blank character is found, 1 otherwise
    int blank = 1;
    int i;
  
    for (i=0; i<strlen(cptr); i++, cptr++)
    {
      if (*cptr != ' ')
      {
        blank = 0;
        break;
      }//endif
    }//endfor
    return (blank);
  }`

