  function `void Initialize()
  {
     CFMLevel =0;
     Current_Page = 810;
     CascadeMenuActive = 0 ;
  
     int i,j;      // loop variables
  
     //printf("VideoSetno = %d\\n",VideoSetno) ;
  
     DisplayAdvisoryMessage(" ");
     DisplayAdvisoryMessage1(" ");
     DisplayAdvisoryMessage2(" ");
     DisplayAdvisoryMessage3(" ");
  
     SETUP = 0;
     strcpy(SetupButton.Label,SetupButton.StaticLabel);   //20161121 CORENET by Philkyu Kwon
     Interface->VTFlagMessage.data.flipflop2 = 0;
     ProcessError2Msg.visibility = 0;
  
     procMsg.visibility = 1;
  
        for(j=1;j<=4;j++)
           execute("{VideoTrend%dPID.ERROR=0;}",j);
  
  // Save Old PID for Startinf Time Update
  
     SaveOldPid() ;
  
  // Request vtrend data to CCUR
     Interface->VTFlagMessage.data.requestOption = 6; //dummy option..
     execute("{sendMessageToHost(VTREND_RESET_REQUEST);}");
  
  
  // Video visibility for request message
  // RequestTrendDataMsg.visibility = 1;
  
  // SetNo = VideoSetno ;
  // Priority = 0 ;
  
    // if ((1<=VideoSetno)&&(VideoSetno<=5))	// 20170308 CORENET by Philkyu Kwon
     if ((1<=VideoSetno)&&(VideoSetno<=2))	// 20170308 CORENET by Philkyu Kwon
     {
         i = VideoSetno ;
         VideoSetno = 0 ;
         execute("{setNo%d.Select();}",i) ;
     }
     else { VideoSetno = 0;  setNo1.Select(); }
  
  // DisRate = VT_ScanRate1 ;
  
     if (DisRate==1)        disRate001.Select();
     else if (DisRate==2)   disRate002.Select();
     else if (DisRate==5)   disRate005.Select();
     else if (DisRate==10)  disRate010.Select();
     else if (DisRate==30)  disRate030.Select();
     else if (DisRate==60)  disRate060.Select();
     else if (DisRate==600) disRate600.Select();
     else { DisRate = 1;    disRate001.Select(); }
  
    update();
  }`

  function `int IsAllBlank(char * cptr)
  {
    // Return 0 if one non-blank character is found, 1 otherwise
    int blank = 1;
    int i;
  
    for (i=0; i<strlen(cptr); i++, cptr++)
    {
      if (*cptr != ' ')
      {
        blank = 0;
        break;
      }//endif
    }//endfor
    return (blank);
  }`

  function `int IsDigital(char * PID)
  {
    int retval, sigtype;
  
    // get a pointer to the record for the PID
    execute("{pRECORD = &%s;}",PID);
  
    sigtype = pRECORD->sig_type;
    switch(sigtype)
    {
      case CI:
      case DI:
      case SOE:
      case BCI:
      case DL:
      case QD:
      case XD:
      case CO:
      case BCO:
        retval = 1;
        break;
      default:
        retval = 0;
        break;
    }//endswitch
    return(retval);
  }`

  function `int isDigital(RECORD *PID)
  {
    int retval, sigtype;
  
    // get a pointer to the record for the PID
    pRECORD = PID ;
  
    sigtype = pRECORD->sig_type;
  
    switch(sigtype)
    {
      case CI:
      case DI:
      case SOE:
      case BCI:
      case DL:
      case QD:
      case XD:
      case CO:
      case BCO:
        retval = 1;
        break;
      default:
        retval = 0;
        break;
    }//endswitch
    return(retval);
  }`

