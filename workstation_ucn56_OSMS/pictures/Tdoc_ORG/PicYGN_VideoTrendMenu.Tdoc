  function `void InitButtons_SetNo()
  {
     int i;
  
     procMsg.visibility = 1;
  
  // Data Request
     Interface->VTFlagMessage.data.requestOption = VideoSetno;
     execute("{sendMessageToHost(VTREND_RESET_REQUEST);}");
     printf("########### REQUEST VTREND DATA... ##########") ;
  
     if (VideoSetno!=1) setNo1.UnSelect();
     if (VideoSetno!=2) setNo2.UnSelect();
  
    // 20170308 CORENET by Philkyu Kwon *******************
    // if (VideoSetno!=3) setNo3.UnSelect();
    // if (VideoSetno!=4) setNo4.UnSelect();
    // if (VideoSetno!=5) setNo5.UnSelect();
    // ****************************************************
  
  // ChooseSetup.UnSelect();
  // execute("{setNo%d.Select();}",button);
  // VideoSetno = SetNo ;
  
     for(i=1;i<=4;i++)
        execute("{VideoTrend%dPID.ERROR=0;}",i);
  
  // DisRate = VT_ScanRate1 ;
  
     switch(VideoSetno)
     {
        case 1 : DisRate = VT_ScanRate1 ; break;
        case 2 : DisRate = VT_ScanRate2 ; break;
  	// 20170308 CORENET by Philkyu Kwon *******************
       // case 3 : DisRate = VT_ScanRate3 ; break;
       // case 4 : DisRate = VT_ScanRate4 ; break;
       // case 5 : DisRate = VT_ScanRate5 ; break;
       // ************************************************
        default: DisRate = 1 ; break;
     }
  
  // DisplayRate Button Reset
     execute("{disRate%03d.Select();}",DisRate) ;
  
     if(OldPriority)
     {
        FlagReset(OldSetno) ;
     }
  
     FlagSet(VideoSetno) ;
  
     update();
  }`

