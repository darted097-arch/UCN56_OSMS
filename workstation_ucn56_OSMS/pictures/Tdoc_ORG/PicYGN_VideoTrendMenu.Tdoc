  function `void SaveOldPid()
  {
     int i,j ;
  
     for(i=1; i<=NUM_VIDEO_SETS; i++)
        for (j=1;j<=NUM_VIDEO_PER_SET;j++)
        {
              execute("{strcpy(&OldPid[%d*40+%d*10-50], pVideoTrendData->Set%dPoint%d.VideoTrendId) ;}",i,j,i,j) ;
        }
  
  }`

  function `void SettingUp(int Sel)
  {
    int i,j;
    InputDialogueNumber * poMinValue;
    InputDialogueNumber * poMaxValue;
    InputDialogueNumber * poBasValue;
    InputDialogueText   * poPID;
  
  // Error Check...
  
    if(SETUP == 1)
    {
  
         for (j=1; j<=NUM_VIDEO_PER_SET; j++)
         {
           execute("{ProcessERROR = VideoTrend%dPID.ERROR;}",j);
           if (1 == ProcessERROR) break;
           execute("{ProcessERROR = VideoTrend%dMinValue.ERROR;}",j);
           if (1 == ProcessERROR) break;
           execute("{ProcessERROR = VideoTrend%dMaxValue.ERROR;}",j);
           if (1 == ProcessERROR) break;
           execute("{ProcessERROR = VideoTrend%dBase.ERROR;}",j);
           if (1 == ProcessERROR) break;
  
         } //endfor
  
  
  // Checking for being setup/modify
  
         if (!ProcessERROR)
         {
            Interface->VideoTrendSetupData.Setupno = Sel;
  
  //          printf(" selected no. === %d ",Interface->VideoTrendSetupData.Setupno);
  
  
  // Display Rate Setting...
  
            for (j=1;j<=NUM_VIDEO_PER_SET;j++)
            {
  
               execute("{strcpy(Interface->VideoTrendSetupData.Point%d.VideoTrendId, VideoTrend%dPID.TheNewText);}" ,j,j);
  
               if (IsAllBlank(GetstrPID(j)))
                  execute ("{pRECORD = \`&ERRORPID\`;}");
               else if (IsDigital(GetstrPID(j)))		  // For Digital PID
               {
                     execute("{Interface->VideoTrendSetupData.Point%d.Minimum  = VideoTrend%dMinValue.TheNewNumber;}",j,j);
                     execute("{Interface->VideoTrendSetupData.Point%d.Maximum  = VideoTrend%dMaxValue.TheNewNumber;}",j,j);
                     execute("{Interface->VideoTrendSetupData.Point%d.Baseline = VideoTrend%dBase.TheNewNumber;}",j,j);
               }
               else
               {
                  execute ("{pRECORD = \`&%s\`;}",GetstrPID(j));

		  /***********CORENET 20170620**********************
  
                  if ( (Interface->System.displayedUnits) && (!(pRECORD->pipbitmap & bMETUNIT)) )
                  {
                     execute("{Interface->VideoTrendSetupData.Point%d.Minimum  = (VideoTrend%dMinValue.TheNewNumber - pRECORD->moffset) / pRECORD->mfactor;}",j,j);
                     execute("{Interface->VideoTrendSetupData.Point%d.Maximum  = (VideoTrend%dMaxValue.TheNewNumber - pRECORD->moffset) / pRECORD->mfactor;}",j,j);
                     execute("{Interface->VideoTrendSetupData.Point%d.Baseline = (VideoTrend%dBase.TheNewNumber     - pRECORD->moffset) / pRECORD->mfactor;}",j,j);
                  }
                  else if ( (!Interface->System.displayedUnits) && (pRECORD->pipbitmap & bMETUNIT) )
                  {
                     execute("{Interface->VideoTrendSetupData.Point%d.Minimum  = VideoTrend%dMinValue.TheNewNumber * pRECORD->mfactor + pRECORD->moffset;}",j,j);
                     execute("{Interface->VideoTrendSetupData.Point%d.Maximum  = VideoTrend%dMaxValue.TheNewNumber * pRECORD->mfactor + pRECORD->moffset;}",j,j);
                     execute("{Interface->VideoTrendSetupData.Point%d.Baseline = VideoTrend%dBase.TheNewNumber     * pRECORD->mfactor + pRECORD->moffset;}",j,j);
                  }
                  else */
                  {
                     execute("{Interface->VideoTrendSetupData.Point%d.Minimum  = VideoTrend%dMinValue.TheNewNumber;}",j,j);
                     execute("{Interface->VideoTrendSetupData.Point%d.Maximum  = VideoTrend%dMaxValue.TheNewNumber;}",j,j);
                     execute("{Interface->VideoTrendSetupData.Point%d.Baseline = VideoTrend%dBase.TheNewNumber;}",j,j);
                  }
               }
            }
  
            procMsg.visibility = 1;
  
            execute("{sendMessageToHost(PROCESS_VTREND_DATA);}");
            ProcessError2Msg.visibility = 0;
  
  //        Request vtrend data to CCUR
  
            Interface->VTFlagMessage.data.requestOption = 6; //dummy option..
            execute("{sendMessageToHost(VTREND_RESET_REQUEST);}");
  
  //        Return to Main VTREND Menu
  
            SETUP = 0 ;
  
  //        VT_ScanRate1 = DisRate ;
            execute("{VT_ScanRate%d = DisRate;}",VideoSetno);
  
            execute( "{setNo%d.Select();}",Sel ) ;
  
       } // endif (1 != error)
       else
       {
            ProcessError2Msg.visibility = 1;
       }
  
    }
  
  }`

  function `void SetupNcancel()
  {
     if (!SETUP)         // For SETUP
     {
        if(Priority)
        {
             SETUP = 1 ;
  //         printf("VideoTrend%d SetupMode...",VideoSetno) ;
  //         FlagSet(VideoSetno) ;
        }
     }
     else                     // For CANCEL
     {
        SETUP = 0 ;
        CancelSetup() ;
        execute("{setNo%d.Select();}",VideoSetno) ;
  //      DisRate = VT_ScanRate1 ;
  //      execute("{disRate%03d.Select();}",DisRate) ;
  
     }
     update() ;
  }`

  function `void TimeUpdate()
  {
     int i,j,k;
        for(i=0 ;i<200;i++)
        {
           if(OldPid[i]==' ') OldPid[i] = '\\0' ;
  //         if((i%10==8) ||(i%10==9)) OldPid[i] = '\\0' ;
        }
  
  //      i = VideoSetno ;
  
        execute("{ manageTempShopList(INIT_TEMP_SHOP_LIST,dummy_arg);}");
  
        for(i=1; i<=NUM_VIDEO_SETS; i++) {
           for (j=1;j<=NUM_VIDEO_PER_SET;j++)
           {
               for(k=0; k<10 ;k++)
                  execute("{if(pVideoTrendData->Set%dPoint%d.VideoTrendId[%d]==\\' \\') pVideoTrendData->Set%dPoint%d.VideoTrendId[%d] = \\'\\\\0\\';}",i,j,k,i,j,k) ;
  
               execute("{ppid = Interface->VideoTrendData.Set%dPoint%d.VideoTrendId ;}",i,j) ;
               if((strlen(ppid)==0)||(ppid[0]==' ')) ppid = "ERRORPID" ;
  
               execute("{ if ( strcmp(pVideoTrendData->Set%dPoint%d.VideoTrendId,&OldPid[%d*40+%d*10-50] ) ) { manageTempShopList(TEMP_SHOP_LIST_ADD,pVideoTrendData->Set%dPoint%d.VideoTrendId); ::YGN3and4.VideoSet%dTr%d = \\\`%s->value\\\`; strcpy(VideoSet%d->Trend%d.Time, Interface->System.timeString) ; strcpy(VideoSet%d->Trend%d.Date, Interface->System.dateString) ; time(&VideoSet%d->Trend%d.Counts) ; } }",i,j,i,j,i,j,i,j,ppid, i,j,i,j,i,j) ;
           }
        }
  
