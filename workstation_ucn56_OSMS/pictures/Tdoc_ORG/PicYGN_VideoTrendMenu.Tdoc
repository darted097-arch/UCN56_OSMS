  function `void UpdateLocalsFromInterface()
  {
     int i,j;
  //   float a;
  //   char *temp;
  
     i = VideoSetno ;
  //  for (i=1; i<=NUM_VIDEO_SETS; i++)
     for (j=1; j<=NUM_VIDEO_PER_SET; j++)
     {
  //    Get the PID stuff
        execute("{strcpy(VideoTrend%dPID.TheOriginalText,pVideoTrendData->Set%dPoint%d.VideoTrendId);}",j,i,j);
        execute("{strcpy(VideoTrend%dPID.TheNewText,VideoTrend%dPID.TheOriginalText);}",j,j);
        execute("{VideoTrend%dPID.ERROR = 0;}",j);
  //      execute("{printf(\\"%s\\",VideoTrend%dPID.TheNewText);}","%s",j);
  
  
  // Metric/English Conversion
  
     if (IsAllBlank(GetstrPID(j)))
        execute ("{pRECORD = \`&ERRORPID\`;}");
     else if (IsDigital(GetstrPID(j)))		  // For Digital PID
     {
        execute("{VideoTrend%dMinValue.TheNewNumber = pVideoTrendData->Set%dPoint%d.Minimum;}",j,i,j);
        execute("{VideoTrend%dBase.TheNewNumber =     pVideoTrendData->Set%dPoint%d.Baseline;}",j,i,j);
        execute("{VideoTrend%dMaxValue.TheNewNumber = pVideoTrendData->Set%dPoint%d.Maximum;}",j,i,j);
     }
     else                                           // For Analog PID
     {
        execute ("{pRECORD = \`&%s\`;}",GetstrPID(j));

	/************************ CORENET 20170629*********************
  
        if ( (Interface->System.displayedUnits) && (!(pRECORD->pipbitmap & bMETUNIT)) )
        {
           execute("{VideoTrend%dMinValue.TheNewNumber = pVideoTrendData->Set%dPoint%d.Minimum  * pRECORD->mfactor + pRECORD->moffset ;}",j,i,j);
           execute("{VideoTrend%dBase.TheNewNumber =     pVideoTrendData->Set%dPoint%d.Baseline * pRECORD->mfactor + pRECORD->moffset ;}",j,i,j);
           execute("{VideoTrend%dMaxValue.TheNewNumber = pVideoTrendData->Set%dPoint%d.Maximum  * pRECORD->mfactor + pRECORD->moffset ;}",j,i,j);
        }
        else if ( (!Interface->System.displayedUnits) && (pRECORD->pipbitmap & bMETUNIT) )
        {
           execute("{VideoTrend%dMinValue.TheNewNumber = (pVideoTrendData->Set%dPoint%d.Minimum  - pRECORD->moffset) / pRECORD->mfactor ;}",j,i,j);
           execute("{VideoTrend%dBase.TheNewNumber =     (pVideoTrendData->Set%dPoint%d.Baseline - pRECORD->moffset) / pRECORD->mfactor ;}",j,i,j);
           execute("{VideoTrend%dMaxValue.TheNewNumber = (pVideoTrendData->Set%dPoint%d.Maximum  - pRECORD->moffset) / pRECORD->mfactor ;}",j,i,j);
        }
        else
	*/
        {
           execute("{VideoTrend%dMinValue.TheNewNumber = pVideoTrendData->Set%dPoint%d.Minimum;}",j,i,j);
           execute("{VideoTrend%dBase.TheNewNumber =     pVideoTrendData->Set%dPoint%d.Baseline;}",j,i,j);
           execute("{VideoTrend%dMaxValue.TheNewNumber = pVideoTrendData->Set%dPoint%d.Maximum;}",j,i,j);
        }
  
     }
  
  //    Get the MinValue stuff
  
        execute("{VideoTrend%dMinValue.TheOriginalNumber = VideoTrend%dMinValue.TheNewNumber;}",j,j);
        execute("{sprintf(VideoTrend%dMinValue.TheNewText, \\"%s\\", VideoTrend%dMinValue.TheNewNumber);}",j,GetstrMinNumberFormat(j),j);
        execute("{sprintf(VideoTrend%dMinValue.TheOriginalText, \\"%s\\", VideoTrend%dMinValue.TheOriginalNumber);}",j,GetstrMinNumberFormat(j),j);
        execute("{VideoTrend%dMinValue.ERROR = 0;}",j);
  
  //    Get the Base stuff
  
        execute("{VideoTrend%dBase.TheOriginalNumber = VideoTrend%dBase.TheNewNumber;}",j,j);
        execute("{sprintf(VideoTrend%dBase.TheNewText, \\"%s\\", VideoTrend%dBase.TheNewNumber);}",j,GetstrBasNumberFormat(j),j);
        execute("{sprintf(VideoTrend%dBase.TheOriginalText, \\"%s\\", VideoTrend%dBase.TheOriginalNumber);}",j,GetstrBasNumberFormat(j),j);
        execute("{VideoTrend%dBase.ERROR = 0;}",j);
  
  //    Get the MaxValue stuff
  
        execute("{VideoTrend%dMaxValue.TheOriginalNumber = VideoTrend%dMaxValue.TheNewNumber;}",j,j);
        execute("{sprintf(VideoTrend%dMaxValue.TheNewText, \\"%s\\", VideoTrend%dMaxValue.TheNewNumber);}",j,GetstrMaxNumberFormat(j),j);
        execute("{sprintf(VideoTrend%dMaxValue.TheOriginalText, \\"%s\\", VideoTrend%dMaxValue.TheOriginalNumber);}",j,GetstrMaxNumberFormat(j),j);
        execute("{VideoTrend%dMaxValue.ERROR = 0;}",j);
     }
  
     AssignPid() ;
  
  
  //ProcessError1Msg.visibility = 0;
  
    ProcessError2Msg.visibility = 0;
    procMsg.visibility = 0;
  
  //RequestTrendDataMsg.visibility = 0;
  
    update();
  }`

  function `void ValueErrorReset(int i)
  {
     switch(i)
     {
        case 1 : VideoTrend1MinValue.ERROR = 0 ;
                 VideoTrend1Base.ERROR = 0 ;
                 VideoTrend1MaxValue.ERROR = 0 ;
                 break ;
        case 2 : VideoTrend2MinValue.ERROR = 0 ;
                 VideoTrend2Base.ERROR = 0 ;
                 VideoTrend2MaxValue.ERROR = 0 ;
                 break ;
        case 3 : VideoTrend3MinValue.ERROR = 0 ;
                 VideoTrend3Base.ERROR = 0 ;
                 VideoTrend3MaxValue.ERROR = 0 ;
                 break ;
        case 4 : VideoTrend4MinValue.ERROR = 0 ;
                 VideoTrend4Base.ERROR = 0 ;
                 VideoTrend4MaxValue.ERROR = 0 ;
                 break ;
     }
  }
  
  
  `

  function `void VerifyBase(int trenD)
  {
  // Verify valid input for the Min Value entered for trenD #
  
    int error = 0;
  
    execute("{xx = VideoTrend%dMinValue.TheNewNumber;}",trenD);
    execute("{yy = VideoTrend%dBase.TheNewNumber;}",trenD);
    execute("{zz = VideoTrend%dMaxValue.TheNewNumber;}",trenD);
  
    if ( !((xx <= yy)&&(yy <= zz)) ) error = 1;
  
    if (error)
      execute("{VideoTrend%dBase.ERROR = 1;}",trenD);
    else
    {
      execute("{VideoTrend%dBase.ERROR = 0;}",trenD);
      ProcessError2Msg.visibility = 0 ;
    }
  }`

  function `void VerifyMaxValue(int trenD)
  {
  // Verify valid input for the Max Value entered for trenD #
    InputDialogueNumber * poMax = 0;
    InputDialogueNumber * poMin = 0;
  //  float x,y,z;
    int error = 0;
    int check_type;
  
    poMax = GetpoMaxValue(trenD);
    poMin = GetpoMinValue(trenD);
  
    // Determine the type of checking that is needed and do it.
    check_type = GetPID_CheckType(GetstrPID(trenD));
    switch(check_type)
    {
      case NO_RANGE_TYPE_CHECK:
        error = 0;
        break;
  
      case ZERO_OR_ONE_TYPE_CHECK:
        if (1.0 != poMax->TheNewNumber) error = 1;
        break;
  
      case FULL_TYPE_CHECK:
      default:
  
        xx = GetDB_LoER(trenD);
        yy = poMax->TheNewNumber;
        zz = GetDB_HiER(trenD);
  
        execute("{sprintf(temp,\\"%s\\",xx);}",poMax->TheNumberFormat); xx = atof(temp);
        execute("{sprintf(temp,\\"%s\\",yy);}",poMax->TheNumberFormat); yy = atof(temp);
        execute("{sprintf(temp,\\"%s\\",zz);}",poMax->TheNumberFormat); zz = atof(temp);
  
        // if the entered value is not between the hi and lo engineering range,
        // we have an error
        if ( !((xx <= yy) && (yy <= zz)) ) error = 1;
  
        if (poMax->TheNewNumber <= poMin->TheNewNumber) error = 1;
        break;
    }//endswitch
  
    if (0 == error)
      execute("{VideoTrend%dMaxValue.ERROR = 0;}",trenD);
    else
      execute("{VideoTrend%dMaxValue.ERROR = 1;}",trenD);
  
  }`

  function `void VerifyMinMaxValues(int trenD)
  {
  
    execute("{pRECORD = \`&%s\`;}",GetstrPID(trenD));
  
    execute("{sprintf(temp,\\"%s\\",VideoTrend%dMaxValue.TheNewNumber);}",pRECORD->disfmt,trenD);
    execute("{VideoTrend%dMaxValue.TheNewNumber = atof(temp);}",trenD);
    execute("{VideoTrend%dMaxValue.TheOriginalNumber = VideoTrend%dMaxValue.TheNewNumber;}",trenD,trenD);
  
    execute("{sprintf(temp,\\"%s\\",VideoTrend%dMinValue.TheNewNumber);}",pRECORD->disfmt,trenD);
    execute("{VideoTrend%dMinValue.TheNewNumber = atof(temp);}",trenD);
    execute("{VideoTrend%dMinValue.TheOriginalNumber = VideoTrend%dMinValue.TheNewNumber;}",trenD,trenD);
  
    execute("{sprintf(temp,\\"%s\\",VideoTrend%dBase.TheNewNumber);}",pRECORD->disfmt,trenD);
    execute("{VideoTrend%dBase.TheNewNumber = atof(temp);}",trenD);
    execute("{VideoTrend%dBase.TheOriginalNumber = VideoTrend%dBase.TheNewNumber;}",trenD,trenD);
  
  
  
    execute("{Temp = VideoTrend%dPID.ERROR;}", trenD);
  
    if ( (!IsAllBlank(GetstrPID(trenD))) || (0 == Temp) )
    {
      VerifyMinValue(trenD);
      VerifyMaxValue(trenD);
      VerifyBase(trenD) ;
    }
    ProcessError2Msg.visibility=0 ;
  }`

  function `void VerifyMinValue(int trenD)
  {
  // Verify valid input for the Min Value entered for trenD #
    InputDialogueNumber * poMin = 0;
    InputDialogueNumber * poMax = 0;
    int error = 0;
    int check_type;
  
    poMin = GetpoMinValue(trenD);
    poMax = GetpoMaxValue(trenD);
  
    // Determine the type of checking that is needed and do it.
    check_type = GetPID_CheckType(GetstrPID(trenD));
    switch(check_type)
    {
      case NO_RANGE_TYPE_CHECK:
        error = 0;
        break;
  
      case ZERO_OR_ONE_TYPE_CHECK:
        if (0.0 != poMin->TheNewNumber) error = 1;
        break;
  
      case FULL_TYPE_CHECK:
      default:
        xx = GetDB_LoER(trenD);
        yy = poMin->TheNewNumber;
        zz = GetDB_HiER(trenD);
  
        execute("{sprintf(temp,\\"%s\\",xx);}",poMin->TheNumberFormat); xx = atof(temp);
        execute("{sprintf(temp,\\"%s\\",yy);}",poMin->TheNumberFormat); yy = atof(temp);
        execute("{sprintf(temp,\\"%s\\",zz);}",poMin->TheNumberFormat); zz = atof(temp);
  
        // if the entered value is not between the hi and lo engineering values,
        // we have an error.
        if ( !((xx <= yy) &&  (yy <= zz)) ) error = 1;
  
        if (poMin->TheNewNumber >= poMax->TheNewNumber) error = 1;
        break;
    }//endswitch
  
  //   printf("VideoTrend%dMinValue.ERROR = %d",trenD,error) ;
  
    if (0 == error)
      execute("{VideoTrend%dMinValue.ERROR = 0;}",trenD);
    else
      execute("{VideoTrend%dMinValue.ERROR = 1;}",trenD);
  }`

  function `void VideoMinMaxFromPID(int trenD)
  {
  
  // set Min and Max values from the database for VALID PIDs.
  // Action for INVALID PIDs is not defined
  
      // Set the Numbers in the Min and Max fields.
    if (1 == IsAllBlank(GetstrPID(trenD)))
    {
      execute("{VideoTrend%dMinValue.TheNewNumber = 0.0;}",trenD);
      execute("{VideoTrend%dMinValue.TheOriginalNumber = 0.0;}",trenD);
  
      execute("{VideoTrend%dMaxValue.TheNewNumber = 0.0;}",trenD);
      execute("{VideoTrend%dMaxValue.TheOriginalNumber = 0.0;}",trenD);
  
      execute("{VideoTrend%dBase.TheNewNumber = 0.0;}",trenD);
      execute("{VideoTrend%dBase.TheOriginalNumber = 0.0;}",trenD);
  
    }//endif PID is all blanks
    else
    {
  
      if (IsDigital(GetstrPID(trenD)))		// For Digital PID
      {
         execute("{VideoTrend%dMinValue.TheNewNumber = 0.0;}",trenD);
         execute("{VideoTrend%dMinValue.TheOriginalNumber = 0.0;}",trenD);
         execute("{VideoTrend%dMaxValue.TheNewNumber = 1.0;}",trenD);
         execute("{VideoTrend%dMaxValue.TheOriginalNumber = 1.0;}",trenD);
         execute("{VideoTrend%dBase.TheNewNumber = 0.5;}",trenD);
         execute("{VideoTrend%dBase.TheOriginalNumber = 0.5;}",trenD);
      }
      else					// For Analog PID
      {
         execute("{pRECORD = \`&%s\`;}",GetstrPID(trenD));
  
         if ((EngRangeLo(pRECORD)==0) && (EngRangeHi(pRECORD)==0))
         {                                                              // for constant & calculated PID (yrlee 990223)
            execute("{VideoTrend%dMinValue.TheNewNumber = pRECORD->value -100;}",trenD);
            execute("{VideoTrend%dMinValue.TheOriginalNumber = VideoTrend%dMinValue.TheNewNumber;}",trenD,trenD);
            execute("{VideoTrend%dMaxValue.TheNewNumber = pRECORD->value +100;}",trenD);
            execute("{VideoTrend%dMaxValue.TheOriginalNumber = VideoTrend%dMaxValue.TheNewNumber;}",trenD,trenD);
            execute("{VideoTrend%dBase.TheNewNumber = pRECORD->value;}",trenD);
            execute("{VideoTrend%dBase.TheOriginalNumber = VideoTrend%dBase.TheNewNumber;}",trenD,trenD);
         }
         else
         {
            execute("{VideoTrend%dMinValue.TheNewNumber = EngRangeLo(pRECORD);}",trenD);
            execute("{VideoTrend%dMinValue.TheOriginalNumber = VideoTrend%dMinValue.TheNewNumber;}",trenD,trenD);
            execute("{VideoTrend%dMaxValue.TheNewNumber = EngRangeHi(pRECORD);}",trenD);
            execute("{VideoTrend%dMaxValue.TheOriginalNumber = VideoTrend%dMaxValue.TheNewNumber;}",trenD,trenD);
  
            execute("{VideoTrend%dBase.TheNewNumber = (VideoTrend%dMinValue.TheNewNumber + VideoTrend%dMaxValue.TheNewNumber)/2;}",trenD,trenD,trenD);
            execute("{sprintf(temp,\\"%s\\",VideoTrend%dBase.TheNewNumber);}",pRECORD->disfmt,trenD);
            execute("{VideoTrend%dBase.TheNewNumber = atof(temp);}",trenD);
            execute("{VideoTrend%dBase.TheOriginalNumber = VideoTrend%dBase.TheNewNumber;}",trenD,trenD);
  
         }
      }//endelse not all blank
    }
  
    execute("{sprintf(VideoTrend%dMinValue.TheNewText, \\"%s\\", VideoTrend%dMinValue.TheNewNumber);}",trenD,GetstrMinNumberFormat(trenD),trenD);
    execute("{sprintf(VideoTrend%dMinValue.TheOriginalText, \\"%s\\", VideoTrend%dMinValue.TheOriginalNumber);}",trenD,GetstrMinNumberFormat(trenD),trenD);
    execute("{VideoTrend%dMinValue.ERROR = 0;}",trenD);
  
    execute("{sprintf(VideoTrend%dMaxValue.TheNewText, \\"%s\\", VideoTrend%dMaxValue.TheNewNumber);}",trenD,GetstrMinNumberFormat(trenD),trenD);
    execute("{sprintf(VideoTrend%dMaxValue.TheOriginalText, \\"%s\\", VideoTrend%dMaxValue.TheOriginalNumber);}",trenD,GetstrMinNumberFormat(trenD),trenD);
    execute("{VideoTrend%dMaxValue.ERROR = 0;}",trenD);
  
    execute("{sprintf(VideoTrend%dBase.TheNewText, \\"%s\\", VideoTrend%dBase.TheNewNumber);}",trenD,GetstrMinNumberFormat(trenD),trenD);
    execute("{sprintf(VideoTrend%dBase.TheOriginalText, \\"%s\\", VideoTrend%dBase.TheOriginalNumber);}",trenD,GetstrMinNumberFormat(trenD),trenD);
    execute("{VideoTrend%dBase.ERROR = 0;}",trenD);
  
  }//end routine`

