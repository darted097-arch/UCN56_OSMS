  function `void InitButtons_DisRate()
  {
  
   if (DisRate!=1)   disRate001.UnSelect();
   if (DisRate!=2)   disRate002.UnSelect();
   if (DisRate!=5)   disRate005.UnSelect();
   if (DisRate!=10)  disRate010.UnSelect();
   if (DisRate!=30)  disRate030.UnSelect();
   if (DisRate!=60)  disRate060.UnSelect();
