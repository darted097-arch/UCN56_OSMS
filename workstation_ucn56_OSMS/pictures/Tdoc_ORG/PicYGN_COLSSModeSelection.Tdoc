     OP31.up.foregroundFillColour = COLOR_BUTTON_TOP_SHADOW;
  
     OP31.downright.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
     OP31.downright.foregroundFillColour = COLOR_BUTTON_BOTTOM_SHADOW;
     OP31.down.foregroundColour = COLOR_BUTTON_BOTTOM_SHADOW;
