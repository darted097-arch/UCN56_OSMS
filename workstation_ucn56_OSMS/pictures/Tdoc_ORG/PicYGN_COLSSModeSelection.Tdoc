  function `void Option1()
  {
     OptionSelected = COLSS_SCHEDULED_MODE;
     KeepSelected1();
     ProcessModeChange(OptionSelected);
  
  }`

  function `void Option2()
  {
     OptionSelected = COLSS_UNSCHEDULED_MODE;
     KeepSelected1();
     ProcessModeChange(OptionSelected);
  }`

  function `void Option3()
  {
     OptionSelected = COLSS_TEST_MODE;
     KeepSelected1();
     ProcessModeChange(OptionSelected);
  }`

  function `void ProcessBurnupOption(int selection)
  {
     SelectedBurnupOption = selection ;
     BurnupStatus=TRUE;
  
     switch (selection)
     {
        case 1 :   // Yes Button Pressed
           NoButton.UnSelect();
           break;
        case 0 :   // No Button Pressed
           YesButton.UnSelect();
           break;
     }
     update();
  }`

  function `void ProcessingConfirmed(int mode)
  {
     colss_current_mode=\`pColssData->ModeData->colss_current_mode\`;
  //
     OptionSelected = colss_current_mode;
  // printf("COLSS selected = %d", colss_current_mode );
  // printf("option selected = %d", OptionSelected);
     KeepSelectedAfter();
  //
     update();
  
     printf("### colss_current_mode = %4X",colss_current_mode);
  
     switch(mode)
     {
        case CONFIRM_COLSS_CURRENT_MODE:
        case CONFIRM_COLSS_MODE_CHANGE:
             ChangeColssMode(colss_current_mode);
             DisplayModeChanged(colss_current_mode);
             break;
        case CONFIRM_COLSS_TEST_CASE:
             InitTestInput();
             ChangeColssMode(colss_current_mode );
             DisplayModeChanged(colss_current_mode ); // Mode should be current_colss_mode from ccur
             break;
     }
     update();
  }`

  function `void ProcessModeChange(int mode)
  {
     int   goModeChange;
  
     goModeChange = Request_Mode_Change(mode);
  
     if(goModeChange)
     {  IsMenuSelected = TRUE;
        ChangeColssMode(mode);
     }
  }`

  function `void ProcessPrintOption(int OptionSelected)
  {
     SelectedPrintOption = OptionSelected;
     PrintOptionStatus=TRUE;
  
     switch(OptionSelected)
     {
        case 1:
           OP31.IsPrintOptionSelected = TRUE;
           OP32.IsPrintOptionSelected = FALSE;
           OP33.IsPrintOptionSelected = FALSE;
           OP31.TheFontColor = 0;
  //         OP31.backgroundTextColour = 1;
           OP32.TheFontColor = 1;
  //         OP32.backgroundTextColour = 0;
           OP33.TheFontColor = 1;
  //         OP33.backgroundTextColour = 0;
           break;
        case 2:
           OP31.IsPrintOptionSelected = FALSE;
           OP32.IsPrintOptionSelected = TRUE;
           OP33.IsPrintOptionSelected = FALSE;
           OP31.TheFontColor = 1;
  //         OP31.backgroundTextColour = 0;
           OP32.TheFontColor = 0;
  //         OP32.backgroundTextColour = 1;
           OP33.TheFontColor = 1;
  //         OP33.backgroundTextColour = 0;
           break;
        case 3:
           OP31.IsPrintOptionSelected = FALSE;
           OP32.IsPrintOptionSelected = FALSE;
           OP33.IsPrintOptionSelected = TRUE;
           OP31.TheFontColor = 1;
  //         OP31.backgroundTextColour = 0;
           OP32.TheFontColor = 1;
  //         OP32.backgroundTextColour = 0;
           OP33.TheFontColor = 0;
  //         OP33.backgroundTextColour = 1;
           break;
     }
     update();
  }`

  function `void ProcessProcessButton()
  {
  //
     OptionSelected = SelectedMenu;
  //
     if (IsMenuSelected == TRUE)
     {
     switch(SelectedMenu)
     {
        case COLSS_SCHEDULED_MODE:
              if (colss_current_mode == COLSS_UNSCHEDULED_MODE){
  
         KeepSelected1();
         pColssData->ModeData->ws_to_host_mode = COLSS_SCHEDULED_MODE;
         pColssData->message_type = REQUEST_COLSS_MODE_CHANGE;
         DisplayAdvisoryMessage3("REQUESTING COLSS SCHEDULED MODE CHANGE");
         execute("{sendMessageToHost(REQUEST_COLSS_PROCESSING);}");
         }	// CORENET 20170511 by Philkyu Kwon
         else
                 DisplayAdvisoryMessage("MODE MUST BE UNSCHED");
  
         break;
  
        case COLSS_UNSCHEDULED_MODE:
  
         KeepSelected1();
         pColssData->ModeData->ws_to_host_mode = COLSS_UNSCHEDULED_MODE;
         pColssData->message_type = REQUEST_COLSS_MODE_CHANGE;
         DisplayAdvisoryMessage3("REQUESTING COLSS UNSCHEDULED MODE CHANGE");
         execute("{sendMessageToHost(REQUEST_COLSS_PROCESSING);}");
	 
         break;
  
        case 3:
  
	//CORENET 20170629 by Philkyu Kwon
         if (colss_current_mode != COLSS_UNSCHEDULED_MODE)
                 DisplayAdvisoryMessage("MODE MUST BE UNSCHED");
	 else
	 {
         	KeepSelected1();
         	if( TestInputVerify() == TRUE)
         	{
            		pColssData->ModeData->ws_to_host_mode = COLSS_TEST_MODE;
            		pColssData->message_type = REQUEST_COLSS_TEST_CASE;
            		pColssData->ModeData->test_case = SelectedTestCaseOption;
            		pColssData->ModeData->use_burnup_file = SelectedBurnupOption ;
            		pColssData->ModeData->print_option = SelectedPrintOption ;
            		DisplayAdvisoryMessage3("REQUESTING COLSS TEST");
            		execute("{sendMessageToHost(REQUEST_COLSS_PROCESSING);}");
            		text1_box.foregroundFillColour = 0;
            		text2_box.foregroundFillColour = 0;
            		text3_box.foregroundFillColour = \`COLOR_ACTIVE_ON_OPEN\`;
            		unscheduledMode.TheTitle = "UNSCHEDULED MODE (OFF)";
            		testMode.TheTitle = "TEST CASE (ON)";
            		DisplayAdvisoryMessage2("COLSS IN TEST MODE");
         	}
	 }
  
         break;
       } // end of switch statement
     } else DisplayAdvisoryMessage("SELECT MODE AND/OR TEST INPUT");
      ProcessText.Initialize();
  //    CancelText.Initialize();
  
    update();
  }`

  function `void ProcessTestCase(char *str)
  {
      SelectedTestCaseOption =  atoi(str);
     if (SelectedTestCaseOption == 99)
     {
        DisplayAdvisoryMessage("41 TEST CASES ARE SELECTED");
        YesButton.Select();
     }
     else
     if (SelectedTestCaseOption < 1 || SelectedTestCaseOption > 46)
     {
        DisplayAdvisoryMessage("TEST CASE INPUT MUST BE 1 TO 46");
        TestCaseNumStatus = FALSE;
        return;
     }
     TestCaseNumStatus = TRUE;
     return;
   }`

  function `int Request_Mode_Change(int mode)
  {
     int changeMode = FALSE ;
  //colss_current_mode= \`pColssData->ModeData->colss_current_mode\`;update();
  
     switch(mode)
     {
         case COLSS_TEST_MODE:
              if (colss_current_mode == COLSS_UNSCHEDULED_MODE)
                  changeMode=TRUE;
              else
                  DisplayAdvisoryMessage("MODE MUST BE UNSCHED");
              break;
        case COLSS_SCHEDULED_MODE:
              if (colss_current_mode == COLSS_UNSCHEDULED_MODE)
                 changeMode=TRUE;
              else
              {
                 ChangeColssMode(COLSS_SCHEDULED_MODE);
                 DisplayAdvisoryMessage("MODE MUST BE UNSCHED");
              }
              break;
  
        case COLSS_UNSCHEDULED_MODE:
              if (colss_current_mode != COLSS_UNSCHEDULED_MODE)
                 changeMode=TRUE;
              else
              {
                 ChangeColssMode(COLSS_UNSCHEDULED_MODE);
                 DisplayAdvisoryMessage("MODE MUST BE SCHED");
              }
              break;
  
     }
     return(changeMode);
  }`

  function `void selectOption(int selectedValue)
  {
     Option = selectedValue;
     displayOptionSelected(selectedValue);
     SetupReadInputValue(selectedValue);
     update();
  }`

  function `void TestInputBox_Visible(int isActive)
  {
     InputArea.Active = isActive ;
     YesButton.Active  = isActive;
     NoButton.Active  =isActive ;
  //   text11.Active  = isActive ;
  //   text12.Active  = isActive ;
  //   text13.Active  = isActive ;
  
     update();
  }`

  function `int TestInputVerify()
  {
     int return_status = FALSE;
  
     if(TestCaseNumStatus == FALSE) DisplayAdvisoryMessage("ENTER TEST CASE NUMBER");
  
     if(BurnupStatus == FALSE) DisplayAdvisoryMessage2("SELECT IF USE OF BURNUP FILE");
  
     if(PrintOptionStatus == FALSE) DisplayAdvisoryMessage3("ENTER PRINT OPTION NUMBER");
  
     if ((TestCaseNumStatus == TRUE) &&
         (BurnupStatus == TRUE )&&
         (PrintOptionStatus == TRUE ))
          return_status = TRUE;
  
     if(44<=SelectedTestCaseOption && SelectedTestCaseOption<=46)
        if(SelectedPrintOption==3)
        { DisplayAdvisoryMessage2("SUMMART PAGES OPTION IS NOT AVAILABLE");
          DisplayAdvisoryMessage3("FOR TEST CASES 44, 45 AND 46");
          return_status = FALSE;
         }
     update();
     return(return_status);
  }`

