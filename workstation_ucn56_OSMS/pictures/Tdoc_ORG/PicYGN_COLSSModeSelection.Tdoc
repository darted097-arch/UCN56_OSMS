picture PicYGN_COLSSModeSelection
{
  worldX = 0;
  worldY = 0;
  worldWidth = 1280;
  worldHeight = 824;
  oneToOne = 1;
  backgroundColour = 0;
  updateMode = 2;
  resizeMode = 0;
  xSnap = 1;
  ySnap = 1;
  radiusSnap = 0;
  angleSnap = 0;
  crosshairStyle = 1;
  crosshairLength = 0;
  crosshairFollowSnap = `isInEditMode()`;
  crosshairVisibility = `isInEditMode()`;
  xReference = 500;
  yReference = 500;
  xScaleFactor = 1;
  yScaleFactor = 1;
  rotationAngle = 0;

  int BurnupStatus = 0;

  int colss_current_mode = `pColssData->ModeData->colss_current_mode`;

  int IsMenuSelected = 1;

  int MaxTime = 0;

  int OptionSelected = 3;

  Colss_Data* pColssData = `&Interface->ColssData`;

  char PictureNumber[50] = "121";

  char PictureTitle[50] = "COLSS   MODES";

  int PrintOptionStatus = 0;

  int run_status = 1;

  int SelectedBurnupOption = -1;

  int SelectedMenu = 2;

  int SelectedPrintOption = -1;

  int SelectedTestCaseOption = -1;

  int TestCaseNumStatus = 0;

  int TestInputStatus = 0;

  int TheFontColor = 4;

  int TheTextFont = `font7`;

  function `void ChangeColssMode(int mode)
  {
     switch(mode)
     {
        case COLSS_SCHEDULED_MODE:
  
         TestInputBox_Visible(0);
  //     SelectedMenu = 1;
         scheduledMode.IsOptionSelected = TRUE;
         scheduledMode.TheFontColor = 0;
  //       scheduledMode.backgroundTextColour = 1;
         unscheduledMode.IsOptionSelected = FALSE;
         unscheduledMode.TheFontColor = 1;
  //       unscheduledMode.backgroundTextColour = 0;
         testMode.IsOptionSelected =  FALSE;
         testMode.TheFontColor = 1;
  //       testMode.backgroundTextColour = 0;
         break;
  
        case COLSS_UNSCHEDULED_MODE:
  
         TestInputBox_Visible(0);
  //     SelectedMenu = 2;
         scheduledMode.IsOptionSelected = FALSE;
         scheduledMode.TheFontColor = 1;
  //       scheduledMode.backgroundTextColour = 0;
         unscheduledMode.IsOptionSelected = TRUE;
         unscheduledMode.TheFontColor = 0;
  //       unscheduledMode.backgroundTextColour = 1;
         testMode.IsOptionSelected =  FALSE;
         testMode.TheFontColor = 1;
  //       testMode.backgroundTextColour = 0;
         break;
  
        case COLSS_TEST_MODE:
  
         TestInputBox_Visible(1);
  //     SelectedMenu = 3;
         scheduledMode.IsOptionSelected = FALSE;
         scheduledMode.TheFontColor = 1;
  //       scheduledMode.backgroundTextColour = 0;
         unscheduledMode.IsOptionSelected = FALSE;
         unscheduledMode.TheFontColor = 1;
  //       unscheduledMode.backgroundTextColour = 0;
         testMode.IsOptionSelected =  TRUE;
         testMode.TheFontColor = 0;
  //       testMode.backgroundTextColour = 1;
         break;
    }
    SelectedMenu = mode ;
    update();
  }`

  function `void DisplayModeChanged(int mode)
  {
     switch(mode)
     {
        case COLSS_SCHEDULED_MODE:
         text1_box.foregroundFillColour = \`COLOR_ACTIVE_ON_OPEN\`;
         text2_box.foregroundFillColour = 0;
         text3_box.foregroundFillColour = 0;
         scheduledMode.TheTitle = "SCHEDULED MODE (ON)";
         unscheduledMode.TheTitle = "UNSCHEDULED MODE (OFF)";
         DisplayAdvisoryMessage("COLSS IN SCHEDULED MODE");
         break;
  
        case COLSS_UNSCHEDULED_MODE:
         text1_box.foregroundFillColour = 0;
         text2_box.foregroundFillColour = \`COLOR_ACTIVE_ON_OPEN\`;
         text3_box.foregroundFillColour = 0;
         scheduledMode.TheTitle = "SCHEDULED MODE (OFF)";
         unscheduledMode.TheTitle = "UNSCHEDULED MODE (ON)";
         testMode.TheTitle = "TEST CASE (OFF)";
         DisplayAdvisoryMessage("COLSS IN UNSCHEDULED MODE");
         break;
  
  //      case COLSS_TEST_MODE:
  //       text1_box.foregroundFillColour = 0;
  //       text2_box.foregroundFillColour = 0;
  //       text3_box.foregroundFillColour = \`COLOR_ACTIVE_ON_OPEN\`;
  //       unscheduledMode.TheTitle = "UNSCHEDULED MODE (OFF)";
  //       testMode.TheTltle = "TEST CASE (ON)";
  //       break;
       } // end of switch statement
  
    update();
  }`

  // ***CORENET 20170601 by Philkyu Kwon ************
  //
  // ***************************************************
  function `void DummyProcess()
  {
    printf("Button Select OR Button Unselected");
  }`

  function `void Initialize()
  {
  //
     Current_Page = 121;
     CFMLevel = 0;
  //
     KeepSelected();
  //
     run_status = TRUE;
  //  For Test Case Inputs
     InitTestInput();
     TestInputBox_Visible(0);
  //
     IsMenuSelected = FALSE;
     scheduledMode.IsOptionSelected = FALSE;
     unscheduledMode.IsOptionSelected = FALSE;
     testMode.IsOptionSelected =  FALSE;
     DisplayAdvisoryMessage3("REQUESTING COLSS CURRENT MODE");
     pColssData->message_type = REQUEST_COLSS_CURRENT_MODE;
     pColssData->ModeData->ws_to_host_mode = -1;
     pColssData->ModeData->colss_current_mode = -1;
     pColssData->ModeData->test_case = 0;
     pColssData->ModeData->use_burnup_file = 0;
     pColssData->ModeData->print_option=0;
  
     text1_box.foregroundFillColour = 0;
     text2_box.foregroundFillColour = 0;
     text3_box.foregroundFillColour = 0;
  
     execute("{sendMessageToHost(REQUEST_COLSS_PROCESSING);}");
  
     ProcessText.Initialize();
  //   CancelText.Initialize();
     update();
  }`

  function `void InitTestInput()
  {
  //  For Test Case Inputs
  //    TestInputBox_Visible(0);
       strcpy(InputArea.TheNewText," ");
       strcpy(InputArea.TheOriginalText," ");
       InputArea.TheNewNumber = 0.0;
       InputArea.TheOriginalNumber = 0.0;
        YesButton.Initialize();
        NoButton.Initialize();
        SelectedBurnupOption = -1;
        SelectedPrintOption = -1;
        SelectedTestCaseOption = -1;
        BurnupStatus = FALSE;
        TestCaseNumStatus = FALSE;
        PrintOptionStatus = FALSE;
  
        UnKeepSelected();
  
  //       text11.TheFontColor = 1;
  //       text11.backgroundTextColour = 0;
  //       text12.TheFontColor = 1;
  //       text12.backgroundTextColour = 0;
  //       text13.TheFontColor = 1;
  //       text13.backgroundTextColour = 0;
     update();
  }`

  function `void InputVerify()
  {
  ProcessProcessButton();
  }`

