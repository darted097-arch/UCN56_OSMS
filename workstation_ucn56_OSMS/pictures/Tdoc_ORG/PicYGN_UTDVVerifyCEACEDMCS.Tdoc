  function `void ActonQuality()
  {
  // This portion needs the quality each cea position(see UTDVStructure.pdat) to
  // set the proper colors of the values. Temporarily this routine set the quality of
  // all the values to GOOD by executing the function called RestoreColorAndState()
  // in InputDialogueNumberActBad class
  
     int i,j;
  
        for (i=1; i<=6; ++i)
           for (j=1; j<=4; ++j)
           {
              execute("{ceaPos%d%d.RestoreColorAndState();}",i,j);
           }
  //
     cea_avg.RestoreColorAndState();
  }`

  function `int Avg_type()
  {
     int i,j;
  
     Avg=11; // BAD
  
     for (i=1;i<=6; i++)
     {
        for (j=1;j<=4; j++)
        {
           execute("{TEMP_VIS = n%d%d.TheNewNumber;}",i,j);
  
           if ( (1<=TEMP_VIS) && (TEMP_VIS<=73) )
           {
              execute("{Avg &= B_FceaPos%d%d.foregroundColour;}",i,j);
           }
         }
     }
  
     if (Avg==11)
     {
        cea_avg.TheNewNumber = -1 ;
        strcpy(cea_avg.TheNewText," BD -------");
     }
     else
     {
        sprintf(cea_avg.TheNewText,"%-8.2f",cea_avg.TheNewNumber);
     }
     strcpy(cea_avg.TheOriginalText,cea_avg.TheNewText);
  
     return Avg;
  }`

  function `void BehaviorAndVis()
  {
     InputButtonBehavior();
     KeepVis();
  }`

  function `void ChangeToNextGroup()
  {
  if ( 0 == strcmp(changeYN.TheNewText, "N") )
   {
     if ( strcmp(selectGrp.TheNewText, "P") == 0)
     {   strcpy(selectGrp.TheNewText, "1"); strcpy(selectGrp.TheOriginalText, "1"); selectGrp.Flag = 2;}
     else if ( strcmp(selectGrp.TheNewText, "1") == 0)
     {   strcpy(selectGrp.TheNewText, "2"); strcpy(selectGrp.TheOriginalText, "2"); selectGrp.Flag = 3;}
     else if ( strcmp(selectGrp.TheNewText, "2") == 0)
     {   strcpy(selectGrp.TheNewText, "3"); strcpy(selectGrp.TheOriginalText, "3"); selectGrp.Flag = 4;}
     else if ( strcmp(selectGrp.TheNewText, "3") == 0)
     {   strcpy(selectGrp.TheNewText, "4"); strcpy(selectGrp.TheOriginalText, "4"); selectGrp.Flag = 5;}
     else if ( strcmp(selectGrp.TheNewText, "4") == 0)
     {   strcpy(selectGrp.TheNewText, "5"); strcpy(selectGrp.TheOriginalText, "5"); selectGrp.Flag = 6;}
     else if ( strcmp(selectGrp.TheNewText, "5") == 0)
     {   strcpy(selectGrp.TheNewText, "A"); strcpy(selectGrp.TheOriginalText, "A"); selectGrp.Flag = 7;}
     else if ( strcmp(selectGrp.TheNewText, "A") == 0)
     {   strcpy(selectGrp.TheNewText, "B"); strcpy(selectGrp.TheOriginalText, "B"); selectGrp.Flag = 8;}
     else if ( strcmp(selectGrp.TheNewText, "B") == 0)
     {   strcpy(selectGrp.TheNewText, "E"); strcpy(selectGrp.TheOriginalText, "E"); selectGrp.Flag = 9;}
     else if ( strcmp(selectGrp.TheNewText, "E") == 0)
     {   strcpy(selectGrp.TheNewText, "R"); strcpy(selectGrp.TheOriginalText, "R"); selectGrp.Flag = 0;}
     else if ( strcmp(selectGrp.TheNewText, "R") == 0)
     {   strcpy(selectGrp.TheNewText, "P"); strcpy(selectGrp.TheOriginalText, "P"); selectGrp.Flag = 1;}
   }
  else if ( strcmp(changeYN.TheNewText, "Y") == 0)
   {
     if ( strcmp(selectGrp.TheNewText, "1") == 0)
     {   strcpy(selectGrp.TheNewText, "P"); strcpy(selectGrp.TheOriginalText, "P"); selectGrp.Flag = 0;}
     else if ( strcmp(selectGrp.TheNewText, "2") == 0)
     {   strcpy(selectGrp.TheNewText, "1"); strcpy(selectGrp.TheOriginalText, "1"); selectGrp.Flag = 1;}
     else if ( strcmp(selectGrp.TheNewText, "3") == 0)
     {   strcpy(selectGrp.TheNewText, "2"); strcpy(selectGrp.TheOriginalText, "2"); selectGrp.Flag = 2;}
     else if ( strcmp(selectGrp.TheNewText, "4") == 0)
     {   strcpy(selectGrp.TheNewText, "3"); strcpy(selectGrp.TheOriginalText, "3"); selectGrp.Flag = 3;}
     else if ( strcmp(selectGrp.TheNewText, "5") == 0)
     {   strcpy(selectGrp.TheNewText, "4"); strcpy(selectGrp.TheOriginalText, "4"); selectGrp.Flag = 4;}
     else if ( strcmp(selectGrp.TheNewText, "A") == 0)
     {   strcpy(selectGrp.TheNewText, "5"); strcpy(selectGrp.TheOriginalText, "5"); selectGrp.Flag = 5;}
     else if ( strcmp(selectGrp.TheNewText, "B") == 0)
     {   strcpy(selectGrp.TheNewText, "A"); strcpy(selectGrp.TheOriginalText, "A"); selectGrp.Flag = 6;}
     else if ( strcmp(selectGrp.TheNewText, "P") == 0)
     {   strcpy(selectGrp.TheNewText, "B"); strcpy(selectGrp.TheOriginalText, "B"); selectGrp.Flag = 7;}
   }
  }`

