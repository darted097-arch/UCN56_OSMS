  function `void DisplayCEAData()
  {
     int i,j;
  
     strcpy(changeYN.TheNewText, "N");
     changeYN.Flag = 1;
     SubGroup.visibility = 1;
  
     execute("{strcpy(SubGroup.TheNewText, Interface->UtdvDialogue.filename1);}");
  
     //if(Interface->System.displayedUnits==METRIC) // JHC 990418
     if(Interface->System.displayedUnits==1) // for METRIC by CORENET 2017 Philkyu Kwon
     {
        cea_avg.TheNewNumber = Interface->UtdvDialogue.cea_average;
  
        for (i=1;i<=6; i++)
        {
           for (j=1;j<=4; j++)
           {
              execute("{ n%d%d.TheNewNumber = Interface->UtdvDialogue.col%d.row%dCeaNumber;}",i,j,i,j);
              execute("{ n%d%d.TheOriginalNumber = n%d%d.TheNewNumber;}",i,j,i,j);
  
              execute("{TEMP_VIS = n%d%d.TheNewNumber;}",i,j);                                 // START by yrlee 990422
  
              if ( (1<=TEMP_VIS) && (TEMP_VIS<=73) )
              {
                 execute("{iquality = Interface->UtdvDialogue.col%d.row%dCeaQuality;}",i,j);
  
                 if(iquality)
                 {
                    execute("{ ceaPos%d%d.TheNewNumber = Interface->UtdvDialogue.col%d.row%dCeaValue;}",i,j,i,j);
                    execute("{ ceaPos%d%d.TheOriginalNumber = ceaPos%d%d.TheNewNumber;}",i,j,i,j);
                    execute("{ sprintf(ceaPos%d%d.TheNewText,\\"%s\\",ceaPos%d%d.TheNewNumber);}",i,j,"%-8.2f",i,j);
                 }
                 else
                 {
                    execute("{ ceaPos%d%d.TheNewNumber = -1.0;}",i,j);
                    execute("{ ceaPos%d%d.TheOriginalNumber = -1.0;}",i,j);
                    execute("{ strcpy(ceaPos%d%d.TheNewText,\\" BD -------\\");}",i,j);
                 }
                 execute("{ strcpy(ceaPos%d%d.TheOriginalText,ceaPos%d%d.TheNewText);}",i,j,i,j);
              }                                                                                 // END by yrlee 990422
  
           }  // outer for-loop
        }
  
       // new added......................
        for (j=1;j<=4; j++)
        {
         execute("{ grp%d.TheNewNumber = Interface->UtdvDialogue.col%d.SubGrpNumber;}",j,j);
         execute("{ grp%d.TheOriginalNumber = grp%d.TheNewNumber;}",j,j);
        }
     }
     else  // for English Unit
     {
        cea_avg.TheNewNumber = (Interface->UtdvDialogue.cea_average)/2.54;
        for (i=1;i<=6; i++)
        {
           for (j=1;j<=4; j++)
           {
  
              execute("{ n%d%d.TheNewNumber = Interface->UtdvDialogue.col%d.row%dCeaNumber;}",i,j,i,j);
              execute("{ n%d%d.TheOriginalNumber = n%d%d.TheNewNumber;}",i,j,i,j);
  
              execute("{TEMP_VIS = n%d%d.TheNewNumber;}",i,j);                                    // START by yrlee 990422
  
              if ( (1<=TEMP_VIS) && (TEMP_VIS<=73) )
              {
                 execute("{iquality = Interface->UtdvDialogue.col%d.row%dCeaQuality;}",i,j);
  
                 if(iquality)
                 {
                    execute("{ ceaPos%d%d.TheNewNumber = (Interface->UtdvDialogue.col%d.row%dCeaValue)/2.54;}",i,j,i,j);
                    execute("{ ceaPos%d%d.TheOriginalNumber = ceaPos%d%d.TheNewNumber;}",i,j,i,j);
                    execute("{ sprintf(ceaPos%d%d.TheNewText,\\"%s\\",ceaPos%d%d.TheNewNumber);}",i,j,"%-8.2f",i,j);
                 }
                 else
                 {
                    execute("{ ceaPos%d%d.TheNewNumber = -1;}",i,j);
                    execute("{ ceaPos%d%d.TheOriginalNumber = -1;}",i,j);
                    execute("{ strcpy(ceaPos%d%d.TheNewText,\\" BD -------\\");}",i,j);
                 }
                 execute("{ strcpy(ceaPos%d%d.TheOriginalText,ceaPos%d%d.TheNewText);}",i,j,i,j);
              }                                                                                    // END by yrlee 990422
  
  
           }  // outer for-loop
         }
  
          // new added......................
           for (j=1;j<=4; j++)
           {
            execute("{ grp%d.TheNewNumber = Interface->UtdvDialogue.col%d.SubGrpNumber;}",j,j);
            execute("{ grp%d.TheOriginalNumber = grp%d.TheNewNumber;}",j,j);
           }
        }
  
        TextProcessing.visibility = 0;
  //
        BehaviorAndVis();
        Confirmed = 1;
        Avg_type() ;
        update();
  }`

  function `void escape()
  {
  DisplayPage(Page652);
  }`

  function `void GettingData()
  {
     if (0 == UTDVDataWaitingTime)
     {
        TextProcessing.visibility = 0;
        WaitingUTDVData694 = 0;
        DisplayCEAData();
     }
     else
     {
        UTDVDataWaitingTime = UTDVDataWaitingTime - 1;
     }
  }`

  function `void GrpColor()  //JHC 990419
  {
     selGrpText.pText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;
     selGrpText.rText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;
     selGrpText.sText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;
     selGrpText.eText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;
     selGrpText.cText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;
     if((strcmp(selectGrp.TheNewText,"P")) == 0)
        selGrpText.pText.foregroundColour = \`COLOR_DATA_NORMAL\`;
     else if((strcmp(selectGrp.TheNewText,"A")) ==0)
        selGrpText.sText.foregroundColour = \`COLOR_DATA_NORMAL\`;
     else if((strcmp(selectGrp.TheNewText,"B")) ==0)
        selGrpText.sText.foregroundColour = \`COLOR_DATA_NORMAL\`;
     else if((strcmp(selectGrp.TheNewText,"E")) ==0)
        selGrpText.eText.foregroundColour = \`COLOR_DATA_NORMAL\`;
     else if((strcmp(selectGrp.TheNewText,"R")) ==0)
        selGrpText.cText.foregroundColour = \`COLOR_DATA_NORMAL\`;
     else
        selGrpText.rText.foregroundColour = \`COLOR_DATA_NORMAL\`;
  }
  `

  function `void Initialize()
  {
     InitialVis();
  
     //if(Interface->System.displayedUnits==ENGLISH)	 //JHC 990418
     if(Interface->System.displayedUnits==0)	 //CORENET 20170414 by Philkyu Kwon
        { TextE.visibility=1;TextM.visibility=0; update();}
     else
        { TextE.visibility=0;TextM.visibility=1; update();}
  
     printf("Current DisplayUnit = %d  <- 0 = ENGLISH, 1 = METRIC", Interface->System.displayedUnits);// CORENET
  
     Current_Page = 694;
     CFMLevel =0;
     QLTYcea_avg = 1;
  //
     Interface->UtdvDialogue.current_page = Current_page;
  
  // For sending the selected option from page 695
     if (0==Option_From_695)
     {
     strcpy(changeYN.TheNewText, "N");
     strcpy(changeYN.TheOriginalText, "N");
     selYNText.nText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     selYNText.yText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     selGIText.visibility = 0; selectGI.visibility = 0;
     selectGrp.visibility = 1; selGrpText.visibility = 1 ;
  
     strcpy(selectGI.TheNewText, "I");
     strcpy(selectGI.TheOriginalText, "I");
     selectGI.Flag = 0;
     changeYN.Flag = 1;
     selGIText.iText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     selGIText.gText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
  
     strcpy(selectGrp.TheNewText, "P");
     strcpy(selectGrp.TheOriginalText, "P");
     selGrpText.pText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     selGrpText.rText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     selGrpText.sText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     selGrpText.eText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     selGrpText.cText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
  
     execute("{strcpy(Interface->UtdvDialogue.change, changeYN.TheNewText);}");
     execute("{strcpy(Interface->UtdvDialogue.cea_modify, selectGI.TheNewText);}");
     execute("{strcpy(Interface->UtdvDialogue.next_group, selectGrp.TheNewText);}");
  
     }
     else if (1==Option_From_695)
     {
     strcpy(changeYN.TheNewText, "N");
     strcpy(changeYN.TheOriginalText, changeYN.TheNewText);
     selYNText.nText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     selYNText.yText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     selGIText.visibility = 0; selectGI.visibility = 0;
     selectGrp.visibility = 1; selGrpText.visibility = 1 ;
  
     strcpy(selectGI.TheNewText, "I");
     strcpy(selectGI.TheOriginalText, selectGI.TheNewText);
     selectGI.Flag = 0;
     changeYN.Flag = 0;
     selGIText.iText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     selGIText.gText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
  
     strcpy(selectGrp.TheNewText, GroupFrom695);
     strcpy(selectGrp.TheOriginalText, selectGrp.TheNewText);
     selGrpText.pText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;    //JHC 990419
     selGrpText.rText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     selGrpText.sText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     selGrpText.eText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     selGrpText.cText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
     if((strcmp(selectGrp.TheNewText,"P")) == 0)
        selGrpText.pText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     else if((strcmp(selectGrp.TheNewText,"A")) ==0)
        selGrpText.sText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     else if((strcmp(selectGrp.TheNewText,"B")) ==0)
        selGrpText.sText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     else if((strcmp(selectGrp.TheNewText,"E")) ==0)
        selGrpText.eText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     else if((strcmp(selectGrp.TheNewText,"R")) ==0)
        selGrpText.cText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     else
        selGrpText.rText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
  
     execute("{strcpy(Interface->UtdvDialogue.change, changeYN.TheNewText);}");
     execute("{strcpy(Interface->UtdvDialogue.cea_modify, selectGI.TheNewText);}");
     execute("{strcpy(Interface->UtdvDialogue.next_group, selectGrp.TheNewText);}");
     printf("======= %s", selectGrp.TheNewText);
     }
  //
     execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
     Option_From_695 = 0;
  //
  // -------------------------------------------------------
  // THis portion should be run on doUTDVAction when Current_Page
  // and New_page_request are 658.
     WaitingUTDVData658 = 1;
     UTDVDataWaitingTime = 3;
     TextProcessing.visibility = 1;
     DisplayCEAData();
  //
     InputButtonBehavior();
     ActonQuality();
  // -------------------------------------------------------
  //jsk   ChangeToNextGroup();
  
     strcpy(Current_Grp,Interface->UtdvDialogue.next_group);
  }`

  function `void InitialVis()
  {
  int i,j;
     SubGroup.visibility = 0;
     strcpy(SubGroup.TheNewText, " ");
     for (i=1;i<=6; i++)
     {
        for (j=1;j<=4; j++)
        {
            execute("{ceaPos%d%d.visibility = 0;}",i,j);
            execute("{ceaPos%d%d.TheNumber.visibility = 0;}",i,j);
            execute("{ceaPos%d%d.InputArea.visibility = 0;}",i,j);
  //
            execute("{n%d%d.visibility = 0;}",i,j);
            execute("{FceaPos%d%d.visibility = 0;}",i,j);
            execute("{B_FceaPos%d%d.visibility = 0;}",i,j);
            execute("{FceaPos%d%d.backgroundColour = COLOR_PICTURE_BACKGROUND;}",i,j);
        }
     }
  //
        for (j=1;j<=4; j++)
        {
            execute("{SUBG%d.visibility = 0;}",j);
            execute("{grp%d.visibility = 0;}",j);
        }
  //   printf("initVis done!!!");
  
  }`

  function `void InputButtonBehavior()
  {
  int i, j;
  
  if (0 == strcmp( changeYN.TheNewText,"N"))
  {
        selYNText.nText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
        selYNText.yText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
        cea_avg.ActionFlag = 1;
  
        for (i=1; i<=6; ++i)
           for (j=1; j<=4; ++j)
           {
              execute("{ceaPos%d%d.ActionFlag = 1;}",i,j);
           }
  }
  else
  {
     selYNText.yText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
     selYNText.nText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
  
     if (0 == strcmp(selectGI.TheNewText,"I"))
     {
        selGIText.iText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
        selGIText.gText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
        cea_avg.ActionFlag = 1;
  
        for (i=1; i<=6; ++i)
           for (j=1; j<=4; ++j)
           {
              execute("{ceaPos%d%d.ActionFlag = 0;}",i,j);
           }
     }
  //
     else if (0 == strcmp(selectGI.TheNewText,"G"))
     {
        selGIText.gText.foregroundColour = \`COLOR_DATA_NORMAL\`;    //JHC 990419
        selGIText.iText.foregroundColour = \`COLOR_NON_ESSENTIAL\`;  //JHC 990419
  
        for (i=1; i<=6; ++i)
           for (j=1; j<=4; ++j)
           {
              execute("{ceaPos%d%d.ActionFlag = 1;}",i,j);
           }
  
        cea_avg.ActionFlag = 0;
     }
  }
  }`

  function `void KeepVis()
  {
     int i,j;
  
     for (i=1;i<=6; i++)
     {
        for (j=1;j<=4; j++)
        {
           execute("{TEMP_VIS = n%d%d.TheNewNumber;}",i,j);
  
           if ( (1 > TEMP_VIS) || (73 < TEMP_VIS) )
           {
              execute("{ceaPos%d%d.visibility = 0;}",i,j);
              execute("{ceaPos%d%d.TheNumber.visibility = 0;}",i,j);
  //          execute("{n%d%d.visibility = 0;}",i,j);
              execute("{FceaPos%d%d.visibility = 0;}",i,j);
              execute("{B_FceaPos%d%d.visibility = 0;}",i,j);
           }
           else if ( (1 <= TEMP_VIS) && (TEMP_VIS) <= 73 )
           {
              if (strcmp(changeYN.TheNewText, "Y") == 0)
              {
                  selectGI.visibility = 1 ; //jsk
                  selGIText.visibility = 1 ; //jsk
                  selectGrp.visibility = 0 ; //jsk
                  selGrpText.visibility = 0 ; //jsk
  
                  if (strcmp(selectGI.TheNewText, "I") == 0)
                  {
  //                 execute("{B_FceaPos%d%d.visibility = 0;}",i,j);
  //                 execute("{FceaPos%d%d.visibility = 0;}",i,j);
                     execute("{ceaPos%d%d.InputArea.visibility = 1;}",i,j);
                     execute("{ceaPos%d%d.visibility = 1;}",i,j);
                     execute("{n%d%d.visibility = 1;}",i,j);
                  }
                  else if (strcmp(selectGI.TheNewText, "G") == 0)
                  {
                     execute("{B_FceaPos%d%d.visibility = 1;}",i,j);
                     execute("{FceaPos%d%d.visibility = 1;}",i,j);
                     execute("{ceaPos%d%d.TheNumber.visibility = 0;}",i,j);
                     execute("{ceaPos%d%d.visibility = 0;}",i,j);
                     execute("{n%d%d.visibility = 1;}",i,j);
                  }
  //
  //                printf("---- %d %d", ceaPos11.TheNumber.visibility, ceaPos11.visibility);
              }
              else if (strcmp(changeYN.TheNewText, "N") == 0)
              {
                  selectGrp.visibility = 1; //jsk
                  selGrpText.visibility = 1 ; //jsk
                  selectGI.visibility = 0; //jsk
                  selGIText.visibility = 0 ; //jsk
                  execute("{FceaPos%d%d.visibility = 1;}",i,j);
  //------------- To  check the quality of cea value(START)
                  execute("{iquality = Interface->UtdvDialogue.col%d.row%dCeaQuality;}",i,j);
  
                  if (iquality == 0)
                  {
                      // quality is bad, change background and forground colour
                      // printf("QUALITY BAD  %d",iquality);
                      execute("{B_FceaPos%d%d.visibility = 1;}",i,j);
                      execute("{FceaPos%d%d.visibility = 1;}",i,j);
  
                      execute("{B_FceaPos%d%d.backgroundColour = COLOR_BAD_OOR_UNACK;}",i,j);
                      execute("{B_FceaPos%d%d.backgroundFillColour = COLOR_BAD_OOR_UNACK;}",i,j);
                      execute("{B_FceaPos%d%d.foregroundColour = COLOR_BAD_OOR_UNACK;}",i,j);
                      execute("{B_FceaPos%d%d.foregroundFillColour = COLOR_BAD_OOR_UNACK;}",i,j);
  //
  //                  execute("{FceaPos%d%d.backgroundColour = COLOR_BAD_OOR_UNACK;}",i,j);
                      execute("{FceaPos%d%d.foregroundColour = COLOR_PICTURE_BACKGROUND;}",i,j);
                      QLTYcea_avg = 0;
                  }
                  else if (iquality == 1)
                  {
                    // quality is good, KEEP Normal color scheme
                    // printf("QUALITY GOOD  %d",iquality);
  //                  execute("{B_FceaPos%d%d.visibility = 0;}",i,j);
                      execute("{FceaPos%d%d.visibility = 1;}",i,j);
  //
                      execute("{B_FceaPos%d%d.backgroundColour = COLOR_PICTURE_BACKGROUND;}",i,j);
                      execute("{B_FceaPos%d%d.backgroundFillColour = COLOR_PICTURE_BACKGROUND;}",i,j);
                      execute("{B_FceaPos%d%d.foregroundColour = COLOR_PICTURE_BACKGROUND;}",i,j);
                      execute("{B_FceaPos%d%d.foregroundFillColour = COLOR_PICTURE_BACKGROUND;}",i,j);
  //
  //                  execute("{FceaPos%d%d.backgroundColour = COLOR_PICTURE_BACKGROUND;}",i,j);
                      execute("{FceaPos%d%d.foregroundColour = COLOR_DATA_NORMAL;}",i,j);
                  }
  //------------- To  check the quality of cea value(END)
  
                  execute("{ceaPos%d%d.TheNumber.visibility = 0;}",i,j);
                  execute("{ceaPos%d%d.visibility = 0;}",i,j);
                  execute("{n%d%d.visibility = 1;}",i,j);
  //
              }
           }
        }  // inner for-loop
      }  // outer for-loop
  
  // new added......................
     for (j=1;j<=4; j++)
     {
        execute("{TEMP_VIS = grp%d.TheNewNumber;}",j);
        if ((18 < TEMP_VIS) || (1 > TEMP_VIS ))
        {
           execute("{SUBG%d.visibility = 0;}",j);
           execute("{grp%d.visibility = 0;}",j);
        }
        else if ((18 >= TEMP_VIS) || (1 <= TEMP_VIS ))
        {
           execute("{SUBG%d.visibility = 1;}",j);
           execute("{grp%d.visibility = grp%d.TheNewNumber;}",j,j);
        }
     }  // for-loop
  
     update();
  }
        `

  function `void NextAction()
  {
  //
     Interface->UtdvDialogue.option = 1;
     Interface->UtdvDialogue.current_page = Current_page;
  
     execute("{strcpy(Interface->UtdvDialogue.change, changeYN.TheNewText);}");
     execute("{strcpy(Interface->UtdvDialogue.cea_modify, selectGI.TheNewText);}");
     execute("{strcpy(Interface->UtdvDialogue.next_group, selectGrp.TheNewText);}");
  // All opcode and other choices were set in
  // 1) SetChangeOption(),
  // 2) SetGI(), and
  // 3) SetNextGroup()
     execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
  }`

  function `void Process1()
  {
  //
     Interface->UtdvDialogue.option = 1;
     Interface->UtdvDialogue.current_page = Current_page;
  //
     execute("{strcpy(Interface->UtdvDialogue.change, changeYN.TheNewText);}");
     execute("{strcpy(Interface->UtdvDialogue.cea_modify, selectGI.TheNewText);}");
  //   execute("{strcpy(Interface->UtdvDialogue.next_group, selectGrp.TheNewText);}"); // by yrlee990421
  
  // All opcode and other choices were set in
  // 1) SetChangeOption(),
  // 2) SetGI(), and
  // 3) SetNextGroup()
  if ( strcmp(changeYN.TheNewText, "Y") == 0)
  {
     if ( strcmp(selectGI.TheNewText,"G") == 0 )
  //---------------------------------------------------------------------------
       {
         if ( strcmp(cea_avg.TheNewText, " BD -------") == 0 )
           {
           Interface->UtdvDialogue.cea_average = -1;
           //this makes CCUR set all cea group to BAD quality
           }
         else
           {
              if ((cea_avg.TheNewNumber >= 0.0) && (cea_avg.TheNewNumber <= 381.0))
                 //this makes CCUR set all cea group to entered value by operator
                  Interface->UtdvDialogue.cea_average = cea_avg.TheNewNumber;
              else { DisplayAdvisoryMessage1("INVALID CEA POSITION"); return; }
           }
       } // end of "G"
  //---------------------------------------------------------------------------
     else if ( strcmp(selectGI.TheNewText,"I") == 0 )
  //---------------------------------------------------------------------------
      {
        CollectNewCEAPos();
        //printf("dsjfhajfhalkjf called");
      } // end of "I"
     execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
  
  } // end of "Y"
  //---------------------------------------------------------------------------
  else if ( strcmp(changeYN.TheNewText, "N") == 0)
  {
     execute("{strcpy(Interface->UtdvDialogue.next_group, selectGrp.TheNewText);}"); // by yrlee990421
     execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
     strcpy(Current_Grp,Interface->UtdvDialogue.next_group);
     Confirmed=0;
  }
  //jsk ChangeToNextGroup();
  }`

  function `void ProcessGroup()
  {
     Interface->UtdvDialogue.option = 1;
     Interface->UtdvDialogue.current_page = Current_page;
  
  // SubGrpNumber,row1CeaNumber,row1CeaValue in col1
  // temporarily used for each subgroup's cea data sending
     Interface->UtdvDialogue.col1.SubGrpNumber = grp1.TheNewNumber;
     Interface->UtdvDialogue.col1.row1CeaNumber = n11.TheNewNumber;
     Interface->UtdvDialogue.col1.row1CeaValue = ceaPos11.TheNewNumber;
  //   printf(" sub no:/cea no: %d  %d", grp1.TheNewNumber, n11.TheNewNumber);
  
  //   execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
  
  }`

  function `void ProcessingConfirmed()
  {
     TextProcessing.visibility = 0;
  }`

  function `void SetGroupValueAction()
  {
     int i,j,TMP;
  
     if ( strcmp(cea_avg.TheNewText, "bd") == 0 || strcmp(cea_avg.TheNewText, "BD") == 0 )
     {
     for (i=1;i<=6; i++)
        for (j=1;j<=4; j++)
        {
         execute("{TMP = n%d%d.TheNewNumber;}",i,j);
  //     printf(" sfdyghfgdjghkjhfk %d", TMP);
  //     To CHANGE THE COLOR OF THE VALUES
         if (  TMP >= 0 )
           {
               execute("{ceaPos%d%d.ChangeColorAndState();}",i,j);
  //           printf(" Keep bad");
           }
        }
  //
     }
  }`

  function `void SetNextGroup()
  {
  // All choices were set in
  // 1) SetChangeOption(),
  // 2) SetGI(), and
  
  // 3) SetNextGroup() will be set here..
     OpcodeErr.visibility = 0;
  
     Interface->UtdvDialogue.option = 1;
     Interface->UtdvDialogue.current_page = Current_page;
  //   printf("Selected Next Group = %s ",selectGrp.TheNewText);
  
     if ( strcmp(selectGrp.TheNewText, PText) == 0 ||
          strcmp(selectGrp.TheNewText, AText) == 0 ||
          strcmp(selectGrp.TheNewText, BText) == 0 ||
          atoi(selectGrp.TheNewText) == atoi(Text1)||
          atoi(selectGrp.TheNewText) == atoi(Text2)||
          atoi(selectGrp.TheNewText) == atoi(Text3)||
          atoi(selectGrp.TheNewText) == atoi(Text4)||
          atoi(selectGrp.TheNewText) == atoi(Text5)||
          strcmp(selectGrp.TheNewText, RText) == 0 ||
          strcmp(selectGrp.TheNewText, EText) == 0 )
       {
          execute("{strcpy(Interface->UtdvDialogue.next_group, selectGrp.TheNewText);}");
          OpcodeErr.visibility = 0;
  //        execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
  //        printf("compare result = %d  %d",atoi(selectGrp.TheNewText), atoi(Text1));
       }
     else
        {
          OpcodeErr.visibility = 1;
          return;
        }
  //
  //   execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
  }`

  function `void SetTextProcessing()
  {
     TextProcessing.visibility = 1;
  }`

