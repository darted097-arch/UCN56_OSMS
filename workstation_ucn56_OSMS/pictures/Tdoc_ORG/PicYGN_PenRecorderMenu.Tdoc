  function `void ExecuteFailure(int Set, int Pen)
  {
    InputDialogueText *Input = 0;
  
    //  Get pointer to PID
  
    //printf (" executing failure " );
  
    Input = GetpoPID(Set,Pen);
    Input->ERROR = 1;
  
    pPidStr = "ERRORPID";
    execute("{pSet%dPen%dRec = &%s;}",Set,Pen,pPidStr);
  
    update();
  }`

  function `void ExecuteSuccess(int Set, int Pen)
  {
    InputDialogueText * Input = 0;
  
    //  Get pointer to PID
  
   // printf(" executing success ");
  
    Input = GetpoPID(Set,Pen);
    Input->ERROR = 0;
  
    SetMinMaxFromPID(Set,Pen);
  
    pPidStr = GetstrPID(Set, Pen);
    execute("{pSet%dPen%dRec = &%s;}",Set,Pen,pPidStr);
  
    update();
  }`

  function `float GetDB_HiER(int Set, int Pen)
  {
  // Returns the database High Engineering Range for the PID in Set #, Pen #
  
    execute("{DB_HiER = %s;}",GetstrDB_HiER(Set, Pen));
    return(DB_HiER);
  }`

  function `float GetDB_LoER(int Set, int Pen)
  {
  // Returns the Low Engineering Range for the PID in Set #, Pen #
  
    execute("{DB_LoER = %s;}",GetstrDB_LoER(Set, Pen));
    return(DB_LoER);
  }`

  function `int GetPID_CheckType(char * PID)
  {
    int point_type;
    int retval = FULL_TYPE_CHECK;
  
    strcpy(TEMPSTR, PID);
    strcat(TEMPSTR, ".sig_type");
    execute("{TEMPINT = %s;}",TEMPSTR);
    point_type = TEMPINT;
  
    switch (point_type)
    {
      case AI:
      case PI:
      case FI:
      case ROD:
        retval = FULL_TYPE_CHECK;
        break;
  
      case CI:
      case DI:
      case SOE:
      case BCI:
      case DL:
      case QD:
      case XD:
      case CO:
      case BCO:
        retval = ZERO_OR_ONE_TYPE_CHECK;
        break;
  
      case XA:
      case QA:
        retval = NO_RANGE_TYPE_CHECK;
        break;
  
      case AO:
      case KO:
        strcpy(TEMPSTR, PID);
        strcat(TEMPSTR, ".erange_lo");
        execute("{DB_LoER = %s;}",TEMPSTR);
        strcpy(TEMPSTR, PID);
        strcat(TEMPSTR, ".erange_hi");
        execute("{DB_HiER = %s;}",TEMPSTR);
        if ((0.0 == DB_LoER)  &&  (0.0 == DB_HiER))
          retval = NO_RANGE_TYPE_CHECK;
        else
          retval = FULL_TYPE_CHECK;
        break;
  
      default:
        printf("%s GetPID_CheckType() ERROR: Point type not found", PictureTitle);
        retval = FULL_TYPE_CHECK;
        break;
    }
    return(retval);
  }`

