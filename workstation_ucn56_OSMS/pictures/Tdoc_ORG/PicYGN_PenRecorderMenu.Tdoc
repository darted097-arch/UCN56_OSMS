  function `int IsAllBlank(char * cptr)
  {
    // Return 0 if one non-blank character is found, 1 otherwise
    int blank = 1;
    int i;
  
    for (i=0; i<strlen(cptr); i++, cptr++)
    {
      if (*cptr != ' ')
      {
        blank = 0;
        break;
      }//endif
    }//endfor
    return (blank);
  }`

  function `int IsDigital(char * PID)
  {
    int retval, sigtype;
  
    // get a pointer to the record for the PID
    execute("{pRECORD = &%s;}",PID);
  
    sigtype = pRECORD->sig_type;
    switch(sigtype)
    {
      case CI:
      case DI:
      case SOE:
      case BCI:
      case DL:
      case QD:
      case XD:
      case CO:
      case BCO:
        retval = 1;
        break;
      default:
        retval = 0;
        break;
    }//endswitch
    return(retval);
  }`

  function `void Process1()
  {
    int i,j;
    InputDialogueNumber * poMinValue;
    InputDialogueNumber * poMaxValue;
    InputDialogueText   * poPID;
  
    //if (1 == Interface->System.slaveUpdating) return;	//CORENET 20170620
    if (0 == Interface->System.connected) return;
  
  //  printf("\\n%s Process(): Processing", PictureTitle);
  
    for (i=1; i<=NUM_PEN_SETS; i++)
    {
      for (j=1; j<=NUM_PENS_PER_SET; j++)
      {
        execute("{ProcessERROR = Set%dPen%dPID.ERROR;}",i,j);
        if (1 == ProcessERROR) break;
        execute("{ProcessERROR = Set%dPen%dMinValue.ERROR;}",i,j);
        if (1 == ProcessERROR) break;
        execute("{ProcessERROR = Set%dPen%dMaxValue.ERROR;}",i,j);
        if (1 == ProcessERROR) break;
        poMinValue = GetpoMinValue(i,j);
        poMaxValue = GetpoMaxValue(i,j);
        poPID = GetpoPID(i,j);
  
        if ( ((poMaxValue->TheNewNumber <= poMinValue->TheNewNumber) ||
             (poMinValue->TheNewNumber >= poMaxValue->TheNewNumber))
          && (0 == IsAllBlank(poPID->TheNewText)))
        {
  //        printf("  the error point id is :  %s ",poPID->TheNewText);
          ProcessERROR = 1;
          poMinValue.ERROR = 1;
          poMaxValue.ERROR = 1;
          break;
        } //endif
      } //endfor
      if (1 == ProcessERROR) break;
    }//endfor
  
    if (1 != ProcessERROR)
    {
      for (i=1;i<=NUM_PEN_SETS;i++)
        for (j=1;j<=NUM_PENS_PER_SET;j++)
        {
  //      execute("{printf(\\"Updating PEN_DATA with %%s\\", Set%dPen%dPID.TheNewText);}",i,j);
          execute("{strcpy(pPenRecorderData->trend%dPen%d.Pid,Set%dPen%dPID.TheNewText);}",i,j,i,j);
          execute("{pPenRecorderData->trend%dPen%d.Minimum = Set%dPen%dMinValue.TheNewNumber;}",i,j,i,j);
          execute("{pPenRecorderData->trend%dPen%d.Maximum = Set%dPen%dMaxValue.TheNewNumber;}",i,j,i,j);
  //      execute("{printf(\\"Reading from PEN_DATA for Set%dPen%dPID = %%s\\",pPenRecorderData->trend%dPen%d.Pid);}",i,j,i,j);
        }
      execute("{sendMessageToHost(PROCESS_PEN_DATA);}");
      RequestPenDataMsg.visibility = 1;
  //    Interface->System.sentData = 1;
  //    Interface->System.receivedData = 0;
  //    Interface->GenericResponseMessage.data.returnStatus = -1;
      ProcessErrorMsg.visibility = 0;
  //    printf("PenRec.Process(): DONE WITHOUT ERRORS\\n");
    } // endif (1 != error)
    else
    {
      ProcessErrorMsg.visibility = 1;
  //    printf("PenRec.Process(): ERRORS FOUND\\n");
    }
  }`

  function `void Reset()
  {
    printf("%s Resetting", PictureTitle);
    UpdateLocalsFromInterface();
  }`

  function `void SetMinMaxFromPID(int Set, int Pen)
  {
  
  // Sets Min and Max values from the database for VALID PIDs.
  // Action for INVALID PIDs is not defined
  
      // Set the Numbers in the Min and Max fields.
    if (1 == IsAllBlank(GetstrPID(Set,Pen)))
    {
      execute("{Set%dPen%dMinValue.TheNewNumber = 0.0;}",Set,Pen);
      execute("{Set%dPen%dMinValue.TheOriginalNumber = 0.0;}",Set,Pen);
  
      execute("{Set%dPen%dMaxValue.TheNewNumber = 0.0;}",Set,Pen);
      execute("{Set%dPen%dMaxValue.TheOriginalNumber = 0.0;}",Set,Pen);
    }//endif PID is all blanks
    else
    {
      if (IsDigital(GetstrPID(Set, Pen)))
      {
        execute("{Set%dPen%dMinValue.TheNewNumber = 0.0;}",Set,Pen);
        execute("{Set%dPen%dMinValue.TheOriginalNumber = 0.0;}",Set,Pen);
        execute("{Set%dPen%dMaxValue.TheNewNumber = 1.0;}",Set,Pen);
        execute("{Set%dPen%dMaxValue.TheOriginalNumber = 1.0;}",Set,Pen);
      }//endif is digital point
      else // analog
      {
         execute("{pRECORD = \`&%s\`;}",GetstrPID(Set,Pen));
  //       printf("PIP bit map is: %04X",pRECORD->pipbitmap);
  //       printf("Hi engineer range is: %f", pRECORD->erange_hi);
         if ( (Interface->System.displayedUnits) && (!(pRECORD->pipbitmap & bMETUNIT) ))
  
         {
  	  temp_range_lo = pRECORD->erange_lo * pRECORD->mfactor + pRECORD->moffset;
  	  temp_range_hi = pRECORD->erange_hi * pRECORD->mfactor + pRECORD->moffset;
         }
         else  if ( (!Interface->System.displayedUnits) && (pRECORD->pipbitmap & bMETUNIT) )
         {
  	  temp_range_lo =  (pRECORD->erange_lo -pRECORD->moffset) / pRECORD->mfactor;
  	  temp_range_hi =  (pRECORD->erange_hi -pRECORD->moffset) / pRECORD->mfactor;
         }
         else
         {
            temp_range_lo = pRECORD->erange_lo;
            temp_range_hi = pRECORD->erange_hi;
         }
         execute("{Set%dPen%dMinValue.TheNewNumber = temp_range_lo;}",Set,Pen);
         execute("{Set%dPen%dMinValue.TheOriginalNumber = temp_range_lo;}",Set,Pen);
  
         execute("{Set%dPen%dMaxValue.TheNewNumber = temp_range_hi;}",Set,Pen);
         execute("{Set%dPen%dMaxValue.TheOriginalNumber = temp_range_hi;}",Set,Pen);
      }//endelse not a digital point
    }//endelse not all blank
  
    execute("{sprintf(Set%dPen%dMinValue.TheNewText, \\"%s\\", Set%dPen%dMinValue.TheNewNumber);}",Set,Pen,GetstrMinNumberFormat(Set, Pen),Set,Pen);
    execute("{sprintf(Set%dPen%dMinValue.TheOriginalText, \\"%s\\", Set%dPen%dMinValue.TheOriginalNumber);}",Set,Pen,GetstrMinNumberFormat(Set, Pen),Set,Pen);
    execute("{Set%dPen%dMinValue.ERROR = 0;}",Set,Pen);
  
    execute("{sprintf(Set%dPen%dMaxValue.TheNewText, \\"%s\\", Set%dPen%dMaxValue.TheNewNumber);}",Set,Pen,GetstrMinNumberFormat(Set, Pen),Set,Pen);
    execute("{sprintf(Set%dPen%dMaxValue.TheOriginalText, \\"%s\\", Set%dPen%dMaxValue.TheOriginalNumber);}",Set,Pen,GetstrMinNumberFormat(Set, Pen),Set,Pen);
    execute("{Set%dPen%dMaxValue.ERROR = 0;}",Set,Pen);
  }//end routine`

  function `void UpdateLocalsFromInterface()
  {
    int i,j;
  
    for (i=1; i<=NUM_PEN_SETS; i++)
      for (j=1; j<=NUM_PENS_PER_SET; j++)
      {
  //    Get the PID stuff
        execute("{strcpy(Set%dPen%dPID.TheOriginalText,pPenRecorderData->trend%dPen%d.Pid);}",i,j,i,j);
        execute("{strcpy(Set%dPen%dPID.TheNewText,Set%dPen%dPID.TheOriginalText);}",i,j,i,j);
        execute("{Set%dPen%dPID.ERROR = 0;}",i,j);
  
        execute("{pPidStr = pPenRecorderData->trend%dPen%d.Pid;}",i,j);
        if (IsAllBlank(pPidStr))
        {
  	 pPidStr = "BLANK";
        }
        execute("{pSet%dPen%dRec = &%s;}",i,j,pPidStr);
  
  //    Get the MinValue stuff
        execute("{Set%dPen%dMinValue.TheNewNumber = pPenRecorderData->trend%dPen%d.Minimum;}",i,j,i,j);
        execute("{Set%dPen%dMinValue.TheOriginalNumber = Set%dPen%dMinValue.TheNewNumber;}",i,j,i,j);
        execute("{sprintf(Set%dPen%dMinValue.TheNewText, \\"%s\\", Set%dPen%dMinValue.TheNewNumber);}",i,j,GetstrMinNumberFormat(i,j),i,j);
        execute("{sprintf(Set%dPen%dMinValue.TheOriginalText, \\"%s\\", Set%dPen%dMinValue.TheOriginalNumber);}",i,j,GetstrMinNumberFormat(i,j),i,j);
        execute("{Set%dPen%dMinValue.ERROR = 0;}",i,j);
  
  //    Get the MaxValue stuff
        execute("{Set%dPen%dMaxValue.TheNewNumber = pPenRecorderData->trend%dPen%d.Maximum;}",i,j,i,j);
        execute("{Set%dPen%dMaxValue.TheOriginalNumber = Set%dPen%dMaxValue.TheNewNumber;}",i,j,i,j);
        execute("{sprintf(Set%dPen%dMaxValue.TheNewText, \\"%s\\", Set%dPen%dMaxValue.TheNewNumber);}",i,j,GetstrMaxNumberFormat(i,j),i,j);
        execute("{sprintf(Set%dPen%dMaxValue.TheOriginalText, \\"%s\\", Set%dPen%dMaxValue.TheOriginalNumber);}",i,j,GetstrMaxNumberFormat(i,j),i,j);
        execute("{Set%dPen%dMaxValue.ERROR = 0;}",i,j);
      }
  
    ProcessErrorMsg.visibility = 0;
    RequestPenDataMsg.visibility = 0;
    update();
  }`

  function `void VerifyMaxValue(int Set, int Pen)
  {
  // Verify valid input for the Max Value entered for Set #, Pen #
    InputDialogueNumber * poMax = 0;
    InputDialogueNumber * poMin = 0;
    float x,y,z;
    int error = 0;
    int check_type;
  
    poMax = GetpoMaxValue(Set, Pen);
    poMin = GetpoMinValue(Set, Pen);
  
    // Determine the type of checking that is needed and do it.
    check_type = GetPID_CheckType(GetstrPID(Set, Pen));
    switch(check_type)
    {
      case NO_RANGE_TYPE_CHECK:
        error = 0;
        break;
  
      case ZERO_OR_ONE_TYPE_CHECK:
        if (1.0 != poMax->TheNewNumber) error = 1;
        break;
  
      case FULL_TYPE_CHECK:
      default:
        x = GetDB_LoER(Set, Pen);
        y = poMax->TheNewNumber;
        z = GetDB_HiER(Set, Pen);
  
        // if the entered value is not between the hi and lo engineering range,
        // we have an error
        if ( !((x <= y) && (y <= z)) ) error = 1;
  
        if (poMax->TheNewNumber <= poMin->TheNewNumber) error = 1;
        break;
    }//endswitch
  
    if (0 == error)
      execute("{Set%dPen%dMaxValue.ERROR = 0;}", Set, Pen);
    else
      execute("{Set%dPen%dMaxValue.ERROR = 1;}", Set, Pen);
  }`

  function `void VerifyMinMaxValues(int Set, int Pen)
  {
    InputDialogueText * Input;
  
    Input = GetpoPID(Set,Pen);
  
  
    if ( (!IsAllBlank(GetstrPID(Set, Pen)))  ||
         (0 == Input->ERROR) )
    {
      VerifyMinValue(Set, Pen);
      VerifyMaxValue(Set, Pen);
    }//endif
  }`

  function `void VerifyMinValue(int Set, int Pen)
  {
  // Verify valid input for the Min Value entered for Set #, Pen #
  //  printf("***** Verifying Min value for %s", GetstrPID(Set, Pen));
    InputDialogueNumber * poMin = 0;
    InputDialogueNumber * poMax = 0;
    float x,y,z;
    int error = 0;
    int check_type;
  
    poMin = GetpoMinValue(Set, Pen);
    poMax = GetpoMaxValue(Set, Pen);
  
    // Determine the type of checking that is needed and do it.
    check_type = GetPID_CheckType(GetstrPID(Set, Pen));
    switch(check_type)
    {
      case NO_RANGE_TYPE_CHECK:
        error = 0;
        break;
  
      case ZERO_OR_ONE_TYPE_CHECK:
        if (0.0 != poMin->TheNewNumber) error = 1;
        break;
  
      case FULL_TYPE_CHECK:
      default:
        x = GetDB_LoER(Set, Pen);
        y = poMin->TheNewNumber;
        z = GetDB_HiER(Set, Pen);
  
        // if the entered value is not between the hi and lo engineering values,
        // we have an error.
        if ( !((x <= y) &&  (y <= z)) ) error = 1;
  
        if (poMin->TheNewNumber >= poMax->TheNewNumber) error = 1;
        break;
    }//endswitch
  
    if (0 == error)
      execute("{Set%dPen%dMinValue.ERROR = 0;}", Set, Pen);
    else
      execute("{Set%dPen%dMinValue.ERROR = 1;}", Set, Pen);
  }`

  function `void VerifyPID(int Set,int Pen)
  {
    int blanks = 1;
    int j;
    char * cptr;
    InputDialogueText * Input = 0;
  
    // Get pointers to the PID, Min, and Max objects
  
    Input = GetpoPID(Set, Pen);
  
    cptr = Input->TheNewText;
  
    blanks = IsAllBlank(cptr);
  
    if (1 == blanks)
    {
      SetMinMaxFromPID(Set,Pen);
      Input->ERROR = 0;
    } //endif
    else
    {
         for ( j=0; j<8; j++)
         {
            if ( (Input->TheNewText[j] < '\\060' ||  (Input->TheNewText[j] > '\\72'
  	       && Input->TheNewText[j] < '\\101') ) ||  Input->TheNewText[j] > '\\132' )
  	      {
  	       Input->TheNewText[j] = '\\0';
  	       break;
  	       }
         }//endfor

         execute("{findPidForGUI(\\"%s\\",\\"%s\\",\\"ExecuteSuccess(%d,%d)\\", \\"ExecuteFailure(%d,%d)\\");}",Input->TheNewText,FindPidScope,Set,Pen,Set,Pen);

     }
  
  }`

  function `int VisibilityMinMaxValues(int Set, int Pen)
  {
    int visibility = 1;
  
    execute("{strncpy(setPenErrStr,Set%dPen%dPID.TheOriginalText,8);}",Set,Pen);
    execute("{setPenErr = Set%dPen%dPID.ERROR;}",Set,Pen);
    execute("{strcpy(tempPidStr,pSet%dPen%dRec->pid);}",Set,Pen);
    setPenErrStr[8] = '\\0';
  
    if (!strlen(setPenErrStr)) visibility=0;
    else if (IsAllBlank(GetstrPID(Set, Pen))) visibility=0;
    else if (setPenErr) visibility=0;
    else if (IsDigital(tempPidStr)) visibility=0;
    else visibility=1;
  
    return(visibility);
  
  }`

