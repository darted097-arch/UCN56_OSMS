  function `int Process_test()
  {
     Checkup();
  
     if( strcmp( gPage74x.dataSource, "T") == 0 && strcmp( gPage74x.resolution, "R") == 0  )
          sendMessageToHost(TAPE_HEADER_74X);
     else
        sendMessageToHost(GRAPH_SETUP_74X);
  
     TheTimer.atTimeDo(50,0,0,1,0, "::YGN3and4.PicYGN_HDSR74Xsetup", "{bProcess.UnSelect();}");
  
     return 0;
  }`

  function `int Process1()
  {
     Checkup();
  
     //***************** CORENET 201705 by Philkyu Kwon *****************************
     int x = -1;
  
     x = ValidateDateTime();
  
     //if( ValidateDateTime() == -1 && strcmp(gPage74x.resolution, "L") == 0 ) {
     if( x == -1 && strcmp(gPage74x.resolution, "L") == 0 ) {
           DisplayAdvisoryMessage1("INVALID FORMAT FOR START DATE OR TIME");
     TheTimer.atTimeDo(50,0,0,1,0, "::YGN3and4.PicYGN_HDSR74Xsetup", "{bProcess.UnSelect();}");
        return -1;
     }
     // ***************************************************************************
  
     if( strcmp( gPage74x.dataSource, "T") == 0 && strcmp( gPage74x.resolution, "R") == 0  )
          sendMessageToHost(TAPE_HEADER_74X);
     else
        sendMessageToHost(GRAPH_SETUP_74X);
  
     TheTimer.atTimeDo(50,0,0,1,0, "::YGN3and4.PicYGN_HDSR74Xsetup", "{bProcess.UnSelect();}");
  
     return 0;
  }`

  function `void ReturnAction(int no)
  {
     int i;
  
     execute("{ strcpy(TempString, bPoint_%d.TheOriginalText); }", no);
  
           for( i=0; i< 8; i++ ) {
             if( TempString[i] == ' ' )
                break;
  
                 TempPid[i] = TempString[i];
           }
          TempPid[i] =  '\\0';
  
     if( strcmp(TempPid,"") == 0 ) {
             execute("{ strcpy(gPage74x.point_%d, \\"\\"); }", no);
             execute("{ strcpy(bPoint_%d.TheOriginalText, \\"\\"); }", no);
             execute("{ strcpy(bPoint_%d.TheOriginalText, \\"\\"); }", no);
  
             execute("{ strcpy(gPage74x.minValue_%d, \\"0.0\\"); }", no);
             execute("{ strcpy(bMinValue_%d.TheOriginalText, \\"0.0\\"); }", no);
             execute("{ strcpy(bMinValue_%d.TheNewText, \\"0.0\\"); }", no);
  
             execute("{ strcpy(gPage74x.baseline_%d, \\"0.0\\"); }", no);
             execute("{ strcpy(bBaseline_%d.TheOriginalText, \\"0.0\\"); }", no);
             execute("{ strcpy(bBaseline_%d.TheNewText, \\"0.0\\"); }", no);
  
             execute("{ strcpy(gPage74x.maxValue_%d, \\"0.0\\"); }", no);
             execute("{ strcpy(bMaxValue_%d.TheOriginalText, \\"0.0\\"); }", no);
             execute("{ strcpy(bMaxValue_%d.TheNewText, \\"0.0\\"); }", no);
  
              execute("{ bPoint_%d.ERROR = 0; }", no);
               update();
              return;
     }
  
     if( FindPointId(TempString) == 0 ) {
          execute("{ SigType = %s->sig_type; }", TempPid);
  
           if( SigType == AI || SigType == PI ||SigType == FI ||SigType == AL ) {
             execute("{ TempMin = EngRangeLo(%s); }", TempPid);
             execute("{ TempMax = EngRangeHi(%s); }", TempPid);
  
              TempBase = (TempMin + TempMax) /2;
              execute("{ strcpy(gPage74x.point_%d, bPoint_%d.TheOriginalText); }", no, no);
  
              sprintf(TempString, "%8.2f", TempMin);
              execute("{ strcpy(gPage74x.minValue_%d, TempString); }", no);
              execute("{ strcpy(bMinValue_%d.TheNewText, TempString); }", no);
              execute("{ strcpy(bMinValue_%d.TheOriginalText, TempString); }", no);
  
              sprintf(TempString, "%8.2f", TempBase);
              execute("{ strcpy(gPage74x.baseline_%d, TempString); }", no);
              execute("{ strcpy(bBaseline_%d.TheNewText, TempString); }", no);
              execute("{ strcpy(bBaseline_%d.TheOriginalText, TempString); }", no);
  
              sprintf(TempString, "%8.2f", TempMax);
              execute("{ strcpy(gPage74x.maxValue_%d, TempString); }", no);
              execute("{ strcpy(bMaxValue_%d.TheNewText, TempString); }", no);
              execute("{ strcpy(bMaxValue_%d.TheOriginalText, TempString); }", no);
                 execute("{ bPoint_%d.ERROR = 1; }", no);
           }
           else if( SigType == CI || SigType == DL || SigType == SOE) {
              execute("{ strcpy(gPage74x.point_%d, bPoint_%d.TheOriginalText); }", no, no);
             execute("{ strcpy(gPage74x.minValue_%d, \\"0.0\\"); }", no);
             execute("{ strcpy(bMinValue_%d.TheOriginalText, \\"0.0\\"); }", no);
             execute("{ strcpy(bMinValue_%d.TheNewText, \\"0.0\\"); }", no);
  
             execute("{ strcpy(gPage74x.baseline_%d, \\"0.0\\"); }", no);
             execute("{ strcpy(bBaseline_%d.TheOriginalText, \\"0.0\\"); }", no);
             execute("{ strcpy(bBaseline_%d.TheNewText, \\"0.0\\"); }", no);
  
             execute("{ strcpy(gPage74x.maxValue_%d, \\"0.0\\"); }", no);
             execute("{ strcpy(bMaxValue_%d.TheOriginalText, \\"0.0\\"); }", no);
             execute("{ strcpy(bMaxValue_%d.TheNewText, \\"0.0\\"); }", no);
  
              execute("{ bPoint_%d.ERROR = 0; }", no);
           }
           else {
              sprintf( TempString, "INVALID PID TYPE: %s", TempPid);
              DisplayAdvisoryMessage1(TempString);
              execute("{ bPoint_%d.ERROR = 0; }", no);
           }
     }
     else {
              execute("{ strcpy(bPoint_%d.TheOriginalText, \\"\\"); }", no);
              execute("{ strcpy(bPoint_%d.TheNewText, \\"\\"); }", no);
  //            execute("{ strcpy(bPoint_%d.TheOriginalText, gPage74x.point_%d); }", no, no);
  //            execute("{ strcpy(bPoint_%d.TheNewText, gPage74x.point_%d); }", no, no);
              execute("{ bPoint_%d.ERROR = 0; }", no);
  
              sprintf( TempString, "INVALID PID: %s", TempPid);
              DisplayAdvisoryMessage1(TempString);
     }
     update();
     return;
  }
  `

  function `void ReturnActionForStartDate()
  {
     int i;
  
     strcpy(TempString, bStartDate.TheOriginalText);
           for( i=0; i< 8; i++ ) {
             if( TempString[i] == ' ' )
                break;
  
                 TempPid[i] = TempString[i];
           }
          TempPid[i] =  '\\0';
  
     if( TempPid[2] == '/' && TempPid[5] == '/' && strcmp(TempPid,"") != 0 )
        strcpy(gPage74x.startDate, bStartDate.TheOriginalText);
     else {
              strcpy(gPage74x.startDate, "");
              strcpy(bStartDate.TheOriginalText, "");
              strcpy(bStartDate.TheNewText, "");
            DisplayAdvisoryMessage1("INVALID FORMAT FOR START DATE");
             update();
     }
     return;
  }`

  function `void ReturnActionForStartTime()
  {
     int i;
  
     strcpy(TempString, bStartTime.TheOriginalText);
           for( i=0; i< 8; i++ ) {
             if( TempString[i] == ' ' )
                break;
  
                 TempPid[i] = TempString[i];
           }
          TempPid[i] =  '\\0';
  
     if( TempPid[2] == ':' && TempPid[5] == ':' && strcmp(TempPid,"") != 0 )
        strcpy(gPage74x.startTime, bStartTime.TheOriginalText);
     else {
              strcpy(gPage74x.startTime, "");
              strcpy(bStartTime.TheOriginalText, "");
              strcpy(bStartTime.TheNewText, "");
            DisplayAdvisoryMessage1("INVALID FORMAT FOR START TIME");
             update();
     }
     return;
  }`

  function `int SavePage74x( int num )
  {
     execute("{ gPage74%d.graphSet = gPage74x.graphSet; }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.dataSource, gPage74x.dataSource); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.resolution, gPage74x.resolution); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.startDate, gPage74x.startDate); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.startTime, gPage74x.startTime); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.endDate, gPage74x.endDate); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.endTime, gPage74x.endTime); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.validStartDate, gPage74x.validStartDate); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.validStartTime, gPage74x.validStartTime); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.validEndDate, gPage74x.validEndDate); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.validEndTime, gPage74x.validEndTime); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.point_1, gPage74x.point_1); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74%d.point_2, gPage74x.point_2); }", num);
