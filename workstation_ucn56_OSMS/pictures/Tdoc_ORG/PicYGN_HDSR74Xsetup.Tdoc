  //   executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.validEndDate, gPage74%d.validEndDate); }", num);
  //   executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.validEndTime, gPage74%d.validEndTime); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.point_1, gPage74%d.point_1); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.point_2, gPage74%d.point_2); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.point_3, gPage74%d.point_3); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.point_4, gPage74%d.point_4); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.baseline_1, gPage74%d.baseline_1); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.baseline_2, gPage74%d.baseline_2); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.baseline_3, gPage74%d.baseline_3); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.baseline_4, gPage74%d.baseline_4); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.maxValue_1, gPage74%d.maxValue_1); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.maxValue_2, gPage74%d.maxValue_2); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.maxValue_3, gPage74%d.maxValue_3); }", num);
     executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.maxValue_4, gPage74%d.maxValue_4); }", num);
  //   executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.enablePage, gPage74%d.enablePage); }", num);
  //   executeAsync( "::YGN3and4.PicYGN_HDSR74Xsetup", "{ strcpy( gPage74x.tapeUse, gPage74%d.tapeUse); }", num);
  }`

  function `void Initialize()
  {
     int num;
     num = gPage74x.graphSet;
     CFMLevel = 0;
     Current_Page = 175;
  
     ClearAdvisoryMessage();
     MakeTitle(num);
     InitializeInput();
     executeAsync ("::YGN3and4.PicYGN_HDSR750","{InitializeInput();}");
  
     bProcess.UnSelect();
     TheTimer.atIntervalDo(200,0,0,5,0, "::YGN3and4.PicYGN_HDSR74Xsetup", "{ sendMessageToHost(HDSR_GRAPH_SETUP); UpdateDataRange();}");
  
  // reset bPoint.ERROR
     if( FindPointId(gPage74x.point_1) == 0 )
          if( IsDigital(gPage74x.point_1) == 1 )
              bPoint_1.ERROR = 0;
           else
              bPoint_1.ERROR = 1;
     else
        bPoint_1.ERROR = 0;
  
     if( FindPointId(gPage74x.point_2) == 0 )
          if( IsDigital(gPage74x.point_2) == 1 )
              bPoint_2.ERROR = 0;
           else
        bPoint_2.ERROR = 1;
     else
        bPoint_2.ERROR = 0;
  
     if( FindPointId(gPage74x.point_3) == 0 )
          if( IsDigital(gPage74x.point_3) == 1 )
              bPoint_3.ERROR = 0;
           else
        bPoint_3.ERROR = 1;
     else
        bPoint_3.ERROR = 0;
  
     if( FindPointId(gPage74x.point_4) == 0 )
          if( IsDigital(gPage74x.point_4) == 1 )
              bPoint_4.ERROR = 0;
           else
        bPoint_4.ERROR = 1;
     else
        bPoint_4.ERROR = 0;
  }
  `

