  function `void BaselineReturnAction(int no)
  {
     int i;
  
     execute("{ strcpy(TempString, gPage74x.point_%d); }", no);
  
           for( i=0; i< 8; i++ ) {
             if( TempString[i] == ' ' )
                break;
  
                 TempPid[i] = TempString[i];
           }
          TempPid[i] =  '\\0';
  
     if( strcmp(TempPid,"") == 0 ) {
             execute("{ strcpy(gPage74x.baseline_%d, \\"0.0\\"); }", no);
             execute("{ strcpy(bBaseline_%d.TheOriginalText, \\"0.0\\"); }", no);
             execute("{ strcpy(bBaseline_%d.TheNewText, \\"0.0\\"); }", no);
          return;
     }
  
     execute("{ strcpy(TempString, bBaseline_%d.TheOriginalText); }", no);
  
           for( i=0; i< 8; i++ ) {
             if( TempString[i] == ' ' )
                break;
  
                 TempPid[i] = TempString[i];
           }
          TempPid[i] =  '\\0';
  
     if( strcmp(TempPid,"") == 0 ) {
             execute("{ strcpy(gPage74x.baseline_%d, \\"0.0\\"); }", no);
             execute("{ strcpy(bBaseline_%d.TheOriginalText, \\"0.0\\"); }", no);
             execute("{ strcpy(bBaseline_%d.TheNewText, \\"0.0\\"); }", no);
     }
     else
             execute("{ strcpy(gPage74x.baseline_%d, bBaseline_%d.TheOriginalText); }", no, no);
  
     update();
  }`

  function `int Checkup()
  {
           if( strcmp( gPage74x.dataSource, "D") != 0 && strcmp( gPage74x.dataSource, "T") != 0 ) {
              DisplayAdvisoryMessage1("DATA SOURCE CHOICES: (D,T)");
              return -1;
           }
  
           if( strcmp( gPage74x.resolution, "L") != 0 &&
               strcmp( gPage74x.resolution, "H") != 0 &&
               strcmp( gPage74x.resolution, "R") != 0 &&
               strcmp( gPage74x.resolution, "H1") != 0 &&
               strcmp( gPage74x.resolution, "H2") != 0 ) {
              DisplayAdvisoryMessage1("RESOLUTION CHOICES: (L, H, H1, H2, R)");
  //            return -1;
           }
  
           else if( strcmp(gPage74x.dataSource, "T") == 0 && strcmp(gPage74x.resolution, "H") == 0 ) {
              DisplayAdvisoryMessage1("RESOLUTION CHOICES: (L, H1, H2, R)");
  //            return -1;
           }
  
           else if( strcmp(gPage74x.dataSource, "D") == 0 && ( strcmp(gPage74x.resolution, "H1") == 0 ||
               strcmp(gPage74x.resolution, "H2") == 0 || strcmp(gPage74x.resolution, "R") == 0) ) {
              DisplayAdvisoryMessage1("RESOLUTION CHOICES: (L, H)");
  //            return -1;
           }
  
        // Display valid Hi/Lo disk start/end date/time
           if( strcmp(gPage74x.dataSource, "D") == 0 && strcmp(gPage74x.resolution, "H") == 0 ) {
              strcpy( gPage74x.validStartDate, gPage74x.highDiskDate_1);
              strcpy( gPage74x.validEndDate, gPage74x.highDiskDate_2);
              strcpy( gPage74x.validStartTime, gPage74x.highDiskTime_1);
              strcpy( gPage74x.validEndTime, gPage74x.highDiskTime_2);
           }
           else if( strcmp(gPage74x.dataSource, "D") == 0 && strcmp(gPage74x.resolution, "L") == 0 ) {
              strcpy( gPage74x.validStartDate, gPage74x.lowDiskDate_1);
              strcpy( gPage74x.validEndDate, gPage74x.lowDiskDate_2);
              strcpy( gPage74x.validStartTime, gPage74x.lowDiskTime_1);
              strcpy( gPage74x.validEndTime, gPage74x.lowDiskTime_2);
           }
           else if( strcmp(gPage74x.dataSource, "T") == 0 ) {
                if( strcmp(gPage74x.resolution, "R") == 0 ) {
  //            if( ((strcmp(gPage74x.resolution, "H1") == 0 || strcmp(gPage74x.resolution, "H2") == 0 ) &&
  //                gPage750.iResolution == 1) || ( strcmp(gPage74x.resolution, "L") == 0 &&
  //                gPage750.iResolution == 2) ){
  //               strcpy( gPage74x.validStartDate, gPage750.startDate);
  //               strcpy( gPage74x.validEndDate, gPage750.endDate);
  //               strcpy( gPage74x.validStartTime, gPage750.startTime);
  //               strcpy( gPage74x.validEndTime, gPage750.endTime);
  //            }
  //            else {
                 strcpy( gPage750.startDate, "--/--/--");
                 strcpy( gPage750.endDate, "--/--/--");
                 strcpy( gPage750.startTime, "--:--:--");
                 strcpy( gPage750.endTime, "--:--:--");
              }
                 strcpy( gPage74x.validStartDate, gPage750.startDate);
                 strcpy( gPage74x.validEndDate, gPage750.endDate);
                 strcpy( gPage74x.validStartTime, gPage750.startTime);
                 strcpy( gPage74x.validEndTime, gPage750.endTime);
                 UpdateDataRange();
           }
           update();
  }`

  function `int CheckupBlank( char * pointName )
  {
     if( strcmp( pointName,"" ) == 0 )
        return -1;
     else
        return 0;
  }`

  function `int EvaluateRange(char *pid)
  {
       TempMin = EngRangeLo(pid);
       TempMax = EngRangeHi(pid);
  
       TempBase = (TempMin + TempMax) /2;
        return 0;
  }`

  function `void Finished()
  {
     TheTimer.cancel(200);
  }`

  function `int Init74x( int num )
  {
