  instance DialogueSymbols.InputDialogueText50 bDataSource
  {
    x = 445;
    y = 65;
    visibility = 1;
    xReference = 445;
    yReference = 65;
    xScaleFactor = 1;
    yScaleFactor = 1;
    rotationAngle = 0;
    BackgroundColour = `COLOR_BUTTON_BACKGROUND`;
    BottomShadow = `COLOR_BUTTON_BOTTOM_SHADOW`;
    ERROR = 0;
    ExecuteSelect = "DummyProcess()";	//CORENET 0705
    ExecuteUnSelect = "DummyProcess()";	//CORENET 0705
    Height = 30;
    isDown = 0;
    isInside = 1;
    MaxCharacters = 3;
    ReturnAction = "{ strcpy(gPage74x.dataSource, bDataSource.TheOriginalText); Checkup(); }";
    Scope = "::YGN3and4.PicYGN_HDSR74Xsetup";
    SelectColour = `COLOR_BUTTON_SELECTED`;
    Selected = 0;
    TextColour = `COLOR_PICTURE_BACKGROUND`;
    TextFont = 4;
    TextX = 10;
