  function `void SendFileName()
{
   if (option>0 && fileCharsEntered>0)
   {
   Interface->UtdvDialogue.option=option;
   Interface->UtdvDialogue.current_page=696;
   strcpy(Interface->UtdvDialogue.filename1,fileName1);
   execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
   processingText.visibility=1;
   }
   else
   {  
      if(option<=0)
//       optionError.visibility=1;
      if(fileCharsEntered<=0)
         fileError.visibility=1;
    }
//
    update();
}`



