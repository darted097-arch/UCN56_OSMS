  function `void ProcessFileName()
{
  inputFileName.InputArea.visibility=1;
  IsFileBlank(inputFileName.TheNewText);

  if (fileCharsEntered > 0)
  {
     strcpy(fileName1,inputFileName.TheNewText);
     strcpy(inputFileName.TheOriginalText,inputFileName.TheNewText);
     fileError.visibility=0;
//     SendFileName();
  }
  else
  {
     fileError.visibility=1;
  }
  update();
}`



