            execute ("{strcpy(XRBP_IN19.TheOriginalText,TextS);}");          
             }
          if(susp==0)   
             execute ("{strcpy(XRBP_IN19.TheOriginalText,XRBP_IN19.TheNewText);}");          
//
// Permit the result of " " according UCN 3&4.
      susp=0;
      execute ("{CEA_MAN = Interface->XRBP.data.input_val[19] ;}");
          if (CEA_MAN== 2) execute ("{strcpy(XRBP_IN20.TheNewText, Text1);}");
           else if (CEA_MAN== 3) execute ("{strcpy(XRBP_IN20.TheNewText, Text2);}");
           else if (CEA_MAN== 4) execute ("{strcpy(XRBP_IN20.TheNewText, Text3);}");
           else if (CEA_MAN== 5) execute ("{strcpy(XRBP_IN20.TheNewText, Text4);}");
           else if (CEA_MAN== 6) execute ("{strcpy(XRBP_IN20.TheNewText, Text5);}");
           else if (CEA_MAN== 7) execute ("{strcpy(XRBP_IN20.TheNewText, TextP);}");
           else if (CEA_MAN== 9) execute ("{strcpy(XRBP_IN20.TheNewText, TextA);}");
           else if (CEA_MAN==10) execute ("{strcpy(XRBP_IN20.TheNewText, TextB);}");
           else if (CEA_MAN==0 || CEA_MAN==1 || CEA_MAN==8) 
                                 execute ("{strcpy(XRBP_IN20.TheNewText, TextS);}");
           else {
            susp=1;
            ClearAdvisoryMessage();
            DisplayAdvisoryMessage("ERROR OUTPUTING TO DISPLAY. RESULTS MAY NOT BE CORRECT");
