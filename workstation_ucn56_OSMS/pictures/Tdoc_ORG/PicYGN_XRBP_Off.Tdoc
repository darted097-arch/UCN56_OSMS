       if((CASE_FLAG==1) && (LASTCASE.TheNewNumber==1)) {
              Wait.visibility=1;
              Wait1.visibility=1;
              CASE_FLAG=0;
              }
         else {
              Wait1.visibility=0;
              Wait.visibility=0;
             }
//
      ClearAdvisoryMessage();
      DisplayAdvisoryMessage("REQUEST PROCESSED BY HOST");
//
