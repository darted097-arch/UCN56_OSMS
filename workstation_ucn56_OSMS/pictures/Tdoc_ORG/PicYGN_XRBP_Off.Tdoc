//
      for (i=1;i<11;i++)
         {
        execute ("{XRBP_IN%d.TheNewNumber = Interface->XRBP.data.input_val[%d];}",i,i-1);
        execute ("{strcpy(XRBP_IN%d.TheOriginalText,TextS);}",i);
        execute ("{XRBP_IN%d.TheOriginalNumber = XRBP_IN%d.TheNewNumber;}",i,i);
         }
//     Set initial time to previous final time for next input.
        execute ("{XRBP_IN11.TheNewNumber = Interface->XRBP.data.input_val[12];}");
        execute ("{strcpy(XRBP_IN11.TheOriginalText,TextS);}");
        execute ("{XRBP_IN11.TheOriginalNumber = XRBP_IN12.TheNewNumber;}");
//
      for (i=12;i<19;i++)
         {
        execute ("{XRBP_IN%d.TheNewNumber = Interface->XRBP.data.input_val[%d];}",i,i-1);
        execute ("{strcpy(XRBP_IN%d.TheOriginalText,TextS);}",i);
        execute ("{XRBP_IN%d.TheOriginalNumber = XRBP_IN%d.TheNewNumber;}",i,i);
         }
//
// Do not permit the result of " " according UCN 3&4.
      susp=0;
      execute ("{CEA_ASI = Interface->XRBP.data.input_val[18];}");
          if (CEA_ASI==2) execute ("{strcpy(XRBP_IN19.TheNewText, Text1);}");
           else if (CEA_ASI== 3) execute ("{strcpy(XRBP_IN19.TheNewText, Text2);}");
           else if (CEA_ASI== 4) execute ("{strcpy(XRBP_IN19.TheNewText, Text3);}");
           else if (CEA_ASI== 5) execute ("{strcpy(XRBP_IN19.TheNewText, Text4);}");
           else if (CEA_ASI== 6) execute ("{strcpy(XRBP_IN19.TheNewText, Text5);}");
           else if (CEA_ASI== 7) execute ("{strcpy(XRBP_IN19.TheNewText, TextP);}");
           else if (CEA_ASI== 9) execute ("{strcpy(XRBP_IN19.TheNewText, TextA);}");
           else if (CEA_ASI==10) execute ("{strcpy(XRBP_IN19.TheNewText, TextB);}");
           else {
            susp=1;
