  function `void Initialize()
{
   ClearAdvisoryMessage();

   CFMLevel = 0;
   Current_Page = 621;

   if(XRBP_FLAG!=623){
      //DisplayAdvisoryMessage("INITIALIZING XRBP OFF-LINE MODE");
      execute("{sendMessageToHost(XRBP_INIT);}");
      Wait.visibility=1;
      Wait1.visibility=0;
      CASE_FLAG=0;
      }

   XRBP_FLAG=621;
}`



  function `void Process1()
{
    int result;
    int i;

    ClearAdvisoryMessage();

    // Verify each input field for offline XRBP
    for (i=0;i<22;i++) {
        result = VerifyInput(i);
        if (result != 0) {
           ClearAdvisoryMessage();
           DisplayAdvisoryMessage("CANNOT SEND XRBP OFF-LINE CALCULATION REQUEST MESSAGE");
           DisplayAdvisoryMessage1("INVALID INPUT EXIST");
           return; 
        }
    }
    // if everything is good, then send the message to CCUR
       DisplayAdvisoryMessage("SENDING XRBP OFF-LINE CALCULATION REQUEST MESSAGE");
       SaveData();
       execute("{sendMessageToHost(XRBP_REQUEST);}"); 

       Wait.visibility=1;
       Wait1.visibility=0;
}
        
       `



  function `int VerifyInput(int number)
{
    float  value;
    char   *temp;
    float  temp_DegF;

    switch (number)
    {
        case 1: //Criticality Search - 1=PPM,2=ROD,3=PWR,4=TAVG
          value = XRBP_IN1.TheNewNumber;
          if ((value<1.0)||(value>4.0)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("PRIMARY AND SECONDARY SEARCH PARAMETERS");
             DisplayAdvisoryMessage2("MUST BE 1,2,3 OR 4");
             DisplayAdvisoryMessage3("SECONDARY SEARCH PARAMETER MAY BE 0");
             XRBP_IN1.input_mode_Btn();
             return(1);
          }
          XRBP_IN1.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN1.TheOriginalText,TextS);}");
          break;
        case 2: //Initial Depletion Value
          value = XRBP_IN2.TheNewNumber;
          if (value<0.0) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("INITIAL DEPLETION VALUE:");
             DisplayAdvisoryMessage2("MUST BE GREATER THAN OR EQUAL TO 0");
             DisplayAdvisoryMessage3(" ");
             XRBP_IN2.input_mode_Btn();
             return(1);
          }
          XRBP_IN2.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN2.TheOriginalText,TextS);}");
          break;
        case 3: //Incremental Depletion Value
          value = XRBP_IN3.TheNewNumber;
          if (value<0.0) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("INCREMENTAL DEPLETION VALUE:");
             DisplayAdvisoryMessage2("MUST BE GREATER THAN OR EQUAL TO 0");
             DisplayAdvisoryMessage3(" ");
             XRBP_IN3.input_mode_Btn();
             return(1);
          } 
          XRBP_IN3.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN3.TheOriginalText,TextS);}");
          break;
        case 4: // Final Depletion Value
          value = XRBP_IN4.TheNewNumber;
         if (value<0.0) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("FINAL DEPLETION VALUE:");
             DisplayAdvisoryMessage2("MUST BE GREATER THAN OR EQUAL TO 0");
             DisplayAdvisoryMessage3(" ");
             XRBP_IN4.input_mode_Btn();
             return(1);
          } 
          XRBP_IN4.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN4.TheOriginalText,TextS);}");
          break;
        case 5: // Exposure Block Number to be Read
          value = XRBP_IN5.TheNewNumber;
          if ((value<0.0)||(value>50.0)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("EXPOSURE BLOCK NUMBER TO READ:");
             DisplayAdvisoryMessage2("MUST BE BETWEEN 0 AND 50");
             XRBP_IN5.input_mode_Btn();
             return(1);
          } 
          XRBP_IN5.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN5.TheOriginalText,TextS);}");
          break;
        case 6: // Exposure Block Number to be Written
          value = XRBP_IN6.TheNewNumber;
          if ((value<-50.0)||(value>50.0)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("EXPOSURE BLOCK NUMBER TO BE WRITTEN:");
             DisplayAdvisoryMessage2("MUST BE BETWEEN -50 AND 50");
             XRBP_IN6.input_mode_Btn();
             return(1);
          } 
          XRBP_IN6.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN6.TheOriginalText,TextS);}");
          break;
        case 7: // Boron Concentration
          value = XRBP_IN7.TheNewNumber;
          if ((value<0.0)||(value>2000.0)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("BORON CONCENTRATION:");
             DisplayAdvisoryMessage2("MUST BE FROM 0 TO 2000");
             XRBP_IN7.input_mode_Btn();
             return(1);
          } 
          XRBP_IN7.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN7.TheOriginalText,TextS);}");
          break;
        case 8: // Core Power Level 
          value = XRBP_IN8.TheNewNumber;
          if (value<0.0) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("CORE POWER LEVEL:");
             DisplayAdvisoryMessage2("MUST BE A POSITIVE NUMBER");
             XRBP_IN8.input_mode_Btn();
             return(1);
          } 
          XRBP_IN8.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN8.TheOriginalText,TextS);}");
          break;
        case 9: // Xenon-Iodine Block Numbers to be Read
          value = XRBP_IN9.TheNewNumber;
          if ((value<0.0)||(value>50.)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("XENON-IODINE BLOCK NUMBER TO BE READ:");
             DisplayAdvisoryMessage2("MUST BE BETWEEN 0 AND 50");
             XRBP_IN9.input_mode_Btn();
             return(1);
          } 
          XRBP_IN9.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN9.TheOriginalText,TextS);}");
          break;
        case 10: // Xenon-Iodine Block Numbers to be Written 
          value = XRBP_IN10.TheNewNumber;
          if ((value<0.0)||(value>50.0)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("XENON-IODINE BLOCK NUMBER TO BE WRITTEN:");
             DisplayAdvisoryMessage2("MUST BE BETWEEN 0 AND 50");
             XRBP_IN10.input_mode_Btn();
             return(1);
          } 
          XRBP_IN10.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN10.TheOriginalText,TextS);}");
          break;
        case 11: //Initial Xenon Transient Value
          value = XRBP_IN11.TheNewNumber;
          if (value<0.0) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("INITIAL XENON TRANSIENT VALUE:");
             DisplayAdvisoryMessage2("MUST BE GREATER THAN OR EQUAL TO 0");
             XRBP_IN11.input_mode_Btn();
             return(1);
          } 
          XRBP_IN11.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN11.TheOriginalText,TextS);}");
          break;
        case 12: //Incremental Xenon Transient Value
          value = XRBP_IN12.TheNewNumber;
          if (value<0.0) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("INCREMENTAL XENON TRANSIENT VALUE:");
             DisplayAdvisoryMessage2("MUST BE GREATER THAN OR EQUAL TO 0");
             XRBP_IN12.input_mode_Btn();
             return(1);
          } 
          XRBP_IN12.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN12.TheOriginalText,TextS);}");
          break;
        case 13: //Final Xenon Transient Value 
          value = XRBP_IN13.TheNewNumber;
          if (value<0.0) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("FINAL XENON TRANSIENT VALUE:");
             DisplayAdvisoryMessage2("MUST BE GREATER THAN OR EQUAL TO 0");
             XRBP_IN13.input_mode_Btn();
             return(1);
          } 
          XRBP_IN13.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN13.TheOriginalText,TextS);}");
          break;
        case 14: // Core Average Moderator Inlet Temperature
          value = XRBP_IN14.TheNewNumber;
          temp_DegF = (value * 1.8 ) +32.;
          if (temp_DegF<300.0) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("CORE AVERAGE MODERATOR INLET TEMP:");
             DisplayAdvisoryMessage2("MUST BE GREATER THAN OR EQUAL TO 150");
             XRBP_IN14.input_mode_Btn();
             return(1);
          } 
          XRBP_IN14.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN14.TheOriginalText,TextS);}");
          break;
        case 15: // ASI Search Flag 
          value = XRBP_IN15.TheNewNumber;
          if ((value != 0) && (value != 1)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("ASI SEARCH FLAG:");
             DisplayAdvisoryMessage2("MUST BE 0 OR 1");
             XRBP_IN15.input_mode_Btn();
             return(1);
          } 
          XRBP_IN15.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN15.TheOriginalText,TextS);}");
          break;
        case 16: //ASI SEARCH TARGET VALUE
          value = XRBP_IN16.TheNewNumber;
          if ((value < -1.0) || (value > 1.0)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("ASI SEARCH TARGET VALUE:");
             DisplayAdvisoryMessage2("MUST BE BETWEEN -1 AND 1");
             XRBP_IN16.input_mode_Btn();
             return(1);
          } 
          XRBP_IN16.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN16.TheOriginalText,TextS);}");
          break;
        case 17: //ASI SEARCH DEAD BAND
          value = XRBP_IN17.TheNewNumber;
          if ((value < 0.0) || (value > 0.1)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("ASI SEARCH DEAD BAND:");
             DisplayAdvisoryMessage2("MUST BE BETWEEN 0 AND 0.1");
             XRBP_IN17.input_mode_Btn();
             return(1);
          } 
          XRBP_IN17.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN17.TheOriginalText,TextS);}");
          break;
        case 18: //ASI SEARCH CONTROL BAND
          value = XRBP_IN18.TheNewNumber;
          if ((value < 0.0) || (value > 0.1)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("ASI SEARCH CONTROL BAND:");
             DisplayAdvisoryMessage2("MUST BE BETWEEN 0 AND 0.1");
             XRBP_IN18.input_mode_Btn();
             return(1);
          } 
          XRBP_IN18.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN18.TheOriginalText,TextS);}");
          break;
        case 19: //ASI SEARCH SELECTED CONTROL ROD GROUP
                 // Accoding to UCN 3&4, the input of " " is not prohibited.
          temp = XRBP_IN19.TheNewText;
          if (strcmp(temp,"1")==0) CEA_ASI=2;
          else if (strcmp(temp,"2")==0) CEA_ASI=3;
          else if (strcmp(temp,"3")==0) CEA_ASI=4;
          else if (strcmp(temp,"4")==0) CEA_ASI=5;
          else if (strcmp(temp,"5")==0) CEA_ASI=6;
          else if (strcmp(temp,"P")==0) CEA_ASI=7;
          else if (strcmp(temp,"A")==0) CEA_ASI=9;
          else if (strcmp(temp,"B")==0) CEA_ASI=10;
          else if (strcmp(temp," ")==0) CEA_ASI=0;
          else {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("ASI SEARCH SELECTED CEA GROUP:");
             DisplayAdvisoryMessage2("ALLOWABLE ENTRIES ARE: A,B,1,2,3,4,5,P");
             execute ("{strcpy(XRBP_IN19.TheOriginalText, prev_ASI);}");
             XRBP_IN19.input_mode_Btn();
             XRBP_IN19.Selected=0;
             return(1);
          }  
          execute ("{strcpy(prev_ASI,XRBP_IN19.TheNewText);}");
          break; 
        case 20: //CONTROL ROD GROUP NUMBER (MANUAL OPERATION)
                 // Accoding to UCN 3&4, the input of " " is permitted.
          temp = XRBP_IN20.TheNewText;
          if (strcmp(temp,"1")==0) CEA_MAN=2;
          else if (strcmp(temp,"2")==0) CEA_MAN=3;
          else if (strcmp(temp,"3")==0) CEA_MAN=4;
          else if (strcmp(temp,"4")==0) CEA_MAN=5;
          else if (strcmp(temp,"5")==0) CEA_MAN=6;
          else if (strcmp(temp,"P")==0) CEA_MAN=7;
          else if (strcmp(temp,"A")==0) CEA_MAN=9;
          else if (strcmp(temp,"B")==0) CEA_MAN=10;
          else if (strcmp(temp," ")==0) CEA_MAN=0;
          else {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("CEA GROUP (MANUAL OPERATION):");
             DisplayAdvisoryMessage2("ALLOWABLE ENTRIES ARE: A,B,1,2,3,4,5, ,P");
             execute ("{strcpy(XRBP_IN20.TheOriginalText,prev_MAN);}");
             XRBP_IN20.input_mode_Btn();
             XRBP_IN20.Selected=0;
             return(1);
          } 
          execute ("{strcpy(prev_MAN, XRBP_IN20.TheNewText);}"); 
          break; 
        case 21: //CONTROL ROD GROUP POSITION
          value = XRBP_IN21.TheNewNumber;
          if ((value < 0.0) || (value > 381)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("CEA GROUP POSITION:");
             DisplayAdvisoryMessage2("MUST BE FROM 0 TO 381");
             XRBP_IN21.input_mode_Btn();
             return(1);
          } 
          XRBP_IN21.TheOriginalNumber=value;
          execute ("{strcpy(XRBP_IN21.TheOriginalText,TextS);}");
          break;
        case 0:
          value = LASTCASE.TheNewNumber;
          if ((value != 0) && (value != 1)) {
             ClearAdvisoryMessage();
             DisplayAdvisoryMessage1("LAST CASE:");
             DisplayAdvisoryMessage2("MUST BE 0 OR 1");
             LASTCASE.input_mode_Btn();
             return(1);
          } 
          LASTCASE.TheOriginalNumber=value;
          execute ("{strcpy(LASTCASE.TheOriginalText,TextS);}");
          break;
      }
      return(0);
}`



  function `void Escape()
{
//This function is used for footer keys except PREV and NEXT keys.
//
      XRBP_FLAG=0;
}`



  function `void SaveData() //Send the user inputs to message buffer
{
      int i;	// loop counter
   //
      for (i=1;i<19;i++){
          execute ("{Interface->XRBP.data.input_val[%d] = XRBP_IN%d.TheNewNumber;}",i-1,i);
      }
      execute ("{Interface->XRBP.data.input_val[18] = CEA_ASI;}");
      execute ("{Interface->XRBP.data.input_val[19] = CEA_MAN;}");
      //execute ("{Interface->XRBP.data.last_case = atoi(LASTCASE.TheNewText);}");
      execute ("{Interface->XRBP.data.last_case = LASTCASE.TheNewNumber;}");
      execute ("{Interface->XRBP.data.input_val[20] = XRBP_IN21.TheNewNumber;}"); 
//
      if(LASTCASE.TheNewNumber==1)
               CASE_FLAG=1;
        else
               CASE_FLAG=0;          
}
`



  function `void Init_Completed()
{ 
   if((Current_Page!=621) && (Current_Page!=623)) 
      return;

      int i;	// loop counter
      int susp; // FLAG for CEA Group Display

   //
      for (i=1;i<19;i++)
        {
        execute ("{XRBP_IN%d.TheNewNumber = Interface->XRBP.data.input_val[%d];}",i,i-1);
        execute ("{strcpy(XRBP_IN%d.TheOriginalText,TextS);}",i);
        execute ("{XRBP_IN%d.TheOriginalNumber = XRBP_IN%d.TheNewNumber;}",i,i);
        }
      susp=0;
      execute ("{CEA_ASI = Interface->XRBP.data.input_val[18];}");
          if (CEA_ASI==2) execute ("{strcpy(XRBP_IN19.TheNewText, Text1);}");
           else if (CEA_ASI== 3) execute ("{strcpy(XRBP_IN19.TheNewText, Text2);}");
           else if (CEA_ASI== 4) execute ("{strcpy(XRBP_IN19.TheNewText, Text3);}");
           else if (CEA_ASI== 5) execute ("{strcpy(XRBP_IN19.TheNewText, Text4);}");
           else if (CEA_ASI== 6) execute ("{strcpy(XRBP_IN19.TheNewText, Text5);}");
           else if (CEA_ASI== 7) execute ("{strcpy(XRBP_IN19.TheNewText, TextP);}");
           else if (CEA_ASI== 9) execute ("{strcpy(XRBP_IN19.TheNewText, TextA);}");
           else if (CEA_ASI==10) execute ("{strcpy(XRBP_IN19.TheNewText, TextB);}");
           else susp=1;
           // XRBP doesn't permit the result of " " according UCN 3&4.
             //else if (CEA_ASI==0 || CEA_ASI==1 || CEA_ASI==8) 
             //                      execute ("{strcpy(XRBP_IN19.TheNewText, TextS);}");
          if(susp==0)  
              execute ("{strcpy(XRBP_IN19.TheOriginalText,XRBP_IN19.TheNewText);}"); 
//
      susp=0;
      execute ("{CEA_MAN = Interface->XRBP.data.input_val[19] ;}");
          if (CEA_MAN== 2) execute ("{strcpy(XRBP_IN20.TheNewText, Text1);}");
           else if (CEA_MAN== 3) execute ("{strcpy(XRBP_IN20.TheNewText, Text2);}");
           else if (CEA_MAN== 4) execute ("{strcpy(XRBP_IN20.TheNewText, Text3);}");
           else if (CEA_MAN== 5) execute ("{strcpy(XRBP_IN20.TheNewText, Text4);}");
           else if (CEA_MAN== 6) execute ("{strcpy(XRBP_IN20.TheNewText, Text5);}");
           else if (CEA_MAN== 7) execute ("{strcpy(XRBP_IN20.TheNewText, TextP);}");
           else if (CEA_MAN== 9) execute ("{strcpy(XRBP_IN20.TheNewText, TextA);}");
           else if (CEA_MAN==10) execute ("{strcpy(XRBP_IN20.TheNewText, TextB);}");
           else if (CEA_MAN==0 || CEA_MAN==1 || CEA_MAN==8) 
                                 execute ("{strcpy(XRBP_IN20.TheNewText, TextS);}");
           else susp=1;
          if(susp==0)  
             execute ("{strcpy(XRBP_IN20.TheOriginalText, XRBP_IN20.TheNewText);}");
//
      execute ("{XRBP_IN21.TheNewNumber = Interface->XRBP.data.input_val[20];}");
      execute ("{strcpy(XRBP_IN21.TheOriginalText,TextS);}");
      execute ("{XRBP_IN21.TheOriginalNumber = XRBP_IN21.TheNewNumber;}");
//
      execute ("{LASTCASE.TheNewNumber = Interface->XRBP.data.last_case;}");
      execute ("{strcpy(LASTCASE.TheOriginalText,TextS);}");
      execute ("{LASTCASE.TheOriginalNumber = LASTCASE.TheNewNumber;}");
    
      Wait.visibility=0;
      Wait1.visibility=0;
      update();

       //DisplayAdvisoryMessage("INITIALIZATION COMPLETED");
       //DisplayAdvisoryMessage1("THE PREVIOUSLY RUN CASE IS PRESENTED.");
       //DisplayAdvisoryMessage2("IT IS RECOMMEDED TO SET THE LAST CASE RUN TO 1.");
}
     `



  function `void Host_Messages()
{
   if((Current_Page!=621) && (Current_Page!=623)) 
      return;

   ClearAdvisoryMessage();
   DisplayAdvisoryMessage1(Interface->GenericConfirmMessage.data.message1);
   DisplayAdvisoryMessage2(Interface->GenericConfirmMessage.data.message2);
   DisplayAdvisoryMessage3(Interface->GenericConfirmMessage.data.message3);
}`



