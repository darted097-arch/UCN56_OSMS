         }
         else                               // For Analog PID
         {
	 /* ***********CORENET 20170620*************************************
            if ( (Interface->System.displayedUnits) && (!(StaPID1->pipbitmap & bMETUNIT)) )
            {
               Trend1.Baseline =  Interface->VideoTrendData.Set1Point1.Baseline * StaPID1->mfactor + StaPID1->moffset;
               Trend1.BASE =      Interface->VideoTrendData.Set1Point1.Baseline * StaPID1->mfactor + StaPID1->moffset;
