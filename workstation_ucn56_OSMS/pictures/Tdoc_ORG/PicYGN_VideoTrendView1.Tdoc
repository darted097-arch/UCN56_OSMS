  function `void escape()
  {
     ProcMsg.visibility = 1 ;
  
     if(Priority)   // Set flipflop by yrlee
     {
        Interface->VTFlagMessage.data.requestOption = 1;
        Interface->VTFlagMessage.data.flipflop1 = 0;
        execute("{sendMessageToHost(REQUEST_VTREND_DATA);}");
     }
     execute("{::YGN3and4.PicYGN_VideoTrendMenu.SaveOldPid();}") ;
  }`

  function `void escapeToMenu()
  {
     ProcMsg.visibility = 1 ;
  
     if(Priority)   // Set flipflop by yrlee
     {
        Interface->VTFlagMessage.data.requestOption = 1;
        Interface->VTFlagMessage.data.flipflop1 = 0;
        execute("{sendMessageToHost(REQUEST_VTREND_DATA);}");
     }
  
     VideoSetno = 1;
     execute("{::YGN3and4.PicYGN_VideoTrendMenu.SaveOldPid();}") ;
     execute("{DisplayPage(\\"%s\\");}",TheDisplayPage);
  }`

