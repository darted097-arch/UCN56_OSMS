  function `void Initialize()
  {
   int i,j;      // loop variables
  
  //printf("%s Initialize()",PictureTitle);
  
     CFMLevel = 0;
     Current_Page = 820;
  
     DisplayRate = 2;	
     PrintDuration = 0;
     DurationLimit = \`DisplayRate*200/60\`;
     PrintNo = 0;
  
  
  // Request dtrend data from host
     execute("{sendMessageToHost(REQUEST_DTREND_DATA);}");
  
  // Set visibility for request message
     DisplayAdvisoryMessage(" ");
     DisplayAdvisoryMessage1(" ");
     DisplayAdvisoryMessage2(" ");
     DisplayAdvisoryMessage3(" ");
  
     SETUP = 0 ;
     DTrendInUse = 0;
     UsedMsg.visibility = 0;
     ProcessProcessingMsg.visibility = 0;
     ProcessBlank1Msg.visibility = 0 ;
     ProcessError1Msg.visibility = 0 ;
  
     ProcessReqMsg.visibility = 1;
  
     ProcessDownloadERROR = 1;
  
  
       for (i=1;i<=NUM_DTREND_SETS;i++)
        for (j=1;j<=NUM_DTREND_PER_SET;j++)
      {
  //      execute("{Set%dTrd%dPID.UnSelectButton();}",i,j);
        execute("{Set%dTrd%dPID.ERROR=0;}",i,j);
      }
  
     if(Sel==1) Group1Button.Select() ;
     else Group2Button.Select() ;
  
     strcpy(SetupButton.Label,SetupButton.StaticLabel);   //2016.11.21 core-net
  
    update();
  }`

  function `int IsAllBlank(char * cptr)
  {
    // Return 0 if one non-blank character is found, 1 otherwise
    int blank = 1;
    int i;
  
    for (i=0; i<strlen(cptr); i++, cptr++)
    {
      if (*cptr != ' ')
      {
        blank = 0;
        break;
      }//endif
    }//endfor
    return (blank);
  }`

  function `void MAINescape()
  {
     int i;
  // Request dtrend reset to the host
     execute("{sendMessageToHost(RESET_DTREND_REQUEST);}");
     DTrendTimer_Active = 0;
  }`

  function `void ProcessNoError(int Set)
  {
    int i,j,k;
  
      for (i=1;i<=NUM_DTREND_SETS;i++)
        for (j=1;j<=NUM_DTREND_PER_SET;j++)
           execute("{strcpy(pDigitalTrendData->Set%dPoint%d, Set%dTrd%dPID.TheNewText);}" ,i,j,i,j);
  
      DTrendSet = Set;
  
      if(!DTrendInUse)
      {
         pDigitalTrendData->prtQueue = printQ = 1 ;
         execute("{sendMessageToHost(PROCESS_DTREND_DATA);}");
      }
  
        ProcessReqMsg.visibility = 1;
        ProcessError1Msg.visibility = 0;
        ProcessBlank1Msg.visibility = 0;
  
        printf("--------------noToPrint   : %d\\n",pDigitalTrendData->nosToPrint);
        printf("--------------displayRate : %d\\n",pDigitalTrendData->displayRate);
  
        displayPicture("Main","PicYGN_DigitalTrendView.ppic");
  //>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> CORENET
  	Group1Select.UnSelect();
        strcpy(SetupButton.Label,SetupButton.StaticLabel) ; //2016.11.14 core-net
  //<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
  }`

  function `void ProcessSetup(int Set)
  {
     int i, j ;
     PidInputButton   *poPID;
  
     i = Set ;
     ProcessERROR = 0 ;
  
  // PID ERROR CHECK
  
     for (j=1;j<=NUM_DTREND_PER_SET;j++)
     {
       execute("{ProcessERROR |= Set%dTrd%dPID.ERROR;}",i,j);
     }
  
     ProcessERROR |= PrintDuration_btn.ERROR ;
     ProcessERROR |= DisplayRate_btn.ERROR ;
  
  // NO PID DATA CHECK
  
     for (j=1; j<=NUM_DTREND_PER_SET; j++)
     {
        poPID = GetpoPID(Set,j);
  
        if (0 == IsAllBlank(poPID->TheNewText))
        {
         ProcessBLANK = 0;
         break;
        }
        else
        {
         ProcessBLANK = 1;
        }
     }
  
  
     if (ProcessERROR)
     {
        ProcessBlank1Msg.visibility = 0;
        ProcessError1Msg.visibility = 1;
     }
     else if (ProcessBLANK)
     {
        ProcessBlank1Msg.visibility = 1;
     }
     else
     {
       for (j=1;j<=NUM_DTREND_PER_SET;j++)
       {
          execute("{strcpy(pDigitalTrendData->Set%dPoint%d,Set%dTrd%dPID.TheNewText);}" ,i,j,i,j);
       }
  
        pDigitalTrendData->nosToPrint = PrintNo ;
        pDigitalTrendData->displayRate = DisplayRate;
	//CORENET 20170629
	execute("{DT_ScanRate = DisplayRate;}");
  
        pDigitalTrendData->prtQueue = printQ = 0 ;
  
        execute("{sendMessageToHost(PROCESS_DTREND_DATA);}");
  
        SETUP = 0 ;
  
        ProcessBlank1Msg.visibility = 0 ;
        ProcessError1Msg.visibility = 0 ;
  
        strcpy(SetupButton.Label,SetupButton.StaticLabel);   //2016.11.21 core-net
  
        update() ;
  
     }
  }
  `

  function `void ProcessThis(int Set)
  {
    int i,j;
    PidInputButton   *poPID;
  
  //  pDigitalTrendData->nosToPrint = 5 ; //initialize first, copy later
  //  pDigitalTrendData->nosToPrint = atoi(PrintDuration_btn.TheOriginalText);
  
  // Check the PidInputButton for each Trend Set which does not contain PID at all.
  
     i = Set ;
  
     for (j=1; j<=NUM_DTREND_PER_SET; j++)
     {
        poPID = GetpoPID(Set,j);
  
        if (0 == IsAllBlank(poPID->TheNewText))
        {
         ProcessBLANK = 0;
         break;
        }
        else
        {
         ProcessBLANK = 1;
        }
     } //endfor(j=1)
  
  
     if (ProcessBLANK)
        execute("{ProcessBlank%dMsg.visibility = 1;}",1);
     else if (ProcessDownloadERROR)
        ProcessProcessingMsg.visibility = 1;
     else
        ProcessNoError(Set);
  
  
  }`

  function `void ResetRate()
  {
  //   printf("%d",pDigitalTrendData->displayRate) ;
  }`

  function `void SetupNcancel()
  {
     if ((!SETUP)&&(!DTrendInUse))         // For SETUP
     {
        SETUP = 1 ;
     }
     else                     // For CANCEL
     {
        escapeSetup() ;
        SETUP = 0 ;
     }
     update() ;
  }`

  function `void UpdateLocalsForInUseMessage()
  {
    int i,j;
    DTrendInUse = 1;
    ProcessDownloadERROR = 0;
  
     DisplayRate = pDigitalTrendData->displayRate;
     PrintDuration_btn.TheNewNumber = pDigitalTrendData->nosToPrint;
     PrintDuration_btn.TheOriginalNumber = pDigitalTrendData->nosToPrint;
  
     sprintf(PrintDuration_btn.TheNewText,"%d",PrintDuration_btn.TheNewNumber);
     sprintf(PrintDuration_btn.TheOriginalText,"%d",PrintDuration_btn.TheOriginalNumber);
  
    execute("{ manageTempShopList(INIT_TEMP_SHOP_LIST, Set1Trd1PID.TheNewText);}");
  
    for (i=1; i<=NUM_DTREND_SETS; i++)
      for (j=1; j<=NUM_DTREND_PER_SET; j++)
      {
  //    Get the PID stuff
        execute("{strcpy(Set%dTrd%dPID.TheOriginalText,pDigitalTrendData->Set%dPoint%d);}",i,j,i,j);
        execute("{strcpy(Set%dTrd%dPID.TheNewText,Set%dTrd%dPID.TheOriginalText);}",i,j,i,j);
        execute("{Set%dTrd%dPID.ERROR = 0;}",i,j);
        if (IsAllBlank(GetstrPID(i,j))) continue;
        AddTempShop(i,j);
      }
  
    execute("{ manageTempShopList(TEMP_SHOP_LIST_SEND, Set1Trd1PID.TheNewText);}");
  
    ProcessError1Msg.visibility = 0;
    ProcessBlank1Msg.visibility = 0;
    ProcessReqMsg.visibility = 0;
    ProcessProcessingMsg.visibility = 0;
    PrintDuration_btn.ERROR = 0 ;
    UsedMsg.visibility = 1;
  
     PrintNo = pDigitalTrendData->nosToPrint;
     DisplayRate = pDigitalTrendData->displayRate;
  
     update();
  
  }`

  function `void UpdateLocalsFromInterface()
  {
  
    int i,j;
  
     ProcessDownloadERROR = 0;
  
     DisplayRate = pDigitalTrendData->displayRate;
     if(0==DisplayRate) DisplayRate = 2;
  
     PrintNo = pDigitalTrendData->nosToPrint;
     PrintDuration = \`DisplayRate*PrintNo/60\`;
  
  
     DisplayRate_btn.TheNewNumber = DisplayRate ;
     DisplayRate_btn.TheOriginalNumber = DisplayRate ;
     sprintf(DisplayRate_btn.TheNewText,"%d",DisplayRate_btn.TheNewNumber);
     sprintf(DisplayRate_btn.TheOriginalText,"%d",DisplayRate_btn.TheOriginalNumber);
  
     PrintDuration_btn.TheNewNumber = PrintDuration ;
     PrintDuration_btn.TheOriginalNumber = PrintDuration ;
     sprintf(PrintDuration_btn.TheNewText,"%d",PrintDuration_btn.TheNewNumber);
     sprintf(PrintDuration_btn.TheOriginalText,"%d",PrintDuration_btn.TheOriginalNumber);
  
  
  
  //  printf("Before Shopping List code in UpdateLocalsFromInterface()");
  
    execute("{ manageTempShopList(INIT_TEMP_SHOP_LIST, dummy_args);}");
  
    for (i=1; i<=NUM_DTREND_SETS; i++)
      for (j=1; j<=NUM_DTREND_PER_SET; j++)
      {
  //    Get the PID stuff
        execute("{strcpy(Set%dTrd%dPID.TheOriginalText,pDigitalTrendData->Set%dPoint%d);}",i,j,i,j);
        execute("{strcpy(Set%dTrd%dPID.TheNewText,Set%dTrd%dPID.TheOriginalText);}",i,j,i,j);
        execute("{Set%dTrd%dPID.ERROR = 0;}",i,j);
        if (IsAllBlank(GetstrPID(i,j))) continue;
        AddTempShop(i,j);
      }
  
    execute("{ manageTempShopList(TEMP_SHOP_LIST_SEND, dummy_args);}");
  
    ProcessError1Msg.visibility = 0;
    ProcessBlank1Msg.visibility = 0;
    ProcessReqMsg.visibility = 0;
    ProcessProcessingMsg.visibility = 0;
    PrintDuration_btn.ERROR = 0 ;
  
    update();
  }`

  function `void VerifyPID(int Set,int Trd)
  {
    int blanks = 1;
    char * cptr;
    PidInputButton * Input = 0;
  
    // Get pointers to the PID objects
    Input = GetpoPID(Set, Trd);
  
    cptr = Input->TheNewText;
  
    blanks = IsAllBlank(cptr);
  
    if (1 == blanks)
    {
      Input->ERROR = 0;
    }//endif
  
    else
    {
      Input->ERROR = FindPointId(Input->TheNewText);
    }
  
    if (Input->ERROR != 0)
    {
      Input->ERROR = 1;
    }
    else
    {
  //   if (IsAllBlank(GetstrPID(Set,Trd))) continue;
  //   AddTempShop(Set, Trd);
  //   execute("{ manageTempShopList(TEMP_SHOP_LIST_SEND, Set1Trd1PID.TheNewText);}");
     ProcessError1Msg.visibility = 0;
     ProcessBlank1Msg.visibility = 0;
    }
    update();
  }`

  function `void VerifyValidDisplayRate_btn()
  {
  
  // Verify valid input for the entered Display Rate Value
     int x;
     int error = 0;
     x = DisplayRate_btn.TheNewNumber;
  
  // If the entered value is not between the 1 and 200,  we have an error.
  
     if ((1 <= x)&&(x <= 300))
     {
        DisplayRate_btn.ERROR = 0;
        DisplayRate = DisplayRate_btn.TheNewNumber ;
     }
     else
        DisplayRate_btn.ERROR = 1;
  
     ProcessError1Msg.visibility = 0 ;
  
     PrintNo = PrintDuration*60 / DisplayRate ;
  
     DurationLimit = \`DisplayRate*200/60\`;
     VerifyValidPrintDuration_btn();
  
     update();
  }  `

  function `void VerifyValidPrintDuration_btn()
  {
  
  // Verify valid input for the entered Display Rate Value
     int x;
     int error = 0;
     x = PrintDuration_btn.TheNewNumber;
  
  // If the entered value is not between the 1 and 200,  we have an error.
  
     if ((0 <= x)&&(x <= DurationLimit))
     {
        PrintDuration_btn.ERROR = 0;
        PrintDuration = PrintDuration_btn.TheNewNumber ;
     }
     else
        PrintDuration_btn.ERROR = 1;
  
     ProcessError1Msg.visibility = 0 ;
  
     PrintNo = PrintDuration*60 / DisplayRate ;
  
    update();
  }  `

