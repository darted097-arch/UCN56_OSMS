  function `void AddTempShop(int Set,int Trd)
  {
  
  //  ADD TEMPOTRARY SHOPPING LIST
  
      execute("{ strcpy(TEMP,Set%dTrd%dPID.TheNewText);}",Set,Trd);
  
      if (TEMP[0] != ' ')
         execute("{ manageTempShopList(TEMP_SHOP_LIST_ADD, TEMP);}");
  
  //     execute("{printf(\\"InsertedShoppingList= %%s\\", Set%dTrd%dPID.TheNewText);}",Set,Trd);
   }`

  function `void escape()
  {
  // CORENET 2017 by Philkyu Kwon
    if(SETUP == 0){
     int i;
  // Request dtrend reset to the host
     execute("{sendMessageToHost(RESET_DTREND_REQUEST);}");
     DTrendTimer_Active = 0;
     strcpy(SetupButton.Label,SetupButton.StaticLabel); //2016.11.14 CORENET by Philkyu Kwon
     execute("{DisplayPage(\\"%s\\");}",TheDisplayPage);
     }
     else
     {
       SETUP = 0;
       escapeSetup();
       }
  
  }`

  function `void escapeSetup()
  {
     int i, j ;
  
  
     for (i=1;i<=NUM_DTREND_SETS;i++)
       for (j=1;j<=NUM_DTREND_PER_SET;j++)
       {
          execute("{strcpy(Set%dTrd%dPID.TheNewText,pDigitalTrendData->Set%dPoint%d);}" ,i,j,i,j);
          execute("{strcpy(Set%dTrd%dPID.TheOriginalText,pDigitalTrendData->Set%dPoint%d);}" ,i,j,i,j);
          execute("{Set%dTrd%dPID.ERROR=0;}",i,j);
       }
  
     ProcessBlank1Msg.visibility = 0 ;
     ProcessError1Msg.visibility = 0 ;
     PrintDuration_btn.ERROR = 0 ;
  
     PrintNo = pDigitalTrendData->nosToPrint;
     DisplayRate = pDigitalTrendData->displayRate;
     //PrintDuration = \`DisplayRate*200/60\`;
     PrintDuration = \`PrintNo*DisplayRate/60\`;	//CORENET 0703
  
     PrintDuration_btn.TheNewNumber = PrintDuration ;
     PrintDuration_btn.TheOriginalNumber = PrintDuration ;
     sprintf(PrintDuration_btn.TheNewText,"%d",PrintDuration_btn.TheNewNumber);
     sprintf(PrintDuration_btn.TheOriginalText,"%d",PrintDuration_btn.TheOriginalNumber);
  
     strcpy(SetupButton.Label,SetupButton.StaticLabel) ; //2016.11.14 CORENET by Philkyu Kwon
  
  }
  `

  function `PidInputButton * GetpoPID(int Set, int Trd)
  {
    // Returns a pointer to the object that holds the PID
    // for Set #, Trd #
  
    execute("{poPID = &Set%dTrd%dPID;}", Set, Trd);
    return(poPID);
  
  }`

  function `char * GetstrPID(int Set, int Trd)
  {
  // Returns the string of the PID for Set #, Trd #
    PidInputButton * idt = 0;
  
    idt = GetpoPID(Set, Trd);
    return(idt->TheNewText);
  }`

