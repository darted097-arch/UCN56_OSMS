  function `void ReadyView()
{
    if(GroupDisplay_CurrentTime == 1){
       InterValue();
//==       ProcessGroupView();
       GroupDisplay_CurrentTime = GR_DisplayRate;
     }
     else {
       GroupDisplay_CurrentTime--;
       ProcessSleepView(); 
      }
}`



  function `void Initialize()
 {
   int i,k,m ;
   char *blank = "BLANK";

//   Current_Page = 832;

   CFMLevel = 0;

   DisplayAdvisoryMessage(" ");
   DisplayAdvisoryMessage1(" ");
   DisplayAdvisoryMessage2(" ");
   DisplayAdvisoryMessage3(" ");

//   k = Interface->GroupDisplay.data.group.groupNumber;
   k = Interface->GenericRequestMessage.data.requestOption;
   m = Interface->GroupDisplay.data.group.displayRate;

  // printf("RequestOption is k = %d", k);
   printf("DisplayRate is m = %d", m);

   sprintf(TempTitle,"GROUP DISPLAY %d",k);	//CORENET 201705 by Philkyu Kwon
  // printf("TempTitle is %s", TempTitle);

   strcpy(::YGN3and4.PicYGN_header.PictureTitle.theText, TempTitle);	//CORENET 201705 by Philkyu Kwon
  // printf("YGN Title is %s",::YGN3and4.PicYGN_header.PictureTitle.theText);
   //execute("{strcpy(PictureTitle,\\"GROUP DISPLAY %d\\");}",k);
   GR_Page = k + 10;
   Current_Page = GR_Page;

//1998.6.16 Interface->FlagHandleMessage.data.requestOption = k;
//          Interface->FlagHandleMessage.data.flipflop1 = 1;  //for flag set
//          execute("{sendMessageToHost(GROUP_RESET_REQUEST);}");

   procMsg.visibility = 0 ;
   Perror.visibility = 0;
   Perror1.visibility = 0;

 //CaButton.UnSelect();  

   strcpy(STITLE,Interface->GroupDisplay.data.group.Title) ;
   sprintf(dtime,"%d",Interface->GroupDisplay.data.group.displayRate);
   tbase.theText = dtime;
   // ******CORENET 201705 by Philkyu Kwon**********************
   printf("*******************************");
   printf("dtime = %s",dtime);
   printf("YGN dtime = %c", &::YGN3and4.PicYGN_GroupDisplayView.dtime[0]);
   printf("YGN2 dtime = %c", ::YGN3and4.PicYGN_GroupDisplayView.dtime[0]);
   printf("*******************************");
   // **************************************************************


// Checking setup is correct 

   if (m <= 0)
   { 
      Perror.visibility = 1;
      Perror1.visibility = 1;

      for(i=1 ; i<=24 ; i++)
      {
         execute("{symbol%d.ThePointId = \`&BLANK\`;}",i) ;
         execute("{symbol%d.visibility = 0;}",i);
      }
   } 

   else
   {  
      Perror.visibility = 0; 
      Perror1.visibility = 0;  

      if(m > 1) 
      { 
         tsec2.visibility = 1;    
         tsec1.visibility = 0; 
      }
      else 
      {
         tsec1.visibility = 1;    
         tsec2.visibility = 0; 
      }

// Initilization for visibility
 
      for (i=1 ; i<=24 ; i++) 
          execute("{symbol%d.visibility = 1;}",i);
  
 
      GroupDisplay_Active = 0;
      GroupDisplay_CurrentTime = GR_DisplayRate;

// Display for PID Information & Add shopping list

      execute("{manageTempShopList(INIT_TEMP_SHOP_LIST,dummy_arg);}");  

      for (i=1 ; i<=24 ; i++)
      {
         execute("{strcpy(TEMP,Interface->GroupDisplay.data.group.Point%d);}",i) ;

         if (strlen(TEMP) > 0)
         {
             execute("{PicturePointId%d = \\\`&%s\\\`;}",i,TEMP);
             execute("{symbol%d.ThePointId = \\\`PicturePointId%d\\\`;}",i,i) ;
             execute("{manageTempShopList(TEMP_SHOP_LIST_ADD,TEMP);}");
         }
         else 
         {
             execute("{PicturePointId%d = \\\`&BLANK\\\`;}",i) ;
             execute("{symbol%d.ThePointId = \\\`PicturePointId%d\\\`;}",i,i) ;
             execute("{symbol%d.visibility = 0;}",i) ;
         }
         //printf("%d: strlen = %d",i,strlen(TEMP));
      }
      execute("{manageTempShopList(TEMP_SHOP_LIST_SEND,dummy_arg);}"); 

   }
   Priority = !Interface->FlagHandleMessage.data.flipflop2 ;

   if (Priority) 
      FlagSet(k) ;

   update();

}`



  function `char* sigTypeDisplay()
{
 switch(ThePointId->sig_type) {

     case  1:   return("AO");
     case  2:   return("QA");
     case  3:   return("XA");
     case  4:   return("KO");
     case  5:   return("AL");

     case  6:   return("AI");
     case  7:   return("PI");
     case  8:   return("FI");
     case  9:   return("ROD");
     case 10:  return("CI");

     case 11:  return("DI");
     case 12:  return("SOE");
     case 13:  return("BCI");
     case 14:  return("DL");
     case 15:  return("QD");

     case 16:  return("XD");
     case 17:  return("CO");
     case 18:  return("BCO");

     default:  return("");
    }
}`



