  function `void FlagSet(int Sel)
{
//   Set Flag for Using...
//   int k ;

//   k = Interface->GroupDisplay.data.group.groupNumber;

   Interface->FlagHandleMessage.data.requestOption = Sel;
   Interface->FlagHandleMessage.data.flipflop1 = 1;   //for flag set 
   execute("{sendMessageToHost(GROUP_RESET_REQUEST);}");

   //printf("------------------------\\nGRDISP %d Flag = ON\\n------------------------",Sel) ;
}`



  function `void FlagReset(int Sel)
{
//   Set Flag for Using...
//   int k ;

//   k = Interface->GroupDisplay.data.group.groupNumber;

   Interface->FlagHandleMessage.data.requestOption = Sel ;
   Interface->FlagHandleMessage.data.flipflop1 = 0;   //for flag set 
   execute("{sendMessageToHost(GROUP_RESET_REQUEST);}");

   //printf("========================\\nGRDISP %d Flag = OFF\\n========================",Sel) ;
}`



  function `void escapeToMenu()
{
   int k = Interface->GroupDisplay.data.group.groupNumber;

//1998.6.16  Interface->FlagHandleMessage.data.requestOption = k;
//           Interface->FlagHandleMessage.data.flipflop1 = 0;  //for flag reset
//           execute("{sendMessageToHost(GROUP_RESET_REQUEST);}");

   if(Priority)
      FlagReset(Interface->GroupDisplay.data.group.groupNumber) ;

   GroupDisplay_CurrentTime = GR_DisplayRate;
   GroupDisplay_Active = 1;
   DelayedDisplayPicture("PicYGN_GroupDisplayMenu.ppic");

   procMsg.visibility = 1 ;
}`



  function `void FlagResetAll()   // This Function is only used for development.
{
   int i ;

   for(i=1 ; i<=20 ; i++)
      FlagReset(i) ;
}`



