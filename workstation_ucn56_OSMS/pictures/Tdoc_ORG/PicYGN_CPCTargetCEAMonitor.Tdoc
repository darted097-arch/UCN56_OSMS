picture PicYGN_CPCTargetCEAMonitor
{
  worldX = 0;
  worldY = 0;
  worldWidth = 1280;
  worldHeight = 824;
  oneToOne = 1;
  backgroundColour = 0;
  updateMode = 2;
  resizeMode = 0;
  xSnap = 0;
  ySnap = 0;
  radiusSnap = 0;
  angleSnap = 0;
  crosshairStyle = 1;
  crosshairLength = 0;
  crosshairFollowSnap = `isInEditMode()`;
  crosshairVisibility = `isInEditMode()`;
  xReference = 500;
  yReference = 500;
  xScaleFactor = 1;
  yScaleFactor = 1;
  rotationAngle = 0;

  char PictureNumber[50] = "434";

  char PictureTitle[50] = "CPC TARGET CEA MONITOR";

  RECORD* PointId = `&RCT111X`;

  float SP = 5;

  function `void Initialize()
  {
     CFMLevel =0;
     Current_Page = 434;
  //   GetAlarmData();
  //   EscapeButton.UnSelect();
     execute("{sendMessageToHost(REQUEST_CEA_TRACK_MONITOR4);}");
  
     DisplayAdvisoryMessage("DATA REQUESTED");
  
     int i;
  
     for (i=1 ; i<=72 ; i++)
     {
        execute("{mx%d.TheNewNumber=0;}",i) ;
        execute("{mn%d.TheNewNumber=0;}",i) ;
     }
  
     LPD1.TheNewNumber  = 0;
     DNBR1.TheNewNumber = 0;
  
     LPD2.TheNewNumber  = 0;
     DNBR2.TheNewNumber = 0;
  
     LPD3.TheNewNumber  = 0;
     DNBR3.TheNewNumber = 0;
  
     LPD4.TheNewNumber  = 0;
     DNBR4.TheNewNumber = 0;
  }`

  function `void ProcessingConfirmed(int opcode)
  {
  
     int  i;
  
     for (i=1;i<=72;i++)
           {
          execute ("{mx%d.TheNewNumber = Interface->CEATrackingMonitor4.cmax_pos_val[%d];}",i,i-1);
          }
     for (i=1;i<=72;i++)
           {
          execute ("{mn%d.TheNewNumber = Interface->CEATrackingMonitor4.cmin_pos_val[%d];}",i,i-1);
          }
         LPD1.TheNewNumber = Interface->CEATrackingMonitor4.max_each_LPD[0];
         LPD2.TheNewNumber = Interface->CEATrackingMonitor4.max_each_LPD[1];
         LPD3.TheNewNumber = Interface->CEATrackingMonitor4.max_each_LPD[2];
         LPD4.TheNewNumber = Interface->CEATrackingMonitor4.max_each_LPD[3];
         DNBR1.TheNewNumber = Interface->CEATrackingMonitor4.max_each_DNBR[0];
         DNBR2.TheNewNumber = Interface->CEATrackingMonitor4.max_each_DNBR[1];
         DNBR3.TheNewNumber = Interface->CEATrackingMonitor4.max_each_DNBR[2];
         DNBR4.TheNewNumber = Interface->CEATrackingMonitor4.max_each_DNBR[3];
  }
  
  `

  function `void Update()
  {
     int i;
  
     DisplayAdvisoryMessage("             ");
  
  
        for (i=1 ; i<=72 ; i++)
        {
           execute("{mx%d.TheNewNumber=Interface->CEATrackingMonitor4.CPCTargetMonitorData.cmax_pos_val[%d];}",i,i-1) ;
           execute("{mn%d.TheNewNumber=Interface->CEATrackingMonitor4.CPCTargetMonitorData.cmin_pos_val[%d];}",i,i-1) ;
        }
  
        for (i=1 ; i<=4 ; i++)
        {
           execute("{LPD%d.TheNewNumber=Interface->CEATrackingMonitor4.CPCTargetMonitorData.max_each_LPD[%d];}",i,i-1) ;
           execute("{DNBR%d.TheNewNumber=Interface->CEATrackingMonitor4.CPCTargetMonitorData.max_each_DNBR[%d];}",i,i-1) ;
        }
  
  }
  
  `

