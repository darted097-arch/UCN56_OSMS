     KeepSelected();
  }`

  function `void Process1()
  {
  if (SELECTED == 0) {DisplayAdvisoryMessage("SELECT OPTION 1 - 4 FIRST"); return;}
  else
  {
     Interface->UtdvDialogue.option = Option;
     Interface->UtdvDialogue.current_page = Current_page;
  
     if (Option == 1)
     {
     execute("{strcpy(Interface->UtdvDialogue.filename1, file1.TheNewText);}");
     execute("{strcpy(Interface->UtdvDialogue.filename2, file2.TheNewText);}");
     //printf(" file1 and 2: %s, %s", Interface->UtdvDialogue.filename1,Interface->UtdvDialogue.filename2);
     }
  
     if (Option == 2)
     {
     execute("{strcpy(Interface->UtdvDialogue.filename1, file1.TheNewText);}");
  //   execute("{strcpy(Interface->UtdvDialogue.filename2, file2.TheNewText);}");
     }
  
     if (Option == 3)
     {
  //   execute("{strcpy(Interface->UtdvDialogue.filename1, file1.TheNewText);}");
     execute("{strcpy(Interface->UtdvDialogue.filename2, file2.TheNewText);}");
     }
  
     if (Option == 4)
     {
  //   execute("{strcpy(Interface->UtdvDialogue.filename1, file1.TheNewText);}");
  //   execute("{strcpy(Interface->UtdvDialogue.filename2, file2.TheNewText);}");
     }
  //   Interface->UtdvDialogue.current_page = 681;
     execute("{sendMessageToHost(PROCESS_UTDV_SEND);}");
     //printf("Selected Option = %d", Option);
  //
  }
  }`

