  function `void Initialize()
  {
     int k;
     Current_Page = 681;
     CFMLevel =0;
     Current_page =681;
     SELECTED = 0;
  //6.19
     UnselectAllButton();
     k = Interface->System.cpuNum;
  
     if (k == 1) {
        strcpy(file1.TheNewText,"LOG1:UTLMID.DAT");
        strcpy(file2.TheNewText,"LOG1:UTLHCEA.DAT");
        strcpy(file1.TheOriginalText,"LOG1:UTLMID.DAT");
        strcpy(file2.TheOriginalText,"LOG1:UTLHCEA.DAT");
        }
       else {
        strcpy(file1.TheNewText,"LOG2:UTLMID.DAT");
        strcpy(file2.TheNewText,"LOG2:UTLHCEA.DAT");
        strcpy(file1.TheOriginalText,"LOG2:UTLMID.DAT");
        strcpy(file2.TheOriginalText,"LOG2:UTLHCEA.DAT");
        }
  
    processfiles.UnSelect(); //jsk
    update();
  }`

