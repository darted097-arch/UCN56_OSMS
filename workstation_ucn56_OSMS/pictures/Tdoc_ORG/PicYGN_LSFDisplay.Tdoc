  function `void Process1()
{
     int pair = 0;
  
  if (ERROR ==0)
  {
     //printf("Sending LSF Pairs\\n");
     ProcessingErrorMsg.visibility = 0;
     ProcessingMsg.visibility=1;
     strcpy(pDBC_DATA->PID,PicturePointId->pid);
     //printf("PID = %s",pDBC_DATA->PID);
     for(pair=0;pair<16;pair++)
     {
     /*
        execute("{ pDBC_DATA->X[%d]=(Interface->System.displayedUnits) ? Counts%d.TheNewNumber
		 : Counts%d.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset; }",pair,pair+1,pair+1);
        execute("{ pDBC_DATA->Y[%d]=(Interface->System.displayedUnits) ? Value%d.TheNewNumber
                 : Value%d.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset; }",pair,pair+1,pair+1);
	*/
        execute("{ pDBC_DATA->X[%d]=(Interface->System.displayedUnits) ? Counts%d.TheNewNumber : Counts%d.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset; }", pair, pair+1, pair+1);
        execute("{ pDBC_DATA->Y[%d]=(Interface->System.displayedUnits) ? Value%d.TheNewNumber : value%d.TheNewNumber * PicturesPointId->mfactor + PicturePointId->moffset; }", pair, pair+1, pair+1);

//        printf("X[%d] = %-8.2f",pair,pDBC_DATA->X[pair]);
//        printf("Y[%d] = %-8.2f",pair,pDBC_DATA->Y[pair]);
     }
     execute("{sendMessageToHost(PROCESS_LSF_DATA);}");
   }
   else
   {
       ProcessingErrorMsg.visibility = 1;
   }   
}`



  function `void ProcessingConfirmed()
{
   ProcessingMsg.visibility = 0;

   if(Interface->LSF_Info_Data.Rtn_Status == 21)
      DegreeErrorMessage.visibility = 1 ;
   else 
      DegreeErrorMessage.visibility = 0 ;

   if(Interface->LSF_Info_Data.Rtn_Status == 22)
   {
      MinPairsMessage.visibility = 1 ;
      MinPairsNumber.visibility = 1 ;
   }
   else 
   {
      MinPairsMessage.visibility = 0 ;
      MinPairsNumber.visibility = 0 ;
   }

   //printf("Return Status = %d",Interface->LSF_Info_Data.Rtn_Status) ;
   update();
}`



  function `int IsInScan()
{
  int retval;

  if(PicturePointId->pisabitmap & bOOSCAN)
    retval = 0;
  else
    retval = 1;
  
  return(retval);
}`



  function `void VerifyLimits()
{
   int i;

   MinPairsMessage.visibility = 0 ;
   MinPairsNumber.visibility = 0 ;
   DegreeErrorMessage.visibility = 0 ;

   ERROR &= 0xFFFFFFFC ;

   for(i=1;i<=16;i++)
   {
      execute("{ TempCnt=Counts%d.TheNewNumber; }",i);
      execute("{ TempVal=Value%d.TheNewNumber; }",i);

      if((TempCnt!=-9999) && (TempVal!=-9999))
      {
         if((TempCnt < LoCountLimit) || (HiCountLimit < TempCnt))
         {
            ERROR |= 0x00000001 ;
         }

         if((TempVal < Range_lo) || (Range_hi < TempVal))
         {
            ERROR |= 0x00000002 ;
         }
      }
   }

   if (ERROR & 0x00000003) DataPairErrorMsg.visibility = 1 ;
   else DataPairErrorMsg.visibility = 0 ;
}
`



  function `void SCountConfirmed()
{
   int i ;

//---------------------------------------------------------------------------------------------

   HiCountLimit = Interface->LSF_Info_Data.HiSLim ;
   LoCountLimit = Interface->LSF_Info_Data.LoSLim ;
   //printf("HiSLim : %10d      LoSLim : %10d",HiCountLimit, LoCountLimit) ;

//---------------------------------------------------------------------------------------------
   WaitMsg.visibility = 0 ;


  if ((Interface->LSF_Info_Data.PolyOrder<1)||(Interface->LSF_Info_Data.PolyOrder>5))
  {
     DegreeErrorMessage.visibility = 1 ;
     ERROR |= 0x00000020 ;
  }
  else
  {
      CountsLabel1.visibility = 1 ;
      CountsLabel2.visibility = 1 ;
      ValueLabel1.visibility = 1 ;
      ValueLabel2.visibility = 1 ;

      for(i=1;i<=16;i++)
      {
          execute("{ Counts%d.visibility=1; }",i);
          execute("{ Value%d.visibility=1; }",i);
          execute("{ ItemNum%d.visibility=1; }",i);
          execute("{ Value%d.TheNumber.visibility=1; }",i);
      }   

      Counts1.TheNumber.visibility=\`!Counts1.Selected&&!Counts1.ERROR\`;Value1.TheNumber.visibility=\`!Value1.Selected&&!Value1.ERROR\`;
      Counts2.TheNumber.visibility=\`!Counts2.Selected&&!Counts2.ERROR\`;Value2.TheNumber.visibility=\`!Value2.Selected&&!Value2.ERROR\`;
      Counts3.TheNumber.visibility=\`!Counts3.Selected&&!Counts3.ERROR\`;Value3.TheNumber.visibility=\`!Value3.Selected&&!Value3.ERROR\`;
      Counts4.TheNumber.visibility=\`!Counts4.Selected&&!Counts4.ERROR\`;Value4.TheNumber.visibility=\`!Value4.Selected&&!Value4.ERROR\`;
      Counts5.TheNumber.visibility=\`!Counts5.Selected&&!Counts5.ERROR\`;Value5.TheNumber.visibility=\`!Value5.Selected&&!Value5.ERROR\`;
      Counts6.TheNumber.visibility=\`!Counts6.Selected&&!Counts6.ERROR\`;Value6.TheNumber.visibility=\`!Value6.Selected&&!Value6.ERROR\`;
      Counts7.TheNumber.visibility=\`!Counts7.Selected&&!Counts7.ERROR\`;Value7.TheNumber.visibility=\`!Value7.Selected&&!Value7.ERROR\`;
      Counts8.TheNumber.visibility=\`!Counts8.Selected&&!Counts8.ERROR\`;Value8.TheNumber.visibility=\`!Value8.Selected&&!Value8.ERROR\`;
      Counts9.TheNumber.visibility=\`!Counts9.Selected&&!Counts9.ERROR\`;Value9.TheNumber.visibility=\`!Value9.Selected&&!Value9.ERROR\`;
      Counts10.TheNumber.visibility=\`!Counts10.Selected&&!Counts10.ERROR\`;Value10.TheNumber.visibility=\`!Value10.Selected&&!Value10.ERROR\`;
      Counts11.TheNumber.visibility=\`!Counts11.Selected&&!Counts11.ERROR\`;Value11.TheNumber.visibility=\`!Value11.Selected&&!Value11.ERROR\`;
      Counts12.TheNumber.visibility=\`!Counts12.Selected&&!Counts12.ERROR\`;Value12.TheNumber.visibility=\`!Value12.Selected&&!Value12.ERROR\`;
      Counts13.TheNumber.visibility=\`!Counts13.Selected&&!Counts13.ERROR\`;Value13.TheNumber.visibility=\`!Value13.Selected&&!Value13.ERROR\`;
      Counts14.TheNumber.visibility=\`!Counts14.Selected&&!Counts14.ERROR\`;Value14.TheNumber.visibility=\`!Value14.Selected&&!Value14.ERROR\`;
      Counts15.TheNumber.visibility=\`!Counts15.Selected&&!Counts15.ERROR\`;Value15.TheNumber.visibility=\`!Value15.Selected&&!Value15.ERROR\`;
      Counts16.TheNumber.visibility=\`!Counts16.Selected&&!Counts16.ERROR\`;Value16.TheNumber.visibility=\`!Value16.Selected&&!Value16.ERROR\`;

//      Counts1.InputArea.visibility= \`Counts1.Selected || Counts1.ERROR\`;
//      Value1.InputArea.visibility=   \`Value1.Selected || Value1.ERROR\`;

      VerifyLimits() ;
   }
}`



