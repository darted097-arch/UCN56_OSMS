picture PicYGN_LSFDisplay
{

  RECORD *PictureLowAlarmPID = 0;
  RECORD *PictureHighAlarmPID = 0;
  int LoCountLimit = 0;
  int HiCountLimit = 8000;
  float TempVal = -9999;
  float TempCnt = -9999;
  int ERROR = 32;
  char TheDisplayPage[50] = "PicYGN_DBChangeMenu";
  RECORD *PicturePointId = `&RCT111X`;	
  char *PageBack = "";
  char *PageForward = "";
  char *PictureNumber = "561";
  char *PictureTitle = "LEAST SQUARES FIT";
  DB_CHANGE_DATA *pDBC_DATA = `&::YGN3and4.InterfaceToGUI.Interface.DatabaseDisplaysData`;
  int MasterCpu = 1;	//CORENET 20170706
  //int MasterCpu = `(Interface->System.slaveUpdating==0)?1:0`;
  float Range_hi = `EngRangeHi(PicturePointId)`;
  float Range_lo = `EngRangeLo(PicturePointId)`;

  function `void Initialize()
{

   Current_Page = 561;
   CFMLevel = 0;
   int i;

   //CORENET 20170516 by Philkyu Kwon
   CascadeEnterActive = 0;
   CascadeEnter.unmap();
   
   HiCountLimit = 0 ;
   LoCountLimit = 0 ;

   DisplayAdvisoryMessage(" ");
   DisplayAdvisoryMessage1(" ");
   DisplayAdvisoryMessage2(" ");
   DisplayAdvisoryMessage3(" ");

// Initialize DB info block
   DBCinfo.pPID = PicturePointId;
   strcpy(pDBC_DATA->PID,PicturePointId->pid);   

   ERROR = 0 ;

// Turn off processing message
   ProcessingErrorMsg.visibility = 0;
   DataPairErrorMsg.visibility = 0 ;
   ProcessingMsg.visibility = 0;
   PointIDErrorMsg.visibility = 0;
   MinPairsMessage.visibility = 0 ;
   MinPairsNumber.visibility = 0 ;
   DegreeErrorMessage.visibility = 0 ;

   CountsLabel1.visibility = 0 ;
   CountsLabel2.visibility = 0 ;
   ValueLabel1.visibility = 0 ;
   ValueLabel2.visibility = 0 ;

   ChangeProtected.visibility = 0 ;


   for(i=1;i<=16;i++)
   {
      execute("{ Counts%d.visibility=0; }",i);
      execute("{ Counts%d.TheNumber.visibility=0; }",i);
      execute("{ Value%d.visibility=0; }",i);
      execute("{ Value%d.TheNumber.visibility=0; }",i);
      execute("{ ItemNum%d.visibility=0; }",i);
      execute("{ Counts%d.ERROR=0; }",i);                //Clear Limits Errors
      execute("{ Value%d.ERROR=0; }",i);
   } 

if (MasterCpu)
{
   if(PicturePointId->sig_type < MinimumDigitalType)     //for Analog PID
   {
      if(PicturePointId->pipbitmap&bCHGPROT)  // Change Protected
      {
         ChangeProtected.visibility = 1 ;
         ERROR |= 0x00000010 ;
      }
      else
      { 
         if(IsInScan())        //for In-Scan
         {
            OOS_Msg.visibility = 1;
            WaitMsg.visibility = 0;
            ERROR |= 0x00000004 ;
         }
         else                  //for Out-Of-Scan
         {
//--------------------------------------------------------------------------------------------------
            strcpy(Interface->LSF_Info_Data.PID,PicturePointId->pid) ;   // Request CountLimits
            execute("{sendMessageToHost(REQUEST_LSF_SCOUNT);}");
//--------------------------------------------------------------------------------------------------
            OOS_Msg.visibility = 0;
            WaitMsg.visibility = 1 ;
      
            for(i=1;i<=16;i++)
            {
//             Init item number
               execute("{ ItemNum%d.theText=\\"%d.\\"; }",i,i);

// ************CORENET 0705**************************************************
/*
//             Init count entry fields
               execute("{ Counts%d.TheOriginalNumber=-9999; }",i);
               execute("{ sprintf(Counts%d.TheOriginalText,Counts%d.TheNumberFormat,-9999); }",i,i);
               execute("{ Counts%d.TheNewNumber=-9999; }",i);
               execute("{ sprintf(Counts%d.TheNewText,Counts%d.TheNumberFormat,-9999); }",i,i);
 
//             Init value entry fields
               execute("{ Value%d.TheOriginalNumber=-9999; }",i);
               execute("{ sprintf(Value%d.TheOriginalText,Value%d.TheNumberFormat,-9999); }",i,i);
               execute("{ Value%d.TheNewNumber=-9999; }",i);
               execute("{ sprintf(Value%d.TheNewText,Value%d.TheNumberFormat,-9999); }",i,i);
*/
// ************CORENET 0705************************************************
//             Init count entry fields
               execute("{ Counts%d.TheOriginalNumber= 0; }",i);
               execute("{ sprintf(Counts%d.TheOriginalText,Counts%d.TheNumberFormat, 0); }",i,i);
               execute("{ Counts%d.TheNewNumber= 0; }",i);
               execute("{ sprintf(Counts%d.TheNewText,Counts%d.TheNumberFormat, 0); }",i,i);
 
//             Init value entry fields
               execute("{ Value%d.TheOriginalNumber= 0; }",i);
               execute("{ sprintf(Value%d.TheOriginalText,Value%d.TheNumberFormat, 0); }",i,i);
               execute("{ Value%d.TheNewNumber= 0; }",i);
               execute("{ sprintf(Value%d.TheNewText,Value%d.TheNumberFormat, 0); }",i,i);
            }
         }
      }
   }
   else              //for Digital PID
   {
      PointIDErrorMsg.visibility = 1;
      ERROR |= 0x00000008 ;
   }
}
else 
{
   ERROR |= 0x00000080 ;
}


// For variable alarm limits

   if(IsAnalog(PicturePointId))
   {
      if(0 != PicturePointId->lIPN)
      {
         execute ("{PictureLowAlarmPID = \`&::YGN3and4.InterfaceToGUI.%s\`;}",PicturePointId->message1);
      }
      else
      {
         PictureLowAlarmPID = 0;
      }

      if(0 != PicturePointId->hIPN)
      {
         execute ("{PictureHighAlarmPID = \`&::YGN3and4.InterfaceToGUI.%s\`;}",PicturePointId->message2);
      }
      else
      {
         PictureHighAlarmPID = 0;
      }
   }

   update();
}`


