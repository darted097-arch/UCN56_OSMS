picture PicYGN_ChgAlmLimitsDisplay
{

  float Range_lo = `EngRangeLo(PicturePointId)`;
  float Range_hi = `EngRangeHi(PicturePointId)`;
  RECORD *PictureHighAlarmPID = `&::YGN3and4.InterfaceToGUI.IMTQMSPB`;
  RECORD *PictureLowAlarmPID = 0;
  int Protected = `(PicturePointId->pipbitmap&bCHGPROT)||(PicturePointId->sig_type==SOE)`;
  int ERROR = `HiHiLimitEntry.ERROR || HiLimitEntry.ERROR || LoLimitEntry.ERROR || LoLoLimitEntry.ERROR`;
  char TheDisplayPage[50] = "PicYGN_DBChangeMenu";
  DB_CHANGE_DATA *pDBC_DATA = `&::YGN3and4.InterfaceToGUI.Interface.DatabaseDisplaysData`;
  RECORD *PicturePointId = `&APEA0045`;
  char *PageBack = "";
  char *PageForward = "";
  char *PictureNumber = "521";
  char *PictureTitle = "CHANGE ALARM LIMITS";
  int NoAlarm = `!Protected && !(AnalogAlarm||DigitalAlarm)`;
  int DigitalAlarm = `Digital && (PicturePointId->pipbitmap&bALMTYP)`;
  int AnalogAlarm = `Analog && (PicturePointId->pipbitmap&0x0F00)`;
  int Analog = `(PicturePointId->sig_type<MinimumDigitalType)`;
  int Digital = `(PicturePointId->sig_type>=MinimumDigitalType)`;

  function `void Initialize()
{
   Current_Page = 521;
   CFMLevel = 0;
   
   DisplayAdvisoryMessage(" ");
   DisplayAdvisoryMessage1(" ");
   DisplayAdvisoryMessage2(" ");
   DisplayAdvisoryMessage3(" ");

   HiHiLimitEntry.ERROR = 0 ;
   HiLimitEntry.ERROR = 0 ;
   LoLimitEntry.ERROR = 0 ;
   LoLoLimitEntry.ERROR = 0 ;

   ProcessingMsg.visibility = 0;
   ProcessingErrorMsg.visibility = 0;

   DBCinfo.pPID = PicturePointId;
   strcpy(pDBC_DATA->PID,PicturePointId->pid);

   sprintf(HiHiLimitEntry.TheOriginalText,"%-8.2f",HiHiLimitEntry.TheOriginalNumber) ;
   sprintf(HiLimitEntry.TheOriginalText,"%-8.2f",HiLimitEntry.TheOriginalNumber) ;
   sprintf(LoLimitEntry.TheOriginalText,"%-8.2f",LoLimitEntry.TheOriginalNumber) ;
   sprintf(LoLoLimitEntry.TheOriginalText,"%-8.2f",LoLoLimitEntry.TheOriginalNumber) ;

   HiHiLimitEntry.TheNewNumber = \`HiHiLimitEntry.TheOriginalNumber\` ;
   HiLimitEntry.TheNewNumber = \`HiLimitEntry.TheOriginalNumber\` ;
   LoLimitEntry.TheNewNumber = \`LoLimitEntry.TheOriginalNumber\` ;
   LoLoLimitEntry.TheNewNumber = \`LoLoLimitEntry.TheOriginalNumber\` ;

   strcpy(HiHiLimitEntry.TheNewText,HiHiLimitEntry.TheOriginalText) ;
   strcpy(HiLimitEntry.TheNewText,HiLimitEntry.TheOriginalText) ;  
   strcpy(LoLimitEntry.TheNewText,LoLimitEntry.TheOriginalText) ;
   strcpy(LoLoLimitEntry.TheNewText,LoLoLimitEntry.TheOriginalText) ;

   //printf("\\n%-8.2f    %-8.2f    %-8.2f    %-8.2f\\n",HiHiLimitEntry.TheOriginalNumber,HiLimitEntry.TheOriginalNumber,
   //       LoLimitEntry.TheOriginalNumber, LoLoLimitEntry.TheOriginalNumber ) ;


   if(IsAnalog(PicturePointId))
   {
      if(0 != PicturePointId->lIPN)
      {
         execute ("{PictureLowAlarmPID = \`&::YGN3and4.InterfaceToGUI.%s\`;}",PicturePointId->message1);
      }
      else
      {
         PictureLowAlarmPID = 0;
      }

      if(0 != PicturePointId->hIPN)
      {
         execute ("{PictureHighAlarmPID = \`&::YGN3and4.InterfaceToGUI.%s\`;}",PicturePointId->message2);
      }
      else
      {
         PictureHighAlarmPID = 0;
      }

      LoLoLimitEntry.TheNumberFormat = PicturePointId->disfmt;
   }   
   else LoLoLimitEntry.TheNumberFormat = "%d";

   update();
}`



  function `void Process1()
{
   if (ERROR ==0)
   {
      ProcessingMsg.visibility = 1;
//      ProcessingErrorMsg.visibility = 0;

      if(PicturePointId->sig_type >= MinimumDigitalType)      // FOR DIGITAL
      {             
         if(PicturePointId->pipbitmap & bALMTYP)
           pDBC_DATA->LoLoLim = LoLoLimitEntry.TheNewNumber;
         else
           pDBC_DATA->LoLoLim = 0.0;
      }
      else                                                   // FOR ANALOG
      {
         if(PicturePointId->pipbitmap & bLLE)
           pDBC_DATA->LoLoLim = (Interface->System.displayedUnits) ? LoLoLimitEntry.TheNewNumber :
                                LoLoLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
         else
           pDBC_DATA->LoLoLim = 0.0;

         if(PicturePointId->pipbitmap & bLE) 
           pDBC_DATA->LoLim   = (Interface->System.displayedUnits) ? LoLimitEntry.TheNewNumber :
                                LoLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
         else
           pDBC_DATA->LoLim   = 0.0;

         if(PicturePointId->pipbitmap & bHE)
           pDBC_DATA->HiLim   = (Interface->System.displayedUnits) ? HiLimitEntry.TheNewNumber :
                                HiLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
         else
           pDBC_DATA->HiLim   = 0.0;
  
         if(PicturePointId->pipbitmap & bHHE)
           pDBC_DATA->HiHiLim = (Interface->System.displayedUnits) ? HiHiLimitEntry.TheNewNumber :
                                HiHiLimitEntry.TheNewNumber * PicturePointId->mfactor + PicturePointId->moffset ;
         else
           pDBC_DATA->HiHiLim = 0.0;
      }

      execute("{sendMessageToHost(PROCESS_CHGLIM_DATA);}");
   }
   else
   {
     ProcessingErrorMsg.visibility = 1;
   }
   update();
}`



  function `void ProcessingConfirmed()
{
  ProcessingMsg.visibility = 0;
  update();
}`



  function `void VerifyLimits()
{
   if(PicturePointId->sig_type < MinimumDigitalType)  //for Analog 
   {
      if(PicturePointId->pipbitmap&bHHE)
      {
          if((HiHiLimitEntry.TheNewNumber >= Range_lo) && (HiHiLimitEntry.TheNewNumber <= Range_hi))
               HiHiLimitEntry.ERROR = 0;
          else
               HiHiLimitEntry.ERROR = 1;
      }

      if(PicturePointId->pipbitmap&bHE)
      {
          if((HiLimitEntry.TheNewNumber >= Range_lo) && (HiLimitEntry.TheNewNumber <= Range_hi))
               HiLimitEntry.ERROR = 0;
          else
               HiLimitEntry.ERROR = 1;
      }

      if(PicturePointId->pipbitmap&bLE)
      {
          if((LoLimitEntry.TheNewNumber >= Range_lo) && (LoLimitEntry.TheNewNumber <= Range_hi))
               LoLimitEntry.ERROR = 0;
          else
               LoLimitEntry.ERROR = 1;
      }

      if(PicturePointId->pipbitmap&bLLE)
      {
          if((LoLoLimitEntry.TheNewNumber >= Range_lo) && (LoLoLimitEntry.TheNewNumber <= Range_hi))
               LoLoLimitEntry.ERROR = 0;
          else
               LoLoLimitEntry.ERROR = 1;
      }

//      ValueErrorMsg.visibility = HiHiLimitEntry.ERROR || HiLimitEntry.ERROR || LoLimitEntry.ERROR || LoLoLimitEntry.ERROR ;
   }
   else       // for Digital
   {
      if(((LoLoLimitEntry.TheNewNumber==0)||(LoLoLimitEntry.TheNewNumber==1)) && (PicturePointId->pipbitmap&bALMTYP))
          LoLoLimitEntry.ERROR = 0;
      else
          LoLoLimitEntry.ERROR = 1;

//      ValueErrorMsg.visibility = LoLoLimitEntry.ERROR ;
   }

   ProcessingErrorMsg.visibility = 0 ;

}`



  dialogue
  {
    event = `buttonPressed(Right)`;
    action = statement `{
  Initialize();
}`;
  }

