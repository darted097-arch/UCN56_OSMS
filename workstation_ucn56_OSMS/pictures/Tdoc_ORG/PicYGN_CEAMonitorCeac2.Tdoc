  float SP = 5;

  function `void Diff_Cal(int i)
  {
  //   int  i;
  
          execute ("{diff%d.TheNewNumber = max%d.TheNewNumber - min%d.TheNewNumber;}",i,i,i);
  
  }`

  function `void escape()
  {
     DisplayPage("PicYGN_CEAMenu.ppic");
     update();
  }`

  function `void Initialize()
  {
     CFMLevel =0;
     Current_Page = 432;
     int i;
  
     execute("{sendMessageToHost(REQUEST_CEA_TRACK_MONITOR2);}");
  
     DisplayAdvisoryMessage("DATA REQUESTED");
  
     for (i=1 ; i<=73 ; i++)
     {
        execute("{max%d.TheNewNumber=0;}",i) ;
        execute("{min%d.TheNewNumber=0;}",i) ;
        execute("{diff%d.TheNewNumber = max%d.TheNewNumber - min%d.TheNewNumber;}",i,i,i) ;
     }
  
  //   LPD.TheNewNumber  = 0;
  //   DNBR.TheNewNumber = 0;
  
  //   Update();
  
  }`

  function `void processingConfirmed(int opcode)
  {
  //   max1.TheNewNumber = Interface->CEATrackingMonitor1.max_pos_val[0];
  
     int  i;
  
     for (i=1;i<=73;i++)
           {
          execute ("{max%d.TheNewNumber = Interface->CEATrackingMonitor1.max_pos_val[%d];}",i,i-1);
          execute ("{min%d.TheNewNumber = Interface->CEATrackingMonitor1.min_pos_val[%d];}",i,i-1);
          execute ("{diff%d.TheNewNumber = max%d.TheNewNumber - min%d.TheNewNumber;}",i,i,i);
          }
  
         LPD.TheNewNumber = Interface->CEATrackingMonitor1.LPD;
         DNBR.TheNewNumber = Interface->CEATrackingMonitor1.DNBR;
  
         DisplayAdvisoryMessage("PROCESSING CONFIRMED");
  
  }`

  function `void selectedShape(int selectedNo)
  {
     switch(selectedNo){
        case 1: {
         text1_box.foregroundFillColour=1;
         text1.foregroundColour=0;
         text2_box.foregroundFillColour=0;
         text2.foregroundColour=1;
         text3_box.foregroundFillColour=0;
         text3.foregroundColour=1;
         update();
         break;
       }
        case 2: {
         text1_box.foregroundFillColour=0;
         text1.foregroundColour=1;
         text2_box.foregroundFillColour=1;
         text2.foregroundColour=0;
         text3_box.foregroundFillColour=0;
         text3.foregroundColour=1;
         update();
         break;
        }
        case 3: {
         text1_box.foregroundFillColour=0;
         text1.foregroundColour=1;
         text2_box.foregroundFillColour=0;
         text2.foregroundColour=1;
         text3_box.foregroundFillColour=1;
         text3.foregroundColour=0;
         update();
         break;
        }
        default: {
         text1_box.foregroundFillColour=0;
         text1.foregroundColour=1;
         text2_box.foregroundFillColour=0;
         text2.foregroundColour=1;
         text3_box.foregroundFillColour=0;
         text3.foregroundColour=1;
         update();
         break;
        }
  
  
     }
  }`

  function `void sim()
  {
     CFMLevel =0;
     Current_Page = 431;
     int i;
  
  //   execute("{sendMessageToHost(REQUEST_CEA_TRACK_MONITOR1);}");
  
  //   DisplayAdvisoryMessage("DATA REQUESTED");
  
     for (i=1 ; i<=73 ; i++)
     {
        execute("{max%d.TheNewNumber=381;}",i) ;
        execute("{min%d.TheNewNumber=376;}",i) ;
        execute("{diff%d.TheNewNumber = max%d.TheNewNumber - min%d.TheNewNumber;}",i,i,i) ;
     }
  
  //   LPD.TheNewNumber  = 0;
  //   DNBR.TheNewNumber = 0;
  
  //   Update();
  
  }`

  function `void Update()
  {
     int i;
  
     DisplayAdvisoryMessage("             ");
  
  
        for (i=1 ; i<=73 ; i++)
        {
           execute("{max%d.TheNewNumber=Interface->CEATrackingMonitor2.IndiCeaMonitor2Data.max_pos_val[%d];}",i,i-1) ;
           execute("{min%d.TheNewNumber=Interface->CEATrackingMonitor2.IndiCeaMonitor2Data.min_pos_val[%d];}",i,i-1) ;
           execute("{diff%d.TheNewNumber = max%d.TheNewNumber - min%d.TheNewNumber;}",i,i,i) ;
        }
  
           execute("{LPD.TheNewNumber = Interface->CEATrackingMonitor2.IndiCeaMonitor2Data.LPD;}") ;
           execute("{DNBR.TheNewNumber = Interface->CEATrackingMonitor2.IndiCeaMonitor2Data.DNBR;}") ;
  
  }
  
