  class Digits
  {





    float Number = -234;

    instance TrendLibrary.Digit Digit1
    {
      attribute number = `(Number<0)?0:(Number>=100)?(int)Number/100:0`;
      x = 0;
      y = 3;
      visibility = `Number>=100`;
      xReference = 0;
      yReference = 3;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }  // end of instance Digit1



    instance TrendLibrary.Digit Digit2
    {
      attribute number = `(Number<0)?0:(int)Number/10-Digit1.number*10`;
      x = 171;
      y = 3;
      visibility = `Number>=10`;
      xReference = 171;
      yReference = 3;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }  // end of instance Digit2



    instance TrendLibrary.Digit Digit3
    {
      attribute number = `(Number<0)?0:(int)(Number-Digit1.number*100-Digit2.number*10)`;
      x = 341;
      y = 3;
      visibility = 1;
      xReference = 341;
      yReference = 3;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }  // end of instance Digit3



    instance TrendLibrary.Digit Digit4
    {
      attribute number = `(Number<0)?0:(int)(Number*10 - Digit1.number*1000 - Digit2.number*100 - Digit3.number*10)`;
      x = 531;
      y = 2;
      visibility = 1;
      xReference = 531;
      yReference = 2;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }  // end of instance Digit4



    circle 
    {
      x = 507;
      y = 239;
      radius = 9.25338;
      visibility = 1;
      foregroundFillColour = `COLOR_ACTIVE_ON_SECURITY`;
      backgroundFillColour = -1;
      foregroundColour = `COLOR_ACTIVE_ON_SECURITY`;
      backgroundColour = -1;
      lineWidth = 0;
      linePattern = `SolidPattern`;
      fillPattern = `SolidPattern`;
      xReference = 507;
      yReference = 239;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
    }



    instance TrendLibrary.Digit Digit5
    {
      attribute number = `(Number<0)?0:(int)(Number*100 - Digit1.number*10000 - Digit2.number*1000 - Digit3.number*100 - Digit4.number*10)`;
      x = 698;
      y = 2;
      visibility = 1;
      xReference = 698;
      yReference = 2;
      xScaleFactor = 1;
      yScaleFactor = 1;
      rotationAngle = 0;
