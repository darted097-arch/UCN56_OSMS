library TrendLibrary
{




  class VideoTrend
  {
    float OORL_VALUE = -99998;

    float OORH_VALUE = 99998;

    float Baseline = `(HighLimit+LowLimit)/2.0`;

    char TheTrackTime[10] = "14:58:08";

    char *DigitalOnePhrase = `TheVariable->message2`;

    char *DigitalZeroPhrase = `TheVariable->message1`;

    float LowLimit = 0;

    float HighLimit = 400;

    char *TheTrendVariable = "::YGN3and4.VideoSet1Tr1";

    RECORD *TheVariable = `&ERRORPID`;

    int TheFrequency = 1;

    float BASE = 0;

function `void ComputeBaseline()
{
   float MinY, MaxY;     // The min and max Y coordinates
   float TheY;           // The computed Y coordinate

if(strcmp(TheVariable->pid,"ERRORPID"))
{
//
// Compute the min and max Y coordinates
   MinY = TheTrend.y+TheTrend.height;
   MaxY = TheTrend.y;
//
 if (BASE == 0) {
// Compute the Baseline line
   TheY = MinY - ( ( (Baseline-LowLimit)/(HighLimit-LowLimit) ) * TheTrend.height);
   printf("Baseline ......") ; }
 else {
   TheY = MinY - ( ( (BASE-LowLimit)/(HighLimit-LowLimit) ) * TheTrend.height);
   printf("BASE......"); }
//
// Remember, the Y coordinates are reverse; they get larger as you go down
   if (TheY > MinY) 
      TheY = MinY;
   if (TheY < MaxY)
      TheY = MaxY;
//
// Now set the line
   TheBaseLine.setY(0,TheY);
   TheBaseLine.setY(1,TheY);
   BaseText.y = TheY+5.0;
}
}`

function `void TrendReset()
{
 TheTrend.reset();
 update();
}`



  dialogue
  {
    event = `shapeLeft()`;
    action = statement `{
   TheTrend.TrendRuler1.visibility = INVISIBLE;
   thePicture().theWindow().update();
}`;
  }

  dialogue
  {
    event = `shapeEntered()`;
    action = statement `{
   TheTrend.TrendRuler1.visibility = VISIBLE;
   thePicture().theWindow().update();
}`;
  }

    trend TheTrend
    {
      trLog = "YGN3and4TrendLog";
      x = 130;
      y = 70;
      width = 900;
      height = 100;

      visibility = 1;
      timespan = `600*TheFrequency`;
      orientation = 0;
      scroll = 0;
      foregroundFillColour = `COLOR_DARK_GRAY`;
      backgroundFillColour = -1;
      foregroundColour = `COLOR_STATIC_TEXT`;
      backgroundColour = -1;
      lineWidth = 2;
      linePattern = `SolidPattern`;
      fillPattern = 1;
      updateMode = 2;

        trendPlot TrendPres1
        {
          variable = `TheTrendVariable`;
          presentation = 0;
          upperLimit = `(TheVariable->sig_type<MinimumDigitalType)?HighLimit:2`;
          lowerLimit = `(TheVariable->sig_type<MinimumDigitalType)?LowLimit:-1`;
          visibility = 1;
          logFrequency = `TheFrequency`;
          foregroundFillColour = `COLOR_DATA_NORMAL`;
          backgroundFillColour = -1;
          foregroundColour = `COLOR_FEEDBACK_MESSAGES`;
          backgroundColour = -1;
          lineWidth = 2;
          linePattern = `SolidPattern`;
          fillPattern = `SolidPattern`;
          autoScale = 0;
          upperBand = 1;
          lowerBand = 1;
          xReference = 0;
          yReference = 0;
          xScaleFactor = 1;
          yScaleFactor = 1;
          rotationAngle = 0;
        }

        trendLabels TrendLabel1
        {
          offset = -7;
          alignment = 0;
          interval = `60*TheFrequency`;

          theFont = `font0`;
          format = "%T";
          visibility = 1;

          foregroundColour = `COLOR_STATIC_TEXT`;

          backgroundColour = -1;

          xReference = 0;
          yReference = 0;
          xScaleFactor = 1;
          yScaleFactor = 1;
          rotationAngle = 0;
        }  // end of trLabel 

        trendRuler TrendRuler1
        {
          visibility = 0;
          foregroundColour = `COLOR_STATIC_TEXT`;
          backgroundColour = -1;
          lineWidth = 0;
          linePattern = 1;
          rulerIsSelected = 1;
          xReference = 0;
          yReference = 0;
          xScaleFactor = 1;
          yScaleFactor = 1;
          rotationAngle = 0;
        } // end of trendRuler

        trendGrid TrendGrid1
        {
          depthPosition = 0;
          noOfLines = 0;
          timeInterval = `60*TheFrequency`;
          timeOffset = 0;

          visibility = 1;
          lineWidth = 1;
          linePattern = 1;

          foregroundColour = `COLOR_NON_ESSENTIAL`;
          backgroundColour = -1;

          xReference = 0;
          yReference = 0;
          xScaleFactor = 1;
          yScaleFactor = 1;
          rotationAngle = 0;
        }  // end of trendGrid

        dialogue
        {
          event = `cursorMoved()`;
          action = statement `{
   TrendRuler1.moveRuler();
   thePicture().theWindow().update();
}`;
        }
        xReference = 31;
        yReference = 65;
        xScaleFactor = 1;
        yScaleFactor = 1;
        rotationAngle = 0;
      }  // end of trend TheTrend



