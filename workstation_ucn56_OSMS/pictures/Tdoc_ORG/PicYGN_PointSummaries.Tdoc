  function `void ProcessPIDinAlarm()
{
  InitConfirmMessages();
  Interface->PRTSUM_REQUEST_MESSAGE.data.Option = 1     ;
  execute(" { sendMessageToHost(PRINT_SUMMARY_MESSAGE); }" ) ;
  procMsg.visibility = 1;
//  printf("data option = %d",Interface->PRTSUM_REQUEST_MESSAGE.data.Option);

}`



