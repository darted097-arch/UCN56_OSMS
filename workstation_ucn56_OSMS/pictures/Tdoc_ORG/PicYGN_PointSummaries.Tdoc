}`



  function `int KludgeConfirm()
{
   //strcpy(Interface->PRTSUM_CONFIRM_MESSAGE.data.message1,"");
   //printf("sent: %d, received: %d",Interface->System.sentData,Interface->System.receivedData);
   //printf("Message is [%s]", Interface->PRTSUM_CONFIRM_MESSAGE.data.message1);
   if (Interface->System.sentData && Interface->System.receivedData)
   {
      DisplayAdvisoryMessage(Interface->PRTSUM_CONFIRM_MESSAGE.data.message1);
      DisplayAdvisoryMessage1(Interface->PRTSUM_CONFIRM_MESSAGE.data.message2);
      DisplayAdvisoryMessage2(Interface->PRTSUM_CONFIRM_MESSAGE.data.message3);
      procMsg.visibility = 0;
      Interface->System.sentData = 0;
      Interface->System.receivedData = 0;
   }
   return (1);
}`



  function `void InitConfirmMessages()
{ strcpy(Interface->PRTSUM_CONFIRM_MESSAGE.data.message1,"");
  strcpy(Interface->PRTSUM_CONFIRM_MESSAGE.data.message2,"");
  strcpy(Interface->PRTSUM_CONFIRM_MESSAGE.data.message3,"");
  update();
}`



