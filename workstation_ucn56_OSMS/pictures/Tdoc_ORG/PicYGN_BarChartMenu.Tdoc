  function `void BarMinMaxFromPID(int Chart)
  {
  
      // Set the Numbers in the Min and Max fields.
  
  
    if (1 == IsAllBlank(GetstrPID(Chart)))
    {
      execute("{BarChart%dMinValue.TheNewNumber = 0.0;}",Chart);
      execute("{BarChart%dMinValue.TheOriginalNumber = 0.0;}",Chart);
  
      execute("{BarChart%dMaxValue.TheNewNumber = 0.0;}",Chart);
      execute("{BarChart%dMaxValue.TheOriginalNumber = 0.0;}",Chart);
  
      execute("{BarChart%dBase.TheNewNumber = 0.0;}",Chart);
      execute("{BarChart%dBase.TheOriginalNumber = 0.0;}",Chart);
  
    }//endif PID is all blanks
    else
    {
      if (IsDigital(GetstrPID(Chart)))		// For Digital PID
      {
        execute("{BarChart%dMinValue.TheNewNumber = 0.0;}",Chart);
        execute("{BarChart%dMinValue.TheOriginalNumber = 0.0;}",Chart);
        execute("{BarChart%dMaxValue.TheNewNumber = 1.0;}",Chart);
        execute("{BarChart%dMaxValue.TheOriginalNumber = 1.0;}",Chart);
        execute("{BarChart%dBase.TheNewNumber = 0.5;}",Chart);
        execute("{BarChart%dBase.TheOriginalNumber = 0.5;}",Chart);
      }//endif is digital point
      else					// For Analog PID
      {
           execute("{pRECORD = \`&%s\`;}",GetstrPID(Chart));
  //-------------------------------------------------------------------------------------------------------------------------
           // For checking Exceptional PID like CIYKASIL that has zero(0) for both
           // engineering range high and low.
           if ( (0==EngRangeLo(pRECORD)) && (0==EngRangeHi(pRECORD)) )
           {
              execute("{BarChart%dMinValue.TheNewNumber = pRECORD->value -100;}",Chart);
              execute("{BarChart%dMinValue.TheOriginalNumber = BarChart%dMinValue.TheNewNumber;}",Chart,Chart);
              execute("{BarChart%dMaxValue.TheNewNumber = pRECORD->value +100;}",Chart);
              execute("{BarChart%dMaxValue.TheOriginalNumber = BarChart%dMaxValue.TheNewNumber;}",Chart,Chart);
              execute("{BarChart%dBase.TheNewNumber = pRECORD->value ;}",Chart);
              execute("{BarChart%dBase.TheOriginalNumber = BarChart%dBase.TheNewNumber;}",Chart,Chart);
           }
           else
           {
              execute("{BarChart%dMinValue.TheNewNumber = EngRangeLo(pRECORD);}",Chart);
              execute("{BarChart%dMinValue.TheOriginalNumber = BarChart%dMinValue.TheNewNumber;}",Chart,Chart);
              execute("{BarChart%dMaxValue.TheNewNumber = EngRangeHi(pRECORD);}",Chart);
              execute("{BarChart%dMaxValue.TheOriginalNumber = BarChart%dMaxValue.TheNewNumber;}",Chart,Chart);
  
              execute("{BarChart%dBase.TheNewNumber =(BarChart%dMinValue.TheNewNumber + BarChart%dMaxValue.TheNewNumber)/2.0;}",Chart,Chart,Chart);
              execute("{sprintf(temp,\\"%s\\",BarChart%dBase.TheNewNumber);}",pRECORD->disfmt,Chart);
              execute("{BarChart%dBase.TheNewNumber = atof(temp);}",Chart);
              execute("{BarChart%dBase.TheOriginalNumber = BarChart%dBase.TheNewNumber;}",Chart,Chart);
           }
      }//endelse not a digital point
  
    }//endelse not all blank
  
    execute("{sprintf(BarChart%dMinValue.TheNewText, \\"%s\\", BarChart%dMinValue.TheNewNumber);}",Chart,GetstrMinNumberFormat(Chart),Chart);
    execute("{sprintf(BarChart%dMinValue.TheOriginalText, \\"%s\\", BarChart%dMinValue.TheOriginalNumber);}",Chart,GetstrMinNumberFormat(Chart),Chart);
    execute("{BarChart%dMinValue.ERROR = 0;}",Chart);
  
    execute("{sprintf(BarChart%dMaxValue.TheNewText, \\"%s\\", BarChart%dMaxValue.TheNewNumber);}",Chart,GetstrMinNumberFormat(Chart),Chart);
    execute("{sprintf(BarChart%dMaxValue.TheOriginalText, \\"%s\\", BarChart%dMaxValue.TheOriginalNumber);}",Chart,GetstrMinNumberFormat(Chart),Chart);
    execute("{BarChart%dMaxValue.ERROR = 0;}",Chart);
  
    execute("{sprintf(BarChart%dBase.TheNewText, \\"%s\\", BarChart%dBase.TheNewNumber);}",Chart,GetstrMinNumberFormat(Chart),Chart);
    execute("{sprintf(BarChart%dBase.TheOriginalText, \\"%s\\", BarChart%dBase.TheOriginalNumber);}",Chart,GetstrMinNumberFormat(Chart),Chart);
    execute("{BarChart%dBase.ERROR = 0;}",Chart);
  }//end routine`

