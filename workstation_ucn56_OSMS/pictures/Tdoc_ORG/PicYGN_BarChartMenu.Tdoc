  function `float GetDB_HiER(int Chart)
  {
  // Returns the database High Engineering Range for the PID in Bar #, Chart #
  
     execute ("{pRECORD = \`&%s\`;}",GetstrPID(Chart));
  
     DB_HiER = EngRangeHi(pRECORD) ;
  
   //  strcpy(StrLoER, GetstrPID(Chart));
  
   // execute("{DB_HiER = %s;}",GetstrDB_HiER(Chart));
  
  
  
    return(DB_HiER);
  }`

  function `float GetDB_LoER(int Chart)
  {
  // Returns the Low Engineering Range for the PID in Bar #, Chart #
  
     execute ("{pRECORD = \`&%s\`;}",GetstrPID(Chart));
  
     DB_LoER = EngRangeLo(pRECORD) ;
  
  
  //  execute("{DB_LoER = %s;}",GetstrDB_LoER(Chart));
    return(DB_LoER);
  }`

  function `int GetPID_CheckType(char * PID)
  {
    int point_type;
    int retval = FULL_TYPE_CHECK;
  
    strcpy(TEMPSTR, PID);
    strcat(TEMPSTR, ".sig_type");
    execute("{TEMPINT = %s;}",TEMPSTR);
    point_type = TEMPINT;
  
    switch (point_type)
    {
      case AI:
      case PI:
      case FI:
      case ROD:
        retval = FULL_TYPE_CHECK;
        break;
  
      case CI:
      case DI:
      case SOE:
      case BCI:
      case DL:
      case QD:
      case XD:
      case CO:
      case BCO:
        retval = ZERO_OR_ONE_TYPE_CHECK;
        break;
  
      case XA:
      case QA:
        retval = NO_RANGE_TYPE_CHECK;
        break;
  
      case AO:
      case KO:
        strcpy(TEMPSTR, PID);
        strcat(TEMPSTR, ".erange_lo");
        execute("{DB_LoER = %s;}",TEMPSTR);
        strcpy(TEMPSTR, PID);
        strcat(TEMPSTR, ".erange_hi");
        execute("{DB_HiER = %s;}",TEMPSTR);
        if ((0.0 == DB_LoER)  &&  (0.0 == DB_HiER))
          retval = NO_RANGE_TYPE_CHECK;
        else
          retval = FULL_TYPE_CHECK;
        break;
  
      default:
        //printf("%s GetPID_CheckType() ERROR: Point type not found", PictureTitle);
        retval = FULL_TYPE_CHECK;
        break;
    }
    return(retval);
  }`

