  }`

  function `void SaveSetting()
  {
     int i,j;
     InputDialogueNumber * poMinValue;
     InputDialogueNumber * poMaxValue;
     InputDialogueNumber * poBasValue;
     InputDialogueText   * poPID;
  
     i = Sel ;
  
     for (j=1; j<=NUM_BAR_PER_SET; j++)
     {
        execute("{ProcessERROR = BarChart%dPID.ERROR;}",j);
        if (1 == ProcessERROR) break;
        execute("{ProcessERROR = BarChart%dMinValue.ERROR;}",j);
        if (1 == ProcessERROR) break;
        execute("{ProcessERROR = BarChart%dMaxValue.ERROR;}",j);
        if (1 == ProcessERROR) break;
        execute("{ProcessERROR = BarChart%dBase.ERROR;}",j);
        if (1 == ProcessERROR) break;
  
        poMinValue = GetpoMinValue(j);
        poMaxValue = GetpoMaxValue(j);
        poBasValue = GetpoBaseValue(j);  // by kwang
        poPID = GetpoPID(j);
  
  
        // In case of Reversed Range, Check the the MAX and MIN is within the engineering range.
        // For example, the Pid IMR1S1 has reversed engineering range.
        if ( (poMaxValue->TheNewNumber <= poBasValue->TheNewNumber)&&(poBasValue->TheNewNumber <= poMinValue->TheNewNumber) )
           { ProcessERROR = 0; }
        // In case of Normal Range, Check the the MAX and MIN is within the engineering range
        else if ( ((poMaxValue->TheNewNumber >= poBasValue->TheNewNumber)&&(poBasValue->TheNewNumber >= poMinValue->TheNewNumber)) )
           { ProcessERROR = 0; }
        else
        {
          ProcessERROR = 1;
          poMinValue.ERROR = 1;
          poMaxValue.ERROR = 1;
          break;
        } //endif
     } //endfor
  
     if (!ProcessERROR)
     {
        i = Sel ;
  
        for (j=1;j<=NUM_BAR_PER_SET;j++)
        {
           execute("{strcpy(pBarChartData->Group%dPoint%d.BarChartId, BarChart%dPID.TheNewText);}" ,i,j,j);
           execute ("{pRECORD = \`&%s\`;}",GetstrPID(j));
  
           if (IsDigital(GetstrPID(j)))		// For Digital PID
           {
              execute("{pBarChartData->Group%dPoint%d.Minimum  = BarChart%dMinValue.TheNewNumber;}",i,j,j);
              execute("{pBarChartData->Group%dPoint%d.Maximum  = BarChart%dMaxValue.TheNewNumber;}",i,j,j);
              execute("{pBarChartData->Group%dPoint%d.Baseline = BarChart%dBase.TheNewNumber;}",i,j,j);
           }
           else
           {
              if (IsAllBlank(GetstrPID(j))!=1)
              {
                 if ( (Interface->System.displayedUnits) && (!(pRECORD->pipbitmap & bMETUNIT)) )
                 {
                    execute("{pBarChartData->Group%dPoint%d.Minimum  = (BarChart%dMinValue.TheNewNumber - pRECORD->moffset) / pRECORD->mfactor;}",i,j,j);
                    execute("{pBarChartData->Group%dPoint%d.Maximum  = (BarChart%dMaxValue.TheNewNumber - pRECORD->moffset) / pRECORD->mfactor;}",i,j,j);
                    execute("{pBarChartData->Group%dPoint%d.Baseline = (BarChart%dBase.TheNewNumber     - pRECORD->moffset) / pRECORD->mfactor;}",i,j,j);
                 }
                 else if ( (!Interface->System.displayedUnits) && (pRECORD->pipbitmap & bMETUNIT) )
                 {
                    execute("{pBarChartData->Group%dPoint%d.Minimum  = BarChart%dMinValue.TheNewNumber * pRECORD->mfactor + pRECORD->moffset;}",i,j,j);
                    execute("{pBarChartData->Group%dPoint%d.Maximum  = BarChart%dMaxValue.TheNewNumber * pRECORD->mfactor + pRECORD->moffset;}",i,j,j);
                    execute("{pBarChartData->Group%dPoint%d.Baseline = BarChart%dBase.TheNewNumber     * pRECORD->mfactor + pRECORD->moffset;}",i,j,j);
                 }
                 else
                 {
                    execute("{pBarChartData->Group%dPoint%d.Minimum  = BarChart%dMinValue.TheNewNumber;}",i,j,j);
                    execute("{pBarChartData->Group%dPoint%d.Maximum  = BarChart%dMaxValue.TheNewNumber;}",i,j,j);
                    execute("{pBarChartData->Group%dPoint%d.Baseline = BarChart%dBase.TheNewNumber;}",i,j,j);
                 }
              }
           }
        } // by yrlee
  
        ProcessError1Msg.visibility = 0;
        procMsg.visibility = 1 ;
  
        execute("{sendMessageToHost(PROCESS_BAR_DATA);}");  // by yrlee (990114)
        SETUP = 0;   //2016.11.11 core-net
  
     } // endif (1 != ProcessERROR)
     else
     {
        ProcessError1Msg.visibility = 1;
     } //endelse
  
     strcpy(SetupButton.Label,SetupButton.StaticLabel) ; //2016.11.11 core-net
     update() ;
  }
  
  `

  function `void SetupNcancel()
  {
     if (!SETUP)         // For SETUP
     {
        if (accesslevel<5)
           SETUP = 1 ;
        else
           DisplayAdvisoryMessage("ACCESS LEVEL 3 OR 4 REQUIRED");
     }
     else                     // For CANCEL
     {
        SETUP = 0 ;
        procMsg.visibility = 1 ;
        Reset() ;
     }
  
     update() ;
  }`

  function `void UpdateLocalsFromInterface()
  {
    int i,j;
  
  // start ------- changed by yrlee
  
  
  //  for (i=1; i<=NUM_BAR_SETS; i++)
  
      i = Sel ;                      // Group Selection
  
      for (j=1; j<=NUM_BAR_PER_SET; j++)
      {
  
  
  //    Get the PID stuff
        execute("{strcpy(BarChart%dPID.TheOriginalText,pBarChartData->Group%dPoint%d.BarChartId);}",j,i,j);
        execute("{strcpy(BarChart%dPID.TheNewText,BarChart%dPID.TheOriginalText);}",j,j);
        execute("{BarChart%dPID.ERROR = 0;}",j);
  
  // Metric/English Conversion
  
        execute ("{pRECORD = \`&%s\`;}",GetstrPID(j));
  
        if (IsAllBlank(GetstrPID(j)))
           execute ("{pRECORD = \\\`&ERRORPID\\\`;}");
        else if (IsDigital(GetstrPID(j)))              // For Digital PID
        {
              execute("{BarChart%dMinValue.TheNewNumber = pBarChartData->Group%dPoint%d.Minimum ;}",j,i,j);
              execute("{BarChart%dBase.TheNewNumber =     pBarChartData->Group%dPoint%d.Baseline;}",j,i,j);
              execute("{BarChart%dMaxValue.TheNewNumber = pBarChartData->Group%dPoint%d.Maximum ;}",j,i,j);
        }
        else
        {
           if ( (Interface->System.displayedUnits) && (!(pRECORD->pipbitmap & bMETUNIT)) )
           {
              execute("{BarChart%dMinValue.TheNewNumber = pBarChartData->Group%dPoint%d.Minimum  * pRECORD->mfactor + pRECORD->moffset ;}",j,i,j);
              execute("{BarChart%dBase.TheNewNumber =     pBarChartData->Group%dPoint%d.Baseline * pRECORD->mfactor + pRECORD->moffset ;}",j,i,j);
              execute("{BarChart%dMaxValue.TheNewNumber = pBarChartData->Group%dPoint%d.Maximum  * pRECORD->mfactor + pRECORD->moffset ;}",j,i,j);
           }
           else if ( (!Interface->System.displayedUnits) && (pRECORD->pipbitmap & bMETUNIT) )
           {
              execute("{BarChart%dMinValue.TheNewNumber = (pBarChartData->Group%dPoint%d.Minimum - pRECORD->moffset) / pRECORD->mfactor ;}",j,i,j);
              execute("{BarChart%dBase.TheNewNumber =     (pBarChartData->Group%dPoint%d.Baseline- pRECORD->moffset) / pRECORD->mfactor ;}",j,i,j);
              execute("{BarChart%dMaxValue.TheNewNumber = (pBarChartData->Group%dPoint%d.Maximum - pRECORD->moffset) / pRECORD->mfactor;}",j,i,j);
           }
           else
           {
              execute("{BarChart%dMinValue.TheNewNumber = pBarChartData->Group%dPoint%d.Minimum ;}",j,i,j);
              execute("{BarChart%dBase.TheNewNumber =     pBarChartData->Group%dPoint%d.Baseline;}",j,i,j);
              execute("{BarChart%dMaxValue.TheNewNumber = pBarChartData->Group%dPoint%d.Maximum ;}",j,i,j);
           }
        }
  
  
  
  
  //    Get the MinValue stuff
  
        execute("{BarChart%dMinValue.TheOriginalNumber = BarChart%dMinValue.TheNewNumber;}",j,j);
        execute("{sprintf(BarChart%dMinValue.TheNewText, \\"%s\\", BarChart%dMinValue.TheNewNumber);}",j,GetstrMinNumberFormat(j),j);
        execute("{sprintf(BarChart%dMinValue.TheOriginalText, \\"%s\\", BarChart%dMinValue.TheOriginalNumber);}",j,GetstrMinNumberFormat(j),j);
        execute("{BarChart%dMinValue.ERROR = 0;}",j);
  
  //    Get the Base stuff
  
        execute("{BarChart%dBase.TheOriginalNumber = BarChart%dBase.TheNewNumber;}",j,j);
        execute("{sprintf(BarChart%dBase.TheNewText, \\"%s\\", BarChart%dBase.TheNewNumber);}",j,GetstrBasNumberFormat(j),j);
        execute("{sprintf(BarChart%dBase.TheOriginalText, \\"%s\\", BarChart%dBase.TheOriginalNumber);}",j,GetstrBasNumberFormat(j),j);
        execute("{BarChart%dBase.ERROR = 0;}",j);
  
  //    Get the MaxValue stuff
  
        execute("{BarChart%dMaxValue.TheOriginalNumber = BarChart%dMaxValue.TheNewNumber;}",j,j);
        execute("{sprintf(BarChart%dMaxValue.TheNewText, \\"%s\\", BarChart%dMaxValue.TheNewNumber);}",j,GetstrMaxNumberFormat(j),j);
        execute("{sprintf(BarChart%dMaxValue.TheOriginalText, \\"%s\\", BarChart%dMaxValue.TheOriginalNumber);}",j,GetstrMaxNumberFormat(j),j);
        execute("{BarChart%dMaxValue.ERROR = 0;}",j);
  
      }
  
  // end ------- changed by yrlee
  
  
  /*
   //printf("%s|",pBarChartData->Group1Point1.BarChartId) ;
   //printf("%s|",pBarChartData->Group1Point2.BarChartId) ;
   //printf("%s|",pBarChartData->Group1Point3.BarChartId) ;
   //printf("%s|",pBarChartData->Group1Point4.BarChartId) ;
  
   //printf("%s|",pBarChartData->Group2Point1.BarChartId) ;
   //printf("%s|",pBarChartData->Group2Point2.BarChartId) ;
   //printf("%s|",pBarChartData->Group2Point3.BarChartId) ;
   //printf("%s|",pBarChartData->Group2Point4.BarChartId) ;
  */
  
    AssignPid() ;
  
    ProcessError1Msg.visibility = 0;
    procMsg.visibility = 0 ;
  
    update();
  }`

  function `void ValueErrorReset(int i)
  {
     switch(i)
     {
        case 1 : BarChart1MinValue.ERROR = 0 ;
                 BarChart1Base.ERROR = 0 ;
                 BarChart1MaxValue.ERROR = 0 ;
                 break ;
        case 2 : BarChart2MinValue.ERROR = 0 ;
                 BarChart2Base.ERROR = 0 ;
                 BarChart2MaxValue.ERROR = 0 ;
                 break ;
        case 3 : BarChart3MinValue.ERROR = 0 ;
                 BarChart3Base.ERROR = 0 ;
                 BarChart3MaxValue.ERROR = 0 ;
                 break ;
        case 4 : BarChart4MinValue.ERROR = 0 ;
                 BarChart4Base.ERROR = 0 ;
                 BarChart4MaxValue.ERROR = 0 ;
                 break ;
     }
  }
  `

  function `void VerifyBaseValue(int Bar, int Chart)
  {
  
    int error = 0;
  
    execute("{xx = BarChart%dMinValue.TheNewNumber;}",Chart);
    execute("{yy = BarChart%dBase.TheNewNumber;}",Chart);
    execute("{zz = BarChart%dMaxValue.TheNewNumber;}",Chart);
  
    if ( !((xx <= yy)&&(yy <= zz)) ) error = 1;
  
    if (error)
      execute("{BarChart%dBase.ERROR = 1;}",Chart);
    else
    {
      execute("{BarChart%dBase.ERROR = 0;}",Chart);
      ProcessError1Msg.visibility = 0 ;
    }
  
  
  
  
  }`

  function `void VerifyMaxValue(int Bar, int Chart)
  {
  // Verify valid input for the Max Value entered for Bar #, Chart #
    InputDialogueNumber * poMax = 0;
    InputDialogueNumber * poMin = 0;
    int error = 0;
    int check_type;
  
    poMax = GetpoMaxValue(Chart);
    poMin = GetpoMinValue(Chart);
  
    // Determine the type of checking that is needed and do it.
    check_type = GetPID_CheckType(GetstrPID(Chart));
    switch(check_type)
    {
      case NO_RANGE_TYPE_CHECK:
        error = 0;
        break;
  
      case ZERO_OR_ONE_TYPE_CHECK:
        if (1.0 != poMax->TheNewNumber) error = 1;
        break;
  
      case FULL_TYPE_CHECK:
      default:
        xx = GetDB_LoER(Chart);
        yy = poMax->TheNewNumber;
        zz = GetDB_HiER(Chart);
  
        execute("{sprintf(temp,\\"%s\\",xx);}",poMax->TheNumberFormat); xx = atof(temp);
        execute("{sprintf(temp,\\"%s\\",yy);}",poMax->TheNumberFormat); yy = atof(temp);
        execute("{sprintf(temp,\\"%s\\",zz);}",poMax->TheNumberFormat); zz = atof(temp);
  
        // if the entered value is not between the hi and lo engineering range,
        // we have an error
        if ( !((xx <= yy) && (yy <= zz)) ) error = 1;
  
        if (poMax->TheNewNumber <= poMin->TheNewNumber) error = 1;
        break;
    }//endswitch
  
    if (0 == error)
     {
      execute("{BarChart%dMaxValue.ERROR = 0;}", Chart);
      ProcessError1Msg.visibility = 0 ;
     }
    else
     {
      execute("{BarChart%dMaxValue.ERROR = 1;}", Chart);
     }
  }`

  function `void VerifyMinMaxValues(int Bar, int Chart)
  {
    int error;
  
    execute("{pRECORD = \`&%s\`;}",GetstrPID(Chart));
  
    execute("{sprintf(temp,\\"%s\\",BarChart%dMaxValue.TheNewNumber);}",pRECORD->disfmt,Chart);
    execute("{BarChart%dMaxValue.TheNewNumber = atof(temp);}",Chart);
    execute("{BarChart%dMaxValue.TheOriginalNumber = BarChart%dMaxValue.TheNewNumber;}",Chart,Chart);
  
    execute("{sprintf(temp,\\"%s\\",BarChart%dMinValue.TheNewNumber);}",pRECORD->disfmt,Chart);
    execute("{BarChart%dMinValue.TheNewNumber = atof(temp);}",Chart);
    execute("{BarChart%dMinValue.TheOriginalNumber = BarChart%dMinValue.TheNewNumber;}",Chart,Chart);
  
    execute("{sprintf(temp,\\"%s\\",BarChart%dBase.TheNewNumber);}",pRECORD->disfmt,Chart);
    execute("{BarChart%dBase.TheNewNumber = atof(temp);}",Chart);
    execute("{BarChart%dBase.TheOriginalNumber = BarChart%dBase.TheNewNumber;}",Chart,Chart);
  
    execute("{error = BarChart%dPID.ERROR;}", Chart);
    if ( (!IsAllBlank(GetstrPID(Chart)))  ||
         (0 == error) )
    {
      VerifyMinValue(Bar, Chart);
      VerifyMaxValue(Bar, Chart);
      VerifyBaseValue(Bar, Chart);
    }//endif
  //----------------------------------------------------------------
  //   PROCESS button error processing using OneSecondTimer
  //
  
  //by yrlee      ProcessButtonERRFlag = 1;
  
  //----------------------------------------------------------------
  //   this portion should be included for HF, bUT NOW SOME PICASSO's
  //   mis-operarion keeps this from being implemented.
  //   ProcessErrorReset();
  //   After return from ProcessErrorReset(), Do the followings
  //   ProcessError1Msg.visibility = PROCESS1_ERROR;
  //   update();
  //   printf(" ERROR is Zero");
  //
  }`

  function `void VerifyMinValue(int Bar, int Chart)
  {
  // Verify valid input for the Min Value entered for Bar #, Chart #
    InputDialogueNumber * poMin = 0;
    InputDialogueNumber * poMax = 0;
    int error = 0;
    int check_type;
  
    poMin = GetpoMinValue(Chart);
    poMax = GetpoMaxValue(Chart);
  
    // Determine the type of checking that is needed and do it.
    check_type = GetPID_CheckType(GetstrPID(Chart));
    switch(check_type)
    {
      case NO_RANGE_TYPE_CHECK:
        error = 0;
        break;
  
      case ZERO_OR_ONE_TYPE_CHECK:
        if (0.0 != poMin->TheNewNumber) error = 1;
  //      printf("adifaklsdjflkasd");
        break;
  
      case FULL_TYPE_CHECK:
      default:
        xx = GetDB_LoER(Chart);
        yy = poMin->TheNewNumber;
        zz = GetDB_HiER(Chart);
  
        execute("{sprintf(temp,\\"%s\\",xx);}",poMax->TheNumberFormat); xx = atof(temp);
        execute("{sprintf(temp,\\"%s\\",yy);}",poMax->TheNumberFormat); yy = atof(temp);
        execute("{sprintf(temp,\\"%s\\",zz);}",poMax->TheNumberFormat); zz = atof(temp);
  
        // if the entered value is not between the hi and lo engineering range,
        // we have an error
        if ( !((xx <= yy) && (yy <= zz)) ) error = 1;
  
        if (poMax->TheNewNumber <= poMin->TheNewNumber) error = 1;
        break;
    }//endswitch
  
    if (0 == error)
     {
      execute("{BarChart%dMinValue.ERROR = 0;}", Chart);
      ProcessError1Msg.visibility = 0 ;
     }
    else
     {
      execute("{BarChart%dMinValue.ERROR = 1;}", Chart);
     }
  }`

  function `void VerifyPID(int Bar,int Chart)
  {
    int blanks = 1;
    char * cptr;
    InputDialogueText * Input = 0;
    // Get pointers to the PID, Min, and Max objects
    Input = GetpoPID(Chart);
  
    cptr = Input->TheNewText;
  
    blanks = IsAllBlank(cptr);
  
    if (1 == blanks)
    {
      BarMinMaxFromPID(Chart);
      Input->ERROR = 0;
    }//endif
    else
    {
      Input->ERROR = FindPointId(Input->TheNewText);
    }
  
    if (Input->ERROR != 0)
    {
      Input->ERROR = 1;
    }
    else if (1 != blanks)
    {
      BarMinMaxFromPID(Chart);
      ProcessError1Msg.visibility = 0 ;
    } // endelseif (1 == blanks)
    update();
  }`

