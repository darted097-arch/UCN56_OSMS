  function `int IsAllBlank(char * cptr)
  {
    // Return 0 if one non-blank character is found, 1 otherwise
    int blank = 1;
    int i;
  
    for (i=0; i<strlen(cptr); i++, cptr++)
    {
      if (*cptr != ' ')
      {
        blank = 0;
        break;
      }//endif
    }//endfor
    return (blank);
  }`

  function `int IsDigital(char * PID)
  {
    int retval, sigtype;
  
    // get a pointer to the record for the PID
    execute("{pRECORD = &%s;}",PID);
  
    sigtype = pRECORD->sig_type;
    switch(sigtype)
    {
      case CI:
      case DI:
      case SOE:
      case BCI:
      case DL:
      case QD:
      case XD:
      case CO:
      case BCO:
        retval = 1;
        break;
      default:
        retval = 0;
        break;
    }//endswitch
    return(retval);
  }`

  function `int isDigital(RECORD *PID)
  {
    int retval, sigtype;
  
    // get a pointer to the record for the PID
    pRECORD = PID ;
  
    sigtype = pRECORD->sig_type;
  
    switch(sigtype)
    {
      case CI:
      case DI:
      case SOE:
      case BCI:
      case DL:
      case QD:
      case XD:
      case CO:
      case BCO:
        retval = 1;
        break;
      default:
        retval = 0;
        break;
    }//endswitch
    return(retval);
  }`

  function `void ProcessThis(int sel)
  {
    int i,j;
    InputDialogueNumber * poMinValue;
    InputDialogueNumber * poMaxValue;
    InputDialogueNumber * poBasValue;
    InputDialogueText   * poPID;
  
  
      i = Sel = sel ;
  
  
  //  ADD TEMPOTRARY SHOPPING LIST
  
      execute("{ manageTempShopList(INIT_TEMP_SHOP_LIST,dummy_arg);}");
  
      for (j=1; j<=NUM_BAR_PER_SET; j++)
      {
        execute("{ strcpy(TEMP, pBarChartData->Group%dPoint%d.BarChartId);}",i,j);
        if(strlen(TEMP)>1)
           execute("{ manageTempShopList(TEMP_SHOP_LIST_ADD, TEMP);}");
      }
  
      execute("{ manageTempShopList(TEMP_SHOP_LIST_SEND,dummy_arg);}");
  
  //    execute("{sendMessageToHost(PROCESS_BAR_DATA);}");  commented out by yrlee (990114)
  
  //--------------------------------------------------------------------------------------------------------
  //  For PREV, NEXT, sending shopping list is enough
     if (Current_Page == 851 || Current_Page == 852) return;
     //------------------------------------------------------------------------------------------------------
  
     if (Sel == 1)
     {
  //   execute ("{displayPicture(\\"Main\\",\\"%s.ppic\\");}",PageForward1);
       DisplayPage(Page851);
     }
     else
     {
  //   execute ("{displayPicture(\\"Main\\",\\"%s.ppic\\");}",PageForward2);
       DisplayPage(Page852);
     }
  
  //>>>>>>>>>>>>>>>>>>>>>>>> CORENET
  	Group1Select.UnSelect();
  //<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<
  
     update() ;
  }
  `

  function `void Reset()
