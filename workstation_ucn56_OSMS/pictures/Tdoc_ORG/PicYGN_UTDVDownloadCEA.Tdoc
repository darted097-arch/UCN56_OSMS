  function `void GrpClr()  //JHC 990420
{
   desc.pText.foregroundColour = COLOR_NON_ESSENTIAL;
   desc.rText.foregroundColour = COLOR_NON_ESSENTIAL;
   desc.sText.foregroundColour = COLOR_NON_ESSENTIAL;

   if((strcmp(selectGrp.TheNewText,"P")) == 0)
      desc.pText.foregroundColour = COLOR_DATA_NORMAL;    
   else if((strcmp(selectGrp.TheNewText,"A")) ==0)
      desc.sText.foregroundColour = COLOR_DATA_NORMAL;
   else if((strcmp(selectGrp.TheNewText,"B")) ==0)
      desc.sText.foregroundColour = COLOR_DATA_NORMAL;       
   else 
      desc.rText.foregroundColour = COLOR_DATA_NORMAL;   
 }`



